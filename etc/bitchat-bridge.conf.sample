# net-bitchat-bridge — per-feature config (OPTIONAL).
#
# The MAIN /etc/net-mgr/config [bitchat_bridge] section is the single
# source of truth for mode/helper_path/session_name. This file is an
# OPTIONAL overlay for helper env vars and extra args — most installs
# don't need it. The supervisor reads main config first, then overlays
# values from here when present.
#
# Use this file when:
#   - you point at a TUI-style helper that needs the ANSI→JSON shim,
#     and the shim needs env_BITCHAT_BIN pointing at the real binary
#   - you need to pass extra args to the helper at launch
#
# Otherwise leave it alone — defaults from main config are enough.

[helper]
path = /usr/local/bin/net-bitchat-helper-wrap
args =
# Pass the path to the real BitChat binary into the shim's env:
env_BITCHAT_BIN = /home/dkc/src/bitchat-terminal/target/release/bitchat

[session]
# Which net-chat session BitChat messages land in. Create with:
#   net-chat --auth admin create bitchat-bridge access=open
name = bitchat-bridge

[identity]
# Attribution stamped on every relayed message (the `as` field).
# Loopback connections may set `as` freely; this is what readers see
# as the sender (the original BitChat nick is in the message body).
as = bitchat-relay

[daemon]
# net-mgr daemon socket. Loopback = no auth required.
listen = 127.0.0.1:7531
