; /etc/net-mgr/net-chat-autoresponder.conf
; ==========================================================================
; net-chat-autoresponder rule set. INI format:
;
;   ; comments start with ';' or '#'
;   [global]                     ; optional; defaults shown below
;   [rule.NAME]                  ; one section per rule; NAME = [A-Za-z][A-Za-z0-9._-]{0,31}
;
; Overlays: /etc/net-mgr/net-chat-autoresponder.d/*.conf are loaded AFTER
; this file in filename-sort order. A duplicate [rule.NAME] REPLACES the
; earlier one (last-write-wins per rule name), so a site can override the
; wifi-greeting body by dropping ONE file into the .d/ directory without
; editing the packaged default.
;
; State (dedup) file: /var/lib/net-mgr/net-chat-autoresponder.seen —
; owned by the reactor, one line per dedup key ('key\tepoch\n', append-only,
; lazy-pruned). Delete it to force every rule to fire again.
;
; See bin/net-chat-autoresponder --help for CLI. See project_bitchat-bridge
; memory note for the wire-path story (bridge:409-411 strips the '@HEX16:'
; prefix and DMs the peer via helper stdin).
; ==========================================================================

[global]
; NetMgr::Client target — loopback because `as` is trusted by the daemon
; only for loopback connections (see netchat gotcha #6). Non-loopback
; deployments should add auth_key_id/auth_key_file here and the responder
; will $R->auth()/$W->auth() after HELLO. Not needed today because the
; canonical caller (video-c) runs the responder next to its daemon.
listen       = 127.0.0.1:7531

; Sender attribution stamped onto every OBSERVE kind=chat_msg. Used as the
; sender field in the chat_messages row and as the primary self-loop
; guard: on_chat_row drops any row whose sender is in echo_ignore
; (default is JUST this value).
as           = net-chat-autoresponder

; Comma-separated list of sender names whose chat_message rows we drop
; unconditionally. Prevents self-loop when a rule listens on a session
; the reactor also posts into. Our own 'as' name is always ignored —
; add senders here only when you want to filter them out.
; NOTE: do NOT globally add 'bitchat-relay'. The bridge stamps BLE
; inbound with that sender, and any chat_message rule that reacts to
; BLE traffic (e.g. rule.wifi-on-request below) depends on it being
; visible. If you have a rule that would echo-loop, use a per-rule
; `from` filter instead.
echo_ignore  = net-chat-autoresponder

; Dedup state file. Persists across restarts. A fresh install with an
; empty state file greets every already-connected peer exactly once —
; which is the right behaviour when a new site comes up.
state_file   = /var/lib/net-mgr/net-chat-autoresponder.seen

; --------------------------------------------------------------------------
; Rule 1 — the WIFI-URL greeting on first-seen BLE peer sighting.
;
; This REPLACES the in-process greeter that used to live in
; net-bitchat-bridge under [bitchat_bridge].greeting. Wire path:
;
;   bitchat_peers ROW op=insert  --stream-->  autoresponder $R
;   autoresponder $W chat_post   session=bitchat-bridge
;                                body='@<peer_id>: WIFI:...'  as=net-chat-autoresponder
;   daemon _emit_change --stream--> bridge $sub
;   bridge strips '@<hex>:' prefix (bridge:409-411)
;   bridge writes {cmd:send, to_peer:<pid>, body:'WIFI:...'} to helper stdin
;   BLE DM to the peer — BitChat clients render WIFI: URIs as click-to-join.
;
; Keys:
;   trigger    — REQUIRED — one of bitchat_peer_first_seen | chat_message
;   match      — optional Perl regex on bitchat_peers.nickname (default '.*').
;                Named captures land in ${cap.NAME} for target/body.
;   dedup_ttl  — window during which a repeat first-seen for the same
;                peer_id will NOT re-fire this rule. Default 30d. Set to 0
;                to fire on every insert. Suffix: s|m|h|d|w.
;                Sample below uses 15m — see the comment above the rule
;                for the over-fire-vs-under-fire tradeoff.
;   channel    — REQUIRED — bitchat_dm | chat_post
;   target     — REQUIRED literal string with ${…} substitution.
;                For channel=bitchat_dm the resolved value MUST be exactly
;                16 lowercase hex (validated at load AND per-fire).
;                For channel=chat_post it is the session name.
;   body       — REQUIRED literal string with ${…} substitution.
;
; Substitution tokens (target + body):
;   ${peer_id}   the 16-hex BitChat peer id (bitchat_peers row) or,
;                for chat_message rules, the value of the peer_id capture
;   ${nickname}  bitchat_peers.nickname (empty for chat_message)
;   ${sender}    chat_messages.sender (or 'bitchat-relay' for BLE rules)
;   ${session}   chat_messages.session (empty for BLE rules)
;   ${cap.NAME}  any Perl named capture from `match`
;   $$           literal '$'
; --------------------------------------------------------------------------
; dedup_ttl picked for "prefer over-firing" — every decrypted BLE msg
; upserts bitchat_peers (bridge msg-path emit hook) and the 30s peer
; poll re-upserts every in-range peer, so the underlying ROW stream
; heartbeats for any peer that is present. 15m is long enough to
; swallow a normal BLE visit (constant polls all get dedup-skipped
; after the first greet) yet short enough that a peer who leaves
; and returns later the same day gets re-greeted. 30d locked us into
; "greet once ever until the seen-file is deleted" which is the wrong
; side of the tradeoff.
[rule.wifi-greeting]
trigger    = bitchat_peer_first_seen
match      = .*
dedup_ttl  = 15m
channel    = bitchat_dm
target     = ${peer_id}
body       = WIFI:T:WPA;S:video;P:InTheRoom;;

; --------------------------------------------------------------------------
; Rule 2 — reply with the same URI when anyone types 'wifi?' in the bridge
; session. Regex is anchored to the bridge's tagged inbound format
; '[SENDER@bitchat[/chan]] body' (bridge:562-565). v1 replies broadcast
; into bitchat-bridge — the bridge re-radiates to all BLE peers; a future
; revision could DM the asker specifically once we thread sender_peer_id
; through the tag.
;
; chat_message keys (in addition to trigger/channel/target/body):
;   session    — REQUIRED — chat_messages.session to listen on. Sanitized to
;                [A-Za-z0-9._-]{1,64} before the WHERE clause is built.
;   match      — REQUIRED — Perl regex on chat_messages.body. Named
;                captures land in ${cap.NAME}.
;   from       — optional — only fires when chat_messages.sender equals
;                this string exactly.
;   dedup_ttl  — default 0 for chat_message (fire on every match). When
;                set the dedup key is 'RULE_NAME\tsender'.
; --------------------------------------------------------------------------
[rule.wifi-on-request]
trigger    = chat_message
session    = bitchat-bridge
match      = ^\[[^\]]+@bitchat[^\]]*\]\s+(?i)wi-?fi\??\s*$
dedup_ttl  = 5m
channel    = chat_post
target     = ${session}
body       = WIFI:T:WPA;S:video;P:InTheRoom;;

; --------------------------------------------------------------------------
; Rule 3 — ops-channel liveness probe. Someone types '!hello', we ack.
; No dedup: every ping gets an ack, which is the whole point of a probe.
; --------------------------------------------------------------------------
[rule.ops-hello]
trigger    = chat_message
session    = ops
match      = (?i)^!hello\b
channel    = chat_post
target     = ${session}
body       = hi ${sender} — net-chat-autoresponder alive

; --------------------------------------------------------------------------
; Rule 4 (retired) — periodic BLE MESH BROADCAST of the WIFI URI.
;
; Superseded by rule.wifi-fanout + rule.wifi-ack below. The broadcast
; version had no way to suppress itself once a peer had already joined
; the WiFi — every peer in range saw the URI repost every minute
; forever. The fanout+ack pair fixes that: it DMs each peer individually
; and stops DMing that peer as soon as they reply 'y'/'yes'/'ok'.
;
; The old broadcast rule is preserved commented-out as a diagnostic —
; uncomment temporarily if you need to check "does ANY BLE peer see
; anything from us" (broadcast bypasses the bitchat_peers first-seen
; and per-peer DM paths entirely). See rule.wifi-fanout below for the
; production replacement.
;
; PERIODIC-RULE GRAMMAR (in addition to channel/target/body above):
;   trigger    — REQUIRED — 'periodic'
;   every      — REQUIRED — DURATION (s|m|h|d|w suffix); MUST be >= 5s
;                (parser floor — prevents typos like `every=0.5s` from
;                collapsing to fire-every-tick).
;   match      — MUST NOT be set (periodic has no regex — fails load).
;   dedup_ttl  — forced to 0 internally; every interval fires
;                unconditionally.
;   mode       — optional — 'fanout_bitchat_peers' turns the rule into
;                per-peer DM fanout (see rule.wifi-fanout below).
;                Absent/empty = legacy single-fire path (this rule).
;
; Periodic-only substitution tokens (in addition to $$ for a literal
; '$'; ${cap.*} is NOT available on periodic — no regex, no captures):
;   ${now}       current UTC HH:MM:SS (rendered per fire)
;   ${host}      Sys::Hostname::hostname()
;   ${nickname}  [global].as  (or the peer's nickname for fanout rules)
;   ${sender}    [global].as (same as nickname on periodic)
;   ${peer_id}   16-hex peer id — ONLY meaningful for mode=fanout_bitchat_peers
;
; TIMER SEMANTICS
;   Timer state is IN-MEMORY only, NOT persisted. On restart the first
;   fire happens after `every` seconds — not immediately — so a
;   supervisor loop that flaps the responder doesn't spam the mesh.
;   Loop granularity is 10s (recv_line timeout), so an `every` value
;   below 10s effectively rounds up to the next tick.
; --------------------------------------------------------------------------
; [rule.wifi-broadcast]              ; see rule.wifi-fanout below
; trigger    = periodic
; every      = 60s
; channel    = chat_post
; target     = bitchat-bridge
; body       = WIFI:T:WPA;S:video;P:InTheRoom;; — did you get this? reply "ok" if you did.

; --------------------------------------------------------------------------
; Rule 5 — per-peer DM fanout for the WiFi URI (production replacement
; for the retired rule.wifi-broadcast above).
;
; WHAT THIS DOES
;   Every `every` seconds, iterate the reactor's live-peer set
;   (%PEER_LAST_SEEN, populated from bitchat_peers ROW events) and DM
;   the WIFI: URI to each peer_id that has NOT already been marked as
;   ack'd for ack_key=wifi-broadcast. Peers who reply 'y' / 'yes' /
;   'ok' in the mesh (rule.wifi-ack below) get their peer_id recorded
;   in the SeenFile under that ack_key, and the next fanout tick
;   skips them for `acked_ttl` seconds.
;
; ACK PERSISTENCE
;   The ack record lives in the same SeenFile
;   (/var/lib/net-mgr/net-chat-autoresponder.seen, see [global].state_file)
;   as first-seen dedup. Keys are of the form
;       "<ack_key>\tacked\t<peer_id>"
;   which fits the same key-encoding convention used by first-seen
;   dedup ("<rule_name>\t<peer_id>"). In-process ack state is
;   authoritative during the reactor's lifetime; the on-disk log lets
;   a restarted reactor honour recent acks without re-DMing peers who
;   already replied.
;
; ACK TTL — WHY 1h?
;   Long enough to cover a normal event: a peer who joins the WiFi,
;   walks away for lunch, and comes back mid-afternoon is not re-DM'd.
;   Short enough that a peer who dropped off the WiFi (moved, laptop
;   suspend, network reset) gets a fresh reminder within an hour of
;   returning. Bump to `acked_ttl = 6h` for a persistent event, or
;   drop to `10m` for a rapid-iteration diagnostic.
;
; PEER-VISIBILITY LIMITATION
;   Peers we haven't yet received a bitchat_peers ROW for (fresh
;   arrivals within the last poll cycle, silent decrypt failures)
;   are absent from %PEER_LAST_SEEN and therefore not fanned out to.
;   The DM they miss will land on the next tick after their ROW event
;   arrives — under the default 30s peer poll that's a bounded ~1min
;   worst case.
;
; NICKNAME COLLISION LIMITATION
;   The reactor's %NICK_TO_PID reverse map (which the ack rule uses
;   to decode 'y' from '[alice@bitchat] y' back into a peer_id) is
;   nickname-keyed — the bridge tag drops sender_peer_id (see the
;   investigation in bin/net-bitchat-bridge:555-558). If two distinct
;   BLE peers both nickname themselves 'alice', an ack from either
;   marks whichever peer_id was written to %NICK_TO_PID most recently.
;   Schema-authoritative identity is peer_id (bitchat_peers PRIMARY
;   KEY, VARCHAR(16)); closing the gap requires threading peer_id
;   into chat_messages, which is a schema-migration change out of
;   scope for this rule pair.
;
; FANOUT-RULE GRAMMAR (in addition to trigger/every/channel above):
;   mode       — REQUIRED for fanout — 'fanout_bitchat_peers'.
;   channel    — MUST be 'bitchat_dm' (validated at load).
;   target     — MUST resolve to a 16-hex peer_id via ${…} substitution.
;                In practice this is literally '${peer_id}'.
;   body       — DM payload. All periodic tokens are available;
;                ${nickname} is the peer's nickname when known (empty
;                if we haven't decoded a bitchat_peers ROW for them
;                with a non-empty nickname yet).
;   ack_key    — REQUIRED — the SeenFile bucket that a chat_message
;                rule with matching ack_target= populates. Grammar:
;                [A-Za-z][A-Za-z0-9._-]{0,31} (same as rule NAME).
;   acked_ttl  — optional — SeenFile freshness window; default 1h.
;                Suffix s|m|h|d|w. MUST be > 0.
; --------------------------------------------------------------------------
[rule.wifi-fanout]
trigger    = periodic
every      = 60s
mode       = fanout_bitchat_peers
channel    = bitchat_dm
target     = ${peer_id}
body       = WIFI:T:WPA;S:video;P:InTheRoom;;  Reply 'y' to stop these.
ack_key    = wifi-broadcast
acked_ttl  = 1h

; --------------------------------------------------------------------------
; Rule 6 — ack-drop for the wifi-fanout above.
;
; WHAT THIS DOES
;   Listens on the bitchat-bridge chat session for a mesh reply whose
;   body matches y / yes / ok (case-insensitive, allowing leading
;   whitespace). The tagged form the bridge writes is
;       '[NICK@bitchat] BODY'  or  '[NICK@bitchat/#channel] BODY'
;   (see bin/net-bitchat-bridge:555-558), so the match regex extracts
;   (?<nick>...) from that prefix.
;
;   The rule's channel=noop is required (validated at load) — this is
;   a pure state-mutation rule, not a wire post. The reactor
;   reverse-looks up the peer_id via %NICK_TO_PID and records
;   "wifi-broadcast\tacked\t<peer_id>" into the SeenFile. The next
;   fanout tick sees this ack and skips the peer.
;
; ACK-DROP RULE GRAMMAR:
;   trigger    — 'chat_message'
;   session    — chat session to listen on ('bitchat-bridge' for the
;                bridge-tagged mesh feed).
;   match      — REQUIRED — regex with a named (?<nick>...) capture
;                that pulls the nickname out of the bridge tag prefix.
;                Any capture named 'nick' is used; capture named
;                'peer_id' is ignored here (no 16-hex in the bridge
;                tag today — see the "nickname collision" note above).
;   ack_target — REQUIRED — the ack_key= of a periodic fanout rule
;                whose acked_ttl set the SeenFile bucket name.
;                Grammar: [A-Za-z][A-Za-z0-9._-]{0,31}.
;   channel    — MUST be 'noop'. Wire channels are rejected at load
;                to prevent an ack rule from accidentally leaking a
;                reply back into the mesh.
;   target     — optional (ignored on channel=noop).
;   body       — optional (ignored on channel=noop).
;
; UNKNOWN-PEER HANDLING
;   If the nick captured from the reply isn't in %NICK_TO_PID (peer
;   never showed up on bitchat_peers, or hadn't yet as of this reply),
;   the ack is dropped with a WARN log line and no SeenFile record is
;   written. On the next fanout tick that peer will still be DM'd —
;   which is the safe default: better to occasionally re-DM a peer
;   who did ack than to permanently suppress a peer who didn't.
; --------------------------------------------------------------------------
[rule.wifi-ack]
trigger    = chat_message
session    = bitchat-bridge
match      = ^\[(?<nick>[^@\]/]+)(?:/[^@\]]+)?@bitchat[^\]]*\]\s+(?i)(y|yes|ok)\s*$
ack_target = wifi-broadcast
channel    = noop
