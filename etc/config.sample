# net-mgr sample configuration
# Install to /etc/net-mgr/config (or set NET_MGR_CONF env var).
# Other files in /etc/net-mgr/ are loaded by their own components
# (e.g. /etc/net-mgr/dhcp for the dhcp/dnsmasq integration).

[manager]
# Where the manager binds. Comma-separated list of host[:port] entries,
# or the special token 'auto' which expands to every 192.168.*.*
# address on this host plus 127.0.0.1 (LAN-only by default — safe on a
# firewall). Examples:
#   listen = auto                          # default
#   listen = 192.168.15.1:7531             # one specific LAN address
#   listen = 192.168.15.1, 127.0.0.1       # multiple, default port 7531
#   listen = 0.0.0.0:7531                  # legacy "everything" bind
listen = auto
log    = /var/log/net-mgr.log
# Mark an interface offline if last_seen is older than this. Combine
# with [scheduling] presence / scan-ap to keep `online` honest.
offline_after = 300s

[mysql]
db       = netmgr
defaults = /root/.my.cnf
section  = net-mgr

[scanner]
# 'auto' = walk UP wired/wifi interfaces (eth*, en*, wl*) and include
# any 192.168.x.0/24 they sit on. Or comma-separated CIDRs.
networks          = auto

# fping/ip-neigh sweep of known IPs:
presence_interval = 90s
# Full nmap discovery sweep (once we know things are there, infrequent):
discover_interval = 24h
# Re-probe ports of known hosts to catch newly opened services:
reprobe_ports     = 7d

[ap_poll]
interval    = 60s
ssh_timeout = 10s

[timeouts]
# How long since the last observation from a given source before the
# manager considers the device offline w.r.t. that source.
ap    = 120s
fping = 180s
nmap  = 24h
dhcp  = lease     # special: use the lease's own expiry

[paths]
dnsmasq_conf_glob = /usr/local/sgy/conf.d/dnsmasq-*
oui_csv           = /var/lib/ieee-data/oui.csv

[dns]
# Primary listen address. Default UDP/53 needs root or CAP_NET_BIND_SERVICE.
listen   = 0.0.0.0:53
# Fallback port if the primary bind fails (e.g. dnsmasq already on :53).
# 5353 collides with mDNS/avahi-daemon — using 5333 by default.
fallback = 5333
# Upstream forwarders for queries we can't answer locally.
# 'auto' parses /etc/resolv.conf (skipping 127.0.0.0/8).
upstream = auto
# TTL (seconds) we attach to records we synthesize from the DB.
ttl      = 60
# Domain suffix to strip from FQDNs before lookup; empty means none.
domain   = grfx.com

# Manual machine groupings — interfaces auto-correlate when they share
# an SSH hostname or appear together in dnsmasq config; everything else
# goes here. Reloaded on SIGHUP.
[bindings]
# machine "kestrel"   = aa:bb:cc:dd:ee:01, aa:bb:cc:dd:ee:02
# machine "router-up" = 11:22:33:44:55:66

# Peer net-mgr instances to replicate from. Set on hosts that don't
# run their own producers — a relay child opens a long-lived
# SUBSCRIBE+stream connection to each peer and applies received ROWs
# into the local DB. Bidirectional peering is safe (replicated rows
# don't re-emit, so no loop).
[peers]
# sources = kc-qernel, nas3

# Periodic TRIGGERs fired by the daemon itself (each value = interval).
# Opt-in: only enable on hosts that can actually run the producer.
#   - scan-ap polls all known APs over SSH (only works where the
#     SSH keys are — typically kc-qernel).
#   - presence fpings every known IP and updates last_seen.
#   - discover runs a full nmap sweep of all detected /24s.
# Comment out (or 0) to disable. Defaults: all off.
[scheduling]
# scan-ap  = 60s
# presence = 90s
# discover = 24h
