; /etc/net-mgr/shared-wifi.conf
; ==========================================================================
; Shared WiFi credentials for the picker/broadcast surface (net-share-wifi(1),
; net-autoresponder-gui, and any operator running `net-share-wifi --uri LABEL`
; to paste a WIFI: URI into an autoresponder rule).
;
; INI format, one [wifi.LABEL] section per network. LABEL is what the CLI /
; GUI picker shows and is the argument to `--uri`/`--qr`.
;
;   [wifi.LABEL]                             ; LABEL: [A-Za-z0-9_.-]+
;   ssid     = TXT                           ; required
;   auth     = WPA | WPA2 | WEP | nopass     ; optional; default WPA
;   password = TXT                           ; required unless auth=nopass
;   hidden   = true | false                  ; optional; default false
;   note     = TXT                           ; optional; shown in --list and
;                                            ; appended by --uri --note
;
; The key names mirror the bitchat-bridge [wifi_response] section
; (etc/bitchat-bridge.conf.sample) so operators reuse the same vocabulary.
;
; Overlays: /etc/net-mgr/shared-wifi.d/*.conf are loaded AFTER this file in
; filename-sort order (same overlay mechanism NetMgr::Config uses for the
; main /etc/net-mgr/config). A duplicate [wifi.LABEL] REPLACES the earlier
; one — the merge is PER-SECTION, not per-key. This mirrors how nmconnection
; files behave and keeps the mental model "one wifi entry per label" simple.
;
; SECURITY
;   The password field is stored CLEARTEXT — the WIFI: URI QR-code format
;   has no hash mode, so any tool that hands out the credential needs the
;   plaintext PSK. Recommended file modes:
;
;       /etc/net-mgr/shared-wifi.conf       0640 root:net-mgr
;       /etc/net-mgr/shared-wifi.d/         0750 root:net-mgr
;       /etc/net-mgr/shared-wifi.d/*.conf   0640 root:net-mgr
;
;   net-share-wifi warns to STDERR (non-fatal) if the file is world-readable
;   and contains any password= line. Password NEVER appears in --list /
;   --json output — only in --uri / --qr, the explicit "hand it out" path.
;
; DEFAULT (empty) STATE
;   No shared-wifi.conf shipped populated — this file is only a .sample.
;   `net-share-wifi --list` on a fresh install prints nothing and exits 0.
; ==========================================================================

; The site's primary WPA network. Same credentials the bitchat-bridge
; wifi_response section and the wifi-fanout autoresponder rule already use;
; centralizing them here lets both features (and any future picker) read
; from one source of truth.
[wifi.video]
ssid     = video
auth     = WPA
password = InTheRoom
note     = presentation-room WiFi (primary)

; An unencrypted example — a captive-portal / open guest AP. When auth =
; nopass, the WIFI: URI emitted by --uri omits the P: field entirely (which
; is what QR readers expect for open networks).
[wifi.guest]
ssid     = guest-open
auth     = nopass
note     = open guest AP (captive portal — accept ToS)

; Example overlay layout (drop into /etc/net-mgr/shared-wifi.d/*.conf):
;
;   ; /etc/net-mgr/shared-wifi.d/site-video-c.conf
;   [wifi.video]
;   ssid     = video-c
;   password = InTheRoom2
;   note     = video-c site override, rotated 2026-07
