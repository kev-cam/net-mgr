#!/usr/bin/perl
# net-recover-tlsg2424 — bring a factory-reset TL-SG2424 back to its
# configured management IP. Adds a temporary IP alias in the switch's
# default subnet (192.168.0.0/24), ARP-probes the factory IP, then
# either prints the parameters you'll need to enter through the web UI
# (default), OR pushes them in via HTTP (--auto).
#
# Re-run with --cleanup to remove the alias once the switch reboots
# onto its new address.
#
# Usage:
#   net-recover-tlsg2424 --iface eth0                    # print steps
#   net-recover-tlsg2424 --iface eth0 --manual           # + browser + wait + cleanup
#   net-recover-tlsg2424 --iface eth0 --auto             # HTTP push (experimental)
#   net-recover-tlsg2424 --iface eth0 --cleanup          # remove alias
#
# Defaults are tuned for the TL-SG2424 (factory IP 192.168.0.1, web UI
# on http://, login admin/admin or whatever's in ~/.netrc).
#
# Auto-mode endpoint defaults match T1500G/T1600G-era Smart Managed
# firmware. Per-host overrides go in /etc/net-mgr/switches/$HOST.conf
# (INI-style: [endpoints] login_url = .../, [fields] ip = ip, ...) so a
# different model can be supported without editing the script.

use strict;
use warnings;
use Getopt::Long qw(:config no_ignore_case bundling);

my $iface;
my $alias_ip   = '192.168.0.99';
my $factory_ip = '192.168.0.1';
my $expect_oui = '14:cc:20';            # TP-Link Technologies
my $netrc_host = 'swtch15';
my $cleanup;
my $no_browser;
my $describe;
my $auto;
my $manual;
my $verbose;
my $help;

GetOptions(
    'iface|i=s'    => \$iface,
    'alias=s'      => \$alias_ip,
    'factory=s'    => \$factory_ip,
    'host=s'       => \$netrc_host,
    'cleanup'      => \$cleanup,
    'no-browser'   => \$no_browser,
    'auto'         => \$auto,
    'manual'       => \$manual,
    'verbose|v'    => \$verbose,
    'describe'     => \$describe,
    'help|h'       => \$help,
) or usage();
usage() if $help;

# --describe is the discovery contract net-find-lost uses: emit one
# 'key: value' per line and exit 0. No root required.
if ($describe) {
    print "name: TL-SG2424\n";
    print "description: TP-Link 24-port managed switch (factory recovery)\n";
    print "on_subnet: 192.168.0.0/24\n";
    print "on_ip: $factory_ip\n";
    print "oui_prefix: $expect_oui\n";
    exit 0;
}

die "must run as root (need 'ip addr add/del')\n" if $> != 0;
die "need --iface\n" unless $iface;

my $alias_cidr = "$alias_ip/24";

if ($cleanup) {
    my $rc = system('ip', 'addr', 'del', $alias_cidr, 'dev', $iface);
    if ($rc == 0) { print "removed $alias_cidr from $iface\n" }
    else          { warn  "alias del returned $rc (already gone?)\n" }
    # The recovered switch isn't a wandering device any more — clear
    # its row from net-mgr's lost_devices table so the Web UI / DB
    # stop showing it. Best-effort: keep going if the daemon is
    # unreachable or the entry was never there.
    clear_lost_device($netrc_host, $factory_ip);
    exit($rc == 0 ? 0 : 1);
}

# --- Add the alias --------------------------------------------------
print "adding $alias_cidr to $iface ...\n";
my $rc = system('ip', 'addr', 'add', $alias_cidr, 'dev', $iface);
if ($rc != 0) {
    warn "ip addr add returned $rc; trying to continue (alias may already exist)\n";
}

# --- ARP-probe factory IP ------------------------------------------
print "arping $factory_ip on $iface ...\n";
my $arp = `arping -c 3 -w 3 -I $iface $factory_ip 2>&1`;
my ($mac) = $arp =~ /\[([0-9a-fA-F:]{17})\]/;
if (!$mac) {
    print STDERR "$arp\n";
    print STDERR "no response from $factory_ip.\n";
    print STDERR "things to check:\n";
    print STDERR "  - switch is powered on and link LEDs are lit\n";
    print STDERR "  - it's plugged into the L2 segment '$iface' reaches\n";
    print STDERR "  - factory IP isn't different (try --factory <ip>)\n";
    print STDERR "alias $alias_cidr left on $iface; remove with:\n";
    print STDERR "  net-recover-tlsg2424 --iface $iface --cleanup\n";
    exit 1;
}
$mac = lc $mac;
print "found MAC $mac at $factory_ip\n";
if (substr($mac, 0, 8) ne lc($expect_oui)) {
    print "  note: OUI doesn't match TP-Link $expect_oui — proceed only if you're sure.\n";
}

# --- Look up the desired settings ----------------------------------
my %target = lookup_target($netrc_host);
unless ($target{ip} && $target{netmask} && $target{gateway}) {
    warn "warn: dhcp.master is missing fields for $netrc_host (ip="
       . ($target{ip}      // '?')
       . " netmask=" . ($target{netmask} // '?')
       . " gateway=" . ($target{gateway} // '?') . ")\n";
}

# --- --auto: push the IP via the web UI's HTTP endpoints ------------
if ($auto) {
    my $ok = auto_push($factory_ip, $netrc_host, \%target);
    if ($ok) {
        print "\nIP push OK. The switch will reboot onto $target{ip}.\n";
        print "Once it's back, clean up with:\n";
        print "  net-recover-tlsg2424 --iface $iface --cleanup\n";
        exit 0;
    }
    warn "auto-push failed; falling back to manual instructions below.\n";
}

print "\n--- recovery steps ---\n";
print "Open the web UI:        http://$factory_ip/\n";
print "Login:                  admin / admin\n";
print "Navigate to:            System -> System Info -> System IP\n";
print "Set:\n";
print "  IP Address Mode:      Static\n";
printf "  IP Address:           %s\n", $target{ip}      // '(your mgmt IP)';
printf "  Subnet Mask:          %s\n", $target{netmask} // '255.255.255.0';
printf "  Default Gateway:      %s\n", $target{gateway} // '(your gateway)';
print "Apply.\n";
print "\n";
print "*** IMPORTANT: click 'Save Config' (top of UI) BEFORE rebooting. ***\n";
print "*** Apply alone only changes the running config — without Save  ***\n";
print "*** the switch reverts to factory on the next power cycle.      ***\n";
print "\n";
print "Then click 'Reboot'.\n";

if ($manual) {
    # Interactive helper: launch the browser, wait for the operator
    # to do the dance, then run the cleanup automatically. Saves
    # them remembering the cleanup invocation.
    unless ($no_browser) {
        my $opened = 0;
        for my $b (qw(xdg-open sensible-browser firefox chromium)) {
            my $path = "/usr/bin/$b";
            next unless -x $path;
            system { $path } $b, "http://$factory_ip/";
            $opened = 1;
            last;
        }
        if (!$opened) {
            print "\n(no browser found in PATH — open the URL above manually)\n";
        }
    }
    print "\nWhen the switch finishes rebooting and is reachable at "
        . ($target{ip} // 'its new IP') . ", press <enter> to clean up.\n";
    print "Or ^C to leave the alias in place.\n> ";
    my $line = <STDIN>;   # block until enter / ^D / ^C
    print "\n";
    print "cleaning up ...\n";
    my $rc = system('ip', 'addr', 'del', $alias_cidr, 'dev', $iface);
    if ($rc == 0) { print "removed $alias_cidr from $iface\n" }
    else          { warn  "alias del returned $rc (already gone?)\n" }
    clear_lost_device($netrc_host, $factory_ip);
    exit 0;
}

# Non-manual, non-auto: print where the operator needs to go and exit.
# This is the legacy / cron-friendly path (net-find-lost uses it when
# kicking the recovery automatically).
print "\nWhen the switch is back at " . ($target{ip} // 'its new IP') . ":\n";
print "  net-recover-tlsg2424 --iface $iface --cleanup\n";
print "\nOr re-run with --manual to be walked through interactively.\n";

if (!$no_browser && !$ENV{NET_MGR_AUTOMATED}) {
    for my $b (qw(xdg-open sensible-browser firefox chromium)) {
        my $path = "/usr/bin/$b";
        next unless -x $path;
        system { $path } $b, "http://$factory_ip/";
        last;
    }
}

exit 0;

# --- helpers -------------------------------------------------------

# Pull the desired mgmt IP / gateway / netmask from net-mgr's
# dhcp.master if it's there. Falls back to "ask the user" placeholders.
# host{} entries are typically declared outside any subnet{} block, so
# we collect all subnets first, then match the host's fixed-address
# against them.
sub lookup_target {
    my ($host) = @_;
    my %t;
    my $f = '/etc/net-mgr/dhcp.master';
    open my $fh, '<', $f or return %t;

    my @subnets;            # list of { cidr, mask, gw }
    my $cur;                # in-progress subnet hash, undef when outside
    my $host_ip;
    while (<$fh>) {
        if (/^subnet\s+(\S+)\s+netmask\s+(\S+)/) {
            $cur = { cidr => $1, mask => $2 };
            push @subnets, $cur;
        }
        if ($cur && /option\s+routers\s+(\S+);/) {
            $cur->{gw} = $1;
        }
        if ($cur && /^\s*\}/) {
            $cur = undef;
        }
        if (/host\s+\Q$host\E\b.*?fixed-address\s+(\S+);/) {
            $host_ip = $1;
        }
    }
    close $fh;
    return %t unless $host_ip;
    $t{ip} = $host_ip;
    for my $s (@subnets) {
        next unless ip_in_subnet($host_ip, $s->{cidr}, $s->{mask});
        $t{netmask} = $s->{mask};
        $t{gateway} = $s->{gw} if $s->{gw};
        last;
    }

    # dhcp.master uses uppercase placeholders like ROUTER_15 that are
    # substituted by net-var at config-gen time. If we got one, ask
    # net-var to resolve it for us.
    if ($t{gateway} && $t{gateway} =~ /^[A-Z][A-Z0-9_]*$/) {
        my $name = $t{gateway};
        for my $line (`net-var auto 2>/dev/null`) {
            if ($line =~ /^\Q$name\E\s*=\s*(\d+\.\d+\.\d+\.\d+)/) {
                $t{gateway} = $1;
                last;
            }
        }
    }
    return %t;
}

sub ip_in_subnet {
    my ($ip, $net, $mask) = @_;
    my $ipi   = ip_to_int($ip);   return 0 unless defined $ipi;
    my $neti  = ip_to_int($net);  return 0 unless defined $neti;
    my $maski = ip_to_int($mask); return 0 unless defined $maski;
    return ($ipi & $maski) == ($neti & $maski);
}

sub ip_to_int {
    my ($ip) = @_;
    return undef unless $ip =~ /^(\d+)\.(\d+)\.(\d+)\.(\d+)$/;
    return ($1 << 24) | ($2 << 16) | ($3 << 8) | $4;
}

sub usage {
    print <<USAGE;
net-recover-tlsg2424 — bring a factory-reset TL-SG2424 back online.

Usage:
  net-recover-tlsg2424 --iface NAME [--alias IP] [--factory IP] [--host NAME]
  net-recover-tlsg2424 --iface NAME --manual    # interactive helper
  net-recover-tlsg2424 --iface NAME --auto      # HTTP push (experimental)
  net-recover-tlsg2424 --iface NAME --cleanup   # remove alias only

Options:
  --iface, -i NAME   Interface the switch is reachable through (required).
  --alias IP         Temporary IP to add (default 192.168.0.99/24).
  --factory IP       Switch's factory IP (default 192.168.0.1).
  --host NAME        Hostname to look up in /etc/net-mgr/dhcp.master to
                     fill in the target IP/gateway/netmask (default
                     swtch15). Also keys the netrc credential lookup
                     and the per-model overrides in
                     /etc/net-mgr/switches/<NAME>.conf.
  --manual           Interactive helper: set up the alias, launch the
                     browser at the factory IP, wait for the operator
                     to walk through the web-UI steps, then run the
                     cleanup automatically on <enter>. ^C to leave
                     the alias in place.
  --auto             Push the target IP via the switch's web UI
                     instead of printing manual instructions. Reads
                     login creds from ~/.netrc (falls back to factory
                     admin/admin if no entry). Endpoint URLs default
                     to T1500G/T1600G-era firmware; override per
                     model in /etc/net-mgr/switches/<NAME>.conf.
                     Falls back to printing manual instructions if
                     the HTTP push fails.
  --verbose, -v      Print HTTP request/response details under --auto.
  --cleanup          Remove the alias + clear lost_devices row, then exit.
  --no-browser       Don't try to launch a browser at the factory IP.
  --help, -h         Print this help.
USAGE
    exit 1;
}

# ---- auto-push (HTTP) ----------------------------------------------
#
# Logs into the switch's web UI, posts the static-IP form, saves
# config, reboots. Defaults match T1500G/T1600G-era Smart Managed
# firmware. Per-host overrides go in /etc/net-mgr/switches/HOST.conf:
#
#   [endpoints]
#   login_url   = /logon.cgi
#   set_ip_url  = /system_ipv4.cgi
#   save_url    = /save_config.cgi
#   reboot_url  = /reboot.cgi
#
#   [login_fields]      ; sent verbatim, in addition to user/pass
#   cpassword = ""
#   logon     = "Login"
#
#   [ip_fields]         ; %IP%/%MASK%/%GW% are substituted
#   ipMode = 1
#   ip     = %IP%
#   mask   = %MASK%
#   gateway = %GW%
#
# The defaults below are best-guesses; the user is expected to verify
# them per model and add a HOST.conf if they don't match.

sub auto_push {
    my ($factory, $host, $tgt) = @_;
    for my $k (qw(ip netmask gateway)) {
        unless (defined $tgt->{$k}) {
            warn "auto-push: missing target.$k — need it in dhcp.master\n";
            return 0;
        }
    }
    # Try ~/.netrc first; fall back to factory admin/admin if absent
    # (a factory-reset switch by definition accepts those). Override
    # via NET_RECOVER_USER / NET_RECOVER_PASS env if neither suits.
    my %creds = read_netrc($host);
    if (!($creds{login} && defined $creds{password})) {
        $creds{login}    = $ENV{NET_RECOVER_USER} // 'admin';
        $creds{password} = $ENV{NET_RECOVER_PASS} // 'admin';
        warn "auto-push: no netrc credentials for '$host'; "
           . "using factory '$creds{login}/$creds{password}' "
           . "(override via NET_RECOVER_USER / NET_RECOVER_PASS)\n";
    }
    my $cfg = read_switch_conf($host);
    my %ep = (
        login_url  => '/logon.cgi',
        set_ip_url => '/system_ipv4.cgi',
        save_url   => '/save_config.cgi',
        reboot_url => '/reboot.cgi',
        %{ $cfg->{endpoints} // {} },
    );
    my %login_fields = (
        username  => $creds{login},
        password  => $creds{password},
        cpassword => '',
        logon     => 'Login',
        %{ $cfg->{login_fields} // {} },
    );
    my %ip_fields = (
        ipMode  => 1,
        ip      => '%IP%',
        mask    => '%MASK%',
        gateway => '%GW%',
        %{ $cfg->{ip_fields} // {} },
    );
    for my $v (values %ip_fields) {
        $v =~ s/%IP%/$tgt->{ip}/g;
        $v =~ s/%MASK%/$tgt->{netmask}/g;
        $v =~ s/%GW%/$tgt->{gateway}/g;
    }

    require File::Temp;
    my $cookie = File::Temp->new(SUFFIX => '.cookie')->filename;
    my $base   = "http://$factory";

    print "auto-push: login → $base$ep{login_url}\n";
    my ($rc, $body) = web_post($cookie, "$base$ep{login_url}", \%login_fields);
    if ($rc != 0) { warn "  login HTTP rc=$rc\n"; return 0 }
    if ($verbose) { warn "  login body: ", short($body), "\n" }
    if ($body =~ /(error|invalid|incorrect|fail)/i && $body !~ /Logout/i) {
        warn "  login body suggests failure: ", short($body), "\n";
        return 0;
    }

    print "auto-push: set IP $tgt->{ip}/$tgt->{netmask} gw=$tgt->{gateway}\n";
    ($rc, $body) = web_post($cookie, "$base$ep{set_ip_url}", \%ip_fields);
    if ($rc != 0) { warn "  set-IP HTTP rc=$rc\n"; return 0 }
    if ($verbose) { warn "  set-IP body: ", short($body), "\n" }

    print "auto-push: save running → startup\n";
    ($rc, $body) = web_post($cookie, "$base$ep{save_url}", {});
    if ($verbose) { warn "  save body: ", short($body), "\n" }

    print "auto-push: reboot\n";
    ($rc, $body) = web_post($cookie, "$base$ep{reboot_url}", {});
    # rc is often nonzero here because the switch closes the connection.

    unlink $cookie if -e $cookie;
    return 1;
}

# POST $url with form-encoded $form (hashref). Reuses $cookie for
# session continuity. Returns (rc, body) — rc is the curl exit code.
sub web_post {
    my ($cookie, $url, $form) = @_;
    my @data;
    for my $k (sort keys %$form) {
        push @data, '-d', "$k=$form->{$k}";
    }
    my @cmd = ('curl', '-sS', '-m', '8',
               '-b', $cookie, '-c', $cookie,
               '-o', '/tmp/.tlsg-resp', @data, $url);
    warn "  curl: @cmd\n" if $verbose;
    my $rc = system(@cmd);
    my $body = '';
    if (open my $f, '<', '/tmp/.tlsg-resp') {
        local $/; $body = <$f> // ''; close $f;
    }
    return ($rc >> 8, $body);
}

sub short {
    my ($s) = @_;
    $s //= '';
    $s =~ s/\s+/ /g;
    return length($s) > 200 ? substr($s, 0, 200) . '…' : $s;
}

sub read_netrc {
    my ($host) = @_;
    my %r;
    my $path = "$ENV{HOME}/.netrc";
    open my $fh, '<', $path or return %r;
    my $cur = '';
    while (my $line = <$fh>) {
        my @t = split ' ', $line;
        while (@t) {
            my $k = shift @t;
            if    ($k eq 'machine') { $cur = shift @t }
            elsif ($cur eq $host && ($k eq 'login' || $k eq 'user')) {
                $r{login} = shift @t;
            }
            elsif ($cur eq $host && $k eq 'password') {
                $r{password} = shift @t;
            }
            else { shift @t if @t }   # skip unknown value
        }
    }
    close $fh;
    return %r;
}

# Tell the local net-mgr daemon to drop the lost_devices row for
# this switch's factory IP. Looks up the switch's MAC by primary_name
# from net-mgr's interfaces table (the same name used as --host),
# computes the /24 the factory IP lives in, then OBSERVE
# kind=lost_device_delete. Best-effort: failure is logged but
# doesn't fail the cleanup as a whole.
sub clear_lost_device {
    my ($host, $factory) = @_;
    # /24 the factory IP belongs to (e.g. 192.168.0.1 → 192.168.0.0/24).
    my ($base) = $factory =~ /^(\d+\.\d+\.\d+)\.\d+$/
        or return;
    my $subnet = "$base.0/24";

    # Need a Perl client. Sub-shelling avoids hard-failing if the
    # net-mgr libs aren't loadable from this script's context.
    eval {
        local @INC = (@INC, '/usr/local/share/perl5');
        require NetMgr::Client;
        my $cli = NetMgr::Client->new(timeout => 4);
        $cli->hello(consumer => "recover-tlsg.$$");
        # Find MAC by primary_name.
        my $ifs   = $cli->snapshot(1, 'interfaces');
        my $machs = $cli->snapshot(2, 'machines');
        my %name_by_mid = map { $_->{id} => ($_->{primary_name}//'') } @$machs;
        my $mac;
        for my $i (@$ifs) {
            next unless $i->{mac} && defined $i->{machine_id};
            if (($name_by_mid{$i->{machine_id}}//'') eq $host) {
                $mac = lc $i->{mac};
                last;
            }
        }
        unless ($mac) {
            warn "  clear_lost: no MAC for primary_name=$host in DB\n";
            $cli->bye;
            return;
        }
        my $reply = $cli->observe(
            kind   => 'lost_device_delete',
            subnet => $subnet,
            mac    => $mac,
        );
        if ($reply && $reply =~ /^ERR\s+(.*)/) {
            warn "  clear_lost: $1\n";
        } else {
            print "  cleared lost_devices row ($subnet, $mac)\n";
        }
        $cli->bye;
    };
    if ($@) {
        my $e = $@; $e =~ s/\s+at\s+\S+\s+line\s+\d+\.?$//;
        warn "  clear_lost: best-effort failed ($e)\n";
    }
}

# Tiny INI reader for /etc/net-mgr/switches/$HOST.conf.
sub read_switch_conf {
    my ($host) = @_;
    my $path = "/etc/net-mgr/switches/$host.conf";
    my %c;
    return \%c unless -r $path;
    open my $fh, '<', $path or return \%c;
    my $sec = '_top';
    while (my $line = <$fh>) {
        $line =~ s/[\r\n]+\z//;
        $line =~ s/\s*#.*//;
        $line =~ s/^\s+|\s+$//g;
        next unless length $line;
        if ($line =~ /^\[([^\]]+)\]$/) { $sec = $1; next }
        if ($line =~ /^([\w.-]+)\s*=\s*(.*)$/) {
            my ($k, $v) = ($1, $2);
            $v =~ s/^"(.*)"$/$1/;
            $c{$sec}{$k} = $v;
        }
    }
    close $fh;
    return \%c;
}
