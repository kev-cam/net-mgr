#!/usr/bin/perl
# net-mgr-setup — interactive first-time DB (and relay) setup.
#
# Must be run as root (needs to talk to mysql via unix_socket and write the
# credentials file + a systemd drop-in).
#
# Asks whether to use the existing root account (unix_socket auth, no
# password) or create a dedicated MySQL user, then creates the database,
# the user (if needed), writes /etc/net-mgr/root.conf with a [net-mgr]
# section, and verifies the connection. Finally it configures how this node
# replicates from the fleet (relay mode + master).
#
# Non-interactive overrides:
#   --relay-mode none|peer|cluster   how net-mgr-relay runs (else prompts)
#   --master HOST[:PORT]             master for peer mode (else prompts)
#   --allow-existing                 proceed even if other databases exist

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use NetMgr::Client;   # split_hostport/join_hostport for the master endpoint

my $MYCNF    = '/etc/net-mgr/root.conf';
my $SECTION  = 'net-mgr';
my $DBNAME   = 'netmgr';

my ($allow_existing, $relay_mode, $master);
GetOptions(
    'allow-existing' => \$allow_existing,
    'relay-mode=s'   => \$relay_mode,
    'master=s'       => \$master,
) or die "bad options\n";
die "invalid --relay-mode '$relay_mode' (want none|peer|cluster)\n"
    if defined $relay_mode && $relay_mode !~ /^(none|peer|cluster)$/i;

die "must run as root\n" if $> != 0;

# ---- helpers ----------------------------------------------------------
sub prompt {
    my ($q, $default) = @_;
    local $| = 1;
    my $hint = defined $default && length $default ? " [$default]" : '';
    print "$q$hint: ";
    my $ans = <STDIN>;
    chomp $ans if defined $ans;
    return defined $ans && length $ans ? $ans : $default;
}

sub prompt_yn {
    my ($q, $default) = @_;
    while (1) {
        my $a = prompt($q . ' (y/n)', $default);
        return 1 if $a =~ /^y/i;
        return 0 if $a =~ /^n/i;
    }
}

sub prompt_pass {
    my ($q) = @_;
    local $| = 1;
    print "$q: ";
    system('stty', '-echo');
    my $p = <STDIN>;
    system('stty', 'echo');
    print "\n";
    chomp $p;
    return $p;
}

sub mysql_root {
    my (@sql) = @_;
    open my $fh, '|-', 'mysql', '-N', '-B' or die "mysql: $!";
    print {$fh} join(";\n", @sql), ";\n";
    close $fh;
    return $? == 0;
}

sub mysql_root_query {
    my ($sql) = @_;
    open my $fh, '-|', 'mysql', '-N', '-B', '-e', $sql or die "mysql: $!";
    my @rows = <$fh>;
    close $fh;
    chomp for @rows;
    return @rows;
}

sub is_mariadb {
    my @r = mysql_root_query("SELECT VERSION()");
    return $r[0] && $r[0] =~ /MariaDB/i;
}

sub user_exists {
    my ($user, $host) = @_;
    my @r = mysql_root_query(
        "SELECT 1 FROM mysql.user WHERE User='$user' AND Host='$host'");
    return scalar @r > 0;
}

sub db_exists {
    my ($name) = @_;
    my @r = mysql_root_query(
        "SELECT 1 FROM information_schema.schemata WHERE schema_name='$name'");
    return scalar @r > 0;
}

# ---- 1. probe mysql ---------------------------------------------------
print "Checking mysql connectivity (as unix_socket root)...\n";
unless (mysql_root_query("SELECT 1")) {
    die "Cannot connect to mysql as root via unix socket. Is the DB server running?\n";
}
print "  ok\n";

# Don't blow away someone else's databases (ZoneMinder, mediawiki, …).
# Only the system schemas are allowed unless --allow-existing was passed.
{
    my %sys = map { $_ => 1 } qw(information_schema mysql performance_schema sys);
    my @all = mysql_root_query("SHOW DATABASES");
    my @user_dbs = grep { !$sys{$_} && $_ ne $DBNAME } @all;
    if (@user_dbs && !$allow_existing) {
        die "Refusing to proceed: existing user database(s) detected:\n"
          . "  @user_dbs\n\n"
          . "net-mgr-setup will not run on a machine with other application data\n"
          . "without explicit consent — re-run with --allow-existing if you have\n"
          . "a recent mysqldump backup of the listed databases and want to proceed.\n";
    }
}

# ---- 2. existing credentials file -----------------------------------
if (-d $MYCNF) {
    die "$MYCNF exists but is a directory — fix that first:\n"
      . "  rmdir $MYCNF   # or rm -rf if it has content\n";
}
if (-e $MYCNF) {
    print "$MYCNF already exists.\n";
    if (!prompt_yn("Overwrite (or merge [$SECTION] section)?", 'y')) {
        print "Aborted; nothing changed.\n";
        exit 1;
    }
}

# ---- 3. choose auth strategy -----------------------------------------
my $use_root = prompt_yn(
    "Use mysql 'root' account via unix_socket (no password)?\n"
    . "  (Pick 'n' to create a dedicated 'net-mgr' user instead)", 'y');

my ($user, $pass);
if ($use_root) {
    $user = 'root';
    $pass = undef;
} else {
    $user = prompt("MySQL username for net-mgr", 'net-mgr');
    # Pick auth syntax by server vendor:
    #   MySQL  → IDENTIFIED WITH mysql_native_password BY '...'
    #            (pinning to the legacy plugin since MySQL 8's default
    #            caching_sha2_password isn't always supported by DBD::mysql)
    #   MariaDB → IDENTIFIED BY '...'
    #            (its CREATE USER doesn't accept the WITH … BY form)
    my $WITH = is_mariadb()
        ? "IDENTIFIED"
        : "IDENTIFIED WITH mysql_native_password";
    if (user_exists($user, 'localhost')) {
        print "User '$user'\@'localhost' already exists; will reuse.\n";
        $pass = prompt_pass("Existing password for '$user' (leave blank to reset)");
        if (!length $pass) {
            $pass = prompt_pass("New password for '$user'");
            my $repeat = prompt_pass("Repeat new password");
            die "passwords do not match\n" unless $pass eq $repeat;
            mysql_root("ALTER USER '$user'\@'localhost' $WITH BY '$pass'")
                or die "ALTER USER failed\n";
            print "  password reset\n";
        }
    } else {
        $pass = prompt_pass("New password for '$user'");
        my $repeat = prompt_pass("Repeat password");
        die "passwords do not match\n" unless $pass eq $repeat;
        mysql_root("CREATE USER '$user'\@'localhost' $WITH BY '$pass'")
            or die "CREATE USER failed\n";
        print "  user created\n";
    }
}

# ---- 4. database -----------------------------------------------------
if (db_exists($DBNAME)) {
    print "Database '$DBNAME' already exists.\n";
} else {
    mysql_root("CREATE DATABASE $DBNAME") or die "CREATE DATABASE failed\n";
    print "Database '$DBNAME' created.\n";
}

# ---- 5. grants -------------------------------------------------------
mysql_root("GRANT ALL ON $DBNAME.* TO '$user'\@'localhost'")
    or die "GRANT failed\n";
print "Privileges granted on $DBNAME.* to '$user'\@'localhost'.\n";

# ---- 6. write credentials file --------------------------------------
mkdir '/etc/net-mgr' unless -d '/etc/net-mgr';   # alongside the main config
my @existing;
if (-e $MYCNF) {
    open my $fh, '<', $MYCNF or die "read $MYCNF: $!";
    my $cur;
    my $skip = 0;
    while (my $line = <$fh>) {
        if ($line =~ /^\[([^\]]+)\]/) {
            $cur = $1;
            $skip = ($cur eq $SECTION) ? 1 : 0;
            next if $skip;
        }
        next if $skip;
        push @existing, $line;
    }
    close $fh;
}

my $section = "[$SECTION]\nuser=$user\n";
$section .= "password=$pass\n" if defined $pass;
$section .= "host=localhost\ndatabase=$DBNAME\n";

open my $out, '>', $MYCNF or die "write $MYCNF: $!";
print {$out} @existing;
print {$out} "\n" if @existing && $existing[-1] !~ /\n\z/;
print {$out} $section;
close $out;
chmod 0600, $MYCNF;
print "Wrote [$SECTION] to $MYCNF (mode 0600).\n";

# ---- 7. verify -------------------------------------------------------
print "Verifying connection through DBI...\n";
require NetMgr::DB;
my $db = NetMgr::DB->new(defaults_file => $MYCNF, section => $SECTION,
                        db => $DBNAME,
                        schema_dir => "$FindBin::Bin/../sql");
$db->connect;
my $v = $db->bootstrap_schema;
print "Schema bootstrapped to v$v.\n";
$db->disconnect;

# ---- 8. relay mode ---------------------------------------------------
# How this node replicates fleet state from another net-mgr:
#   none    — standalone; net-mgr-relay stays disabled.
#   peer    — pin to a single master with no election (a NAT'd / tunneled /
#             forward-only spoke, e.g. this VM reaching nas3 via 10.0.2.2).
#   cluster — join a [cluster] roster and elect a master.
my $DROPIN_DIR  = '/etc/systemd/system/net-mgr-relay.service.d';
my $DROPIN_FILE = "$DROPIN_DIR/peer.conf";

unless (defined $relay_mode) {
    print "\nnet-mgr-relay replicates fleet state from another net-mgr.\n";
    $relay_mode = prompt("Relay mode (none/peer/cluster)", 'none');
}
$relay_mode = lc $relay_mode;
die "invalid relay mode '$relay_mode' (want none|peer|cluster)\n"
    unless $relay_mode =~ /^(none|peer|cluster)$/;

if ($relay_mode eq 'peer') {
    $master = prompt("Master net-mgr IP/host[:port]", '127.0.0.1:7531')
        unless defined $master && length $master;
    die "peer mode needs a master (--master HOST[:PORT])\n"
        unless defined $master && length $master;
    # Default the port when the master is a bare host or bare IPv6 literal.
    my ($h, $p) = NetMgr::Client::split_hostport($master);
    $master = NetMgr::Client::join_hostport($h, $p // 7531);
    mkdir $DROPIN_DIR unless -d $DROPIN_DIR;
    open my $df, '>', $DROPIN_FILE or die "write $DROPIN_FILE: $!";
    print {$df} <<"EOF";
# Written by net-mgr-setup. Pin net-mgr-relay to a single master: no cluster
# election, no LAN-IP discovery — the relay only ever tries this connection.
# Suits a NAT'd / tunneled / forward-only spoke. Re-run net-mgr-setup (or edit
# / remove this file) to change.
[Service]
ExecStart=
ExecStart=/usr/local/sbin/net-mgr-relay --foreground --peer $master
EOF
    close $df;
    print "Wrote $DROPIN_FILE — relay pinned to $master.\n";
    print "Enable it with:\n";
    print "  systemctl daemon-reload && systemctl enable --now net-mgr-relay\n";
}
elsif ($relay_mode eq 'cluster') {
    unlink $DROPIN_FILE if -e $DROPIN_FILE;   # drop any single-master pin
    print "Cluster mode: set '[cluster] members = host1, host2, ...' in\n";
    print "/etc/net-mgr/config, then:\n";
    print "  systemctl daemon-reload && systemctl enable --now net-mgr-relay\n";
}
else {  # none
    unlink $DROPIN_FILE if -e $DROPIN_FILE;
    print "Relay left standalone (net-mgr-relay disabled). Re-run setup to "
        . "enable replication later.\n";
}

print "\nDone. You can now run:  prove -Ilib t/db.t\n";
