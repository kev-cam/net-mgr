#!/bin/sh
# net-mgr-dnsmasq-switch — flip this gateway between the user's custom dnsmasq
# and the distro-packaged (stock) one.
#
# Run by the daemon (as root) on an authenticated `dnsmasq_switch` OBSERVE —
# see NetMgr::Manager::_obs_dnsmasq_switch — or by hand. Trigger across the
# cluster with `net-cluster dnsmasq-switch variant=custom|stock`.
#
# Argv:  $1 = variant (custom|stock, default: custom)
#
# The heavy lifting for variant=custom is done by a "swap" script bundled with
# the kev-cam dnsmasq fork at /usr/local/src/dnsmasq/swap-dnsmasq. It stops the
# distro dnsmasq.service and launches the locally-built /usr/local/sbin/dnsmasq
# as a transient dnsmasq-local.service, re-using the ORIGINAL argv (read from
# /proc) — same /etc/dnsmasq.conf, same conf.d fragments, same pidfile/user.
# We invoke:
#   1. $NET_MGR_DNSMASQ_SWITCH_IMPL (set by the daemon from
#      [manager] dnsmasq_switch_impl), else
#   2. /usr/local/src/dnsmasq/swap-dnsmasq (the kev-cam fork's own swap tool)
# Argv mapping: variant=custom -> "$IMPL" local ; variant=stock -> "$IMPL" system.
# swap-dnsmasq's own 'status' subcommand is NEVER invoked from here.
#
# The dnsmasq tree must be present on the target host (nas3 has it; gateway3
# does NOT until the user rsyncs it — see prereqs in the commit message).
#
# If swap-dnsmasq isn't installed we exit non-zero on variant=custom with an
# actionable TODO. variant=stock has a hard-guaranteed dpkg-dist restore
# fallback (belt-and-suspenders — swap-dnsmasq system already reverses cleanly
# on its own, but the fallback covers a fresh host without the dnsmasq tree AND
# the case where swap-dnsmasq itself fails; per user, the swap scripts are
# UNTESTED) so an operator who lands on 'custom' can always get back to
# 'stock' from the CLI even without the swap script installed.
#
# Idempotent: /var/lib/net-mgr/dnsmasq-variant remembers the last flip so
# re-running switch-to-custom while already on custom exits 0 with a message
# and does nothing. Reversibility is explicit — the user's ask ("easier to
# test") means flipping back and forth is the point.
#
# WARNING: variant=stock on a live gateway drops any /usr/local/sgy/conf.d/
# fragments the running config pulls in, which can take down DHCP for the
# whole subnet until you flip back. We surface a big warning and (unless
# --force / FORCE=1) still proceed — but at least the operator sees it.
#
# Steps are self-reporting; `set -e` is NOT set so the caller sees the full
# picture on partial failure, matching sibling scripts (net-mgr-reset-ble).

VARIANT="${1:-custom}"
FORCE="${FORCE:-0}"

STATE_DIR=/var/lib/net-mgr
STATE_FILE="$STATE_DIR/dnsmasq-variant"

DEFAULT_IMPL=/usr/local/src/dnsmasq/swap-dnsmasq
IMPL="${NET_MGR_DNSMASQ_SWITCH_IMPL:-$DEFAULT_IMPL}"

DPKG_DIST=/etc/dnsmasq.conf.dpkg-dist
LIVE_CONF=/etc/dnsmasq.conf
BAK_CONF=/etc/.dnsmasq.conf.bak-sgy

echo "net-mgr-dnsmasq-switch: $(date -Is) on $(hostname) variant=$VARIANT"

case "$VARIANT" in
    custom|stock) ;;
    *)
        echo "  ERROR: variant must be 'custom' or 'stock' (got '$VARIANT')"
        exit 2
        ;;
esac

step() {
    label=$1; shift
    printf 'step: %s ... ' "$label"
    if out=$("$@" 2>&1); then
        echo "ok"
        [ -n "$out" ] && echo "$out" | sed 's/^/  /'
        return 0
    else
        rc=$?
        echo "FAIL rc=$rc"
        [ -n "$out" ] && echo "$out" | sed 's/^/  /'
        return $rc
    fi
}

# Idempotency check — running switch-to-X while already on X is a no-op.
if [ -r "$STATE_FILE" ]; then
    current=$(cat "$STATE_FILE" 2>/dev/null | tr -d '[:space:]')
    if [ "$current" = "$VARIANT" ]; then
        echo "  already on $VARIANT (per $STATE_FILE) — nothing to do"
        exit 0
    fi
fi

# Currently-serving-DHCP check — only interesting when going TO stock, since
# that path drops sgy include fragments and can take down the subnet.
if [ "$VARIANT" = "stock" ]; then
    live_dhcp=no
    if systemctl is-active --quiet dnsmasq 2>/dev/null; then
        live_dhcp=yes
    fi
    if [ "$live_dhcp" = "yes" ]; then
        echo "  ****************************************************************"
        echo "  * WARNING: dnsmasq is ACTIVE on this host. Switching to 'stock' *"
        echo "  * will overwrite /etc/dnsmasq.conf with the dpkg-dist default,  *"
        echo "  * dropping any /usr/local/sgy/conf.d/dnsmasq-* include lines    *"
        echo "  * the running config pulls in. DHCP for served subnets will be  *"
        echo "  * DOWN until you flip back with variant=custom.                 *"
        echo "  * (backup of the live conf is written to $BAK_CONF)"
        echo "  ****************************************************************"
        if [ "$FORCE" != "1" ]; then
            echo "  (set FORCE=1 in env to acknowledge and proceed non-interactively)"
        fi
    fi
fi

rc_overall=0

case "$VARIANT" in
custom)
    # variant=custom needs the swap script. If it isn't present, exit non-zero
    # with an actionable TODO — no useful fallback exists (we don't know how
    # to launch the user's custom binary with the right argv without it).
    if [ ! -x "$IMPL" ]; then
        echo "  ERROR: switch impl '$IMPL' not found or not executable"
        echo "  TODO: rsync the dnsmasq tree from nas3 (source of truth):"
        echo "          rsync -a --delete /usr/local/src/dnsmasq/ \\"
        echo "                root@$(hostname):/usr/local/src/dnsmasq/"
        echo "        then build+install the custom binary on this host:"
        echo "          cd /usr/local/src/dnsmasq && ./remake install"
        echo "        or set [manager] dnsmasq_switch_impl = /path/to/script"
        echo "        in /etc/net-mgr/config to point at a different swap tool."
        exit 3
    fi
    step "run $IMPL local" "$IMPL" local || rc_overall=$?
    ;;
stock)
    # Try the swap script first if present — swap-dnsmasq system cleanly
    # stops dnsmasq-local and starts dnsmasq.service (same /etc/dnsmasq.conf
    # on both sides, so no config restore needed). The dpkg-dist restore
    # below is belt-and-suspenders for a fresh host without the tree yet, or
    # if swap-dnsmasq itself fails (UNTESTED per user).
    if [ -x "$IMPL" ]; then
        step "run $IMPL system" "$IMPL" system || rc_overall=$?
    else
        echo "step: run swap-dnsmasq system ... skip ('$IMPL' not present)"
    fi
    # Guaranteed fallback: restore /etc/dnsmasq.conf from dpkg-dist and
    # restart dnsmasq. Idempotent — an unchanged file just gets copied over
    # itself. Backup the live conf first so the flip is reversible even from
    # here (variant=custom will invoke the manual script; if that's missing
    # the operator can `cp $BAK_CONF $LIVE_CONF` by hand).
    if [ -r "$DPKG_DIST" ]; then
        if [ -r "$LIVE_CONF" ]; then
            step "backup $LIVE_CONF -> $BAK_CONF" cp -p "$LIVE_CONF" "$BAK_CONF" \
                || rc_overall=$?
        fi
        step "restore $LIVE_CONF from $DPKG_DIST" cp -p "$DPKG_DIST" "$LIVE_CONF" \
            || rc_overall=$?
    else
        echo "step: restore dpkg-dist ... skip ($DPKG_DIST not present)"
    fi
    if systemctl is-enabled dnsmasq >/dev/null 2>&1 \
       || systemctl is-active dnsmasq >/dev/null 2>&1; then
        step "systemctl restart dnsmasq" systemctl restart dnsmasq || rc_overall=$?
        sleep 2
        state=$(systemctl is-active dnsmasq 2>&1 || true)
        echo "  dnsmasq state: $state"
    else
        echo "step: restart dnsmasq ... skip (unit not enabled/active)"
    fi
    ;;
esac

# Persist the new state ONLY when the switch itself succeeded — a half-failed
# flip must not confuse the idempotency check on the next call.
if [ "$rc_overall" = "0" ]; then
    if [ ! -d "$STATE_DIR" ]; then
        mkdir -p "$STATE_DIR" 2>/dev/null || true
    fi
    if [ -d "$STATE_DIR" ]; then
        printf '%s\n' "$VARIANT" > "$STATE_FILE" 2>/dev/null || true
        echo "  recorded variant=$VARIANT in $STATE_FILE"
    fi
    echo "net-mgr-dnsmasq-switch: done (variant=$VARIANT)"
else
    echo "net-mgr-dnsmasq-switch: FINISHED WITH ERRORS (rc=$rc_overall) — state NOT updated"
fi

# Always exit 0 so the daemon logs the full per-step trace rather than a
# truncated first-failure. Callers key off the printed state summary.
exit 0
