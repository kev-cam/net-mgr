#!/usr/bin/perl
# net-mgr-relay ā€” replicate cluster state from the elected master
# into this host's local DB.
#
# Reads /etc/net-mgr/config for the [cluster] section:
#   [cluster]
#   members  = host1, host2, host3        # the roster
#   role     = auto                        # auto | master | follower | excluded
#   priority = 100                         # lower wins
#
# Every election_interval (default 60s):
#   1. Probe STATUS on every roster member (and self).
#   2. Score each reachable candidate (priority - prefer_lan bonus when
#      not internet-facing); pick lowest, tiebreak by name.
#   3. quorum_ok = reachable >= ceil(N/2).
#
# Then:
#   - If self is the winner AND quorum_ok ā†’ act as master, kill any
#     subscribe-child (we're the source of truth now).
#   - If winner ā‰  self AND quorum_ok ā†’ fork (or replace) a relay
#     child subscribed to the winner's tables.
#   - If !quorum_ok ā†’ no child, log isolated state. The local daemon
#     keeps accepting OBSERVEs (mobile-host case: scan locally, sync
#     when quorum returns).
#
# Legacy [peers] sources is ignored (the cluster roster supersedes
# it). --peer host on the CLI still works as an override for ad-hoc
# debug ā€” disables election, just subscribes to the given peer.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use POSIX qw(:sys_wait_h);
use Time::HiRes qw(sleep);

use IO::Socket::IP;
use IO::Select;

use NetMgr::Config;
use NetMgr::DB;
use NetMgr::Relay;
use NetMgr::Manager;       # for _load_cluster_state
use NetMgr::Client;
use NetMgr::Protocol qw(parse_line format_ok format_err);

my $conf_path  = $ENV{NET_MGR_CONF} // '/etc/net-mgr/config';
my $foreground = 0;
my @peers_cli;
GetOptions(
    'config=s'     => \$conf_path,
    'foreground|f' => \$foreground,
    'peer=s@'      => \@peers_cli,
) or die "bad options\n";

my $cfg = NetMgr::Config->load($conf_path);
my $cluster = NetMgr::Manager::_load_cluster_state($cfg);

# Mode selection.
#   --peer host[,hostā€¦]  legacy/debug fixed-peer mode (no election)
#   else                  cluster mode (election on the configured roster)
my $fixed_peer;
if (@peers_cli) {
    $fixed_peer = (split /,/, $peers_cli[0])[0];
    print STDERR "[net-mgr-relay] fixed-peer mode: $fixed_peer\n";
} elsif (!@{ $cluster->{members} }) {
    print STDERR "[net-mgr-relay] no roster ([cluster] members empty) and no "
               . "--peer; nothing to do. Exiting.\n";
    exit 0;
} else {
    print STDERR "[net-mgr-relay] cluster mode: self=$cluster->{self_name} "
               . "roster=" . join(',', @{ $cluster->{members} }) . " "
               . "role=$cluster->{role} priority=$cluster->{priority}\n";
}

# DB connection settings ā€” each child opens its own connection.
my $mycnf = NetMgr::Config->mysql_defaults_file($cfg);
unless (-r $mycnf) {
    # systemd services usually have no HOME; guard so it isn't a warning.
    $mycnf = "$ENV{HOME}/.my.cnf"
        if $ENV{HOME} && -r "$ENV{HOME}/.my.cnf";
}
die "no readable MySQL option file for [net-mgr] (tried $mycnf)\n"
    unless -r $mycnf;

unless ($foreground) {
    my $pid = fork; die "fork: $!" unless defined $pid;
    exit 0 if $pid;
    require POSIX; POSIX::setsid();
    open STDIN,  '<',  '/dev/null';
    open STDOUT, '>>', '/dev/null';
}

# Per-child state. In cluster mode there's at most one child at a
# time (subscribing to the elected master); in fixed-peer mode the
# single child stays put.
my %child;     # { pid, peer, started_at }

$SIG{TERM} = sub { _kill_child(); exit 0 };
$SIG{INT}  = $SIG{TERM};

if ($fixed_peer) {
    # Legacy mode: spawn once, restart on death, no election.
    while (1) {
        _spawn_child($fixed_peer) unless $child{pid};
        my $kid = waitpid(-1, 0);
        if ($kid > 0 && $child{pid} && $kid == $child{pid}) {
            print STDERR "[net-mgr-relay] child for $fixed_peer exited; "
                . "restart in 10s\n";
            %child = ();
            sleep 10;
        }
    }
    exit 0;
}

# Cluster mode: as of Slice D, the daemon runs its own election off
# the persistent mesh heartbeats. The relay's job is simpler ā€” watch
# the local daemon's STATUS, and if it reports cluster_role=follower
# with a master, subscribe to that master. If the master changes,
# tear down + restart the child against the new one. If we're master
# (or there's no quorum), no child runs.
#
# The relay still runs its legacy run_election() as a fallback so a
# very old daemon (pre-Slice C) still gets a CLUSTER_ROLE push. The
# daemon's own election will override almost immediately when present.
# Loopback proxy socket: apps that need *current* data for one subnet
# (net-reserve) send `REFRESH subnet=a.b.c.0/24` here; we answer from
# ourselves when this host is the master, else scope-pull the subnet
# from the elected master into the local DB. The lazy subscribe-stream
# stays the normal path; this is the on-demand complement.
my $proxy_addr = $cfg->{cluster}{proxy_listen} // '127.0.0.1:7532';
my $proxy_sock;
if (lc($proxy_addr) ne 'none') {
    my ($ph, $pp) = NetMgr::Client::split_hostport($proxy_addr);
    $proxy_sock = IO::Socket::IP->new(
        LocalHost => $ph, LocalPort => $pp // 7532,
        Listen => 5, ReuseAddr => 1, Type => Socket::SOCK_STREAM(),
    ) or print STDERR "[net-mgr-relay] proxy listen $proxy_addr: $! "
                    . "(REFRESH disabled)\n";
    print STDERR "[net-mgr-relay] REFRESH proxy on $proxy_addr\n"
        if $proxy_sock;
}
my $proxy_sel = $proxy_sock ? IO::Select->new($proxy_sock) : undef;

my $tick = $cluster->{election_interval} || 10;
while (1) {
    my $watched = watch_local_status();
    if (defined $watched) {
        apply_watched($watched);
    } else {
        # Local daemon not reachable, or its STATUS doesn't carry the
        # cluster_role field ā€” fall back to the legacy election.
        my $result = run_election();
        apply_election($result);
    }
    while ((my $kid = waitpid(-1, WNOHANG)) > 0) {
        next unless $child{pid} && $kid == $child{pid};
        print STDERR "[net-mgr-relay] subscribe-child died (peer=$child{peer});"
            . " will re-evaluate on next tick\n";
        %child = ();
    }
    proxy_wait($tick);
}

# Sleep the inter-election tick, but wake up for proxy requests.
sub proxy_wait {
    my ($secs) = @_;
    return sleep($secs) unless $proxy_sel;
    my $end = Time::HiRes::time() + $secs;
    while ((my $left = $end - Time::HiRes::time()) > 0) {
        my @ready = $proxy_sel->can_read($left) or last;   # timed out
        for my $l (@ready) {
            my $conn = $l->accept or next;
            eval { handle_proxy($conn) };
            print STDERR "[net-mgr-relay] proxy request failed: $@" if $@;
            close $conn;
        }
    }
}

# One request per connection: read a line, act, reply, done. Short
# alarm so a stuck client can't wedge the election loop.
sub handle_proxy {
    my ($conn) = @_;
    my $line;
    eval {
        local $SIG{ALRM} = sub { die "proxy read timeout\n" };
        alarm 5;
        $line = <$conn>;
        alarm 0;
    };
    die $@ if $@;
    return unless defined $line;
    $line =~ s/[\r\n]+$//;
    my $cmd = eval { parse_line($line) };
    if (!$cmd || $@) {
        my $e = $@ || 'unparsable'; chomp $e;
        $e =~ s/\s+at \S+ line \d+\.?\s*$//;   # strip croak's location
        print {$conn} format_err("bad request: $e"), "\n";
        return;
    }
    if ($cmd->{verb} ne 'REFRESH') {
        print {$conn} format_err("unsupported verb '$cmd->{verb}'"), "\n";
        return;
    }
    my $subnet = $cmd->{kv}{subnet};
    unless (defined $subnet && length $subnet) {
        print {$conn} format_err("REFRESH: missing subnet="), "\n";
        return;
    }

    my $w = watch_local_status();
    unless ($w) {
        print {$conn} format_err("REFRESH: local daemon unreachable"), "\n";
        return;
    }
    my $role = $w->{role} // '';
    if ($role eq 'master' || $role eq 'auto') {
        # We ARE the source of truth ā€” nothing to pull.
        print {$conn} format_ok(role => 'master', rows => 0), "\n";
        return;
    }
    unless ($role eq 'follower' && length $w->{master}) {
        print {$conn} format_err("REFRESH: no master (role=$role)"), "\n";
        return;
    }
    my $addr = $w->{master_addr};
    if (!length($addr // '')) {
        my $ip = resolve_ip($w->{master});
        $addr = $ip ? NetMgr::Client::join_hostport($ip, 7531) : undef;
    }
    unless ($addr) {
        print {$conn} format_err("REFRESH: can't resolve master "
                                . "'$w->{master}'"), "\n";
        return;
    }

    my $db = NetMgr::DB->new(
        defaults_file => $mycnf,
        section       => $cfg->{mysql}{section} // 'net-mgr',
        db            => $cfg->{mysql}{db}      // 'netmgr',
    );
    $db->connect;
    my $rows = eval {
        NetMgr::Relay::refresh_subnet(
            db => $db, peer => $addr, subnet => $subnet,
            replicated_from => $w->{master}, timeout => 10);
    };
    if ($@) {
        my $e = $@; chomp $e;
        print {$conn} format_err("REFRESH: $e"), "\n";
        return;
    }
    print {$conn} format_ok(role => 'follower', master => $w->{master},
                            subnet => $subnet, rows => $rows), "\n";
    print STDERR "[net-mgr-relay] REFRESH $subnet from $w->{master}: "
               . "$rows rows\n";
}

# Returns a hashref of the local daemon's cluster_role / cluster_master /
# cluster_master_addr fields, or undef if the daemon is unreachable or
# the fields aren't populated yet (pre-Slice-C daemon).
sub watch_local_status {
    my $cli = eval {
        NetMgr::Client->new(listen => '127.0.0.1:7531', timeout => 3);
    };
    return undef unless $cli;
    eval { $cli->hello(consumer => "relay-watch.$$") };
    if ($@) { eval { $cli->bye }; return undef }
    my $st = eval { $cli->status };
    eval { $cli->bye };
    return undef unless $st;
    return undef unless exists $st->{cluster_role};
    return {
        role        => $st->{cluster_role},
        master      => $st->{cluster_master}      // '',
        master_addr => $st->{cluster_master_addr} // '',
        quorum_ok   => $st->{quorum_ok},
    };
}

sub apply_watched {
    my ($w) = @_;
    my $role = $w->{role};
    if ($role eq 'master' || $role eq 'auto') {
        _log_status("daemon says role=$role; no subscribe-child needed");
        _kill_child();
        return;
    }
    if ($role eq 'follower' && length $w->{master}) {
        my $addr = $w->{master_addr};
        if (!length $addr) {
            # daemon doesn't have a live mesh socket to the master
            # yet ā€” resolve by name as a fallback. resolve_ip() also
            # net-lookup-verifies reachability.
            $addr = resolve_ip($w->{master});
            return _log_status("daemon says follow $w->{master} but no addr "
                             . "(retry next tick)") unless $addr;
            $addr = NetMgr::Client::join_hostport($addr, 7531);
        }
        my ($host) = NetMgr::Client::split_hostport($addr);
        if ($child{pid} && $child{peer} ne $host) {
            _log_status("master changed to $w->{master} ($addr); "
                      . "restarting child");
            _kill_child();
        }
        unless ($child{pid}) {
            _spawn_child($host, $w->{master});
            _log_status("following $w->{master} ($addr) "
                      . "[via daemon election]");
        }
        return;
    }
    _log_status("daemon role=$role master=$w->{master}; idling");
    _kill_child();
}

# =====================================================================
# Election
# =====================================================================

sub run_election {
    my @probes;
    for my $m (@{ $cluster->{members} }) {
        my $p = probe_member($m);
        push @probes, $p if $p;
    }
    # Election eligibility = candidate is reachable, didn't opt out
    # (role != excluded/follower), AND this daemon's local authority
    # table grants them 'master'. If peer_caps is empty (no
    # /etc/net-mgr/peers file present), fall back to allowing any
    # reachable candidate ā€” keeps single-node and "first time set up"
    # cases working.
    my @candidates;
    my $caps_table = $cluster->{peer_caps} || {};
    my $no_caps_configured = !keys %$caps_table;
    for my $p (@probes) {
        next if ($p->{role} // 'auto') eq 'excluded';
        next if ($p->{role} // 'auto') eq 'follower';
        if (!$no_caps_configured) {
            my $granted = $caps_table->{ $p->{member} } || [];
            next unless grep { $_ eq 'master' } @$granted;
        }
        push @candidates, $p;
    }
    my $reachable_count = scalar @probes;
    my $roster_n        = scalar @{ $cluster->{members} };
    my $quorum_ok       = $roster_n <= 1
                        ? 1
                        : ($reachable_count >= int($roster_n / 2) + 1);

    return { winner => undef, quorum_ok => $quorum_ok,
             reachable => $reachable_count, roster_n => $roster_n }
        unless @candidates;

    @candidates = sort {
           $a->{score} <=> $b->{score}
        || $a->{member} cmp $b->{member}
    } @candidates;
    my $winner = $candidates[0];
    return {
        winner    => $winner,
        quorum_ok => $quorum_ok,
        reachable => $reachable_count,
        roster_n  => $roster_n,
    };
}

# Probe one roster member. Returns a hashref with the relevant STATUS
# fields, or undef if the member couldn't be probed. For self we
# avoid the round-trip and load directly from the local config +
# the local daemon (so an isolated host still elects itself).
sub probe_member {
    my ($name) = @_;
    if ($name eq $cluster->{self_name}) {
        return {
            member          => $name,
            role            => $cluster->{role},
            priority        => $cluster->{priority},
            prefer_lan      => $cluster->{prefer_lan},
            internet_facing => defined $cluster->{internet_facing}
                             ? $cluster->{internet_facing} : 0,
            ip              => '127.0.0.1',
            score           => _score($cluster->{priority},
                                       $cluster->{prefer_lan},
                                       $cluster->{internet_facing}),
        };
    }
    my $ip = resolve_ip($name);
    return undef unless $ip;
    my $cli = eval { NetMgr::Client->new(
        listen => NetMgr::Client::join_hostport($ip, 7531), timeout => 4) };
    return undef unless $cli;
    eval { $cli->hello(consumer => "relay-election.$$") };
    return undef if $@;
    my $st = eval { $cli->status };
    eval { $cli->bye };
    return undef unless $st && $st->{cluster_member};
    return {
        member          => $st->{cluster_member},
        role            => $st->{cluster_role}            // 'auto',
        priority        => $st->{cluster_priority}        // 100,
        prefer_lan      => $st->{cluster_prefer_lan}      // 1,
        internet_facing => $st->{cluster_internet_facing} // 0,
        ip              => $ip,
        score           => _score($st->{cluster_priority},
                                   $st->{cluster_prefer_lan},
                                   $st->{cluster_internet_facing}),
    };
}

sub _score {
    my ($priority, $prefer_lan, $internet_facing) = @_;
    my $s = $priority // 100;
    $s -= 50 if $prefer_lan && !$internet_facing;
    return $s;
}

# Resolve a cluster member name to an IP via net-lookup (which
# already does the right thing ā€” prefers wired, verifies reachable,
# etc.). Cached for the lifetime of this process to avoid hammering
# the local daemon every election tick.
my %resolve_cache;
sub resolve_ip {
    my ($name) = @_;
    return $resolve_cache{$name} if exists $resolve_cache{$name};
    open my $fh, '-|', 'net-lookup', '--verify', $name
        or return ($resolve_cache{$name} = undef);
    my $ip;
    while (my $line = <$fh>) {
        chomp $line;
        if ($line =~ /^(\d+\.\d+\.\d+\.\d+)$/) { $ip = $1; last }
    }
    close $fh;
    return ($resolve_cache{$name} = $ip);
}

# =====================================================================
# Acting on the election result
# =====================================================================

sub apply_election {
    my ($r) = @_;
    my $self_name = $cluster->{self_name};
    if (!$r->{quorum_ok}) {
        _log_status("isolated (no quorum: $r->{reachable}/$r->{roster_n})");
        _push_local_role('auto');
        _kill_child();
        return;
    }
    my $w = $r->{winner};
    if (!$w) {
        _log_status("no eligible candidates; "
                  . "$r->{reachable}/$r->{roster_n} reachable");
        _push_local_role('auto');
        _kill_child();
        return;
    }
    if ($w->{member} eq $self_name) {
        _log_status("self is master ($w->{member} score=$w->{score} "
                  . "quorum=$r->{reachable}/$r->{roster_n})");
        _push_local_role('master');
        _kill_child();
        return;
    }
    # Someone else is master ā€” subscribe to them.
    if ($child{pid} && $child{peer} ne $w->{ip}) {
        _log_status("master changed to $w->{member}; restarting child");
        _kill_child();
    }
    _push_local_role('follower', master => $w->{member});
    unless ($child{pid}) {
        _spawn_child($w->{ip}, $w->{member});
        _log_status("following $w->{member} ($w->{ip}) score=$w->{score} "
                  . "quorum=$r->{reachable}/$r->{roster_n}");
    }
}

# Push the elected role into the local daemon so its STATUS reports
# cluster_role accurately. Loopback-only on the daemon side; the
# daemon refuses non-loopback CLUSTER_ROLE writes. Best-effort ā€”
# if the daemon's down or restarting, we silently skip and try
# again next tick.
my $last_pushed = '';
sub _push_local_role {
    my ($role, %args) = @_;
    my $key = $role . '|' . ($args{master} // '');
    return if $key eq $last_pushed;     # nothing new to say
    my $cli = eval {
        NetMgr::Client->new(listen => '127.0.0.1:7531', timeout => 3);
    };
    return unless $cli;
    eval { $cli->hello(consumer => "relay-cluster-role.$$") };
    if ($@) { eval { $cli->bye }; return }
    eval {
        $cli->cluster_role(
            role   => $role,
            member => $cluster->{self_name},
            ($args{master} ? (master => $args{master}) : ()),
        );
    };
    eval { $cli->bye };
    return if $@;
    $last_pushed = $key;
}

# =====================================================================
# Child process management
# =====================================================================

sub _spawn_child {
    my ($peer, $repl_from) = @_;
    my $pid = fork; die "fork: $!" unless defined $pid;
    if ($pid == 0) {
        my $db = NetMgr::DB->new(
            defaults_file => $mycnf,
            section       => $cfg->{mysql}{section} // 'net-mgr',
            db            => $cfg->{mysql}{db}      // 'netmgr',
        );
        $db->connect;
        NetMgr::Relay::run(
            peer            => $peer,
            db              => $db,
            log_fh          => \*STDERR,
            replicated_from => $repl_from,
        );
        exit 0;
    }
    %child = (pid => $pid, peer => $peer, started_at => time);
    return $pid;
}

sub _kill_child {
    return unless $child{pid};
    kill 'TERM', $child{pid};
    waitpid $child{pid}, 0;
    %child = ();
}

# Log + dedupe consecutive identical status lines so the daemon log
# doesn't get spammed with the same "isolated" line every minute.
my $last_status_msg;     # NB: file-bottom `my ... = ''` would never run ā€”
sub _log_status {        # the main while(1) above never falls through here.
    my ($msg) = @_;
    return if $msg eq ($last_status_msg // '');
    $last_status_msg = $msg;
    my @t = localtime;
    printf STDERR "%04d-%02d-%02d %02d:%02d:%02d [net-mgr-relay] %s\n",
        $t[5]+1900, $t[4]+1, $t[3], $t[2], $t[1], $t[0], $msg;
}
