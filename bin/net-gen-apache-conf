#!/usr/bin/perl
# net-gen-apache-conf — emit the Apache 2.4 snippet for the net-mgr
# web UI.  The bypass-auth IP list is derived from interface_zones
# rows whose zone_class is 'Private' — so Private clients skip basic-
# auth and everyone else (DMZ, Internet, Dummy, …) gets challenged.
#
# Usage:
#   net-gen-apache-conf                     print to stdout
#   net-gen-apache-conf --write [--path P]  write the file (default
#                                           /etc/apache2/conf-available/
#                                           net-mgr.conf)
#   net-gen-apache-conf --reload            write + reload apache2
#
# Loopback (127/8 and ::1) is always allowed without auth.  If
# interface_zones has no Private rows yet, only loopback bypasses
# auth and a warning is printed — that's almost certainly a misconfig
# (no zones set up) rather than the intended policy.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use NetMgr::Config;
use NetMgr::DB;

my $write;
my $reload;
my $path     = '/etc/apache2/conf-available/net-mgr.conf';
my $htpasswd = '/etc/net-mgr/htpasswd';
my $help;
GetOptions(
    'write'      => \$write,
    'reload'     => \$reload,
    'path=s'     => \$path,
    'htpasswd=s' => \$htpasswd,
    'help|h'     => \$help,
) or usage(2);
sub usage {
    my ($rc) = @_;
    print <<'EOT';
net-gen-apache-conf — regenerate the Apache snippet from interface_zones.

  net-gen-apache-conf            print to stdout (default)
  net-gen-apache-conf --write    write /etc/apache2/conf-available/net-mgr.conf
  net-gen-apache-conf --reload   write + systemctl reload apache2

  --path PATH                    write target (default conf-available/net-mgr.conf)
  --htpasswd PATH                AuthUserFile path (default /etc/net-mgr/htpasswd)
EOT
    exit $rc;
}
usage(0) if $help;

my $cfg = NetMgr::Config->load(
    $ENV{NET_MGR_CONF} // '/etc/net-mgr/config');
my $mycnf = (-r "$ENV{HOME}/.my.cnf") ? "$ENV{HOME}/.my.cnf"
          : NetMgr::Config->mysql_defaults_file($cfg);
my $db = NetMgr::DB->new(
    defaults_file => $mycnf,
    section       => $cfg->{mysql}{section},
    db            => $cfg->{mysql}{db},
);
$db->connect;

my $iface_zones = eval { $db->query_table('interface_zones') } || [];
my @private = do {
    my %seen;
    sort grep { !$seen{$_}++ }
         map  { $_->{cidr} }
         grep { ($_->{zone_class} // '') eq 'Private' } @$iface_zones;
};

if (!@private) {
    print STDERR "warning: no Private CIDRs in interface_zones — "
               . "only loopback will bypass auth.  Set up zones with "
               . "'net-zones edit' first.\n";
}

# Loopback always allowed.
my @bypass = ('127.0.0.0/8', '::1', @private);

my $conf = <<"CONF";
# net-mgr web UI — generated by net-gen-apache-conf.
#
# Auth policy:
#   * clients on Private-class CIDRs (interface_zones) skip basic-auth
#   * everyone else needs a valid user in $htpasswd
#
# Regenerate whenever interface_zones changes:
#   net-gen-apache-conf --reload
#
# Create / update the password file:
#   htpasswd -c $htpasswd <user>

ScriptAlias /net-mgr /usr/lib/cgi-bin/net-mgr-web.cgi

<Files "net-mgr-web.cgi">
    SetHandler cgi-script
    Options +ExecCGI
</Files>

<Location /net-mgr>
    AuthType Basic
    AuthName "net-mgr"
    AuthUserFile $htpasswd
    AuthBasicProvider file

    <RequireAny>
CONF
$conf .= "        Require ip $_\n" for @bypass;
$conf .= <<'CONF';
        Require valid-user
    </RequireAny>
</Location>
CONF

if (!$write && !$reload) {
    print $conf;
    exit 0;
}

# Atomic write so a half-written conf can't crash apache mid-reload.
my $tmp = "$path.tmp.$$";
open my $fh, '>', $tmp or die "open $tmp: $!\n";
print $fh $conf;
close $fh or die "close $tmp: $!\n";
rename $tmp, $path or die "rename $tmp -> $path: $!\n";
print STDERR "Wrote $path (" . scalar(@bypass) . " bypass CIDR"
           . (scalar(@bypass) == 1 ? '' : 's') . ").\n";

if (!-r $htpasswd) {
    print STDERR "warning: $htpasswd doesn't exist — non-Private "
               . "clients will fail auth with no way in.  Create it:\n"
               . "  htpasswd -c $htpasswd <username>\n";
}

if ($reload) {
    my $rc = system('systemctl', 'reload', 'apache2');
    die "apache reload failed (exit @{[$rc>>8]})\n" if $rc != 0;
    print STDERR "apache2 reloaded.\n";
}
