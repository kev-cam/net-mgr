#!/usr/bin/perl
# net-ping — manual fping-and-publish-RTT producer for debug.
#
# Usage:
#   net-ping NAME|IP [...]      Ping these targets and push kind=ping
#                                observations. NAME is any regex that
#                                net-lookup would match against
#                                machines.primary_name / hostnames /
#                                friendly_names / aliases; '=' expands
#                                to '.*' the same way. A name that
#                                resolves to several addresses pings
#                                all of them (mirrors --auto's fan-out).
#   net-ping --auto             Ping every known v4 address.
#   net-ping --reset NAME|IP [...]
#                                Clear min_rtt_ms / last_rtt_ms for these
#                                addresses (so a bogus baseline can be re-learned).
#   net-ping --reset --all      Clear them everywhere.
#   net-ping --listen H:P ...   Override manager address.
#
# The regular `discover --presence` periodic does the same RTT push;
# this exists for ad-hoc debugging and for triggering manual resets
# without an SQL prompt.
use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use Socket qw(inet_pton AF_INET AF_INET6);
use NetMgr::Client;
use NetMgr::Producer::Scan;

my $listen;
my $auto;
my $reset;
my $all;
my $samples;
GetOptions(
    'listen=s'  => \$listen,
    'auto'      => \$auto,
    'reset'     => \$reset,
    'all'       => \$all,
    'samples=i' => \$samples,
) or die "bad options\n";

my $cli = NetMgr::Client->new(listen => $listen);
$cli->hello(consumer => "net-ping.$$");

if ($reset) {
    if ($all) {
        my $r = $cli->trigger('reset-rtt', wait => 1, all => 1);
        warn "reset-rtt: $r\n";
        $cli->bye;
        exit 0;
    }
    @ARGV or die "--reset needs targets (name or IP), or --all\n";
    my @targets = resolve_args_to_ips($cli, @ARGV);
    for my $ip (@targets) {
        my $r = $cli->trigger('reset-rtt', wait => 1, addr => $ip);
        warn "reset-rtt $ip: $r\n";
    }
    $cli->bye;
    exit 0;
}

my @ips;
if ($auto) {
    my $rows = $cli->snapshot(1, 'addresses', where => "family = 'v4'");
    my %seen;
    @ips = grep { !$seen{$_}++ } map { $_->{addr} } @$rows;
}
push @ips, resolve_args_to_ips($cli, @ARGV);
@ips or die "usage: $0 [--auto] [--reset [--all]] [NAME|IP ...]\n";

# Need the addr→[mac,...] map to attach the ping observation to the
# right interface row(s).
my $rows = $cli->snapshot(2, 'addresses', where => "family = 'v4'");
my %macs_by_ip;
for my $r (@$rows) {
    next unless $r->{mac} && $r->{addr};
    push @{ $macs_by_ip{ $r->{addr} } }, $r->{mac};
}

my $res;
if ($samples && $samples > 1) {
    # Multi-sample run: collect both min RTT and packet-loss %.
    $res = NetMgr::Producer::Scan::fping_rtt_loss($samples, @ips);
} else {
    # Single-shot. Wrap in same structure as the multi-sample form
    # so the loop below can stay one shape.
    my $r = NetMgr::Producer::Scan::fping_rtt(@ips);
    my %alive = map { $_ => { min_rtt_ms => $r->{alive}{$_} } } keys %{ $r->{alive} };
    $res = { alive => \%alive, dead => $r->{dead} };
}
warn sprintf("alive=%d dead=%d%s\n",
             scalar(keys %{ $res->{alive} }), scalar(@{ $res->{dead} }),
             ($samples && $samples > 1 ? " (samples=$samples)" : ''));
for my $ip (sort keys %{ $res->{alive} }) {
    my $info = $res->{alive}{$ip};
    my $macs = $macs_by_ip{$ip} or next;
    for my $mac (@$macs) {
        my %obs = (kind => 'ping', mac => $mac, addr => $ip,
                   rtt_ms => $info->{min_rtt_ms});
        $obs{loss_pct} = $info->{loss_pct} if defined $info->{loss_pct};
        my $reply = $cli->observe(%obs);
        warn "$ip ($mac): $reply\n" if $reply && $reply =~ /^ERR/;
    }
}

$cli->bye;

# Turn @args (a mix of IP literals and NAME regexes) into a flat list of
# IPs to ping. Name matching mirrors net-lookup's forward path: the arg
# is wrapped as ^(?:...)$ with '=' → '.*', then compared against
# machines.primary_name / hostnames / friendly_names / aliases. Every
# address owned by every matched machine comes back (no scoring / picking
# a "best" — the caller is ping, and pinging the fan-out is the point).
# Args that already parse as v4/v6 addresses pass through untouched, so
# `net-ping 192.168.15.1 nas3=` works. Unresolvable names warn and skip
# so a typo doesn't take out the whole run.
sub resolve_args_to_ips {
    my ($cli, @args) = @_;
    my (@out, @names);
    for my $a (@args) {
        if (inet_pton(AF_INET, $a) || inet_pton(AF_INET6, $a)) {
            push @out, $a;
        } else {
            push @names, $a;
        }
    }
    return @out unless @names;

    # Snapshot only when there's a name to resolve — a pure IP list
    # shouldn't pay for six extra queries. Sub-ids picked above the
    # ping path's 1 and 2 to avoid collision.
    my $machines  = $cli->snapshot(21, 'machines');
    my $hostnames = $cli->snapshot(22, 'hostnames');
    my $friendly  = $cli->snapshot(23, 'friendly_names');
    my $aliases   = $cli->snapshot(24, 'aliases');
    my $ifaces    = $cli->snapshot(25, 'interfaces');
    my $addresses = $cli->snapshot(26, 'addresses', where => "family = 'v4'");

    my %name2mids;
    for my $m (@$machines) {
        push @{ $name2mids{ $m->{primary_name} } }, $m->{id}
            if defined $m->{primary_name} && length $m->{primary_name};
    }
    for my $row (@$hostnames, @$friendly, @$aliases) {
        next unless defined $row->{name} && length $row->{name}
                 && defined $row->{machine_id} && length $row->{machine_id};
        push @{ $name2mids{ $row->{name} } }, $row->{machine_id};
    }

    my %macs_by_mid;
    for my $i (@$ifaces) {
        next unless defined $i->{mac} && defined $i->{machine_id}
                                      && length $i->{machine_id};
        push @{ $macs_by_mid{ $i->{machine_id} } }, $i->{mac};
    }

    my %addrs_by_mac;
    for my $a (@$addresses) {
        next unless defined $a->{addr} && defined $a->{mac};
        push @{ $addrs_by_mac{ $a->{mac} } }, $a->{addr};
    }

    for my $name (@names) {
        (my $rx_src = $name) =~ s/=/.*/g;
        my $rx = eval { qr/^(?:$rx_src)$/ };
        if ($@) {
            warn "net-ping: bad name regex '$name': $@";
            next;
        }
        my %hit;
        for my $key (keys %name2mids) {
            next unless $key =~ $rx;
            for my $mid (@{ $name2mids{$key} }) {
                for my $mac (@{ $macs_by_mid{$mid} || [] }) {
                    for my $ip (@{ $addrs_by_mac{$mac} || [] }) {
                        $hit{$ip} = 1;
                    }
                }
            }
        }
        my @ips = sort keys %hit;
        if (!@ips) {
            warn "net-ping: '$name' didn't resolve to any IP\n";
            next;
        }
        # Give the operator a hint when one name fanned out — otherwise
        # `net-ping nas3=` produces a flurry of ping results with no
        # obvious tie back to the arg that spawned them.
        warn "net-ping: $name -> " . join(', ', @ips) . "\n" if @ips > 1;
        push @out, @ips;
    }
    return @out;
}
