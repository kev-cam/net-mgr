#!/usr/bin/perl
# net-chat-autoresponder — rule-driven reactor for the net-mgr chat stream.
#
# Loads /etc/net-mgr/net-chat-autoresponder.conf (INI) plus any overlays
# in /etc/net-mgr/net-chat-autoresponder.d/*.conf, subscribes to the
# daemon streams the rules reference (bitchat_peers first-seen and/or
# chat_messages per session), and dispatches chat_post replies via
# NetMgr::Client on loopback.
#
# Split of concerns:
#   - net-bitchat-bridge remains the BLE plumbing (helper supervisor,
#     nickname wiring, cross-site relay, WIFI?-in-DM onramp).
#   - THIS process owns rule-based reactions — first-seen greetings, chat
#     canned replies, etc. — that were formerly ad-hoc knobs on the bridge.
#     Moving the wifi-greeting here means an operator can override the
#     greeting body by editing one INI file in
#     /etc/net-mgr/net-chat-autoresponder.d/ WITHOUT touching the bridge.
#
# Two clients, per the house style at net-bitchat-bridge:213-217 and
# net-chat cmd_test:512-513:
#   $R — read/SUBSCRIBE socket (stream-only; no snapshot replay at boot).
#   $W — write/OBSERVE socket (chat_post). Both talk loopback:7531.
#
# Usage:
#   net-chat-autoresponder [--config FILE] [--listen H:P] [--once] [--dry-run]
#
# See etc/net-chat-autoresponder.conf.sample for the rule grammar.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use Fcntl qw(:flock O_RDWR O_CREAT O_APPEND);
use NetMgr::Client;
use NetMgr::Config;
use NetMgr::Protocol qw(parse_line);

$SIG{PIPE} = 'IGNORE';                      # net-chat:60 shape
$| = 1;

# Default config path is euid-aware: root reads /etc/net-mgr/... (unchanged
# from every prior release + what the systemd unit passes explicitly);
# unprivileged runs (e.g. `net-chat-autoresponder --gui` as installer@video-c)
# prefer $XDG_CONFIG_HOME/net-mgr/ so the GUI's Save has a writable target.
# Explicit `--config <path>` always wins via Getopt::Long. See
# NetMgr::Config::resolve_config_file for the full precedence rules.
my %opt = (config => NetMgr::Config->resolve_config_file('net-chat-autoresponder.conf'));
GetOptions(\%opt, 'gui', 'file=s', 'config=s', 'listen=s',
                  'once', 'dry-run', 'help')
    or usage(2);
usage(0) if $opt{help};

# --gui: launch the Tk rule editor + live tester and exit. Everything
# GUI-shaped lives in the nested NetChatAutoresponderGui package at the
# bottom of this file; cmd_gui does the lazy Tk require so the daemon
# path below (the common case) pays no Tk cost at import time.
if ($opt{gui}) {
    cmd_gui(%opt);
    exit 0;
}

# ---- 1. Load rules ----------------------------------------------------------
my ($GLOBAL, @RULES) = load_config($opt{config});
$GLOBAL->{listen} = $opt{listen} if $opt{listen};

# echo_ignore: drop chat_message rows whose sender matches any of these.
# The rule's own $as is always ignored (self-loop guard).
my %ignore = map { $_ => 1 }
             grep { length }
             map  { s/^\s+|\s+$//gr }
             split /,/, ($GLOBAL->{echo_ignore} // $GLOBAL->{as} // '');
$ignore{ $GLOBAL->{as} } = 1 if defined $GLOBAL->{as} && length $GLOBAL->{as};

my $SEEN = SeenFile->open($GLOBAL->{state_file}
                          // '/var/lib/net-mgr/net-chat-autoresponder.seen');

# trigger= is a comma-separated list of triggers this rule reacts to
# (see _compile_rule); a rule appears in every bucket its trigger list
# includes, and the per-callsite ctx builders (on_peer_row, on_chat_row,
# fire_periodic_rules) each stage the substitution slots appropriate
# for whichever surface fired them. Single-value rules land in exactly
# one bucket — full backward compatibility with the pre-multi-trigger
# INI grammar.
my @ble_rules      = grep { _rule_has_trigger($_, 'bitchat_peer_first_seen') } @RULES;
my @chat_rules     = grep { _rule_has_trigger($_, 'chat_message') }            @RULES;
my @periodic_rules = grep { _rule_has_trigger($_, 'periodic') }                @RULES;
my %chat_sessions;
$chat_sessions{$_->{session}}++ for @chat_rules;

sub _rule_has_trigger {
    my ($r, $t) = @_;
    return scalar grep { $_ eq $t } @{ $r->{triggers} // [] };
}

# Peer identity map — updated on every bitchat_peers ROW. Enables:
#   - periodic fanout rules (mode=fanout_bitchat_peers) to iterate live
#     BLE peers by peer_id — see fire_periodic_rules.
#   - chat_message ack rules (ack_target=NAME) to reverse-map a nickname
#     captured from a mesh reply back to the peer_id, so we can mark
#     that peer as having ack'd a fanout broadcast — see on_chat_row.
# NOT persisted. On restart the stream re-subscribe replays the current
# bitchat_peers table within one poll (~30s), so a periodic fanout
# missing its peer map for the very first tick just fans out to an
# empty set — the acked-set persists via SeenFile, no double-fire.
# Collision caveat: nickname is not unique on the mesh (see the schema
# comment on bitchat_peers.nickname — VARCHAR(64) NULL, no UNIQUE). A
# second peer choosing the same nickname will overwrite this map's
# nick->pid mapping; the ack then attributes to whichever peer wrote
# most recently. Peer_id is the schema-authoritative identity, but
# chat_messages.body only carries the nickname (see the bridge's tag
# construction in bin/net-bitchat-bridge:555-558), so this map is the
# best identity recovery available today without a schema change.
my %NICK_TO_PID;    # nickname => peer_id
my %PEER_LAST_SEEN; # peer_id  => epoch (last bitchat_peers ROW time)

# In-memory timer for periodic rules — deliberately NOT persisted. On
# restart the first fire happens after 'every' seconds, not immediately,
# so a supervisor loop that flaps the service doesn't spam the mesh.
{
    my $t0 = time;
    for my $r (@periodic_rules) {
        $r->{_next_fire} = $t0 + $r->{_every_secs};
    }
}

my $multi_trigger_rules = grep { @{ $_->{triggers} || [] } > 1 } @RULES;
warn "[autoresponder] loaded " . scalar(@RULES) . " rule(s) from $opt{config}"
   . " ("      . scalar(@ble_rules)      . " bitchat_peer_first_seen"
   . ", "      . scalar(@chat_rules)     . " chat_message"
   . ", "      . scalar(@periodic_rules) . " periodic"
   . ($multi_trigger_rules
      ? "; $multi_trigger_rules multi-trigger rule(s) counted in >1 bucket"
      : '')
   . ")\n";

# ---- 2. Two connections -----------------------------------------------------
my $R = NetMgr::Client->new(listen => $GLOBAL->{listen}, timeout => 6);
$R->hello(consumer => "autoresponder.sub.$$");
my $W = NetMgr::Client->new(listen => $GLOBAL->{listen}, timeout => 6,
                            as => $GLOBAL->{as});
$W->hello(consumer => "autoresponder.ctrl.$$");

# ---- 3. Subscribe — mode=stream ONLY (no snapshot/history replay) -----------
# Streaming-only is deliberate: the whole point of the daemon-owned
# bitchat_peers table is that op=insert lifecycle events are already
# authoritative first-seen signals. Replaying a snapshot at boot would
# re-greet every peer the daemon has ever seen. The SeenFile is a
# belt-and-braces defence against the daemon changing its emit semantics.
my $next_sub = 1;
if (@ble_rules) {
    $R->send_line("SUBSCRIBE sub=" . $next_sub++
                . " mode=stream FROM bitchat_peers");
    warn "[autoresponder] SUBSCRIBE bitchat_peers (stream)\n";
}
for my $s (sort keys %chat_sessions) {
    (my $q = $s) =~ s/'/''/g;    # SQL-string escape inside the WHERE
    $R->send_line("SUBSCRIBE sub=" . $next_sub++
                . " mode=stream FROM chat_messages WHERE session = '$q'");
    warn "[autoresponder] SUBSCRIBE chat_messages session=$s\n";
}

# ---- 4. React loop (net-watch:77-92 shape) ----------------------------------
# recv_line(10) blocks in select() for at most 10s, so the periodic-rule
# check below runs on every tick (both idle wake-ups AND data-arrival
# ticks). Latency for a due periodic rule is bounded by that 10s timeout.
# If any rule's `every` is < 10s, the effective interval will be rounded
# UP to whatever the next tick lands on — documented at the sample rule.
while (1) {
    my $line = $R->recv_line(10);
    $SEEN->prune;
    fire_periodic_rules(\@periodic_rules) if @periodic_rules;
    next unless defined $line;
    my $c = eval { parse_line($line) };
    if ($@) { warn "[autoresponder] parse: $@"; next }
    next unless $c;
    if ($c->{verb} eq 'ERR') {
        warn "[autoresponder] stream ERR: $c->{msg}\n";
        last;
    }
    next unless $c->{verb} eq 'ROW';
    my $kv = $c->{kv} // {};
    my $t  = $kv->{table} // '';
    if    ($t eq 'bitchat_peers') { on_peer_row($kv) }
    elsif ($t eq 'chat_messages') { on_chat_row($kv) }
    last if $opt{once};
}
eval { $R->bye }; eval { $W->bye };
exit 0;

# ---- handlers ---------------------------------------------------------------

sub on_peer_row {
    my ($kv) = @_;
    # First-seen semantics. The design's authoritative signal is
    # op=insert; the current daemon (_handle_bitchat_peer_upsert at
    # Manager.pm:6075) hardcodes op=update, so we ALSO accept update
    # rows and lean on SeenFile as the primary dedup gate. The
    # first_seen==last_seen fallback is here for a future world where
    # the daemon starts distinguishing insert-vs-update on this table.
    my $op = $kv->{op} // '';
    my $first = $op eq 'insert'
             || $op eq 'update'
             || (defined $kv->{first_seen} && defined $kv->{last_seen}
                                          && $kv->{first_seen} eq $kv->{last_seen});
    return unless $first;
    my $pid = lc($kv->{peer_id} // '');
    return unless $pid =~ /^[0-9a-f]{16}$/;
    my $nick = $kv->{nickname} // '';
    # Refresh the shared peer identity map BEFORE the ble-rule loop so a
    # periodic-fanout rule that fires on the very next tick already sees
    # this peer (the main loop runs fire_periodic_rules BEFORE the ROW
    # handler on the same tick). Skip the nickname->pid entry when the
    # nickname is empty — a nickless peer can still be fanned out to
    # (we DM by peer_id) but has no way for the operator to see who they
    # are in a chat_messages log line.
    $NICK_TO_PID{$nick}    = $pid if length $nick;
    $PEER_LAST_SEEN{$pid}  = time;
    for my $r (@ble_rules) {
        my %cap;
        if (my $re = $r->{_re}) {
            next unless $nick =~ $re;
            %cap = %+;
        }
        my $ctx = { peer_id => $pid, nickname => $nick,
                    sender  => 'bitchat-relay', session => '',
                    map { ("cap.$_" => $cap{$_}) } keys %cap };
        my $key = "$r->{name}\t$pid";
        next if $r->{dedup_ttl} > 0 && $SEEN->check($key, $r->{dedup_ttl});
        $SEEN->record($key) if dispatch($r, $ctx) && $r->{dedup_ttl} > 0;
    }
}

sub fire_periodic_rules {
    my ($rules) = @_;
    my $now = time;
    for my $r (@$rules) {
        next if !defined $r->{_next_fire} || $r->{_next_fire} > $now;
        if (($r->{mode} // '') eq 'fanout_bitchat_peers') {
            _fire_fanout_bitchat_peers($r, $now);
        } else {
            # ${peer_id}/${session}/cap.* aren't meaningful for a wall-clock
            # trigger; leave them empty and let subst() fall through. The
            # ${nickname} slot carries the global 'as' (per design brief) so
            # a broadcast rule can self-identify without re-typing the name.
            my $ctx = {
                peer_id  => '',
                nickname => ($GLOBAL->{as} // ''),
                sender   => ($GLOBAL->{as} // ''),
                session  => '',
            };
            dispatch($r, $ctx);
        }
        # Re-anchor next fire to `now`, NOT (prev _next_fire + every).
        # If the loop was blocked for a long time (parse hang, slow
        # daemon, laptop suspend), we do NOT want to catch up by
        # firing back-to-back and spamming the mesh. Re-anchor is once
        # PER RULE, not once per fanout target — a fanout rule that DMs
        # 20 peers still bumps its own next_fire only once.
        $r->{_next_fire} = $now + $r->{_every_secs};
    }
}

# Per-peer DM fanout for a periodic rule with mode=fanout_bitchat_peers.
# Iterates %PEER_LAST_SEEN (the reactor's live-peer set, refreshed by
# on_peer_row) and dispatches one DM per non-acked peer. Peers whose
# peer_id has been recorded as ack'd (via a chat_message rule with
# ack_target= — see on_chat_row) inside the rule's acked_ttl window
# are skipped silently. Reverse-lookup of nickname from peer_id is
# best-effort and only used to populate ${nickname} in the DM body —
# the DM target is peer_id, so nick-empty peers still get the DM.
sub _fire_fanout_bitchat_peers {
    my ($r, $now) = @_;
    my $ack_key = $r->{ack_key};
    my $ttl     = $r->{_acked_ttl_secs} // 0;
    my ($fired, $skipped) = (0, 0);
    # Reverse map built lazily each tick — O(peers) but a periodic
    # tick is a coarse event; a hot-path optimisation (maintain
    # %PID_TO_NICK alongside %NICK_TO_PID) is easy to add later.
    my %pid_to_nick;
    while (my ($n, $p) = each %NICK_TO_PID) { $pid_to_nick{$p} //= $n }
    for my $pid (sort keys %PEER_LAST_SEEN) {
        if (defined $ack_key && length $ack_key && $ttl > 0) {
            my $seen_key = "$ack_key\tacked\t$pid";
            if ($SEEN->check($seen_key, $ttl)) { $skipped++; next }
        }
        my $ctx = {
            peer_id  => $pid,
            nickname => ($pid_to_nick{$pid} // ''),
            sender   => ($GLOBAL->{as} // ''),
            session  => '',
        };
        dispatch($r, $ctx) and $fired++;
    }
    warn "[autoresponder $r->{name}] fanout: $fired fired, "
       . "$skipped acked-skipped ("
       . scalar(keys %PEER_LAST_SEEN) . " peers known)\n";
}

sub on_chat_row {
    my ($kv) = @_;
    return unless ($kv->{op} // '') eq 'insert';
    my $sender = $kv->{sender} // '';
    return if $ignore{$sender};
    my $sess = $kv->{session} // '';
    my $body = $kv->{body}    // '';
    # Reset command: a whole-body "reset" (case-insensitive, tolerant
    # of leading/trailing whitespace) clears this sender's SEEN
    # history so subsequent rule matches re-fire as if we'd never
    # heard from them. Lets an operator retest a greeting flow
    # without wiping the whole SEEN log or restarting the daemon.
    # Pre-empts rule dispatch: no autoresponder rule can match
    # "reset" (this is a reserved word). The reset also skips this
    # tick's normal rules to avoid the "reset then immediately
    # re-fire the greeting on the same message" double-response.
    if ($body =~ /^\s*reset\s*\z/i) {
        _handle_reset($sender);
        return;
    }
    for my $r (@chat_rules) {
        next unless $r->{session} eq $sess;
        next if defined $r->{from} && $r->{from} ne $sender;
        next unless $body =~ $r->{_re};
        my %cap = %+;
        my $ctx = { peer_id => ($cap{peer_id} // ''), nickname => '',
                    sender  => $sender, session => $sess,
                    map { ("cap.$_" => $cap{$_}) } keys %cap };

        # ack_target=NAME — this is an ACK-drop rule (see design brief).
        # A mesh reply matched by `match` was tagged by the bridge as
        # '[NICK@bitchat[/chan]] BODY' (bin/net-bitchat-bridge:555-558)
        # so the rule's regex extracts (?<nick>...) from that prefix.
        # We reverse-look up the peer_id via %NICK_TO_PID (populated by
        # on_peer_row) and mark that peer as having ack'd the periodic
        # fanout named by ack_target. NO dispatch — this is pure state
        # mutation. The next fanout tick will skip this peer for
        # acked_ttl seconds. Peers we haven't yet seen a bitchat_peers
        # ROW for cannot be marked (no peer_id available); the ack is
        # dropped with a log line so the operator can spot the miss.
        if (defined $r->{ack_target} && length $r->{ack_target}) {
            my $nick = $cap{nick} // '';
            my $pid  = length $nick ? ($NICK_TO_PID{$nick} // '') : '';
            if (!length $pid) {
                warn "[autoresponder $r->{name}] ack_target=$r->{ack_target}"
                   . " nick='$nick' — no peer_id known yet, ack dropped\n";
            } else {
                my $seen_key = "$r->{ack_target}\tacked\t$pid";
                $SEEN->record($seen_key);
                warn "[autoresponder $r->{name}] ack_target=$r->{ack_target}"
                   . " marked $nick ($pid) acked\n";
            }
            # ack rules never dispatch. Do NOT fall through to the
            # dedup/dispatch path below.
            next;
        }

        my $key = "$r->{name}\t$sender";
        next if $r->{dedup_ttl} > 0 && $SEEN->check($key, $r->{dedup_ttl});
        $SEEN->record($key) if dispatch($r, $ctx) && $r->{dedup_ttl} > 0;
    }
}

# Clear the SEEN entries that track a specific sender + their
# resolved peer_id, so the next matching event fires as if we'd
# never seen them. Called by the "reset" reserved-word handler in
# on_chat_row. Also drops in-memory NICK -> PID mapping so a stale
# BitChat handle re-registers on the next bitchat_peers ROW rather
# than sticking around with an old peer_id.
sub _handle_reset {
    my ($sender) = @_;
    my ($nick) = $sender =~ /^([^\@]+)/;
    my $pid = length($nick // '') ? ($NICK_TO_PID{$nick} // '') : '';
    my $cleared = $SEEN->forget_matching(sub {
        my $k = shift;
        return 1 if $k =~ /\t\Q$sender\E\z/;
        return 1 if length $pid && $k =~ /\t\Q$pid\E\z/;
        return 0;
    });
    # Drop the reactor's in-memory client-status for this peer so a
    # subsequent bitchat_peers ROW re-registers them from scratch.
    if (length $pid) {
        delete $PEER_LAST_SEEN{$pid};
        delete $NICK_TO_PID{$nick} if length($nick // '')
                                   && ($NICK_TO_PID{$nick} // '') eq $pid;
    }
    warn "[autoresponder] reset from $sender (pid="
       . (length $pid ? $pid : '?')
       . "): cleared $cleared SEEN entries, dropped in-memory peer status\n";
}

sub dispatch {
    my ($r, $ctx) = @_;
    # channel=noop: pure state-mutation rule. Currently the ack-target
    # path in on_chat_row bypasses dispatch entirely, but we accept a
    # dispatch call so a future rule could combine ack-dropping with
    # in-process side effects (e.g. metrics counter) without a wire post.
    if ($r->{channel} eq 'noop') {
        return 1;
    }
    my $target = subst($r->{target}, $ctx);
    my $body   = subst($r->{body},   $ctx);
    utf8::upgrade($body);

    if ($r->{channel} eq 'bitchat_dm') {
        unless ($target =~ /^[0-9a-f]{16}$/) {
            warn "[autoresponder $r->{name}] bitchat_dm target not 16-hex:"
               . " '$target' — skip\n";
            return 0;
        }
        my $preview = length($body) > 60
                    ? substr($body, 0, 60) . '...' : $body;
        if ($opt{'dry-run'}) {
            warn "[autoresponder dry-run $r->{name}] DM $target: $preview\n";
            return 1;
        }
        # Route via bridge's @HEX16: prefix convention (bridge:409-411).
        # net-chat-autoresponder posts to bitchat-bridge session; bridge's
        # SUBSCRIBE loop strips the prefix and DMs the peer over BLE.
        my $ok = eval { $W->chat_post(session => 'bitchat-bridge',
                                      body    => "\@$target: $body",
                                      as      => $GLOBAL->{as}); 1 };
        if (!$ok) {
            warn "[autoresponder $r->{name}] chat_post(DM) failed: $@";
            return 0;
        }
        warn "[autoresponder $r->{name}] DM $target: $preview\n";
        return 1;
    } elsif ($r->{channel} eq 'chat_post') {
        my $preview = length($body) > 60
                    ? substr($body, 0, 60) . '...' : $body;
        if ($opt{'dry-run'}) {
            warn "[autoresponder dry-run $r->{name}] post $target: $preview\n";
            return 1;
        }
        my $ok = eval { $W->chat_post(session => $target, body => $body,
                                      as => $GLOBAL->{as}); 1 };
        if (!$ok) {
            warn "[autoresponder $r->{name}] chat_post failed: $@";
            return 0;
        }
        warn "[autoresponder $r->{name}] post $target: $preview\n";
        return 1;
    } else {
        warn "[autoresponder $r->{name}] unknown channel '$r->{channel}'\n";
        return 0;
    }
}

# ${peer_id} ${nickname} ${sender} ${session} ${cap.NAME} ${now} ${host} —
# everything else passes through literally. '$$' escapes a literal '$'.
#   ${now}   — current UTC HH:MM:SS (rendered per fire, useful for periodic).
#   ${host}  — Sys::Hostname::hostname() (cached).
sub subst {
    my ($s, $ctx) = @_;
    return '' unless defined $s;
    $s =~ s/\$\$/\x01/g;
    $s =~ s/
        \$\{
          ( peer_id | nickname | sender | session | now | host
          | cap\.[A-Za-z_][A-Za-z0-9_]*
          )
        \}
    / _token_val($1, $ctx) /gex;
    $s =~ s/\x01/\$/g;
    return $s;
}

my $DAEMON_HOST_CACHED;   # separate from NetChatAutoresponderGui::HOST_CACHED
sub _token_val {
    my ($tok, $ctx) = @_;
    if ($tok eq 'now') {
        my @t = gmtime;
        return sprintf('%02d:%02d:%02d', $t[2], $t[1], $t[0]);
    }
    if ($tok eq 'host') {
        unless (defined $DAEMON_HOST_CACHED) {
            require Sys::Hostname;
            $DAEMON_HOST_CACHED = Sys::Hostname::hostname() // '';
        }
        return $DAEMON_HOST_CACHED;
    }
    return defined $ctx->{$tok} ? $ctx->{$tok} : '';
}

# ---- config -----------------------------------------------------------------

# INI value escape/unescape so multi-line values (e.g. a body= carrying a
# UTF8 QR block + trailing SSID/password) survive the single-line-per-key
# INI grammar. Encoding rules:
#   * backslash -> "\\"  (escape the escape)
#   * newline   -> "\n"  (two chars, backslash + n)
# Decoded pass is a state machine over the input so `\\n` decodes to `\n`
# (two chars) rather than newline — leftmost win, no ambiguity. All
# other backslash sequences pass through unchanged (an operator's `\d`
# regex-fragment in a match= isn't damaged).
sub _ini_encode {
    my ($v) = @_;
    return $v unless defined $v;
    $v =~ s/\\/\\\\/g;
    $v =~ s/\n/\\n/g;
    return $v;
}
sub _ini_decode {
    my ($v) = @_;
    return $v unless defined $v;
    return $v unless index($v, '\\') >= 0;   # fast path: no escapes
    my $out = '';
    my $len = length $v;
    my $i = 0;
    while ($i < $len) {
        my $c = substr($v, $i, 1);
        if ($c eq '\\' && $i + 1 < $len) {
            my $n = substr($v, $i + 1, 1);
            if    ($n eq '\\') { $out .= '\\'; $i += 2; next }
            elsif ($n eq 'n')  { $out .= "\n"; $i += 2; next }
        }
        $out .= $c;
        $i++;
    }
    return $out;
}

# Parse an INI file into { section => { key => value } }. Config::Tiny if
# available (matches the rest of the tree); otherwise a hand parser that
# understands [section], key=value, and ';'/'#' comments. Sections may
# repeat (later value wins per key). Values are _ini_decode'd on read so
# encoded multi-line values (body= with a QR block) restore to their
# real form for dispatch. Unknown/unused characters otherwise pass
# through — no shell substitution.
sub _load_ini {
    my ($path) = @_;
    return {} unless -r $path;
    if (eval { require Config::Tiny; 1 }) {
        my $t = Config::Tiny->read($path)
            or die "$path: " . Config::Tiny->errstr . "\n";
        # Config::Tiny returns { section => { key => value } }; decode
        # every value one level deep.
        my %out;
        for my $sect (keys %$t) {
            my $body = $t->{$sect};
            $out{$sect} = { map { $_ => _ini_decode($body->{$_}) } keys %$body };
        }
        return \%out;
    }
    open my $fh, '<', $path or die "$path: $!\n";
    my %cfg;
    my $section = '_';
    while (<$fh>) {
        s/^\s+|\s+$//g;
        next if !length || /^[;#]/;
        if (/^\[(.+?)\]\s*$/) { $section = $1; next }
        if (/^([\w.-]+)\s*=\s*(.*)$/) { $cfg{$section}{$1} = _ini_decode($2) }
    }
    close $fh;
    return \%cfg;
}

# load_config($primary_path):
#   Read $primary_path plus /etc/net-mgr/<basename>.d/*.conf overlays in
#   filename-sort order. Duplicate [rule.NAME] REPLACES the earlier one
#   (last-write-wins). Returns ($GLOBAL, @RULES).
sub load_config {
    my ($primary) = @_;

    (my $overlay_dir = $primary) =~ s/\.conf$//;
    $overlay_dir .= '.d';

    my @paths;
    push @paths, $primary if -e $primary;
    if (-d $overlay_dir) {
        opendir my $dh, $overlay_dir or die "$overlay_dir: $!\n";
        push @paths, map { "$overlay_dir/$_" }
                     sort grep { /\.conf$/ && !/^\./ } readdir $dh;
        closedir $dh;
    }
    unless (@paths) {
        die "no config: neither $primary nor $overlay_dir/*.conf exists\n";
    }

    my %global;
    my %rules;   # NAME => rule hash
    my @order;   # rule-name order for evaluation
    for my $p (@paths) {
        warn "[autoresponder] load $p\n";
        my $ini = _load_ini($p);
        # Merge [global] (later files override individual keys).
        if (ref $ini->{global} eq 'HASH') {
            @global{ keys %{$ini->{global}} } = values %{$ini->{global}};
        }
        for my $sec (sort keys %$ini) {
            next unless $sec =~ /^rule\.([A-Za-z][A-Za-z0-9._-]{0,31})$/;
            my $name = $1;
            my $body = $ini->{$sec};
            next unless ref $body eq 'HASH';
            push @order, $name unless exists $rules{$name};
            $rules{$name} = { %$body, name => $name, _source => $p };
        }
    }

    # Defaults.
    $global{listen}       //= '127.0.0.1:7531';
    $global{as}           //= 'net-chat-autoresponder';
    # SeenFile path is euid-aware for the same reason resolve_config_file is:
    # /var/lib/net-mgr/ is created by systemd's StateDirectory=net-mgr (0755
    # root:root) so an unprivileged operator cannot write there. Fall back
    # to $XDG_STATE_HOME/net-mgr/ when not root; SeenFile->open mkdirs the
    # parent, and if that fails dedup silently degrades (not fatal). An
    # operator-supplied state_file overrides both branches unchanged.
    $global{state_file}   //= do {
        if ($> == 0) { '/var/lib/net-mgr/net-chat-autoresponder.seen' }
        else {
            my $d = NetMgr::Config->user_state_dir;
            $d ? "$d/net-chat-autoresponder.seen"
               : '/var/lib/net-mgr/net-chat-autoresponder.seen';
        }
    };
    $global{echo_ignore}  //= $global{as};

    # Compile / validate rules.
    my @rules;
    for my $name (@order) {
        my $r = $rules{$name};
        my $ok = eval { _compile_rule($r); 1 };
        if (!$ok) {
            my $e = $@; chomp $e;
            warn "[autoresponder] rule '$name' skipped: $e\n";
            next;
        }
        push @rules, $r;
    }

    return (\%global, @rules);
}

# Fills $r->{_re}, $r->{dedup_ttl} (seconds), validates required keys.
# Parses $r->{trigger} as a comma-separated list of triggers into
# $r->{triggers} = [@list]; single-value rules still work unchanged
# (they parse to a one-element list). $r->{trigger} is rewritten to
# the first element for the log line and any legacy scalar readers.
sub _compile_rule {
    my ($r) = @_;
    my $raw_trigger = $r->{trigger};
    die "no trigger="
        unless defined $raw_trigger && length $raw_trigger;
    my @triggers = grep { length }
                   map  { s/^\s+|\s+$//gr }
                   split /,/, $raw_trigger;
    die "no trigger=" unless @triggers;
    # Dedupe (preserve order) — 'periodic, periodic' is silly but valid.
    my %seen_t;
    @triggers = grep { !$seen_t{$_}++ } @triggers;
    my %legal = (bitchat_peer_first_seen => 1,
                 chat_message            => 1,
                 periodic                => 1);
    for my $t (@triggers) {
        die "bad trigger '$t'" unless $legal{$t};
    }
    $r->{triggers} = \@triggers;
    $r->{trigger}  = $triggers[0];   # legacy scalar slot: first entry
    my %has = map { $_ => 1 } @triggers;

    my $ch = $r->{channel} or die "no channel=";
    die "bad channel '$ch'"
        unless $ch eq 'bitchat_dm' || $ch eq 'chat_post' || $ch eq 'noop';

    # target/body are required for wire channels only. channel=noop
    # rules mutate in-process state (SEEN, %NICK_TO_PID) and produce no
    # wire traffic, so those fields are optional there.
    if ($ch ne 'noop') {
        die "no target=" unless defined $r->{target} && length $r->{target};
        die "no body="   unless defined $r->{body};
    }

    # Rule-load target validation for bitchat_dm literals. If the target
    # contains ${...} we defer until per-fire; otherwise it MUST be 16 hex.
    if ($ch eq 'bitchat_dm'
        && defined $r->{target}
        && $r->{target} !~ /\$\{/
        && $r->{target} !~ /^[0-9a-f]{16}$/i)
    {
        die "channel=bitchat_dm target must be 16 lowercase hex "
          . "(got '$r->{target}')";
    }

    # Compile regex under a 2s alarm — pathological patterns fail rule-load
    # rather than crashing the reactor mid-flight.
    # match= is legal when ANY trigger in the list uses it (chat_message,
    # bitchat_peer_first_seen). Periodic-only rules still reject match=
    # (silently ignoring it would confuse readers); mixed rules with
    # periodic + chat_message | first-seen accept it — the periodic
    # firings just don't consult the regex.
    my $match = $r->{match};
    if ($has{chat_message}) {
        die "chat_message trigger needs match=" unless defined $match;
        my $sess = $r->{session};
        die "chat_message trigger needs session="
            unless defined $sess && length $sess;
        die "chat_message session sanitize: '$sess' has forbidden chars"
            unless $sess =~ /^[A-Za-z0-9._-]{1,64}$/;
        # ack_target=NAME: marks the sender's peer_id as ack'ing the named
        # periodic-fanout rule (via ack_key= on that rule). Restrict the
        # NAME to the same shape as [rule.NAME] so it can't smuggle a tab
        # into the SeenFile key encoding "ack_target\tacked\tpeer_id".
        if (defined $r->{ack_target} && length $r->{ack_target}) {
            die "ack_target='$r->{ack_target}' has forbidden chars "
              . "(use [A-Za-z][A-Za-z0-9._-]{0,31})"
                unless $r->{ack_target} =~ /^[A-Za-z][A-Za-z0-9._-]{0,31}$/;
            # Ack rules are pure state mutation — enforce channel=noop
            # so an operator can't accidentally combine ack-dropping
            # with a wire post that would defeat the ack semantics.
            die "ack_target= requires channel=noop (got $ch)"
                unless $ch eq 'noop';
        }
    }
    if ($has{periodic}) {
        # `every` REQUIRED. Enforce a 5s floor so a typo like `every=0.5s`
        # (which _parse_duration would treat as 0 -> fire-every-tick) can't
        # spam the mesh. No dedup, no regex, no session for periodic.
        my $every = $r->{every};
        die "periodic trigger needs every=" unless defined $every && length $every;
        my $secs = _parse_duration($every);
        die "periodic every='$every' must be >= 5s (got ${secs}s)"
            if $secs < 5;
        $r->{_every_secs} = $secs;
        # `match` on an exclusively-periodic rule would be silently
        # ignored, which confuses readers of the config. Fail load in
        # that case only — mixed rules that ALSO include chat_message
        # or bitchat_peer_first_seen legitimately need match=.
        die "periodic trigger does not accept match="
            if defined $r->{match}
            && !$has{chat_message}
            && !$has{bitchat_peer_first_seen};

        # mode=fanout_bitchat_peers: iterate live BLE peers and DM each
        # one whose peer_id hasn't been marked ack'd within acked_ttl.
        # Requires channel=bitchat_dm (per-peer) and an ack_key= naming
        # the SeenFile bucket that chat_message ack_target rules will
        # populate. Missing/empty mode = the legacy single-fire path.
        my $mode = $r->{mode} // '';
        die "periodic mode='$mode' not recognised "
          . "(supported: fanout_bitchat_peers)"
            if length $mode && $mode ne 'fanout_bitchat_peers';
        if ($mode eq 'fanout_bitchat_peers') {
            die "fanout_bitchat_peers requires channel=bitchat_dm (got $ch)"
                unless $ch eq 'bitchat_dm';
            die "fanout_bitchat_peers requires ack_key="
                unless defined $r->{ack_key} && length $r->{ack_key};
            die "ack_key='$r->{ack_key}' has forbidden chars "
              . "(use [A-Za-z][A-Za-z0-9._-]{0,31})"
                unless $r->{ack_key} =~ /^[A-Za-z][A-Za-z0-9._-]{0,31}$/;
            my $atl = $r->{acked_ttl} // '1h';
            my $sec = _parse_duration($atl);
            die "acked_ttl='$atl' must be > 0 (parsed as ${sec}s)"
                unless $sec > 0;
            $r->{_acked_ttl_secs} = $sec;
        }
    }
    $match = '.*' unless defined $match;
    my $re = _compile_re($match);
    $r->{_re} = $re;

    # Duration parse. Default 30d for BLE first-seen; 0 otherwise.
    # Periodic firings never consult dedup — fire_periodic_rules doesn't
    # touch SEEN except in the fanout ack path. For a mixed rule that
    # ALSO fires on first-seen or chat_message, the non-periodic paths
    # still honour dedup_ttl, so we use the first-seen default when
    # first-seen is one of the triggers.
    my $default_ttl = $has{bitchat_peer_first_seen} ? '30d' : '0';
    # Exclusively-periodic rules force dedup_ttl=0 to preserve historic
    # semantics; any mix that includes a non-periodic trigger uses the
    # authored value (or default).
    my $ttl = ($has{periodic}
               && !$has{bitchat_peer_first_seen}
               && !$has{chat_message})
              ? '0'
              : ($r->{dedup_ttl} // $default_ttl);
    $r->{dedup_ttl} = _parse_duration($ttl);
    return 1;
}

sub _compile_re {
    my ($src) = @_;
    my $re;
    local $SIG{ALRM} = sub { die "regex compile timeout\n" };
    alarm(2);
    # `use re 'strict'` (experimental pragma) turns dubious constructs
    # into hard errors so a rule file typo fails at load, not mid-flight.
    # Wrapped in a no-warnings scope so we don't spam every parent load.
    my $ok = eval {
        no warnings 'experimental::re_strict';
        use re 'strict';
        $re = qr/$src/;
        1;
    };
    alarm(0);
    die "bad regex /$src/: $@" unless $ok;
    return $re;
}

sub _parse_duration {
    my ($s) = @_;
    return 0 unless defined $s;
    $s =~ s/^\s+|\s+$//g;
    return 0 if $s eq '' || $s eq '0';
    return $1 * 604800 if $s =~ /^(\d+)w$/i;
    return $1 * 86400  if $s =~ /^(\d+)d$/i;
    return $1 * 3600   if $s =~ /^(\d+)h$/i;
    return $1 * 60     if $s =~ /^(\d+)m$/i;
    return $1 + 0      if $s =~ /^(\d+)s?$/i;
    die "bad duration '$s' (use e.g. 30d, 5m, 90s, 0)\n";
}

sub usage {
    my ($rc) = @_;
    print STDERR <<'USAGE';
net-chat-autoresponder — rule-driven reactor for net-chat.

  net-chat-autoresponder [--config FILE] [--listen H:P] [--once] [--dry-run]
  net-chat-autoresponder --gui [--file FILE] [--listen H:P]

Flags:
  --gui          launch the Tk rule editor + live tester (needs perl-Tk).
                 --file names the primary config (same file the daemon
                 reads); --listen names the daemon whose bitchat_peers /
                 chat_messages / chat_sessions the tester snapshots.
  --config FILE  primary INI (default /etc/net-mgr/net-chat-autoresponder.conf)
                 Overlays in <primary>.d/*.conf are loaded after in sort order.
                 (--file is accepted as an alias, for --gui users.)
  --listen H:P   override [global].listen
  --once         process one row then exit (smoke test)
  --dry-run      log what would be posted, don't actually contact the daemon

See etc/net-chat-autoresponder.conf.sample for the rule grammar.
USAGE
    exit($rc // 0);
}

# ---- --gui dispatch --------------------------------------------------------
# Lazy Tk require is important: the daemon path (the common case) must
# not pay Tk's compile-time cost or fail to start when perl-Tk isn't
# installed on the host. Tk brings a handful of widget subclasses in via
# separate .pm files; each installs the corresponding constructor method
# on Tk parent widgets, so we require them all before entering the run
# loop. Tk->import into main:: makes MainWindow visible as a bareword
# for the nested package's file-scope skeleton code.
sub cmd_gui {
    my (%opt) = @_;
    eval {
        require Tk;
        Tk->import;
        require Tk::ROText;
        require Tk::DialogBox;
        require Tk::Optionmenu;
        require Tk::BrowseEntry;
        1;
    } or die <<MSG;
net-chat-autoresponder --gui needs perl-Tk. Install with:
  Debian/Ubuntu:  sudo apt install perl-tk
  RHEL/Fedora:    sudo dnf install perl-Tk
MSG
    NetChatAutoresponderGui::run(\%opt);
}

# ---- SeenFile ---------------------------------------------------------------
# Append-only 'key\tepoch\n' log. hit(key, ttl) returns 1 if key was seen
# with age <= ttl, otherwise records and returns 0. prune() rewrites the
# file when >2x live entries have expired. flock during writes.
package SeenFile;

use strict;
use warnings;
use Fcntl qw(:flock O_RDWR O_CREAT O_APPEND);

sub open {   ## no critic (Subroutines::ProhibitBuiltinHomonyms)
    my ($class, $path) = @_;
    # Ensure parent dir exists — systemd StateDirectory=net-mgr already
    # creates /var/lib/net-mgr/, but a hand-run smoke test off-service
    # deserves a sensible error. Under an unprivileged run the default
    # is $XDG_STATE_HOME/net-mgr/ which may need TWO levels of dir
    # creation (e.g. ~/.local/state/ + ~/.local/state/net-mgr/), so
    # use File::Path::make_path rather than a single mkdir. Failure
    # here is not fatal — SeenFile silently degrades to in-memory-only.
    (my $parent = $path) =~ s{/[^/]+$}{};
    if (length $parent && !-d $parent) {
        require File::Path;
        my $err;
        File::Path::make_path($parent, { error => \$err });
        if (ref $err eq 'ARRAY' && @$err) {
            my ($first) = @$err;
            my ($k, $v) = %$first;
            warn "[autoresponder] make_path $parent: $v "
               . "(state persistence disabled)\n";
        }
    }
    my $self = bless { path => $path, mem => {}, dirty => 0 }, $class;
    $self->_load;
    return $self;
}

sub _load {
    my ($self) = @_;
    return unless -e $self->{path};
    CORE::open(my $fh, '<', $self->{path})
        or do {
            warn "[autoresponder] open $self->{path}: $!\n";
            return;
        };
    while (<$fh>) {
        chomp;
        next unless length;
        # Parse from the RIGHT: last tab is the ts delimiter, everything
        # before it is the (possibly multi-tab) key. Keys such as
        # 'wifi-broadcast\tacked\tPID_HEX16' would otherwise be split at
        # the first tab and silently dropped by the /^\d+$/ guard.
        my $idx = rindex($_, "\t");
        next if $idx < 0;
        my $k = substr($_, 0, $idx);
        my $t = substr($_, $idx + 1);
        next unless $t =~ /^\d+$/;
        # Later record wins on duplicate keys.
        $self->{mem}{$k} = $t + 0;
    }
    close $fh;
}

sub check {
    my ($self, $key, $ttl) = @_;
    my $prev = $self->{mem}{$key};
    return defined $prev && (time - $prev) <= $ttl;
}

sub record {
    my ($self, $key) = @_;
    my $now = time;
    $self->{mem}{$key} = $now;
    $self->_append($key, $now);
}

# Delete every mem key for which $pred->($k) is true, then rewrite
# the on-disk log so the deletion survives a daemon restart (the
# append-only log format can't express "deleted"). Returns the
# count of removed keys. Called by the "reset" reserved-word
# handler in on_chat_row.
sub forget_matching {
    my ($self, $pred) = @_;
    my $n = 0;
    for my $k (keys %{ $self->{mem} }) {
        if ($pred->($k)) {
            delete $self->{mem}{$k};
            $n++;
        }
    }
    $self->_rewrite if $n;
    return $n;
}

# Overwrite the on-disk log with %mem's current state. Atomic via
# tmp+rename so a crash mid-write leaves the prior log intact.
sub _rewrite {
    my ($self) = @_;
    my $tmp = "$self->{path}.tmp.$$";
    my $fh;
    unless (CORE::open $fh, '>', $tmp) {
        warn "[autoresponder] rewrite $tmp: $!\n";
        return;
    }
    for my $k (sort keys %{ $self->{mem} }) {
        print $fh "$k\t$self->{mem}{$k}\n";
    }
    close $fh;
    rename $tmp, $self->{path}
        or warn "[autoresponder] rename $tmp -> $self->{path}: $!\n";
    $self->{dirty} = 0;
}

sub _append {
    my ($self, $key, $ts) = @_;
    my $fh;
    unless (sysopen $fh, $self->{path},
            O_RDWR | O_CREAT | O_APPEND)
    {
        warn "[autoresponder] open $self->{path}: $! "
           . "(dedup not persisted this round)\n";
        return;
    }
    flock $fh, LOCK_EX;
    print $fh "$key\t$ts\n";
    flock $fh, LOCK_UN;
    close $fh;
    $self->{dirty}++;
}

# Called on every loop tick; cheap unless the file has grown a lot.
sub prune {
    my ($self) = @_;
    return unless $self->{dirty} >= 32;  # rate-limit rewrites
    return unless -f $self->{path};

    # Count expired vs live from the ON-DISK log (not %mem, which is
    # dedup'd). If >2x expired-vs-live, rewrite.
    CORE::open(my $fh, '<', $self->{path}) or return;
    my $live = 0;
    my $expired = 0;
    my $now = time;
    my %latest;
    while (<$fh>) {
        chomp;
        # Parse from the RIGHT (see _load): multi-tab keys must survive.
        my $idx = rindex($_, "\t");
        next if $idx < 0;
        my $k = substr($_, 0, $idx);
        my $t = substr($_, $idx + 1);
        next unless $t =~ /^\d+$/;
        $latest{$k} = $t + 0;
    }
    close $fh;
    for my $t (values %latest) {
        # We can't know per-key TTL here — assume 30d as the outer bound.
        # An entry stays "live" for the coarse window and is compacted
        # once that window elapses. Any newer hit resets it.
        if ($now - $t <= 30 * 86400) { $live++ } else { $expired++ }
    }
    return unless $expired > $live;   # >50% expired = compact

    my $tmp = $self->{path} . ".tmp.$$";
    if (CORE::open(my $out, '>', $tmp)) {
        for my $k (sort keys %latest) {
            next if $now - $latest{$k} > 30 * 86400;
            print $out "$k\t$latest{$k}\n";
        }
        close $out;
        rename $tmp, $self->{path}
            or warn "[autoresponder] rename $tmp -> $self->{path}: $!\n";
        $self->{dirty} = 0;
    } else {
        warn "[autoresponder] compact open $tmp: $!\n";
    }
}

# ---- NetChatAutoresponderGui ----------------------------------------------
# Tk editor + live tester for the rule set this daemon reads. Split out
# from the historical bin/net-autoresponder-gui script; folded in here so
# the two surfaces share a name and there's one config-format loader/writer
# to keep aligned. Entered via `net-chat-autoresponder --gui`; the daemon
# path never reaches this package (cmd_gui exits before returning).
#
# Reads /etc/net-mgr/net-chat-autoresponder.conf plus every overlay in the
# adjacent .d/ directory, in filename-sort order, mirroring load_config()
# above. Each rule is tracked against the file it was last defined in
# (last-write-wins per rule name across overlays) so save-back writes to
# the SAME file — you don't accidentally move a site-override rule out of
# its overlay back into the packaged default.
#
# Rule enable/disable is persisted by prefixing every line of the rule
# section (header + body kv) with '; '. The daemon's INI reader treats
# those as comments so a disabled rule is a no-op at load; the GUI
# restores the rule by stripping that prefix.
#
# Test pane: for the selected rule, sample recent rows from the table
# its trigger consumes (bitchat_peers / chat_messages) via
# NetMgr::Client->snapshot on --listen, then re-run the rule's match /
# from / session filters against each row and show what would fire, with
# the resolved target/body after ${...} substitution. Periodic rules
# have no history to sample; the tester synthesises a single tick
# context and just shows the resolved wire post.
#
# NOTE: the daemon reads its config exactly once at startup. There is no
# SIGHUP handler and no `service_restart` REPAIR action today. After
# Save the GUI shows a reminder to
# `systemctl restart net-chat-autoresponder` — automating that from here
# would need SSH or a new REPAIR action, neither worth the complexity.

package NetChatAutoresponderGui;

use strict;
use warnings;
use File::Copy   ();
use File::Basename qw(basename dirname);
use POSIX          qw(strftime);
use NetMgr::Client;
use NetMgr::Config;

# --- module-scope state (was file-scope in bin/net-autoresponder-gui) -----
our $listen;
our $file;
our %S;
our @KNOWN_SESSIONS;
our ($save_btn, $post_btn);
our %SHARED_WIFI;
our @SHARED_WIFI_LABELS;
our %DISPLAY_TO_LABEL;
# Default is euid-aware via NetMgr::Config->resolve_config_file — see the
# main script's %opt seed for the full story. Left assignable so a `--file`-
# style CLI flag or an ad-hoc test can point the picker at a different file.
our $SHARED_WIFI_CONF = NetMgr::Config->resolve_config_file('shared-wifi.conf');

# Tk widget refs live at package scope so all handler subs can reach them.
our ($mw, $top_bar, $body_frame, $test_frame, $action_bar, $status_lbl);
our ($left_frame, $right_frame, $rules_list, $left_btns);
our (%E, $editor_frame);
our ($test_top, $test_text);
our $sample_n = 50;
our ($listen_var, $file_var);
our $HOST_CACHED;

# Re-entry guard: Tk::Optionmenu fires its -command during construction
# when -variable is initially set to match one of its options, and the
# on_change closures for Trigger/Channel both call build_editor_form,
# which would recurse infinitely as each rebuilt Optionmenu fires again.
# The guard turns those nested calls into no-ops; only the outermost
# invocation (from Load / operator-driven change / do_add_rule) rebuilds.
our $BUILDING_FORM = 0;

# NM keyfile enum state — declared at package scope so row_shared_wifi
# (called from build_editor_form during initial render) can read them
# before _enum_nm_profiles runs. Actual values set by _enum_nm_profiles
# after load_shared_wifi walks /etc/NetworkManager/system-connections/.
our $_NM_KEYFILE_WARNED = 0;
our $_NM_UNREADABLE     = 0;

# --- entry point ----------------------------------------------------------
sub run {
    my ($opt) = @_;
    # Package-scope `our $X = VAL` initializations never ran because the
    # main script short-circuited via `if ($opt{gui}) { cmd_gui; exit }`
    # before Perl reached this package's top-level code. Set the defaults
    # here so run() is the single source of truth for GUI-side state.
    $SHARED_WIFI_CONF //= NetMgr::Config->resolve_config_file('shared-wifi.conf');
    $BUILDING_FORM   //= 0;
    $sample_n        //= 50;
    $listen = $opt->{listen} // $ENV{NET_MGR_LISTEN} // '127.0.0.1:7531';
    # `--file` is the historical GUI name for the primary config; `--config`
    # is the daemon name. Both work here so operators can pass whichever
    # they already have muscle memory for. When neither is given, defer to
    # NetMgr::Config's per-euid resolver: root sees /etc/net-mgr/, an
    # unprivileged operator sees $XDG_CONFIG_HOME/net-mgr/ (typically
    # ~/.config/net-mgr/) so Save has a writable target.
    $file = $opt->{file} // $opt->{config}
                        // NetMgr::Config->resolve_config_file('net-chat-autoresponder.conf');

    %S = (
        rules   => [],
        files   => {},
        order   => [],
        primary => $file,
        sel_idx => undef,
    );

    # --- Tk skeleton (net-cluster-gui:139-150 layout) --------------------
    $mw = MainWindow->new(-title => "net-autoresponder-gui ($file)");
    $mw->geometry('1100x760');

    # Pack order matters: bottom siblings must be packed BEFORE the
    # top+expand=1 siblings so they claim their slice of the cavity
    # first. If action_bar packs after two expand=1 top frames, Tk
    # gives it its natural height but the expanding frames can push
    # it below the visible geometry on some window managers (RDP /
    # xrdp geometry is the reproducer that surfaced this — the Save
    # button was rendered off-screen).
    $top_bar    = $mw->Frame(-relief => 'groove', -bd => 1)
                     ->pack(-side => 'top', -fill => 'x');
    $status_lbl = $mw->Label(-anchor => 'w', -relief => 'sunken')
                     ->pack(-side => 'bottom', -fill => 'x');
    $action_bar = $mw->Frame(-relief => 'raised', -bd => 1)
                     ->pack(-side => 'bottom', -fill => 'x');
    $body_frame = $mw->Frame->pack(-side => 'top', -fill => 'both', -expand => 1);
    $test_frame = $mw->Frame(-relief => 'sunken', -bd => 1)
                     ->pack(-side => 'top', -fill => 'both', -expand => 1, -pady => 2);

    # --- Top bar: daemon target + config file + Load ---------------------
    $top_bar->Label(-text => 'Target daemon:')->pack(-side => 'left', -padx => 4);
    $listen_var = $listen;
    $top_bar->Entry(-textvariable => \$listen_var, -width => 22)
            ->pack(-side => 'left', -padx => 4);
    $top_bar->Label(-text => '   Config:')->pack(-side => 'left');
    $file_var = $file;
    $top_bar->Entry(-textvariable => \$file_var, -width => 44)
            ->pack(-side => 'left', -padx => 4);
    $top_bar->Button(-text => 'Load', -command => \&do_load)
            ->pack(-side => 'left', -padx => 4);
    $top_bar->Button(-text => 'Restart hint', -command => \&show_restart_hint)
            ->pack(-side => 'right', -padx => 4);

    # --- Body: LEFT rule list, RIGHT editor ------------------------------
    $left_frame  = $body_frame->Frame(-relief => 'groove', -bd => 1)
                              ->pack(-side => 'left', -fill => 'y', -padx => 2);
    $right_frame = $body_frame->Frame(-relief => 'groove', -bd => 1)
                              ->pack(-side => 'left', -fill => 'both',
                                     -expand => 1, -padx => 2);

    $left_frame->Label(-text => 'Rules  (Space or double-click to toggle on/off)',
                       -font => '{Helvetica} 9 bold')
               ->pack(-side => 'top', -anchor => 'w', -padx => 4, -pady => 2);
    $rules_list = $left_frame->Scrolled('Listbox',
        -scrollbars => 'oe',
        -width      => 32,
        -height     => 20,
        -font       => '{Monospace} 10',
        -selectmode => 'browse',
        -takefocus  => 1,
    )->pack(-side => 'top', -fill => 'y', -expand => 1, -padx => 4, -pady => 2);
    $rules_list->bind('<<ListboxSelect>>', \&on_rule_pick);
    # Double-click a rule or hit space with a rule selected to flip its
    # enabled bit. Arrow keys move the selection (Tk::Listbox defaults)
    # and the on_rule_pick handler refreshes the editor pane.
    my $lb = $rules_list->Subwidget('scrolled');
    $lb->bind('<Double-Button-1>',
              sub { do_toggle_enabled(); Tk->break });
    $lb->bind('<space>',
              sub { do_toggle_enabled(); Tk->break });
    # Arrow-key movement also refreshes the right pane. Tk::Listbox's
    # default bindings move -active but don't always fire ListboxSelect,
    # so handle the keys explicitly: compute the target index, sync
    # selection + active + visible-window, then call on_rule_pick.
    my @keys = (
        ['<Up>',    sub { my ($c,$s) = @_; $c - 1 } ],
        ['<Down>',  sub { my ($c,$s) = @_; $c + 1 } ],
        ['<Home>',  sub { 0 } ],
        ['<End>',   sub { my ($c,$s) = @_; $s - 1 } ],
        ['<Prior>', sub { my ($c,$s) = @_; $c - 10 } ],
        ['<Next>',  sub { my ($c,$s) = @_; $c + 10 } ],
    );
    for my $spec (@keys) {
        my ($key, $calc) = @$spec;
        $lb->bind($key, sub {
            my $l   = shift;
            my $sz  = $l->size;
            return unless $sz > 0;
            my $cur = ($l->curselection)[0] // 0;
            my $new = $calc->($cur, $sz);
            $new = 0        if $new < 0;
            $new = $sz - 1  if $new >= $sz;
            $l->selectionClear(0, 'end');
            $l->selectionSet($new);
            $l->activate($new);
            $l->see($new);
            on_rule_pick();
            Tk->break;
        });
    }

    $left_btns = $left_frame->Frame->pack(-side => 'top', -fill => 'x', -pady => 2);
    $left_btns->Button(-text => '+ Add',    -command => \&do_add_rule)
              ->pack(-side => 'left',  -padx => 2);
    # Toggle was here — the Space/double-click bindings on the
    # rule list (documented in the pane label) already toggle
    # enable state; a button labelled "Toggle" without context
    # read as a mystery.
    $left_btns->Button(-text => 'Delete',   -command => \&do_delete_rule)
              ->pack(-side => 'left',  -padx => 2);

    build_editor_shell();

    # --- Test pane (bottom half) ----------------------------------------
    $test_top = $test_frame->Frame->pack(-side => 'top', -fill => 'x', -pady => 2);
    $test_top->Label(-text => 'Test pane', -font => '{Helvetica} 9 bold')
             ->pack(-side => 'left', -padx => 4);
    $test_top->Label(-text => '   Sample size:')->pack(-side => 'left');
    $sample_n = 50;
    $test_top->Entry(-textvariable => \$sample_n, -width => 5)
             ->pack(-side => 'left', -padx => 2);
    $test_top->Button(-text => 'Fetch + test selected rule',
                      -command => \&do_test)
             ->pack(-side => 'left', -padx => 6);
    $test_top->Label(-text => '(uses editor state, not the saved rule)',
                     -foreground => '#666')
             ->pack(-side => 'left', -padx => 8);

    $test_text = $test_frame->Scrolled('ROText',
        -scrollbars => 'osoe',
        -wrap       => 'none',
        -font       => '{Monospace} 9',
        -height     => 14,
    )->pack(-side => 'top', -fill => 'both', -expand => 1, -padx => 4, -pady => 2);
    $test_text->tagConfigure('hit',    -foreground => '#040');
    $test_text->tagConfigure('miss',   -foreground => '#888');
    $test_text->tagConfigure('bold',   -font       => '{Monospace} 9 bold');
    $test_text->tagConfigure('err',    -foreground => '#a00');
    $test_text->tagConfigure('resolved', -foreground => '#005');

    # --- Action bar -----------------------------------------------------
    $save_btn = $action_bar->Button(-text => 'Save',
                                    -command => \&do_save_rule)
                           ->pack(-side => 'left', -padx => 4);
    update_save_state();
    # Post: send the current body to the target session as a one-off
    # chat_post, bypassing the rule engine. Useful for "does anyone see
    # this?" pokes and for testing a body without waiting for the next
    # periodic fire. Only meaningful for channel=chat_post rules
    # (target is a session name); disabled otherwise.
    $post_btn = $action_bar->Button(-text => 'Post',
                                    -command => \&do_post_now)
                           ->pack(-side => 'left', -padx => 4);
    update_save_state();
    $action_bar->Button(-text => 'Reload from disk',
                        -command => \&do_load)
               ->pack(-side => 'left', -padx => 4);
    $action_bar->Button(-text => 'Quit', -command => sub { exit 0 })
               ->pack(-side => 'right', -padx => 4);

    do_load();
    # Tk::MainLoop is exported by `use Tk` into the package where the
    # `use` statement ran — that's main::, not NetChatAutoresponderGui::.
    # Call fully-qualified so the sub is found no matter which package
    # ran the require.
    Tk::MainLoop();
    return;
}

# ====================================================================
# Actions
# ====================================================================

sub do_load {
    $file = $file_var;
    $S{primary} = $file;
    $S{files}   = {};
    $S{order}   = [];
    $S{rules}   = [];
    $S{sel_idx} = undef;

    # Refresh the chat_sessions cache alongside the config reload so
    # the session/target BrowseEntry dropdowns reflect the daemon's
    # current sessions. Failure is non-fatal — dropdown is just empty
    # and the operator can still type any name.
    @KNOWN_SESSIONS = fetch_chat_sessions();

    # Refresh the shared-WiFi picker cache. Missing file / parse
    # error is fine — the dropdown shows a hint item instead and
    # the operator can still type the WIFI: URI by hand.
    load_shared_wifi();

    my @paths = overlay_paths($file);
    unless (@paths) {
        set_status("No config found: $file (and no $file.d/*.conf)");
        refresh_rules_list();
        clear_editor();
        return;
    }
    my %by_name;
    my @name_order;
    for my $p (@paths) {
        my @lines = slurp_lines($p);
        $S{files}{$p} = \@lines;
        push @{$S{order}}, $p;
        parse_rules_from($p, \@lines, \%by_name, \@name_order);
    }
    $S{rules} = [ map { $by_name{$_} } @name_order ];
    refresh_rules_list();
    if (@{$S{rules}}) {
        $rules_list->selectionSet(0);
        $S{sel_idx} = 0;
        load_editor_from_rule( $S{rules}[0] );
    } else {
        clear_editor();
    }
    set_status(sprintf "Loaded %d rule(s) from %d file(s)",
               scalar @{$S{rules}}, scalar @paths);
}

sub on_rule_pick {
    my @sel = $rules_list->curselection;
    return unless @sel;
    my $i = $sel[0];
    $S{sel_idx} = $i;
    load_editor_from_rule($S{rules}[$i]);
}

sub do_add_rule {
    my $dlg = $mw->DialogBox(-title => 'New rule',
                             -buttons => ['OK', 'Cancel']);
    my %v = (name => '');
    # Triple-checkbox picker: the operator picks one or more triggers
    # up front so the editor's per-trigger rows appear immediately.
    my %picks = (bitchat_peer_first_seen => 0,
                 chat_message            => 0,
                 periodic                => 0);
    $dlg->add('Label', -text => 'Rule name ([A-Za-z][A-Za-z0-9._-]{0,31}):')
        ->pack(-anchor => 'w', -padx => 8, -pady => 2);
    my $e = $dlg->add('Entry', -textvariable => \$v{name}, -width => 32)
                ->pack(-padx => 8, -pady => 2);
    $e->focus;
    $dlg->add('Label', -text => 'Triggers (check one or more):')
        ->pack(-anchor => 'w', -padx => 8, -pady => 2);
    for my $t (qw(bitchat_peer_first_seen chat_message periodic)) {
        $dlg->add('Checkbutton',
                  -text     => $t,
                  -variable => \$picks{$t},
                  -anchor   => 'w',
        )->pack(-anchor => 'w', -padx => 16, -pady => 1);
    }
    my $ans = $dlg->Show // 'Cancel';
    return unless $ans eq 'OK' || $ans eq 'Ok';
    $v{name} =~ s/^\s+|\s+$//g;
    return msg('Bad name', 'Rule name must match [A-Za-z][A-Za-z0-9._-]{0,31}.')
        unless $v{name} =~ /^[A-Za-z][A-Za-z0-9._-]{0,31}$/;
    my @picked = grep { $picks{$_} }
                     qw(bitchat_peer_first_seen chat_message periodic);
    return msg('No trigger', 'Check at least one trigger before creating the rule.')
        unless @picked;
    for my $r (@{$S{rules}}) {
        return msg('Duplicate', "A rule named '$v{name}' already exists in "
                              . $r->{source} . ".")
            if $r->{name} eq $v{name};
    }
    # New rules append to the primary file. If the primary doesn't yet
    # exist, create it (empty) so the append target is well-defined.
    my $dest = $S{primary};
    if (!exists $S{files}{$dest}) {
        $S{files}{$dest} = [];
        push @{$S{order}}, $dest;
    }
    # Don't seed channel/target/body/session — the operator must fill
    # them in explicitly. Save stays disabled until channel is picked.
    my $starter_kv = { trigger => join(', ', @picked) };
    my $new = {
        name    => $v{name},
        enabled => 1,
        source  => $dest,
        kv      => $starter_kv,
        # start_ln/end_ln get assigned when we write, not now.
    };
    push @{$S{rules}}, $new;
    $S{sel_idx} = $#{ $S{rules} };
    refresh_rules_list();
    $rules_list->selectionClear(0, 'end');
    $rules_list->selectionSet($S{sel_idx});
    load_editor_from_rule($new);
    set_status("New rule '$v{name}' — edit + Save to write it to $dest");
}

sub do_toggle_enabled {
    my $r = current_rule() or return;
    $r->{enabled} = $r->{enabled} ? 0 : 1;
    my $body = editor_kv_dump();
    write_rule_back($r, $body);
    refresh_rules_list();
    reselect_current();
    set_status(($r->{enabled} ? "enabled" : "disabled")
             . " '$r->{name}' in " . basename($r->{source}));
}

sub do_delete_rule {
    my $r = current_rule() or return;
    my $ans = $mw->messageBox(
        -title   => 'Delete rule',
        -message => "Delete '$r->{name}' from " . $r->{source} . "?",
        -type    => 'OKCancel',
        -icon    => 'question',
        -default => 'cancel',
    );
    return unless $ans eq 'Ok' || $ans eq 'OK';
    delete_rule_from_file($r);
    # Drop from the in-memory rules list + reload the file we edited.
    reload_file( $r->{source} );
    refresh_rules_list();
    clear_editor();
    set_status("deleted '$r->{name}' from " . basename($r->{source}));
}

sub do_save_rule {
    my $r = current_rule() or return msg('No rule', 'Pick a rule to save.');
    my $kv = editor_kv_dump();
    # Cheap client-side validation before the write. The daemon will
    # re-validate on next load; this just catches shape errors early.
    if (my $err = validate_kv($kv)) {
        return msg('Invalid rule', $err);
    }
    $r->{kv} = $kv;
    write_rule_back($r, $kv);
    refresh_rules_list();
    reselect_current();
    set_status("saved '$r->{name}' to " . $r->{source}
             . "  (restart net-chat-autoresponder to apply)");
}

sub show_restart_hint {
    # Name the file the operator is currently editing so a user-scope
    # Save doesn't leave the operator wondering why `systemctl restart`
    # didn't pick up their change. The root-owned daemon only reads
    # /etc/net-mgr/net-chat-autoresponder.conf (+ .d/); an installer
    # editing under ~/.config/net-mgr/ needs to promote their file into
    # /etc/net-mgr/net-chat-autoresponder.d/ for systemd to see it.
    my $editing = $S{primary} // $file // '(unset)';
    my $sys_path = '/etc/net-mgr/net-chat-autoresponder.conf';
    my $note = '';
    if (defined $editing && $editing ne $sys_path
        && $editing !~ m{^\Q$sys_path\E\.d/})
    {
        (my $base = $editing) =~ s{.*/}{};
        $note = <<"USER";

NOTE: you are editing a USER-SCOPE file:

  $editing

The systemd service runs as root and reads only /etc/net-mgr/. To promote
your edits into the running service, either copy or symlink this file
into /etc/net-mgr/net-chat-autoresponder.d/ (e.g.
`sudo install -m 0644 '$editing' /etc/net-mgr/net-chat-autoresponder.d/$base`)
and THEN restart the daemon.
USER
    }
    my $body = <<"MSG";
net-chat-autoresponder reads its config once at startup.
Apply saved changes with one of:

  sudo systemctl restart net-chat-autoresponder

Or, for a smoke test without touching systemd:

  sudo -u root net-chat-autoresponder --once --dry-run

There is no in-band SIGHUP / REPAIR action for this today.$note
MSG
    $mw->messageBox(-title => 'Restart the autoresponder',
                    -message => $body, -type => 'OK', -icon => 'info');
}

# ====================================================================
# Editor form (right pane) — dynamic per trigger
# ====================================================================

# Persistent shell: create $editor_frame plus the always-present name +
# trigger row. Trigger-specific rows are torn down and rebuilt whenever
# the trigger changes.
sub build_editor_shell {
    $right_frame->Label(-text => 'Rule editor',
                        -font => '{Helvetica} 9 bold')
                ->pack(-side => 'top', -anchor => 'w', -padx => 4, -pady => 2);
    $editor_frame = $right_frame->Frame->pack(-side => 'top', -fill => 'both',
                                              -expand => 1, -padx => 4, -pady => 2);
    build_editor_form();
}

# Render form rows from scratch based on $E{trigger}. Field values live
# in $E{fields}{<key>} so save can serialize them without asking the
# widgets. Unset $E{fields} at build time so a trigger flip drops keys
# that don't belong to the new trigger.
sub build_editor_form {
    return if $BUILDING_FORM;
    local $BUILDING_FORM = 1;
    $_->destroy for $editor_frame->children;
    $E{fields} //= {};
    $E{trigger_set} //= { map { $_ => 0 }
                              qw(bitchat_peer_first_seen chat_message periodic) };
    my $chan = $E{fields}{channel} // '';

    row_entry( $editor_frame, 'Name:',    'name',    32 );
    # Trigger picker is now a triple Checkbutton — a rule can react to
    # any combination of chat_message / bitchat_peer_first_seen /
    # periodic. The trigger-specific rows below are rendered per
    # checked trigger; toggling a box rebuilds the form so the
    # per-trigger rows appear/disappear immediately.
    row_trigger_checkboxes($editor_frame);
    row_option($editor_frame, 'Channel:', 'channel',
        [ [ '(pick one)' => '' ],
          [ 'bitchat_dm' => 'bitchat_dm' ],
          [ 'chat_post'  => 'chat_post' ],
          [ 'noop'       => 'noop' ] ],
        sub {
            # Channel change swaps the Target row between a plain Entry
            # (bitchat_dm/noop, freeform peer_id / ${var}) and a
            # BrowseEntry backed by chat_sessions (chat_post).
            build_editor_form();
        },
    );
    # Target row: BrowseEntry backed by chat_sessions when
    # channel=chat_post (target IS a session name in that case); plain
    # Entry otherwise (bitchat_dm wants a 16-hex peer_id or ${var}).
    if ($chan eq 'chat_post') {
        row_browse_entry($editor_frame, 'Target:', 'target', 48, \@KNOWN_SESSIONS);
    } else {
        row_entry( $editor_frame, 'Target:', 'target', 48 );
    }
    # Shared-WiFi picker sits ABOVE the body field so an operator
    # composing a rule.wifi-fanout style greeting can pick a
    # credential set and drop the WIFI: URI into the body without
    # typing the escaping by hand. The generated URI shape matches
    # net-bitchat-bridge:531-534 (same escape set) so QR readers
    # parse the greeting identically whichever surface produced it.
    row_shared_wifi($editor_frame);
    row_multi( $editor_frame, 'Body:',      'body' );
    row_entry( $editor_frame, 'Dedup TTL:', 'dedup_ttl', 12 );

    # Per-trigger field sections. Rendered in a fixed order so the
    # layout is stable across edits. Match is a shared field on
    # chat_message + bitchat_peer_first_seen; render it only in the
    # first section that owns it.
    my $set = $E{trigger_set};
    my $rendered_match = 0;
    if ($set->{chat_message}) {
        _editor_section_label($editor_frame, '[chat_message]');
        row_browse_entry($editor_frame, 'Session:', 'session', 32, \@KNOWN_SESSIONS);
        row_entry( $editor_frame, 'Match:',      'match',      48 );
        $rendered_match = 1;
        row_entry( $editor_frame, 'From:',       'from',       32 );
        row_entry( $editor_frame, 'Ack target:', 'ack_target', 32 );
    }
    if ($set->{bitchat_peer_first_seen}) {
        my $suffix = $rendered_match ? '  (Match shared with chat_message above)' : '';
        _editor_section_label($editor_frame, "[bitchat_peer_first_seen]$suffix");
        if (!$rendered_match) {
            row_entry( $editor_frame, 'Match:', 'match', 48 );
            $rendered_match = 1;
        }
    }
    if ($set->{periodic}) {
        _editor_section_label($editor_frame, '[periodic]');
        row_entry( $editor_frame, 'Every:',      'every',      12 );
        row_option($editor_frame, 'Mode:',       'mode',
            [ [ '(single-fire)' => '' ],
              [ 'fanout_bitchat_peers' => 'fanout_bitchat_peers' ] ],
        );
        row_entry( $editor_frame, 'Ack key:',    'ack_key',    32 );
        row_entry( $editor_frame, 'Acked TTL:',  'acked_ttl',  12 );
    }

    my $meta = $editor_frame->Frame->pack(-side => 'top', -fill => 'x', -pady => 4);
    $E{source_label} = $meta->Label(
        -text => 'Source file: (unsaved)',
        -foreground => '#444',
        -anchor => 'w',
    )->pack(-side => 'left', -padx => 4);

    # Toggle Save enable/disable based on whether trigger + channel
    # are both non-blank now that we've refreshed the widget state.
    update_save_state();
}

sub row_entry {
    my ($parent, $label, $key, $width) = @_;
    my $row = $parent->Frame->pack(-side => 'top', -fill => 'x', -pady => 1);
    $row->Label(-text => $label, -width => 12, -anchor => 'w')
        ->pack(-side => 'left');
    $E{fields}{$key} //= '';
    $row->Entry(-textvariable => \$E{fields}{$key}, -width => $width)
        ->pack(-side => 'left', -fill => 'x', -expand => 1);
}

sub row_multi {
    my ($parent, $label, $key) = @_;
    my $row = $parent->Frame->pack(-side => 'top', -fill => 'x', -pady => 1);
    $row->Label(-text => $label, -width => 12, -anchor => 'nw')
        ->pack(-side => 'left');
    my $t = $row->Scrolled('Text',
        -height     => 4,
        -width      => 60,
        -wrap       => 'word',
        -scrollbars => 'oe',
        -font       => '{Monospace} 10',
    )->pack(-side => 'left', -fill => 'x', -expand => 1);
    $E{_multi}{$key} = $t;
    my $init = $E{fields}{$key} // '';
    $t->delete('1.0', 'end');
    $t->insert('end', $init);
    $t->bind('<KeyRelease>', sub {
        $E{fields}{$key} = $t->get('1.0', 'end-1c');
    });
    $E{fields}{$key} = $init;
}

sub row_trigger_checkboxes {
    my ($parent) = @_;
    my $row = $parent->Frame->pack(-side => 'top', -fill => 'x', -pady => 1);
    $row->Label(-text => 'Triggers:', -width => 12, -anchor => 'w')
        ->pack(-side => 'left');
    $E{trigger_set} //= { map { $_ => 0 }
                              qw(bitchat_peer_first_seen chat_message periodic) };
    for my $t (qw(bitchat_peer_first_seen chat_message periodic)) {
        $E{trigger_set}{$t} //= 0;
        $row->Checkbutton(
            -text     => $t,
            -variable => \$E{trigger_set}{$t},
            -anchor   => 'w',
            -command  => sub {
                # Sync the joined-string form the daemon reads out of
                # $E{fields}{trigger}, then rebuild so per-trigger rows
                # come and go with the checkbox.
                _sync_trigger_field();
                build_editor_form();
            },
        )->pack(-side => 'left', -padx => 4);
    }
    _sync_trigger_field();
}

# Derive $E{fields}{trigger} (the comma-joined string that reaches the
# INI writer) from the checkbox state. Order is fixed so a rule that
# round-trips through the editor without changing its trigger set
# writes back the same string it was loaded from.
sub _sync_trigger_field {
    my @picked = grep { $E{trigger_set}{$_} }
                     qw(bitchat_peer_first_seen chat_message periodic);
    $E{fields}{trigger} = join(', ', @picked);
    # $E{trigger} is legacy — a couple of callsites (clear_editor and
    # the old on_change closure) still touch it. Keep it aligned to
    # the first checked trigger for backward compat inside the GUI.
    $E{trigger} = $picked[0] // '';
}

sub _editor_section_label {
    my ($parent, $text) = @_;
    $parent->Label(-text => $text,
                   -font => '{Helvetica} 9 bold',
                   -foreground => '#004',
                   -anchor => 'w')
           ->pack(-side => 'top', -fill => 'x', -pady => 2);
}

sub row_option {
    my ($parent, $label, $key, $options, $on_change) = @_;
    my $row = $parent->Frame->pack(-side => 'top', -fill => 'x', -pady => 1);
    $row->Label(-text => $label, -width => 12, -anchor => 'w')
        ->pack(-side => 'left');
    # Default to the empty sentinel (never auto-pick the first entry).
    # Every option list that reaches here has '' as a valid value —
    # either as the '(pick one)' sentinel (trigger, channel) or the
    # legitimate '(single-fire)' mode. So a fresh rule shows a picker
    # that requires an explicit selection instead of silently seeding
    # bitchat_dm / chat_message and validating on Save.
    $E{fields}{$key} //= '';
    my %ok = map { $_->[1] => 1 } @$options;
    $E{fields}{$key} = ''
        unless defined $E{fields}{$key} && $ok{ $E{fields}{$key} };
    $row->Optionmenu(
        -options  => $options,
        -variable => \$E{fields}{$key},
        ($on_change ? (-command => sub { $on_change->() }) : ()),
    )->pack(-side => 'left');
}

# BrowseEntry variant for fields that map to chat_sessions.name — a
# combo-box: dropdown of known session names for pick-with-mouse, but
# still typeable so an operator can name a session that doesn't yet
# exist (autoresponder chat_opens on first fire).
sub row_browse_entry {
    my ($parent, $label, $key, $width, $choices_ref) = @_;
    my $row = $parent->Frame->pack(-side => 'top', -fill => 'x', -pady => 1);
    $row->Label(-text => $label, -width => 12, -anchor => 'w')
        ->pack(-side => 'left');
    $E{fields}{$key} //= '';
    my $be = $row->BrowseEntry(
        -variable  => \$E{fields}{$key},
        -width     => $width,
        -listwidth => 40,
    )->pack(-side => 'left', -fill => 'x', -expand => 1);
    for my $s (@{ $choices_ref // [] }) {
        my $name = ref($s) ? $s->{name} : $s;
        next unless defined $name && length $name;
        $be->insert('end', $name);
    }
}

# Shared-WiFi picker row. BrowseEntry lists every [wifi.LABEL] section
# discovered by load_shared_wifi() as "LABEL (SSID)"; two buttons handle
# insert-URI and insert-URI-plus-note into the body Text widget at the
# cursor (or replacing the current selection). When no shared-wifi.conf
# is present the dropdown carries a single hint item and the buttons
# silently no-op — a bare empty picker looked confusingly broken.
sub row_shared_wifi {
    my ($parent) = @_;
    my $row = $parent->Frame->pack(-side => 'top', -fill => 'x', -pady => 1);
    $row->Label(-text => 'Share WiFi:', -width => 12, -anchor => 'w')
        ->pack(-side => 'left');
    $E{fields}{_wifi_pick} //= '';
    my $be = $row->BrowseEntry(
        -variable  => \$E{fields}{_wifi_pick},
        -width     => 56,
        -listwidth => 80,
        -browsecmd => sub { _wifi_insert_from_pick(0) },
    )->pack(-side => 'left', -padx => 2);
    if (@SHARED_WIFI_LABELS) {
        for my $label (@SHARED_WIFI_LABELS) {
            my $entry = $SHARED_WIFI{$label} or next;
            my $ssid  = $entry->{ssid} // '?';
            my $disp  = "$label ($ssid)";
            # NM-sourced entries get a " [NM]" suffix so the operator
            # can tell auto-populated picks from curated ones at a
            # glance; nmcli-fallback entries add " (no PSK)" so it's
            # visible without opening a tooltip. MUST match the
            # DISPLAY_TO_LABEL key produced in load_shared_wifi()
            # exactly, or _wifi_insert_from_pick can't resolve the
            # pick back to a label and the buttons silently no-op.
            my $src = $entry->{source} // '';
            $disp .= ' [NM]'         if $src eq 'nm';
            $disp .= ' [NM no PSK]'  if $src eq 'nm-nopsk';
            $be->insert('end', $disp);
        }
    } else {
        # Nothing to offer. Distinguish the "nothing configured" case
        # from the more common "unprivileged operator, NM keyfiles
        # readable only by root" case — the latter has an obvious next
        # step (relaunch under sudo) while the former needs a config
        # file authored.
        if ($_NM_UNREADABLE) {
            $be->insert('end',
                '(NM saved connections need sudo — relaunch: '
              . 'sudo net-chat-autoresponder --gui)');
        } else {
            $be->insert('end',
                '(no shared-wifi.conf — see etc/shared-wifi.conf.sample)');
        }
    }
    # Insert (no note) was here — the BrowseEntry's -browsecmd
    # already fires _wifi_insert_from_pick(0) when the operator
    # picks from the dropdown, so the button was redundant. The
    # with-note variant stays because there's no other trigger
    # for that flow.
    $row->Button(-text => 'Insert w/ note',
                 -command => sub { _wifi_insert_from_pick(1) })
        ->pack(-side => 'left', -padx => 2);
    # QR pops a window with the WIFI: URI rendered as a QR code so
    # the operator can hand off credentials by pointing a camera —
    # skips the bridge / message-body path entirely. Requires
    # qrencode (libqrencode). Degrades to a hint if missing.
    $row->Button(-text => 'QR',
                 -command => \&_show_qr_from_pick)
        ->pack(-side => 'left', -padx => 2);
    # Insert the QR as UTF8 block art into the body. The recipient
    # sees the QR itself in-line and can scan it off their screen —
    # useful when the chat surface doesn't hyperlink WIFI: URIs the
    # way BitChat does. Complements plain URI insert (browsecmd) and
    # the Toplevel view (QR button).
    $row->Button(-text => 'Insert QR',
                 -command => \&_insert_qr_from_pick)
        ->pack(-side => 'left', -padx => 2);
    # Launcher for nm-connection-editor. Some remoting stacks (RDP)
    # don't paint the system-tray NM applet; letting the operator open
    # the editor directly from here sidesteps that. Detached so
    # closing the GUI doesn't take the editor with it.
    $row->Button(-text => 'Edit Connections...',
                 -command => \&_launch_nm_connection_editor)
        ->pack(-side => 'left', -padx => 2);
    # Manual re-enum after the operator adds a WiFi in NM. We don't
    # try to poll the editor's exit — spawning detached means we
    # can't easily know when it's done. One click is cheap.
    $row->Button(-text => 'Refresh',
                 -command => sub { load_shared_wifi(); build_editor_form(); })
        ->pack(-side => 'left', -padx => 2);
    # Sudo-elevated PSK fetch. Only meaningful when we already know
    # the current uid can't read the NM keyfiles ($_NM_UNREADABLE
    # gets set by _enum_nm_profiles when the dir is present but
    # individual .nmconnection files are 0600 root:root). Uses
    # pkexec so a polkit agent renders the auth prompt over X —
    # sudo would need a TTY we can't offer from Tk.
    if ($_NM_UNREADABLE) {
        $row->Button(-text => 'Fetch PSKs (sudo)',
                     -command => \&_pkexec_fetch_psks)
            ->pack(-side => 'left', -padx => 2);
    }
}

# Resolve the picked entry, render its WIFI: URI as a QR code PNG
# via qrencode, and pop a Toplevel showing the image + the raw URI
# beneath it (so the operator can also copy the URI, and so a
# recipient without a scanner can still see the SSID/PSK). Requires
# qrencode in PATH — shows a dnf/apt hint if absent.
sub _resolve_wifi_uri_for_qr {
    # Body-first, picker-fallback. Returns (uri, entry) or ().
    # Entry is a full %SHARED_WIFI hash on the picker path and a
    # minimal { ssid => ... } stub on the body path (no PSK is
    # available or needed once we have the URI verbatim).
    my $uri;
    my $ssid_from_body;
    if (my $t = $E{_multi}{body}) {
        my $body = $t->get('1.0', 'end-1c');
        if ($body =~ /(WIFI:.*?;;)/) {
            $uri = $1;
            ($ssid_from_body) = $uri =~ /S:([^;]*)/;
        }
    }
    if (!defined $uri) {
        my (undef, $entry) = _resolve_picked_wifi();
        return () unless $entry;
        return (_wifi_uri($entry), $entry);
    }
    return ($uri, {
        ssid => (length($ssid_from_body // '')
                 ? $ssid_from_body : '(from body)'),
    });
}

sub _show_qr_from_pick {
    my ($uri, $entry) = _resolve_wifi_uri_for_qr();
    return unless defined $uri;
    my $qrencode;
    for my $cand (qw(/usr/bin/qrencode /usr/local/bin/qrencode)) {
        if (-x $cand) { $qrencode = $cand; last }
    }
    if (!$qrencode) {
        chomp(my $path = `command -v qrencode 2>/dev/null`);
        $qrencode = $path if length $path && -x $path;
    }
    if (!$qrencode) {
        _msg('qrencode not found',
             "Install libqrencode's CLI:\n"
           . "  sudo dnf install qrencode\n"
           . "  sudo apt install qrencode");
        return;
    }
    require File::Temp;
    my ($fh, $png) = File::Temp::tempfile(
        'wifi-qr-XXXXXX', SUFFIX => '.png', TMPDIR => 1, UNLINK => 0);
    close $fh;
    # -s 8: pixel size per module — 8 gives a comfortably scannable
    # ~300px block for typical SSID+PSK URIs. -m 4: quiet zone
    # margin, spec-required for reliable decoding. -l M: medium ECC
    # (balance of size and robustness against camera distortion).
    my @cmd = ($qrencode, '-t', 'PNG', '-s', '8', '-m', '4',
               '-l', 'M', '-o', $png, $uri);
    my $rc = system { $cmd[0] } @cmd;
    if ($rc != 0) {
        _msg('qrencode failed',
             "qrencode exited $rc.\nURI: $uri");
        unlink $png;
        return;
    }
    _show_qr_toplevel($png, $uri, $entry);
}

# Replace the body content with a UTF8 block-character QR of the
# resolved URI. Recipient scans it off their screen — useful when
# the chat surface doesn't render WIFI: URIs as click-to-join.
# `qrencode -t UTF8` uses half-height block chars, so a typical
# WPA URI comes out ~13 rows x ~25 cols — comfortable for a chat
# message. `-m 2` gives a smaller quiet zone (2 modules) to keep
# the message compact; scanners still decode reliably.
sub _insert_qr_from_pick {
    my ($uri) = _resolve_wifi_uri_for_qr();
    return unless defined $uri;
    my $qrencode;
    for my $cand (qw(/usr/bin/qrencode /usr/local/bin/qrencode)) {
        if (-x $cand) { $qrencode = $cand; last }
    }
    if (!$qrencode) {
        chomp(my $path = `command -v qrencode 2>/dev/null`);
        $qrencode = $path if length $path && -x $path;
    }
    if (!$qrencode) {
        _msg('qrencode not found',
             "Install libqrencode's CLI:\n"
           . "  sudo dnf install qrencode\n"
           . "  sudo apt install qrencode");
        return;
    }
    # Piped-open with argv form so the URI is passed verbatim — no
    # shell metachar issues from `;` in the URI.
    my $qr = '';
    if (open my $ph, '-|', $qrencode, '-t', 'UTF8', '-m', '2',
                                       '-l', 'M', '--', $uri) {
        local $/ = undef;
        $qr = <$ph>;
        close $ph;
    }
    if (!length $qr) {
        _msg('QR render failed',
             "qrencode -t UTF8 produced no output.\nURI: $uri");
        return;
    }
    # Trim trailing newline so the block sits flush with what we
    # append below.
    $qr =~ s/\n\z//;
    # Parse the WIFI: URI back into fields so we can append the
    # cleartext SSID + password below the block — a recipient whose
    # camera can't scan (or who's on a text-only surface) still gets
    # a usable credential. Parser respects `\;` / `\\` escaping.
    my (%kv);
    if ($uri =~ /^WIFI:(.+);;\z/) {
        my $inner = $1;
        my ($cur, $esc) = ('', 0);
        my @fields;
        for my $c (split //, $inner) {
            if ($esc)         { $cur .= $c; $esc = 0 }
            elsif ($c eq '\\'){ $esc = 1 }
            elsif ($c eq ';') { push @fields, $cur; $cur = '' }
            else              { $cur .= $c }
        }
        push @fields, $cur if length $cur;
        for my $f (@fields) {
            if ($f =~ /^([A-Z]):(.*)\z/) { $kv{$1} = $2 }
        }
    }
    my $ssid = $kv{S} // '';
    my $pass = $kv{P} // '';
    my @tail;
    push @tail, "SSID: $ssid"     if length $ssid;
    push @tail, "password: $pass" if length $pass;
    my $insert = $qr;
    $insert .= "\n" . join("\n", @tail) if @tail;
    my $t = $E{_multi}{body} or return;
    my $body = $t->get('1.0', 'end-1c');
    # Same replace-in-place / selection-replace / cursor-insert
    # precedence as _wifi_insert_from_pick. When the body already
    # contains a WIFI: URI, swap it out — subsequent Insert-QR
    # clicks re-insert at cursor (no cheap way to detect a prior
    # QR block for replacement).
    if ($body =~ /WIFI:.*?;;/) {
        (my $new = $body) =~ s/WIFI:.*?;;/$insert/;
        $t->delete('1.0', 'end');
        $t->insert('1.0', $new);
    } else {
        my @sel = $t->tagRanges('sel');
        if (@sel) {
            $t->delete($sel[0], $sel[1]);
            $t->insert($sel[0], $insert);
        } else {
            $t->insert('insert', $insert);
        }
    }
    $E{fields}{body} = $t->get('1.0', 'end-1c');
    $t->focus;
}

# Pop a Toplevel with the QR PNG at native size, the SSID label, and
# the WIFI: URI in a read-only Entry (selectable / copy-able). Cleans
# up the temp PNG on window destroy.
sub _show_qr_toplevel {
    my ($png, $uri, $entry) = @_;
    my $ssid = $entry->{ssid} // '?';
    my $dlg = $mw->Toplevel(-title => "QR: $ssid");
    $dlg->transient($mw);
    my $img;
    eval {
        # Tk::Photo needs the PNG image type. Modern perl-Tk (>=804)
        # ships PNG support built-in; older builds may need Tk::PNG.
        require Tk::PNG;
        $img = $dlg->Photo(-file => $png, -format => 'png');
        1;
    } or do {
        # If PNG loading fails at runtime, fall back to a text-mode
        # QR via qrencode -t UTF8 so the operator can still get the
        # code without the image widget.
        $dlg->destroy;
        _show_qr_text($uri, $entry);
        unlink $png;
        return;
    };
    $dlg->Label(-image => $img)->pack(-padx => 8, -pady => 8);
    $dlg->Label(-text => "SSID: $ssid", -font => '{Helvetica} 10 bold')
        ->pack(-anchor => 'w', -padx => 8);
    my $urow = $dlg->Frame->pack(-fill => 'x', -padx => 8, -pady => 4);
    $urow->Label(-text => 'URI:')->pack(-side => 'left');
    my $ue = $urow->Entry(-width => 60, -readonlybackground => 'white');
    $ue->pack(-side => 'left', -fill => 'x', -expand => 1, -padx => 4);
    $ue->insert(0, $uri);
    $ue->configure(-state => 'readonly');
    my $bar = $dlg->Frame->pack(-fill => 'x', -pady => 6);
    $bar->Button(-text => 'Close', -width => 8,
                 -command => sub { $dlg->destroy })
        ->pack(-side => 'right', -padx => 4);
    $dlg->bind('<Escape>', sub { $dlg->destroy });
    # Cleanup temp file when window closes. The image ref must be
    # retained (via the Label) so we can unlink AFTER destroy.
    $dlg->OnDestroy(sub { unlink $png });
}

# Fallback for hosts whose Tk::Photo can't render PNG: qrencode's
# UTF8 output in a monospace ROText widget. Works over ssh -Y even
# on ancient Tk builds.
sub _show_qr_text {
    my ($uri, $entry) = @_;
    my $ssid = $entry->{ssid} // '?';
    chomp(my $utf8 = `qrencode -t UTF8 -m 2 -l M -- \Q$uri\E 2>/dev/null`);
    if (!length $utf8) {
        _msg('QR render failed',
             "qrencode -t UTF8 produced no output.\nURI: $uri");
        return;
    }
    my $dlg = $mw->Toplevel(-title => "QR: $ssid");
    $dlg->transient($mw);
    my $t = $dlg->Scrolled('ROText',
        -scrollbars => 'osoe', -font => '{Monospace} 9',
        -width => 60, -height => 34)->pack(-fill => 'both', -expand => 1);
    $t->insert('end', $utf8);
    $dlg->Label(-text => "SSID: $ssid")->pack(-anchor => 'w', -padx => 8);
    $dlg->Button(-text => 'Close', -command => sub { $dlg->destroy })
        ->pack(-side => 'right', -padx => 6, -pady => 6);
    $dlg->bind('<Escape>', sub { $dlg->destroy });
}

# Manual-entry fallback when pkexec was cancelled / unavailable /
# the profile is genuinely PSK-less. Prompts for SSID + auth + PSK
# and returns a %SHARED_WIFI-shaped hashref, or undef on Cancel.
# The SSID prefills from the nmcli-known entry when we have one so
# the operator only actually types the PSK.
sub _prompt_wifi_credential {
    my ($seed) = @_;
    my $ssid = $seed && length($seed->{ssid} // '') ? $seed->{ssid} : '';
    my $auth = 'WPA';
    my $psk  = '';

    my $dlg = $mw->Toplevel(-title => 'Enter WiFi credential');
    $dlg->transient($mw);
    $dlg->grab();

    my $frm = $dlg->Frame->pack(-fill => 'x', -padx => 8, -pady => 6);
    $frm->Label(-text => "PSK not readable — enter it manually.\n"
                       . "The URI is built from these fields.",
                -justify => 'left')
        ->pack(-side => 'top', -anchor => 'w', -pady => 4);

    my $mkrow = sub {
        my ($label_text, $var_ref, $show) = @_;
        my $r = $frm->Frame->pack(-side => 'top', -fill => 'x', -pady => 2);
        $r->Label(-text => $label_text, -width => 10, -anchor => 'w')
          ->pack(-side => 'left');
        my $e = $r->Entry(-textvariable => $var_ref, -width => 32);
        $e->configure(-show => '*') if $show;
        $e->pack(-side => 'left', -fill => 'x', -expand => 1, -padx => 4);
        return $e;
    };
    $mkrow->('SSID:',   \$ssid, 0);
    my $auth_row = $frm->Frame->pack(-side => 'top', -fill => 'x', -pady => 2);
    $auth_row->Label(-text => 'Auth:', -width => 10, -anchor => 'w')
             ->pack(-side => 'left');
    $auth_row->Optionmenu(
        -variable => \$auth,
        -options  => [ [ 'WPA'    => 'WPA' ],
                       [ 'WPA2'   => 'WPA2' ],
                       [ 'WEP'    => 'WEP' ],
                       [ 'nopass' => 'NOPASS' ] ],
    )->pack(-side => 'left');
    my $psk_entry = $mkrow->('PSK:', \$psk, 1);
    $psk_entry->focus();

    my $ok = 0;
    my $bar = $dlg->Frame->pack(-side => 'top', -fill => 'x', -pady => 6);
    $bar->Button(-text => 'OK', -width => 8,
                 -command => sub { $ok = 1; $dlg->destroy })
        ->pack(-side => 'right', -padx => 4);
    $bar->Button(-text => 'Cancel', -width => 8,
                 -command => sub { $ok = 0; $dlg->destroy })
        ->pack(-side => 'right', -padx => 4);
    # Enter = OK, Escape = Cancel.
    $dlg->bind('<Return>', sub { $ok = 1; $dlg->destroy });
    $dlg->bind('<Escape>', sub { $ok = 0; $dlg->destroy });

    $dlg->waitWindow;

    return undef unless $ok;
    return undef unless length $ssid;
    return undef if $auth ne 'NOPASS' && !length $psk;
    return {
        ssid     => $ssid,
        auth     => $auth,
        password => $psk,
        hidden   => '',
        note     => '',
        source   => 'manual',
    };
}

# Elevate via pkexec to read NM keyfiles as root, extract PSKs, and
# fold them into %SHARED_WIFI. Ends with a build_editor_form() so
# the picker rebuilds with PSK-bearing entries (source flips from
# nm-nopsk → nm and the `[NM no PSK]` marker becomes plain `[NM]`).
sub _pkexec_fetch_psks {
    my $pkexec = -x '/usr/bin/pkexec' ? '/usr/bin/pkexec'
               : -x '/usr/local/bin/pkexec' ? '/usr/local/bin/pkexec'
               : undef;
    if (!$pkexec) {
        _msg('pkexec not found',
             "Install polkit (dnf install polkit / apt install policykit-1)\n"
           . "or relaunch: sudo net-chat-autoresponder --gui");
        return;
    }
    # One shell invocation dumps every .nmconnection with a marker so
    # a single polkit prompt covers the whole set. `sh -c` because
    # pkexec doesn't do shell globbing on its own argv.
    my $reader = q{
        for f in /etc/NetworkManager/system-connections/*.nmconnection; do
            [ -f "$f" ] || continue
            echo "===FILE=== $(basename "$f")"
            cat "$f"
            echo "===END==="
        done
    };
    my $pid = open(my $ph, '-|');
    if (!defined $pid) {
        _msg('fork failed', "Could not spawn pkexec: $!");
        return;
    }
    if ($pid == 0) {
        open STDERR, '>&', \*STDOUT;   # so polkit-refused shows in $out
        { exec { $pkexec } $pkexec, '/bin/sh', '-c', $reader };
        POSIX::_exit(127);
    }
    local $/ = undef;
    my $out = <$ph>;
    close $ph;
    my $rc = $? >> 8;
    if ($rc != 0) {
        _msg('pkexec fetch failed',
             "pkexec exited $rc.\n"
           . "Auth was cancelled, or polkit isn't configured to allow\n"
           . "this action. Relaunch with sudo instead:\n"
           . "  sudo net-chat-autoresponder --gui\n\n"
           . ($out // ''));
        return;
    }
    # Parse the marker-delimited dump into a sequence of {file, ini}
    # blocks and reuse the same wifi-type/psk extraction as
    # _enum_nm_profiles's inner loop. Building a fresh %nm here rather
    # than delegating keeps the pkexec dependency contained to this sub.
    my $merged = 0;
    my $cur_name = '';
    my (%ini, $sect);
    my $flush = sub {
        return unless length $cur_name;
        return unless ($ini{connection}{type} // '') eq 'wifi';
        my $ssid = $ini{wifi}{ssid};
        return unless defined $ssid && length $ssid;
        my $km   = lc($ini{'wifi-security'}{'key-mgmt'} // '');
        my $psk  = $ini{'wifi-security'}{psk} // '';
        my $auth = ($km eq '' || $km eq 'none') ? 'NOPASS'
                 : $km eq 'wep'                 ? 'WEP'
                 :                                'WPA';
        return if $auth ne 'NOPASS' && !length $psk;
        my $id = $ini{connection}{id};
        if (!defined $id || !length $id) {
            ($id = $cur_name) =~ s/\.nmconnection\z//;
        }
        my $label = $id;
        $label =~ s/[^A-Za-z0-9._-]/-/g;
        # Overwrite whatever we had for this label — the pkexec pass
        # is authoritative (it has PSKs).
        $SHARED_WIFI{$label} = {
            ssid     => $ssid,
            auth     => $auth,
            password => $psk,
            hidden   => (($ini{wifi}{hidden} // '') =~ /^(1|true|yes)$/i
                        ? 'true' : ''),
            note     => '',
            source   => 'nm',
        };
        push @SHARED_WIFI_LABELS, $label
            unless grep { $_ eq $label } @SHARED_WIFI_LABELS;
        $merged++;
    };
    for my $ln (split /\n/, ($out // '')) {
        if ($ln =~ /^===FILE=== (.+?)\s*$/) {
            $flush->();
            $cur_name = $1;
            %ini = ();
            $sect = '';
            next;
        }
        next if $ln =~ /^===END===/;
        $ln =~ s/^\s+//;
        next if $ln eq '' || $ln =~ /^[#;]/;
        if ($ln =~ /^\[([^\]]+)\]\s*$/) {
            $sect = lc $1;
            next;
        }
        next unless length $sect;
        if ($ln =~ /^([^=]+?)\s*=\s*(.*)$/) {
            $ini{$sect}{lc $1} = $2;
        }
    }
    $flush->();
    # Rebuild %DISPLAY_TO_LABEL from scratch — labels' source may
    # have flipped (nm-nopsk → nm) and the marker in the display
    # string tracks source.
    %DISPLAY_TO_LABEL = ();
    for my $label (@SHARED_WIFI_LABELS) {
        my $entry = $SHARED_WIFI{$label} or next;
        my $ssid  = $entry->{ssid} // '?';
        my $src   = $entry->{source} // '';
        my $disp  = "$label ($ssid)";
        $disp .= ' [NM]'         if $src eq 'nm';
        $disp .= ' [NM no PSK]'  if $src eq 'nm-nopsk';
        $DISPLAY_TO_LABEL{$disp} = $label;
    }
    # After a successful fetch we're no longer in the "unreadable"
    # state — the Fetch button hides itself on the next rebuild.
    $_NM_UNREADABLE = 0;
    build_editor_form();
    _msg('Fetch complete', "Merged $merged NM profiles with PSKs.");
}

# Fork+exec nm-connection-editor so it survives past the GUI. If the
# binary isn't installed, show a messageBox pointing at the package.
sub _launch_nm_connection_editor {
    my $bin;
    for my $cand (qw(/usr/bin/nm-connection-editor
                     /usr/local/bin/nm-connection-editor)) {
        if (-x $cand) { $bin = $cand; last }
    }
    if (!$bin) {
        chomp(my $path = `command -v nm-connection-editor 2>/dev/null`);
        $bin = $path if length $path && -x $path;
    }
    if (!$bin) {
        _msg('nm-connection-editor not found',
             "Install it with: sudo dnf install nm-connection-editor\n"
           . "(or apt install network-manager-gnome)");
        return;
    }
    my $pid = fork();
    if (!defined $pid) {
        _msg('fork failed', "Could not launch $bin: $!");
        return;
    }
    if ($pid == 0) {
        # Child: detach from GUI's controlling tty and exec.
        POSIX::setsid();
        open STDIN,  '<', '/dev/null';
        open STDOUT, '>', '/dev/null';
        open STDERR, '>', '/dev/null';
        { exec { $bin } $bin };
        POSIX::_exit(127);
    }
    # Parent: reap the immediate double-forked descendant so we don't
    # accumulate a zombie. nm-connection-editor itself re-daemonizes,
    # so waitpid returns quickly once the setsid child has exec'd and
    # the editor forks off. Non-blocking so we never hang the GUI.
    $mw->after(500, sub { waitpid($pid, POSIX::WNOHANG()) });
}

# Resolve the current picker selection to a %SHARED_WIFI entry with a
# usable PSK. Handles nm-nopsk -> pkexec -> manual-entry cascade.
# Returns (label, entry) or () on abort / hint-item / empty pick.
sub _resolve_picked_wifi {
    my $disp  = $E{fields}{_wifi_pick} // '';
    return () unless length $disp;
    my $label = $DISPLAY_TO_LABEL{$disp};
    return () unless defined $label;
    my $entry = $SHARED_WIFI{$label} or return ();
    if (($entry->{source} // '') eq 'nm-nopsk') {
        _pkexec_fetch_psks();
        $entry = $SHARED_WIFI{$label};
        if (!$entry || ($entry->{source} // '') eq 'nm-nopsk'
                    || !length($entry->{password} // '')) {
            my $manual = _prompt_wifi_credential($entry);
            return () unless $manual;
            $entry = $manual;
            $SHARED_WIFI{$label} = $entry;
        }
    }
    return ($label, $entry);
}

# Look up the pick variable, resolve display → label, generate URI, and
# insert into the body Text at the cursor (or replace selection). No-op
# when the pick is the "(no shared-wifi.conf...)" hint or empty.
sub _wifi_insert_from_pick {
    my ($with_note) = @_;
    my (undef, $entry) = _resolve_picked_wifi();
    return unless $entry;
    my $text  = _wifi_uri($entry);
    if ($with_note && length($entry->{note} // '')) {
        $text .= "\n" . $entry->{note};
    }
    my $t = $E{_multi}{body} or return;
    # Precedence:
    #   1. If the body already contains a `WIFI:...;;` URI (e.g. the
    #      operator loaded a rule with the sample body or a stale
    #      pick), REPLACE that URI in place. This is what "Insert
    #      again with a different network" almost always means, and
    #      it's what makes a fresh-out-of-the-sample rule work
    #      without hand-deleting the placeholder URI.
    #   2. Else if there's a selection, replace it.
    #   3. Else insert at the cursor.
    # WIFI: URIs terminate with `;;` per the QR spec — that's the
    # anchor for the regex. Non-greedy so we don't slurp trailing
    # notes on the same line.
    my $body = $t->get('1.0', 'end-1c');
    if ($body =~ /WIFI:.*?;;/) {
        (my $new = $body) =~ s/WIFI:.*?;;/$text/;
        $t->delete('1.0', 'end');
        $t->insert('1.0', $new);
    } else {
        my @sel = $t->tagRanges('sel');
        if (@sel) {
            $t->delete($sel[0], $sel[1]);
            $t->insert($sel[0], $text);
        } else {
            $t->insert('insert', $text);
        }
    }
    # Sync scalar so save picks it up without waiting for a KeyRelease.
    $E{fields}{body} = $t->get('1.0', 'end-1c');
    $t->focus;
}

# Build a WIFI: QR-code URI from a shared-wifi entry hashref. Field order
# and escape set match net-bitchat-bridge:531-534 so QR readers parse a
# GUI-inserted URI identically to the wifi-onramp DM. auth values other
# than nopass emit ;P:<pass>; auth=nopass omits P: entirely — what QR
# readers expect for open networks. hidden=true adds ;H:true;.
sub _wifi_uri {
    my ($entry) = @_;
    my $ssid   = $entry->{ssid}     // '';
    my $auth   = uc($entry->{auth}  // 'WPA');
    my $pass   = $entry->{password} // '';
    my $hidden = ($entry->{hidden}  // '') =~ /^(1|true|yes)$/i;
    my $uri = 'WIFI:T:' . $auth
            . ';S:' . _wifi_esc($ssid);
    $uri .= ';P:' . _wifi_esc($pass) if $auth ne 'NOPASS';
    $uri .= ';H:true' if $hidden;
    $uri .= ';;';
    return $uri;
}

# Escape the five WIFI: URI reserved characters, matching the closure at
# net-bitchat-bridge:531-533 exactly so operators can't tell whether a
# body came from the bridge onramp or the GUI picker.
sub _wifi_esc {
    my $s = shift // '';
    $s =~ s/([\\;,"'])/\\$1/g;
    return $s;
}

# Slurp /etc/net-mgr/shared-wifi.conf (+ shared-wifi.d/*.conf overlays)
# via NetMgr::Config's built-in overlay loader — same code path the main
# daemon uses for its own overlays, so operators only learn one story.
# Section names are lowercased by the loader, so LABEL casing is folded
# — that's fine, labels are just picker keys. Missing file / parse
# failure is non-fatal: we still fall through to the NetworkManager
# keyfile enumeration below; only if BOTH sources come up empty does
# the picker render the "no shared-wifi.conf" hint.
#
# Curated entries carry source => 'shared-wifi.conf'; NM-discovered
# entries carry source => 'nm' and win the display suffix " [NM]" so
# operators can tell at a glance whether a pick came from operator
# intent or from a saved system connection. On label collision the
# curated entry wins — operator intent trumps whatever nmcli stored.
sub load_shared_wifi {
    %SHARED_WIFI       = ();
    @SHARED_WIFI_LABELS = ();
    %DISPLAY_TO_LABEL   = ();
    my $has_primary = -e $SHARED_WIFI_CONF;
    (my $dotd = $SHARED_WIFI_CONF) =~ s/\.conf$/.d/;
    my $has_overlay = 0;
    if (-d $dotd && opendir(my $dh, $dotd)) {
        my @f = grep { /\.conf$/ } readdir $dh;
        closedir $dh;
        $has_overlay = scalar @f;
    }

    if ($has_primary || $has_overlay) {
        my $cfg = eval { NetMgr::Config->load($SHARED_WIFI_CONF) };
        if ($@ || !$cfg) {
            my $err = $@ || 'unknown';
            chomp $err;
            warn "[shared-wifi] parse failed: $err\n";
        } else {
            for my $section (sort keys %$cfg) {
                next unless $section =~ /^wifi\.(.+)$/;
                my $label = $1;
                my $entry = $cfg->{$section};
                next unless ref $entry eq 'HASH';
                next unless defined $entry->{ssid} && length $entry->{ssid};
                $SHARED_WIFI{$label} = {
                    ssid     => $entry->{ssid},
                    auth     => $entry->{auth}     // 'WPA',
                    password => $entry->{password} // '',
                    hidden   => $entry->{hidden}   // '',
                    note     => $entry->{note}     // '',
                    source   => 'shared-wifi.conf',
                };
                push @SHARED_WIFI_LABELS, $label;
                my $disp = "$label ($entry->{ssid})";
                $DISPLAY_TO_LABEL{$disp} = $label;
            }
        }
    }

    # Merge NM-discovered profiles. Curated labels already registered
    # above are left untouched — the collision-loser is skipped with a
    # debug-level warn so an operator wondering why their favourite
    # nmcli connection didn't show up has a breadcrumb.
    my %nm = _enum_nm_profiles();
    for my $label (sort keys %nm) {
        if (exists $SHARED_WIFI{$label}) {
            warn "[shared-wifi] NM label '$label' collides with curated — keeping curated\n";
            next;
        }
        $SHARED_WIFI{$label} = $nm{$label};
        push @SHARED_WIFI_LABELS, $label;
        my $ssid = $nm{$label}{ssid};
        my $src  = $nm{$label}{source} // 'nm';
        my $disp = "$label ($ssid)";
        $disp .= ' [NM]'         if $src eq 'nm';
        $disp .= ' [NM no PSK]'  if $src eq 'nm-nopsk';
        $DISPLAY_TO_LABEL{$disp} = $label;
    }
}

# (Both $_NM_KEYFILE_WARNED and $_NM_UNREADABLE are declared at the top
# of the package next to the other GUI-state 'our' vars, so
# row_shared_wifi can consult them without a forward-declare issue.)

# Enumerate /etc/NetworkManager/system-connections/*.nmconnection and
# turn each wifi profile into a shared-wifi entry hashref. Keyfiles
# are 0600 root:root, so an unprivileged GUI process just gets ENOENT
# / EACCES and quietly returns nothing (with a one-shot stderr hint,
# so an operator running as their own uid has a breadcrumb to explain
# the empty picker).
#
# Grammar is the NetworkManager INI dialect: [section]s with
# key=value lines, blanks/comments allowed. We hand-parse rather than
# reuse NetMgr::Config because its overlay/lowercasing semantics are
# unwanted here and each keyfile is a single flat file.
#
# Returned entries wear source => 'nm' so the picker can suffix the
# display string with " [NM]" and load_shared_wifi() can distinguish
# them from curated entries when applying the collision policy.
sub _enum_nm_profiles {
    my $dir = '/etc/NetworkManager/system-connections';
    my $dh;
    if (!opendir($dh, $dir)) {
        # Directory itself unreadable (or missing) — nothing to do.
        # Not worth warning: this fires on every non-NM host too.
        return ();
    }
    my @files = sort grep { /\.nmconnection\z/ } readdir $dh;
    closedir $dh;

    my %out;
    my $unreadable = 0;
    for my $name (@files) {
        my $path = "$dir/$name";
        my $fh;
        if (!open($fh, '<', $path)) {
            # Individual file unreadable — almost always EACCES because
            # we're not root. Count it so we can warn once at the end.
            $unreadable++;
            next;
        }
        my %ini;
        my $sect = '';
        while (my $ln = <$fh>) {
            $ln =~ s/\r?\n\z//;
            $ln =~ s/^\s+//;
            next if $ln eq '' || $ln =~ /^[#;]/;
            if ($ln =~ /^\[([^\]]+)\]\s*$/) {
                $sect = lc $1;
                next;
            }
            next unless length $sect;
            if ($ln =~ /^([^=]+?)\s*=\s*(.*)$/) {
                my ($k, $v) = (lc $1, $2);
                $ini{$sect}{$k} = $v;
            }
        }
        close $fh;

        next unless ($ini{connection}{type} // '') eq 'wifi';
        my $ssid = $ini{wifi}{ssid};
        next unless defined $ssid && length $ssid;

        # NetworkManager key-mgmt vocabulary → WIFI: URI auth token.
        # Missing/empty section means an open network (no security).
        my $km   = lc($ini{'wifi-security'}{'key-mgmt'} // '');
        my $psk  = $ini{'wifi-security'}{psk} // '';
        my $auth;
        if ($km eq '' || $km eq 'none') {
            $auth = 'NOPASS';
        } elsif ($km eq 'wep') {
            $auth = 'WEP';
        } else {
            # wpa-psk, sae, wpa-eap, ... — treat as WPA family. WPA-EAP
            # won't actually work as a QR handoff but we don't have a
            # better token for it and refusing would surprise the user.
            $auth = 'WPA';
        }
        # A PSK-guarded profile with no stored PSK is useless as a
        # QR handoff (nothing to hand off) — skip it.
        next if $auth ne 'NOPASS' && !length $psk;

        # Prefer [connection].id (what nmcli prints) over the filename
        # stem; fall back to stem if id is missing.
        my $id = $ini{connection}{id};
        if (!defined $id || !length $id) {
            ($id = $name) =~ s/\.nmconnection\z//;
        }
        my $label = $id;
        $label =~ s/[^A-Za-z0-9._-]/-/g;
        # De-dup labels within the NM set (two profiles with names
        # that sanitize to the same string): suffix -1, -2, ...
        my $base = $label;
        my $n = 1;
        while (exists $out{$label}) {
            $label = "$base-$n";
            $n++;
        }
        $out{$label} = {
            ssid     => $ssid,
            auth     => $auth,
            password => $psk,
            hidden   => (($ini{wifi}{hidden} // '') =~ /^(1|true|yes)$/i
                        ? 'true' : ''),
            note     => '',
            source   => 'nm',
        };
    }

    $_NM_UNREADABLE = 1 if $unreadable && !%out;
    if ($unreadable && !$_NM_KEYFILE_WARNED) {
        $_NM_KEYFILE_WARNED = 1;
        warn "[gui] NM keyfiles unreadable, skipping auto-populate "
           . "(run as root to see saved connections)\n";
    }

    # Fallback: even when keyfiles are unreadable at this uid, nmcli
    # talks to NetworkManager over DBus and can enumerate connection
    # NAMES + SSIDs (getting PSKs requires --show-secrets which polkit
    # gates — omitted here). Names alone let the operator SEE their
    # networks and know sudo would unlock the PSKs.
    if (!%out) {
        my $nmcli = -x '/usr/bin/nmcli' ? '/usr/bin/nmcli'
                  : -x '/usr/local/bin/nmcli' ? '/usr/local/bin/nmcli'
                  : undef;
        if ($nmcli) {
            # `-t` terse output, `:` field sep, `-e no` no escapes. We
            # ask for name+type+uuid so we can filter to wifi rows.
            open(my $ph, '-|', $nmcli, '-t', '-f', 'name,type', 'c', 'show')
                or return %out;
            while (my $ln = <$ph>) {
                chomp $ln;
                # nmcli terse output escapes `:` in field values as `\:`.
                # Split on unescaped `:` and undo the escape after.
                my @f = split /(?<!\\):/, $ln, 2;
                my ($name, $type) = @f;
                for ($name, $type) { defined and s/\\:/:/g }
                next unless defined $type;
                # Type is `802-11-wireless` on older NM, plain `wifi` on
                # newer versions. Match either. Skip ethernet, bridge,
                # tun, vpn, gsm, etc.
                next unless $type =~ /(?:wireless|^wifi\z)/i;
                next unless length $name;
                my $label = $name;
                $label =~ s/[^A-Za-z0-9._-]/-/g;
                # Dedup vs. self (unlikely — nmcli returns unique names).
                my $base = $label; my $n = 1;
                while (exists $out{$label}) { $label = "$base-$n"; $n++ }
                $out{$label} = {
                    ssid     => $name,
                    auth     => 'WPA',
                    password => '',      # placeholder — polkit blocks
                    hidden   => '',
                    note     => '(needs sudo for PSK)',
                    source   => 'nm-nopsk',
                };
            }
            close $ph;
            $_NM_UNREADABLE = 1 if %out;
        }
    }
    return %out;
}

sub load_editor_from_rule {
    my ($r) = @_;
    # Reset field storage; parse the (possibly comma-separated) trigger
    # string from the rule into $E{trigger_set} so build_editor_form
    # renders the right per-trigger sections. A legacy single-value
    # rule like `trigger = periodic` parses to a one-element set.
    $E{fields} = {};
    $E{trigger_set} = { map { $_ => 0 }
                            qw(bitchat_peer_first_seen chat_message periodic) };
    my $raw_trigger = $r->{kv}{trigger} // '';
    for my $t (grep { length }
               map  { s/^\s+|\s+$//gr }
               split /,/, $raw_trigger)
    {
        $E{trigger_set}{$t} = 1 if exists $E{trigger_set}{$t};
    }
    # Pre-seed channel so build_editor_form picks the right Target
    # widget shape (BrowseEntry when chat_post, plain Entry otherwise)
    # before the post-build population loop runs.
    $E{fields}{channel} = $r->{kv}{channel} if defined $r->{kv}{channel};
    build_editor_form();
    # Re-sync $E{fields}{trigger} in case the load parsed to something
    # slightly different than the raw INI value (whitespace, order).
    _sync_trigger_field();
    # After build, populate every field from $r->{kv} (unknown keys are
    # silently discarded when the trigger changes and their widget goes
    # away — that's fine, save only serialises known keys).
    $E{fields}{name} = $r->{name};
    for my $k (keys %{$r->{kv}}) {
        next if $k eq 'name';
        if (exists $E{fields}{$k}) {
            $E{fields}{$k} = $r->{kv}{$k};
        }
    }
    # Body sits in a Text widget, not a scalar-bound Entry — sync it.
    if (my $t = $E{_multi}{body}) {
        $t->delete('1.0', 'end');
        $t->insert('end', $r->{kv}{body} // '');
        $E{fields}{body} = $r->{kv}{body} // '';
    }
    $E{source_label}->configure(
        -text => "Source file: $r->{source}"
               . (defined $r->{start_ln}
                    ? sprintf("  (lines %d-%d)",
                              $r->{start_ln}+1, ($r->{end_ln}//$r->{start_ln})+1)
                    : "  (unsaved)"),
    );
    update_save_state();
}

sub clear_editor {
    $E{fields} = {};
    $E{trigger} = '';
    $E{trigger_set} = { map { $_ => 0 }
                            qw(bitchat_peer_first_seen chat_message periodic) };
    build_editor_form();
}

sub editor_kv_dump {
    my %kv;
    # Sync the Text-backed 'body' widget one more time in case the
    # trailing KeyRelease didn't fire.
    if (my $t = $E{_multi}{body}) {
        $E{fields}{body} = $t->get('1.0', 'end-1c');
    }
    # Re-derive $E{fields}{trigger} from the checkbox state — no widget
    # KeyRelease drives this, so we sync unconditionally at dump time.
    _sync_trigger_field();
    for my $k (keys %{ $E{fields} }) {
        next if $k eq 'name';
        # UI-only scratch fields (underscore-prefixed) never make it
        # into a rule kv — e.g. the Share-WiFi picker's _wifi_pick
        # holds the display string, not something the daemon reads.
        next if $k =~ /^_/;
        my $v = $E{fields}{$k};
        next unless defined $v && length $v;
        $kv{$k} = $v;
    }
    # Rule NAME lives on $r->{name}; the editor's 'name' scalar
    # rewrites $r->{name} at save time — see do_save_rule / write_rule_back.
    return \%kv;
}

sub current_rule {
    return undef unless defined $S{sel_idx};
    return $S{rules}[ $S{sel_idx} ];
}

# ====================================================================
# File parsing + save-back
# ====================================================================

# Load order matches the daemon (load_config above): the primary file
# first, then <primary>.d/*.conf sorted. Primary that doesn't exist
# yet is fine — we're editing to create it.
sub overlay_paths {
    my ($primary) = @_;
    (my $overlay = $primary) =~ s/\.conf$//;
    $overlay .= '.d';
    my @paths;
    push @paths, $primary if -e $primary;
    if (-d $overlay) {
        opendir my $dh, $overlay or return @paths;
        push @paths, map { "$overlay/$_" }
                     sort grep { /\.conf$/ && !/^\./ } readdir $dh;
        closedir $dh;
    }
    return @paths;
}

sub slurp_lines {
    my ($path) = @_;
    open my $fh, '<', $path or return ();
    my @lines = <$fh>;
    close $fh;
    chomp @lines;
    return @lines;
}

# Extract every [rule.NAME] / disabled `; [rule.NAME]` section from
# @$lines and stash into $out{name}. Rule sections spans from their
# header line down to (but excluding) the next [section] header of any
# kind, or EOF. Trailing blank lines are trimmed off the range so
# save-back doesn't devour blank separators between rules.
sub parse_rules_from {
    my ($path, $lines, $out, $order) = @_;
    my @secs;
    my $cur;
    for (my $i = 0; $i <= $#$lines; $i++) {
        my $line = $lines->[$i];
        if ($line =~ /^\s*\[([^\]]+)\]\s*$/) {
            _finish_section($cur, $i - 1, $lines) if $cur;
            my $header = $1;
            if ($header =~ /^rule\.([A-Za-z][A-Za-z0-9._-]{0,31})$/) {
                $cur = { name => $1, enabled => 1, source => $path,
                         kv => {}, start_ln => $i };
                push @secs, $cur;
            } else {
                $cur = undef;
            }
            next;
        }
        if ($line =~ /^\s*[;#]\s*\[([^\]]+)\]\s*$/) {
            _finish_section($cur, $i - 1, $lines) if $cur;
            my $header = $1;
            if ($header =~ /^rule\.([A-Za-z][A-Za-z0-9._-]{0,31})$/) {
                $cur = { name => $1, enabled => 0, source => $path,
                         kv => {}, start_ln => $i };
                push @secs, $cur;
            } else {
                $cur = undef;
            }
            next;
        }
        next unless $cur;
        # Body kv accumulation. Disabled rules have every line prefixed
        # with '; ' by our writer, so match that shape for kv extraction.
        # Values are _ini_decode'd so encoded multi-line body= survives
        # the round-trip through the editor.
        if ($cur->{enabled}) {
            if ($line =~ /^\s*([\w.-]+)\s*=\s*(.*?)\s*$/) {
                $cur->{kv}{$1} = main::_ini_decode($2);
            }
        } else {
            if ($line =~ /^\s*[;#]\s*([\w.-]+)\s*=\s*(.*?)\s*$/) {
                $cur->{kv}{$1} //= main::_ini_decode($2);
            }
        }
    }
    _finish_section($cur, $#$lines, $lines) if $cur;
    for my $s (@secs) {
        my $name = $s->{name};
        push @$order, $name unless exists $out->{$name};
        # Last-write-wins (later overlay REPLACES earlier definition),
        # mirroring the daemon's load_config().
        $out->{$name} = $s;
    }
}

sub _finish_section {
    my ($sec, $end, $lines) = @_;
    return unless $sec;
    while ($end > $sec->{start_ln} && $lines->[$end] =~ /^\s*$/) {
        $end--;
    }
    $sec->{end_ln} = $end;
}

# Serialize a rule to file text. Header + key=value lines in a canonical
# order (mirrors the shape of the sample file so diffs stay readable).
sub render_rule {
    my ($r, $kv) = @_;
    my @out;
    my $prefix = $r->{enabled} ? '' : '; ';
    push @out, "$prefix\[rule.$r->{name}\]";
    my @order = qw(trigger session match from ack_target every mode
                   ack_key acked_ttl dedup_ttl channel target body);
    my %seen;
    for my $k (@order) {
        next unless exists $kv->{$k};
        my $v = $kv->{$k};
        next unless defined $v && length $v;
        $seen{$k} = 1;
        # _ini_encode turns any embedded newlines into `\n` literal so
        # multi-line values (e.g. Insert QR body) survive INI round-trip.
        # Decoder is _ini_decode in _load_ini + parse_rules_from.
        push @out, "$prefix$k = " . main::_ini_encode($v);
    }
    for my $k (sort keys %$kv) {
        next if $seen{$k};
        my $v = $kv->{$k};
        next unless defined $v && length $v;
        push @out, "$prefix$k = " . main::_ini_encode($v);
    }
    return @out;
}

# Copy-on-write remap for unprivileged Save: if the rule was loaded
# from a system-scoped path we can't write, mirror it into the
# user-scope equivalent so Save actually lands. Returns the (possibly
# remapped) path and mutates $r->{source} + $S{files} so subsequent
# operations stay in user scope.
sub _cow_source_for_write {
    my ($r) = @_;
    my $path = $r->{source};
    return $path if $> == 0;                             # root: keep /etc/
    return $path unless $path =~ m{^/etc/net-mgr/(.+)$}; # already user or --config
    my $tail = $1;
    my $user_dir = NetMgr::Config->user_config_dir();
    return $path unless defined $user_dir && length $user_dir;
    my $new = "$user_dir/$tail";
    # Mirror the parsed line list from the system-scope key so the
    # user-scope file gets the whole file content on first COW save
    # — otherwise we'd write out only the one edited rule and lose
    # every other rule in the file.
    if (exists $S{files}{$path} && !exists $S{files}{$new}) {
        $S{files}{$new} = [ @{ $S{files}{$path} } ];
    }
    # Rewrite in-memory source pointers on every rule that came from
    # this system path so their next Save also lands in user scope.
    for my $rule (@{ $S{rules} }) {
        $rule->{source} = $new if defined $rule->{source} && $rule->{source} eq $path;
    }
    # If this was the top-bar primary config file, retarget it too so
    # "Reload from disk" reads the user-scope file we just wrote and
    # the top-bar Entry reflects the actual authoritative path.
    if (defined $S{primary} && $S{primary} eq $path) {
        $S{primary} = $new;
        $file_var   = $new if defined $file_var;
    }
    set_status("saved to $new (shadowing system rule; overrides /etc/)");
    return $new;
}

# Replace an existing rule's line range (or append when start_ln
# undefined) with freshly-rendered content, then rewrite the file.
sub write_rule_back {
    my ($r, $kv) = @_;
    # Editor may have renamed the rule; keep $r->{name} in sync.
    if (defined $E{fields}{name} && length $E{fields}{name}
        && $E{fields}{name} =~ /^[A-Za-z][A-Za-z0-9._-]{0,31}$/)
    {
        $r->{name} = $E{fields}{name};
    }
    $r->{kv} = $kv;
    my $path  = _cow_source_for_write($r);
    my $lines = $S{files}{$path} //= [];
    my @new_body = render_rule($r, $kv);

    if (defined $r->{start_ln}) {
        my $start = $r->{start_ln};
        my $end   = $r->{end_ln} // $start;
        splice @$lines, $start, ($end - $start + 1), @new_body;
    } else {
        # Append; add a blank separator if the file isn't empty.
        push @$lines, '' if @$lines && $lines->[-1] ne '';
        push @$lines, @new_body;
    }
    write_file_atomic($path, $lines);
    # Full reparse of the file we touched so start_ln/end_ln stay valid
    # for the next edit. Reparsing every file would drop any yet-unsaved
    # edits on other rules — cheap and correct to only redo the one.
    reload_file($path);
    # Reload_file may have re-created the rule hash — find it by name
    # and re-select so the editor + list stay pointing at it.
    for my $i (0 .. $#{ $S{rules} }) {
        if ($S{rules}[$i]{name} eq $r->{name}
            && $S{rules}[$i]{source} eq $path)
        {
            $S{sel_idx} = $i;
            last;
        }
    }
}

sub delete_rule_from_file {
    my ($r) = @_;
    return unless defined $r->{start_ln};
    my $lines = $S{files}{ $r->{source} } or return;
    my $start = $r->{start_ln};
    my $end   = $r->{end_ln} // $start;
    # Also swallow a leading blank line so we don't leave a double-gap.
    if ($start > 0 && $lines->[$start-1] =~ /^\s*$/) {
        $start--;
    }
    splice @$lines, $start, ($end - $start + 1);
    write_file_atomic($r->{source}, $lines);
}

# Refresh %S{rules} for one file: reparse and merge back into the ordered
# list. Preserves rules from OTHER files unchanged.
sub reload_file {
    my ($path) = @_;
    my @lines = slurp_lines($path);
    $S{files}{$path} = \@lines;
    # Rebuild %S{rules} from all files (cheap; O(files*lines)).
    my %by_name; my @name_order;
    for my $p (@{$S{order}}) {
        my $ls = $S{files}{$p} // [];
        parse_rules_from($p, $ls, \%by_name, \@name_order);
    }
    $S{rules} = [ map { $by_name{$_} } @name_order ];
}

sub write_file_atomic {
    my ($path, $lines) = @_;
    my $dir = dirname($path);
    unless (-d $dir) {
        # Two callers: a .d/ overlay dir on a fresh install (single level
        # under an already-existing /etc/net-mgr/), and a user-scope Save
        # into $XDG_CONFIG_HOME/net-mgr/ where BOTH the ~/.config/ tree
        # and the net-mgr/ subdir may be absent. make_path handles either.
        require File::Path;
        my $err;
        File::Path::make_path($dir, { error => \$err });
        if (ref $err eq 'ARRAY' && @$err) {
            my ($first) = @$err;
            my (undef, $why) = %$first;
            return msg('mkdir failed', "make_path $dir: $why");
        }
    }
    my $tmp = "$path.tmp.$$";
    if (open my $fh, '>', $tmp) {
        print {$fh} join("\n", @$lines);
        print {$fh} "\n" if @$lines && $lines->[-1] ne '';
        close $fh or return msg('close failed', "close $tmp: $!");
    } else {
        return msg('open failed', "open $tmp: $!");
    }
    if (-e $path) {
        File::Copy::copy($path, "$path.bak")
            or warn "backup $path: $!";
    }
    rename $tmp, $path or return msg('rename failed', "rename $tmp: $!");
    return 1;
}

sub refresh_rules_list {
    $rules_list->delete(0, 'end');
    # Compact display forms — the full trigger names are 15-23 chars
    # each and multi-trigger rules blow past the 24-char column budget
    # instantly. The abbreviations still round-trip through the editor
    # unchanged because the underlying kv trigger= is the raw INI string.
    my %short = (bitchat_peer_first_seen => 'ble',
                 chat_message            => 'chat',
                 periodic                => 'periodic');
    for my $r (@{ $S{rules} }) {
        # 'on' / 'off' beats '[x]' / '[ ]' for legibility in a monospace
        # column — no confusion with regex character classes or the
        # optional-arg convention.
        my $mark = $r->{enabled} ? 'on ' : 'off';
        my $src  = basename( $r->{source} );
        my $trig = $r->{kv}{trigger} // '?';
        my @tlist = grep { length }
                    map  { s/^\s+|\s+$//gr }
                    split /,/, $trig;
        my $trig_disp = @tlist
                      ? join(',', map { $short{$_} // $_ } @tlist)
                      : '?';
        $rules_list->insert('end',
            sprintf("%s  %-20s %-24s %s", $mark, $r->{name}, $trig_disp, $src));
    }
}

sub reselect_current {
    return unless defined $S{sel_idx};
    $rules_list->selectionClear(0, 'end');
    $rules_list->selectionSet($S{sel_idx});
    load_editor_from_rule( $S{rules}[ $S{sel_idx} ] );
}

# ====================================================================
# Rule validation (cheap client-side; daemon re-validates)
# ====================================================================

sub validate_kv {
    my ($kv) = @_;
    my $trig_raw = $kv->{trigger} // '';
    my @trigs = grep { length }
                map  { s/^\s+|\s+$//gr }
                split /,/, $trig_raw;
    return "trigger= required" unless @trigs;
    my %valid = map { $_ => 1 } qw(bitchat_peer_first_seen chat_message periodic);
    for my $t (@trigs) {
        return "bad trigger '$t'" unless $valid{$t};
    }
    my %has = map { $_ => 1 } @trigs;
    my $ch = $kv->{channel} // '';
    return "channel= required" unless length $ch;
    return "bad channel '$ch'"
        unless $ch =~ /^(bitchat_dm|chat_post|noop)$/;
    if ($ch ne 'noop') {
        return "target= required for channel=$ch"
            unless defined $kv->{target} && length $kv->{target};
        return "body= required for channel=$ch"
            unless defined $kv->{body};
    }
    if ($ch eq 'bitchat_dm'
        && defined $kv->{target}
        && $kv->{target} !~ /\$\{/
        && $kv->{target} !~ /^[0-9a-f]{16}$/i)
    {
        return "channel=bitchat_dm target must be 16 lowercase hex (got '$kv->{target}')";
    }
    if ($has{chat_message}) {
        return "chat_message: session= required"
            unless defined $kv->{session} && length $kv->{session};
        return "chat_message: session has forbidden chars"
            unless $kv->{session} =~ /^[A-Za-z0-9._-]{1,64}$/;
        return "chat_message: match= required"
            unless defined $kv->{match} && length $kv->{match};
        if (defined $kv->{ack_target} && length $kv->{ack_target}) {
            return "ack_target= requires channel=noop"
                unless $ch eq 'noop';
            return "ack_target has forbidden chars"
                unless $kv->{ack_target} =~ /^[A-Za-z][A-Za-z0-9._-]{0,31}$/;
        }
    }
    if ($has{periodic}) {
        return "periodic: every= required"
            unless defined $kv->{every} && length $kv->{every};
        # match= is only illegal on exclusively-periodic rules; a
        # mixed rule that ALSO fires on chat_message or first-seen
        # legitimately needs match= for those paths.
        if (!$has{chat_message} && !$has{bitchat_peer_first_seen}) {
            return "periodic does not accept match="
                if defined $kv->{match} && length $kv->{match};
        }
        my $mode = $kv->{mode} // '';
        if (length $mode && $mode ne 'fanout_bitchat_peers') {
            return "unknown mode '$mode'";
        }
        if ($mode eq 'fanout_bitchat_peers') {
            return "fanout_bitchat_peers requires channel=bitchat_dm"
                unless $ch eq 'bitchat_dm';
            return "fanout_bitchat_peers requires ack_key="
                unless defined $kv->{ack_key} && length $kv->{ack_key};
        }
    }
    return undef;
}

sub starter_kv_for_trigger {
    my ($trig) = @_;
    if ($trig eq 'bitchat_peer_first_seen') {
        return {
            channel   => 'bitchat_dm',
            match     => '.*',
            dedup_ttl => '15m',
            target    => '${peer_id}',
            body      => 'hello ${nickname}',
        };
    } elsif ($trig eq 'periodic') {
        return {
            channel => 'chat_post',
            every   => '5m',
            target  => 'ops',
            body    => 'periodic ping from ${host} at ${now}',
        };
    } else {   # chat_message
        return {
            channel => 'chat_post',
            session => 'ops',
            match   => '(?i)^!hello\b',
            target  => '${session}',
            body    => 'hi ${sender}',
        };
    }
}

# ====================================================================
# Test pane
# ====================================================================

sub do_test {
    my $kv = editor_kv_dump();
    my $name = $E{fields}{name} // '(unnamed)';
    if (my $err = validate_kv($kv)) {
        _test_clear();
        _test_line("cannot test: $err\n", 'err');
        return;
    }
    my $trig_raw = $kv->{trigger} // '';
    my @trigs = grep { length }
                map  { s/^\s+|\s+$//gr }
                split /,/, $trig_raw;
    _test_clear();
    _test_line("Testing rule '$name' (trigger=$trig_raw, channel=$kv->{channel})\n",
               'bold');
    _test_line(" listen=$listen_var  N=$sample_n\n");
    for my $trig (@trigs) {
        _test_line("\n-- as $trig --\n", 'bold');
        if    ($trig eq 'bitchat_peer_first_seen') { _test_ble($name, $kv) }
        elsif ($trig eq 'chat_message')            { _test_chat($name, $kv) }
        elsif ($trig eq 'periodic')                { _test_periodic($name, $kv) }
    }
    set_status("Test complete.");
}

sub _test_ble {
    my ($name, $kv) = @_;
    my $rows = _snapshot('bitchat_peers') // return;
    _test_line(sprintf("  sampled %d bitchat_peers row(s)\n", scalar @$rows));
    my $re = _try_compile($kv->{match} // '.*') // return;
    my $n_shown = 0;
    my $n_hit = 0;
    my @sorted = sort { ($b->{last_seen}//0) cmp ($a->{last_seen}//0) } @$rows;
    my $n = @sorted; my $limit = $sample_n;
    $limit = $n if $n < $limit;
    for my $r (@sorted[0..$limit-1]) {
        $n_shown++;
        my $nick = $r->{nickname} // '';
        my $pid  = $r->{peer_id} // '';
        if ($nick =~ $re) {
            $n_hit++;
            my %cap = %+;
            my $ctx = { peer_id => $pid, nickname => $nick,
                        sender  => 'bitchat-relay', session => '',
                        map { ("cap.$_" => $cap{$_}) } keys %cap };
            _test_line(sprintf("  HIT peer=%s nick=%s\n", $pid, $nick), 'hit');
            _test_line(sprintf("      -> %s '%s'\n",
                               _subst($kv->{target}, $ctx),
                               _subst($kv->{body}, $ctx)), 'resolved');
        } else {
            _test_line(sprintf("  --- peer=%s nick=%s\n", $pid, $nick), 'miss');
        }
    }
    _test_line(sprintf("\n%d row(s) sampled, %d matched\n", $n_shown, $n_hit),
               'bold');
}

sub _test_chat {
    my ($name, $kv) = @_;
    my $sess = $kv->{session} // '';
    (my $q = $sess) =~ s/'/''/g;
    my $where = "session = '$q'";
    my $rows = _snapshot('chat_messages', where => $where) // return;
    _test_line(sprintf("  sampled %d chat_messages row(s) in session=%s\n",
                       scalar @$rows, $sess));
    my $re = _try_compile($kv->{match} // '.*') // return;
    my @sorted = sort { ($b->{ts}//0) cmp ($a->{ts}//0) } @$rows;
    my $n = @sorted; my $limit = $sample_n;
    $limit = $n if $n < $limit;
    my $n_shown = 0; my $n_hit = 0;
    for my $r (@sorted[0..$limit-1]) {
        $n_shown++;
        my $sender = $r->{sender} // '';
        my $body   = $r->{body}   // '';
        my $matched_from = !defined $kv->{from}
                        || !length $kv->{from}
                        || $kv->{from} eq $sender;
        my $matched_re   = $body =~ $re;
        if ($matched_from && $matched_re) {
            $n_hit++;
            my %cap = %+;
            my $ctx = { peer_id => ($cap{peer_id} // ''),
                        nickname => '',
                        sender  => $sender, session => $sess,
                        map { ("cap.$_" => $cap{$_}) } keys %cap };
            _test_line(sprintf("  HIT sender=%s body=%s\n",
                               $sender, _truncate($body, 60)), 'hit');
            if (($kv->{channel} // '') eq 'noop') {
                _test_line("      -> (noop; no wire post; ack recorded)\n",
                           'resolved');
            } else {
                _test_line(sprintf("      -> %s '%s'\n",
                                   _subst($kv->{target}, $ctx),
                                   _subst($kv->{body}, $ctx)), 'resolved');
            }
        } else {
            _test_line(sprintf("  --- sender=%s body=%s%s\n",
                               $sender, _truncate($body, 60),
                               (!$matched_from ? "  [from!=$kv->{from}]" : '')),
                       'miss');
        }
    }
    _test_line(sprintf("\n%d row(s) sampled, %d matched\n", $n_shown, $n_hit),
               'bold');
}

sub _test_periodic {
    my ($name, $kv) = @_;
    _test_line("periodic rule — no history to sample; showing a synthetic tick.\n");
    my $mode = $kv->{mode} // '';
    if ($mode eq 'fanout_bitchat_peers') {
        my $rows = _snapshot('bitchat_peers') // return;
        _test_line(sprintf("  %d BLE peer(s) known — would DM each unless acked\n",
                           scalar @$rows));
        my $limit = $sample_n;
        $limit = @$rows if $limit > @$rows;
        for my $r (@{$rows}[0..$limit-1]) {
            my $pid  = $r->{peer_id}  // '';
            my $nick = $r->{nickname} // '';
            my $ctx = { peer_id => $pid, nickname => $nick,
                        sender  => 'net-chat-autoresponder', session => '' };
            _test_line(sprintf("  -> DM %s (%s): '%s'\n",
                               $pid, $nick,
                               _subst($kv->{body}, $ctx)), 'resolved');
        }
    } else {
        my $ctx = { peer_id => '', nickname => 'net-chat-autoresponder',
                    sender => 'net-chat-autoresponder', session => '' };
        _test_line(sprintf("  target -> %s\n", _subst($kv->{target}, $ctx)),
                   'resolved');
        _test_line(sprintf("  body   -> %s\n", _subst($kv->{body},   $ctx)),
                   'resolved');
    }
}

# Snapshot chat_sessions from the target daemon so the session/target
# BrowseEntry dropdowns can offer known names. Returns a list of
# hashrefs sorted by name; empty list on any failure (daemon down,
# table missing on a fresh install, etc). Deliberately quiet — the
# fallback (empty dropdown, freeform typing) is a fine degraded mode.
sub fetch_chat_sessions {
    my $cli = eval {
        NetMgr::Client->new(listen => $listen_var, timeout => 5);
    };
    return () unless $cli;
    my $ok = eval { $cli->hello(consumer => "autoresponder-gui.$$"); 1 };
    unless ($ok) {
        eval { $cli->bye };
        return ();
    }
    my $rows = eval { $cli->snapshot(1, 'chat_sessions') };
    eval { $cli->bye };
    return () unless ref($rows) eq 'ARRAY';
    for my $r (@$rows) {
        delete @{$r}{qw(op sub table mode)};
    }
    return sort { ($a->{name} // '') cmp ($b->{name} // '') } @$rows;
}

# Enable Save only when trigger AND channel are both explicitly picked
# (non-blank). The empty '(pick one)' sentinel value fails this check
# so a fresh rule can't be Saved without the operator picking both
# sinks — the click just silently no-ops instead of firing an
# 'Invalid rule' dialog for a trivially unfinished form. Guarded on
# $save_btn because build_editor_form runs during the Tk skeleton
# setup, before the action bar has been created.
sub update_save_state {
    return unless defined $save_btn;
    # Save is always ENABLED — validate_kv catches unfinished forms
    # with a messageBox that names the missing field. Greying Save
    # out on empty forms was too subtle: the operator saw "no Save
    # button" instead of "I haven't picked a trigger yet".
    $save_btn->configure(-state => 'normal');
    my $chan = $E{fields}{channel} // '';
    # Post is only meaningful for chat_post rules (target = session name);
    # for bitchat_dm the target is a peer_id which requires the bridge
    # to relay, and noop rules have no wire effect. Enable based on the
    # Channel Optionmenu only — body/target emptiness is caught inside
    # do_post_now, since those fields don't drive update_save_state
    # from every keystroke.
    if (defined $post_btn) {
        my $post_state = $chan eq 'chat_post' ? 'normal' : 'disabled';
        $post_btn->configure(-state => $post_state);
    }
}

# One-off chat_post that bypasses the rule engine: use the editor's
# current target (session) + body and post now via a fresh NetMgr::Client
# on $listen. as=global.as so the daemon attributes it to the responder
# process even though this is a hand-driven poke. Any ${…} tokens in
# the body are passed through verbatim — this is a raw post, not a rule
# fire, so there is no context to resolve them from.
sub do_post_now {
    my $chan = $E{fields}{channel} // '';
    my $tgt  = $E{fields}{target}  // '';
    my $body = $E{fields}{body}    // '';
    return _msg('Post', 'Post only works on channel=chat_post rules.')
        if $chan ne 'chat_post';
    return _msg('Post', 'Target and Body are required.')
        unless length $tgt && length $body;
    my $as = $S{global}{as} // 'net-chat-autoresponder';
    my $ok = eval {
        require NetMgr::Client;
        my $c = NetMgr::Client->new(listen => $listen, timeout => 6);
        $c->hello(consumer => "autoresponder.gui.$$");
        eval { $c->chat_open(name => $tgt); };  # idempotent; ignore ERR:exists
        $c->chat_post(session => $tgt, body => $body, as => $as);
        eval { $c->bye };
        1;
    };
    if ($ok) {
        $status_lbl->configure(-text => "posted to $tgt")
            if defined $status_lbl;
    } else {
        my $err = $@; chomp $err;
        _msg('Post failed', $err);
    }
}

# _msg — tiny wrapper around Tk's messageBox so error dialogs match
# the rest of the GUI's popups. Kept minimal on purpose; the daemon
# path never touches it.
sub _msg {
    my ($title, $body) = @_;
    return unless defined $mw;
    $mw->messageBox(-type => 'ok', -icon => 'info',
                    -title => $title, -message => $body);
}

sub _snapshot {
    my ($table, %args) = @_;
    my $cli = eval {
        NetMgr::Client->new(listen => $listen_var, timeout => 5);
    };
    if (!$cli) {
        _test_line("connect $listen_var failed: $@\n", 'err');
        return undef;
    }
    my $ok = eval { $cli->hello(consumer => "autoresponder-gui.$$"); 1 };
    if (!$ok) {
        _test_line("HELLO failed: $@\n", 'err');
        eval { $cli->bye }; return undef;
    }
    my $rows = eval { $cli->snapshot(1, $table, %args) };
    if ($@ || !defined $rows) {
        my $e = $@; chomp $e;
        _test_line("snapshot $table failed: $e\n", 'err');
        eval { $cli->bye }; return undef;
    }
    # Client->snapshot leaves the wire envelope on each row; strip so
    # rule fields see just the columns (Multi::snapshot_all:198-200).
    for my $r (@$rows) {
        delete @{$r}{qw(op sub table mode)};
    }
    eval { $cli->bye };
    return $rows;
}

# Substitution mirroring the daemon's subst(). Kept small — only the
# token vocabulary the rule engine supports.
sub _subst {
    my ($s, $ctx) = @_;
    return '' unless defined $s;
    $s =~ s/\$\$/\x01/g;
    $s =~ s/
        \$\{
          ( peer_id | nickname | sender | session | now | host
          | cap\.[A-Za-z_][A-Za-z0-9_]*
          )
        \}
    / _subst_val($1, $ctx) /gex;
    $s =~ s/\x01/\$/g;
    return $s;
}

sub _subst_val {
    my ($tok, $ctx) = @_;
    if ($tok eq 'now') {
        my @t = gmtime;
        return sprintf('%02d:%02d:%02d', $t[2], $t[1], $t[0]);
    }
    if ($tok eq 'host') {
        unless (defined $HOST_CACHED) {
            require Sys::Hostname;
            $HOST_CACHED = Sys::Hostname::hostname() // '';
        }
        return $HOST_CACHED;
    }
    return defined $ctx->{$tok} ? $ctx->{$tok} : '';
}

sub _try_compile {
    my ($src) = @_;
    my $re;
    local $SIG{ALRM} = sub { die "timeout\n" };
    alarm 2;
    my $ok = eval { $re = qr/$src/; 1 };
    alarm 0;
    unless ($ok) {
        _test_line("regex compile failed: $@\n", 'err');
        return undef;
    }
    return $re;
}

sub _test_clear { $test_text->delete('1.0', 'end') }

sub _test_line {
    my ($t, @tags) = @_;
    $test_text->insert('end', $t, @tags ? [ @tags ] : ());
}

sub _truncate {
    my ($s, $n) = @_;
    return $s unless defined $s && length $s > $n;
    return substr($s, 0, $n) . '...';
}

# ====================================================================
# Misc helpers
# ====================================================================

sub set_status { $status_lbl->configure(-text => " $_[0]") }
sub msg {
    my ($title, $body) = @_;
    $mw->messageBox(-title => $title, -message => $body,
                    -type => 'OK', -icon => 'info');
    return undef;
}

1;
