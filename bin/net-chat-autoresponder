#!/usr/bin/perl
# net-chat-autoresponder — rule-driven reactor for the net-mgr chat stream.
#
# Loads /etc/net-mgr/net-chat-autoresponder.conf (INI) plus any overlays
# in /etc/net-mgr/net-chat-autoresponder.d/*.conf, subscribes to the
# daemon streams the rules reference (bitchat_peers first-seen and/or
# chat_messages per session), and dispatches chat_post replies via
# NetMgr::Client on loopback.
#
# Split of concerns:
#   - net-bitchat-bridge remains the BLE plumbing (helper supervisor,
#     nickname wiring, cross-site relay, WIFI?-in-DM onramp).
#   - THIS process owns rule-based reactions — first-seen greetings, chat
#     canned replies, etc. — that were formerly ad-hoc knobs on the bridge.
#     Moving the wifi-greeting here means an operator can override the
#     greeting body by editing one INI file in
#     /etc/net-mgr/net-chat-autoresponder.d/ WITHOUT touching the bridge.
#
# Two clients, per the house style at net-bitchat-bridge:213-217 and
# net-chat cmd_test:512-513:
#   $R — read/SUBSCRIBE socket (stream-only; no snapshot replay at boot).
#   $W — write/OBSERVE socket (chat_post). Both talk loopback:7531.
#
# Usage:
#   net-chat-autoresponder [--config FILE] [--listen H:P] [--once] [--dry-run]
#
# See etc/net-chat-autoresponder.conf.sample for the rule grammar.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use Fcntl qw(:flock O_RDWR O_CREAT O_APPEND);
use NetMgr::Client;
use NetMgr::Protocol qw(parse_line);

$SIG{PIPE} = 'IGNORE';                      # net-chat:60 shape
$| = 1;

my %opt = (config => '/etc/net-mgr/net-chat-autoresponder.conf');
GetOptions(\%opt, 'gui', 'file=s', 'config=s', 'listen=s',
                  'once', 'dry-run', 'help')
    or usage(2);
usage(0) if $opt{help};

# --gui: launch the Tk rule editor + live tester and exit. Everything
# GUI-shaped lives in the nested NetChatAutoresponderGui package at the
# bottom of this file; cmd_gui does the lazy Tk require so the daemon
# path below (the common case) pays no Tk cost at import time.
if ($opt{gui}) {
    cmd_gui(%opt);
    exit 0;
}

# ---- 1. Load rules ----------------------------------------------------------
my ($GLOBAL, @RULES) = load_config($opt{config});
$GLOBAL->{listen} = $opt{listen} if $opt{listen};

# echo_ignore: drop chat_message rows whose sender matches any of these.
# The rule's own $as is always ignored (self-loop guard).
my %ignore = map { $_ => 1 }
             grep { length }
             map  { s/^\s+|\s+$//gr }
             split /,/, ($GLOBAL->{echo_ignore} // $GLOBAL->{as} // '');
$ignore{ $GLOBAL->{as} } = 1 if defined $GLOBAL->{as} && length $GLOBAL->{as};

my $SEEN = SeenFile->open($GLOBAL->{state_file}
                          // '/var/lib/net-mgr/net-chat-autoresponder.seen');

my @ble_rules      = grep { $_->{trigger} eq 'bitchat_peer_first_seen' } @RULES;
my @chat_rules     = grep { $_->{trigger} eq 'chat_message' }            @RULES;
my @periodic_rules = grep { $_->{trigger} eq 'periodic' }                @RULES;
my %chat_sessions;
$chat_sessions{$_->{session}}++ for @chat_rules;

# Peer identity map — updated on every bitchat_peers ROW. Enables:
#   - periodic fanout rules (mode=fanout_bitchat_peers) to iterate live
#     BLE peers by peer_id — see fire_periodic_rules.
#   - chat_message ack rules (ack_target=NAME) to reverse-map a nickname
#     captured from a mesh reply back to the peer_id, so we can mark
#     that peer as having ack'd a fanout broadcast — see on_chat_row.
# NOT persisted. On restart the stream re-subscribe replays the current
# bitchat_peers table within one poll (~30s), so a periodic fanout
# missing its peer map for the very first tick just fans out to an
# empty set — the acked-set persists via SeenFile, no double-fire.
# Collision caveat: nickname is not unique on the mesh (see the schema
# comment on bitchat_peers.nickname — VARCHAR(64) NULL, no UNIQUE). A
# second peer choosing the same nickname will overwrite this map's
# nick->pid mapping; the ack then attributes to whichever peer wrote
# most recently. Peer_id is the schema-authoritative identity, but
# chat_messages.body only carries the nickname (see the bridge's tag
# construction in bin/net-bitchat-bridge:555-558), so this map is the
# best identity recovery available today without a schema change.
my %NICK_TO_PID;    # nickname => peer_id
my %PEER_LAST_SEEN; # peer_id  => epoch (last bitchat_peers ROW time)

# In-memory timer for periodic rules — deliberately NOT persisted. On
# restart the first fire happens after 'every' seconds, not immediately,
# so a supervisor loop that flaps the service doesn't spam the mesh.
{
    my $t0 = time;
    for my $r (@periodic_rules) {
        $r->{_next_fire} = $t0 + $r->{_every_secs};
    }
}

warn "[autoresponder] loaded " . scalar(@RULES) . " rule(s) from $opt{config}"
   . " ("      . scalar(@ble_rules)      . " bitchat_peer_first_seen"
   . ", "      . scalar(@chat_rules)     . " chat_message"
   . ", "      . scalar(@periodic_rules) . " periodic)\n";

# ---- 2. Two connections -----------------------------------------------------
my $R = NetMgr::Client->new(listen => $GLOBAL->{listen}, timeout => 6);
$R->hello(consumer => "autoresponder.sub.$$");
my $W = NetMgr::Client->new(listen => $GLOBAL->{listen}, timeout => 6,
                            as => $GLOBAL->{as});
$W->hello(consumer => "autoresponder.ctrl.$$");

# ---- 3. Subscribe — mode=stream ONLY (no snapshot/history replay) -----------
# Streaming-only is deliberate: the whole point of the daemon-owned
# bitchat_peers table is that op=insert lifecycle events are already
# authoritative first-seen signals. Replaying a snapshot at boot would
# re-greet every peer the daemon has ever seen. The SeenFile is a
# belt-and-braces defence against the daemon changing its emit semantics.
my $next_sub = 1;
if (@ble_rules) {
    $R->send_line("SUBSCRIBE sub=" . $next_sub++
                . " mode=stream FROM bitchat_peers");
    warn "[autoresponder] SUBSCRIBE bitchat_peers (stream)\n";
}
for my $s (sort keys %chat_sessions) {
    (my $q = $s) =~ s/'/''/g;    # SQL-string escape inside the WHERE
    $R->send_line("SUBSCRIBE sub=" . $next_sub++
                . " mode=stream FROM chat_messages WHERE session = '$q'");
    warn "[autoresponder] SUBSCRIBE chat_messages session=$s\n";
}

# ---- 4. React loop (net-watch:77-92 shape) ----------------------------------
# recv_line(10) blocks in select() for at most 10s, so the periodic-rule
# check below runs on every tick (both idle wake-ups AND data-arrival
# ticks). Latency for a due periodic rule is bounded by that 10s timeout.
# If any rule's `every` is < 10s, the effective interval will be rounded
# UP to whatever the next tick lands on — documented at the sample rule.
while (1) {
    my $line = $R->recv_line(10);
    $SEEN->prune;
    fire_periodic_rules(\@periodic_rules) if @periodic_rules;
    next unless defined $line;
    my $c = eval { parse_line($line) };
    if ($@) { warn "[autoresponder] parse: $@"; next }
    next unless $c;
    if ($c->{verb} eq 'ERR') {
        warn "[autoresponder] stream ERR: $c->{msg}\n";
        last;
    }
    next unless $c->{verb} eq 'ROW';
    my $kv = $c->{kv} // {};
    my $t  = $kv->{table} // '';
    if    ($t eq 'bitchat_peers') { on_peer_row($kv) }
    elsif ($t eq 'chat_messages') { on_chat_row($kv) }
    last if $opt{once};
}
eval { $R->bye }; eval { $W->bye };
exit 0;

# ---- handlers ---------------------------------------------------------------

sub on_peer_row {
    my ($kv) = @_;
    # First-seen semantics. The design's authoritative signal is
    # op=insert; the current daemon (_handle_bitchat_peer_upsert at
    # Manager.pm:6075) hardcodes op=update, so we ALSO accept update
    # rows and lean on SeenFile as the primary dedup gate. The
    # first_seen==last_seen fallback is here for a future world where
    # the daemon starts distinguishing insert-vs-update on this table.
    my $op = $kv->{op} // '';
    my $first = $op eq 'insert'
             || $op eq 'update'
             || (defined $kv->{first_seen} && defined $kv->{last_seen}
                                          && $kv->{first_seen} eq $kv->{last_seen});
    return unless $first;
    my $pid = lc($kv->{peer_id} // '');
    return unless $pid =~ /^[0-9a-f]{16}$/;
    my $nick = $kv->{nickname} // '';
    # Refresh the shared peer identity map BEFORE the ble-rule loop so a
    # periodic-fanout rule that fires on the very next tick already sees
    # this peer (the main loop runs fire_periodic_rules BEFORE the ROW
    # handler on the same tick). Skip the nickname->pid entry when the
    # nickname is empty — a nickless peer can still be fanned out to
    # (we DM by peer_id) but has no way for the operator to see who they
    # are in a chat_messages log line.
    $NICK_TO_PID{$nick}    = $pid if length $nick;
    $PEER_LAST_SEEN{$pid}  = time;
    for my $r (@ble_rules) {
        my %cap;
        if (my $re = $r->{_re}) {
            next unless $nick =~ $re;
            %cap = %+;
        }
        my $ctx = { peer_id => $pid, nickname => $nick,
                    sender  => 'bitchat-relay', session => '',
                    map { ("cap.$_" => $cap{$_}) } keys %cap };
        my $key = "$r->{name}\t$pid";
        next if $r->{dedup_ttl} > 0 && $SEEN->check($key, $r->{dedup_ttl});
        $SEEN->record($key) if dispatch($r, $ctx) && $r->{dedup_ttl} > 0;
    }
}

sub fire_periodic_rules {
    my ($rules) = @_;
    my $now = time;
    for my $r (@$rules) {
        next if !defined $r->{_next_fire} || $r->{_next_fire} > $now;
        if (($r->{mode} // '') eq 'fanout_bitchat_peers') {
            _fire_fanout_bitchat_peers($r, $now);
        } else {
            # ${peer_id}/${session}/cap.* aren't meaningful for a wall-clock
            # trigger; leave them empty and let subst() fall through. The
            # ${nickname} slot carries the global 'as' (per design brief) so
            # a broadcast rule can self-identify without re-typing the name.
            my $ctx = {
                peer_id  => '',
                nickname => ($GLOBAL->{as} // ''),
                sender   => ($GLOBAL->{as} // ''),
                session  => '',
            };
            dispatch($r, $ctx);
        }
        # Re-anchor next fire to `now`, NOT (prev _next_fire + every).
        # If the loop was blocked for a long time (parse hang, slow
        # daemon, laptop suspend), we do NOT want to catch up by
        # firing back-to-back and spamming the mesh. Re-anchor is once
        # PER RULE, not once per fanout target — a fanout rule that DMs
        # 20 peers still bumps its own next_fire only once.
        $r->{_next_fire} = $now + $r->{_every_secs};
    }
}

# Per-peer DM fanout for a periodic rule with mode=fanout_bitchat_peers.
# Iterates %PEER_LAST_SEEN (the reactor's live-peer set, refreshed by
# on_peer_row) and dispatches one DM per non-acked peer. Peers whose
# peer_id has been recorded as ack'd (via a chat_message rule with
# ack_target= — see on_chat_row) inside the rule's acked_ttl window
# are skipped silently. Reverse-lookup of nickname from peer_id is
# best-effort and only used to populate ${nickname} in the DM body —
# the DM target is peer_id, so nick-empty peers still get the DM.
sub _fire_fanout_bitchat_peers {
    my ($r, $now) = @_;
    my $ack_key = $r->{ack_key};
    my $ttl     = $r->{_acked_ttl_secs} // 0;
    my ($fired, $skipped) = (0, 0);
    # Reverse map built lazily each tick — O(peers) but a periodic
    # tick is a coarse event; a hot-path optimisation (maintain
    # %PID_TO_NICK alongside %NICK_TO_PID) is easy to add later.
    my %pid_to_nick;
    while (my ($n, $p) = each %NICK_TO_PID) { $pid_to_nick{$p} //= $n }
    for my $pid (sort keys %PEER_LAST_SEEN) {
        if (defined $ack_key && length $ack_key && $ttl > 0) {
            my $seen_key = "$ack_key\tacked\t$pid";
            if ($SEEN->check($seen_key, $ttl)) { $skipped++; next }
        }
        my $ctx = {
            peer_id  => $pid,
            nickname => ($pid_to_nick{$pid} // ''),
            sender   => ($GLOBAL->{as} // ''),
            session  => '',
        };
        dispatch($r, $ctx) and $fired++;
    }
    warn "[autoresponder $r->{name}] fanout: $fired fired, "
       . "$skipped acked-skipped ("
       . scalar(keys %PEER_LAST_SEEN) . " peers known)\n";
}

sub on_chat_row {
    my ($kv) = @_;
    return unless ($kv->{op} // '') eq 'insert';
    my $sender = $kv->{sender} // '';
    return if $ignore{$sender};
    my $sess = $kv->{session} // '';
    my $body = $kv->{body}    // '';
    for my $r (@chat_rules) {
        next unless $r->{session} eq $sess;
        next if defined $r->{from} && $r->{from} ne $sender;
        next unless $body =~ $r->{_re};
        my %cap = %+;
        my $ctx = { peer_id => ($cap{peer_id} // ''), nickname => '',
                    sender  => $sender, session => $sess,
                    map { ("cap.$_" => $cap{$_}) } keys %cap };

        # ack_target=NAME — this is an ACK-drop rule (see design brief).
        # A mesh reply matched by `match` was tagged by the bridge as
        # '[NICK@bitchat[/chan]] BODY' (bin/net-bitchat-bridge:555-558)
        # so the rule's regex extracts (?<nick>...) from that prefix.
        # We reverse-look up the peer_id via %NICK_TO_PID (populated by
        # on_peer_row) and mark that peer as having ack'd the periodic
        # fanout named by ack_target. NO dispatch — this is pure state
        # mutation. The next fanout tick will skip this peer for
        # acked_ttl seconds. Peers we haven't yet seen a bitchat_peers
        # ROW for cannot be marked (no peer_id available); the ack is
        # dropped with a log line so the operator can spot the miss.
        if (defined $r->{ack_target} && length $r->{ack_target}) {
            my $nick = $cap{nick} // '';
            my $pid  = length $nick ? ($NICK_TO_PID{$nick} // '') : '';
            if (!length $pid) {
                warn "[autoresponder $r->{name}] ack_target=$r->{ack_target}"
                   . " nick='$nick' — no peer_id known yet, ack dropped\n";
            } else {
                my $seen_key = "$r->{ack_target}\tacked\t$pid";
                $SEEN->record($seen_key);
                warn "[autoresponder $r->{name}] ack_target=$r->{ack_target}"
                   . " marked $nick ($pid) acked\n";
            }
            # ack rules never dispatch. Do NOT fall through to the
            # dedup/dispatch path below.
            next;
        }

        my $key = "$r->{name}\t$sender";
        next if $r->{dedup_ttl} > 0 && $SEEN->check($key, $r->{dedup_ttl});
        $SEEN->record($key) if dispatch($r, $ctx) && $r->{dedup_ttl} > 0;
    }
}

sub dispatch {
    my ($r, $ctx) = @_;
    # channel=noop: pure state-mutation rule. Currently the ack-target
    # path in on_chat_row bypasses dispatch entirely, but we accept a
    # dispatch call so a future rule could combine ack-dropping with
    # in-process side effects (e.g. metrics counter) without a wire post.
    if ($r->{channel} eq 'noop') {
        return 1;
    }
    my $target = subst($r->{target}, $ctx);
    my $body   = subst($r->{body},   $ctx);
    utf8::upgrade($body);

    if ($r->{channel} eq 'bitchat_dm') {
        unless ($target =~ /^[0-9a-f]{16}$/) {
            warn "[autoresponder $r->{name}] bitchat_dm target not 16-hex:"
               . " '$target' — skip\n";
            return 0;
        }
        my $preview = length($body) > 60
                    ? substr($body, 0, 60) . '...' : $body;
        if ($opt{'dry-run'}) {
            warn "[autoresponder dry-run $r->{name}] DM $target: $preview\n";
            return 1;
        }
        # Route via bridge's @HEX16: prefix convention (bridge:409-411).
        # net-chat-autoresponder posts to bitchat-bridge session; bridge's
        # SUBSCRIBE loop strips the prefix and DMs the peer over BLE.
        my $ok = eval { $W->chat_post(session => 'bitchat-bridge',
                                      body    => "\@$target: $body",
                                      as      => $GLOBAL->{as}); 1 };
        if (!$ok) {
            warn "[autoresponder $r->{name}] chat_post(DM) failed: $@";
            return 0;
        }
        warn "[autoresponder $r->{name}] DM $target: $preview\n";
        return 1;
    } elsif ($r->{channel} eq 'chat_post') {
        my $preview = length($body) > 60
                    ? substr($body, 0, 60) . '...' : $body;
        if ($opt{'dry-run'}) {
            warn "[autoresponder dry-run $r->{name}] post $target: $preview\n";
            return 1;
        }
        my $ok = eval { $W->chat_post(session => $target, body => $body,
                                      as => $GLOBAL->{as}); 1 };
        if (!$ok) {
            warn "[autoresponder $r->{name}] chat_post failed: $@";
            return 0;
        }
        warn "[autoresponder $r->{name}] post $target: $preview\n";
        return 1;
    } else {
        warn "[autoresponder $r->{name}] unknown channel '$r->{channel}'\n";
        return 0;
    }
}

# ${peer_id} ${nickname} ${sender} ${session} ${cap.NAME} ${now} ${host} —
# everything else passes through literally. '$$' escapes a literal '$'.
#   ${now}   — current UTC HH:MM:SS (rendered per fire, useful for periodic).
#   ${host}  — Sys::Hostname::hostname() (cached).
sub subst {
    my ($s, $ctx) = @_;
    return '' unless defined $s;
    $s =~ s/\$\$/\x01/g;
    $s =~ s/
        \$\{
          ( peer_id | nickname | sender | session | now | host
          | cap\.[A-Za-z_][A-Za-z0-9_]*
          )
        \}
    / _token_val($1, $ctx) /gex;
    $s =~ s/\x01/\$/g;
    return $s;
}

my $DAEMON_HOST_CACHED;   # separate from NetChatAutoresponderGui::HOST_CACHED
sub _token_val {
    my ($tok, $ctx) = @_;
    if ($tok eq 'now') {
        my @t = gmtime;
        return sprintf('%02d:%02d:%02d', $t[2], $t[1], $t[0]);
    }
    if ($tok eq 'host') {
        unless (defined $DAEMON_HOST_CACHED) {
            require Sys::Hostname;
            $DAEMON_HOST_CACHED = Sys::Hostname::hostname() // '';
        }
        return $DAEMON_HOST_CACHED;
    }
    return defined $ctx->{$tok} ? $ctx->{$tok} : '';
}

# ---- config -----------------------------------------------------------------

# Parse an INI file into { section => { key => value } }. Config::Tiny if
# available (matches the rest of the tree); otherwise a hand parser that
# understands [section], key=value, and ';'/'#' comments. Sections may
# repeat (later value wins per key). Unknown/unused characters passed
# through — no shell substitution.
sub _load_ini {
    my ($path) = @_;
    return {} unless -r $path;
    if (eval { require Config::Tiny; 1 }) {
        my $t = Config::Tiny->read($path)
            or die "$path: " . Config::Tiny->errstr . "\n";
        # Config::Tiny returns a plain hash with section names; _ is root.
        return { %$t };
    }
    open my $fh, '<', $path or die "$path: $!\n";
    my %cfg;
    my $section = '_';
    while (<$fh>) {
        s/^\s+|\s+$//g;
        next if !length || /^[;#]/;
        if (/^\[(.+?)\]\s*$/) { $section = $1; next }
        if (/^([\w.-]+)\s*=\s*(.*)$/) { $cfg{$section}{$1} = $2 }
    }
    close $fh;
    return \%cfg;
}

# load_config($primary_path):
#   Read $primary_path plus /etc/net-mgr/<basename>.d/*.conf overlays in
#   filename-sort order. Duplicate [rule.NAME] REPLACES the earlier one
#   (last-write-wins). Returns ($GLOBAL, @RULES).
sub load_config {
    my ($primary) = @_;

    (my $overlay_dir = $primary) =~ s/\.conf$//;
    $overlay_dir .= '.d';

    my @paths;
    push @paths, $primary if -e $primary;
    if (-d $overlay_dir) {
        opendir my $dh, $overlay_dir or die "$overlay_dir: $!\n";
        push @paths, map { "$overlay_dir/$_" }
                     sort grep { /\.conf$/ && !/^\./ } readdir $dh;
        closedir $dh;
    }
    unless (@paths) {
        die "no config: neither $primary nor $overlay_dir/*.conf exists\n";
    }

    my %global;
    my %rules;   # NAME => rule hash
    my @order;   # rule-name order for evaluation
    for my $p (@paths) {
        warn "[autoresponder] load $p\n";
        my $ini = _load_ini($p);
        # Merge [global] (later files override individual keys).
        if (ref $ini->{global} eq 'HASH') {
            @global{ keys %{$ini->{global}} } = values %{$ini->{global}};
        }
        for my $sec (sort keys %$ini) {
            next unless $sec =~ /^rule\.([A-Za-z][A-Za-z0-9._-]{0,31})$/;
            my $name = $1;
            my $body = $ini->{$sec};
            next unless ref $body eq 'HASH';
            push @order, $name unless exists $rules{$name};
            $rules{$name} = { %$body, name => $name, _source => $p };
        }
    }

    # Defaults.
    $global{listen}       //= '127.0.0.1:7531';
    $global{as}           //= 'net-chat-autoresponder';
    $global{state_file}   //= '/var/lib/net-mgr/net-chat-autoresponder.seen';
    $global{echo_ignore}  //= $global{as};

    # Compile / validate rules.
    my @rules;
    for my $name (@order) {
        my $r = $rules{$name};
        my $ok = eval { _compile_rule($r); 1 };
        if (!$ok) {
            my $e = $@; chomp $e;
            warn "[autoresponder] rule '$name' skipped: $e\n";
            next;
        }
        push @rules, $r;
    }

    return (\%global, @rules);
}

# Fills $r->{_re}, $r->{dedup_ttl} (seconds), validates required keys.
sub _compile_rule {
    my ($r) = @_;
    my $trigger = $r->{trigger}
        or die "no trigger=";
    die "bad trigger '$trigger'"
        unless $trigger eq 'bitchat_peer_first_seen'
            || $trigger eq 'chat_message'
            || $trigger eq 'periodic';

    my $ch = $r->{channel} or die "no channel=";
    die "bad channel '$ch'"
        unless $ch eq 'bitchat_dm' || $ch eq 'chat_post' || $ch eq 'noop';

    # target/body are required for wire channels only. channel=noop
    # rules mutate in-process state (SEEN, %NICK_TO_PID) and produce no
    # wire traffic, so those fields are optional there.
    if ($ch ne 'noop') {
        die "no target=" unless defined $r->{target} && length $r->{target};
        die "no body="   unless defined $r->{body};
    }

    # Rule-load target validation for bitchat_dm literals. If the target
    # contains ${...} we defer until per-fire; otherwise it MUST be 16 hex.
    if ($ch eq 'bitchat_dm'
        && defined $r->{target}
        && $r->{target} !~ /\$\{/
        && $r->{target} !~ /^[0-9a-f]{16}$/i)
    {
        die "channel=bitchat_dm target must be 16 lowercase hex "
          . "(got '$r->{target}')";
    }

    # Compile regex under a 2s alarm — pathological patterns fail rule-load
    # rather than crashing the reactor mid-flight.
    my $match = $r->{match};
    if ($trigger eq 'chat_message') {
        die "chat_message trigger needs match=" unless defined $match;
        my $sess = $r->{session};
        die "chat_message trigger needs session="
            unless defined $sess && length $sess;
        die "chat_message session sanitize: '$sess' has forbidden chars"
            unless $sess =~ /^[A-Za-z0-9._-]{1,64}$/;
        # ack_target=NAME: marks the sender's peer_id as ack'ing the named
        # periodic-fanout rule (via ack_key= on that rule). Restrict the
        # NAME to the same shape as [rule.NAME] so it can't smuggle a tab
        # into the SeenFile key encoding "ack_target\tacked\tpeer_id".
        if (defined $r->{ack_target} && length $r->{ack_target}) {
            die "ack_target='$r->{ack_target}' has forbidden chars "
              . "(use [A-Za-z][A-Za-z0-9._-]{0,31})"
                unless $r->{ack_target} =~ /^[A-Za-z][A-Za-z0-9._-]{0,31}$/;
            # Ack rules are pure state mutation — enforce channel=noop
            # so an operator can't accidentally combine ack-dropping
            # with a wire post that would defeat the ack semantics.
            die "ack_target= requires channel=noop (got $ch)"
                unless $ch eq 'noop';
        }
    }
    if ($trigger eq 'periodic') {
        # `every` REQUIRED. Enforce a 5s floor so a typo like `every=0.5s`
        # (which _parse_duration would treat as 0 -> fire-every-tick) can't
        # spam the mesh. No dedup, no regex, no session for periodic.
        my $every = $r->{every};
        die "periodic trigger needs every=" unless defined $every && length $every;
        my $secs = _parse_duration($every);
        die "periodic every='$every' must be >= 5s (got ${secs}s)"
            if $secs < 5;
        $r->{_every_secs} = $secs;
        # `match` on a periodic rule would be silently ignored, which
        # confuses readers of the config. Fail load instead.
        die "periodic trigger does not accept match="
            if defined $r->{match};

        # mode=fanout_bitchat_peers: iterate live BLE peers and DM each
        # one whose peer_id hasn't been marked ack'd within acked_ttl.
        # Requires channel=bitchat_dm (per-peer) and an ack_key= naming
        # the SeenFile bucket that chat_message ack_target rules will
        # populate. Missing/empty mode = the legacy single-fire path.
        my $mode = $r->{mode} // '';
        die "periodic mode='$mode' not recognised "
          . "(supported: fanout_bitchat_peers)"
            if length $mode && $mode ne 'fanout_bitchat_peers';
        if ($mode eq 'fanout_bitchat_peers') {
            die "fanout_bitchat_peers requires channel=bitchat_dm (got $ch)"
                unless $ch eq 'bitchat_dm';
            die "fanout_bitchat_peers requires ack_key="
                unless defined $r->{ack_key} && length $r->{ack_key};
            die "ack_key='$r->{ack_key}' has forbidden chars "
              . "(use [A-Za-z][A-Za-z0-9._-]{0,31})"
                unless $r->{ack_key} =~ /^[A-Za-z][A-Za-z0-9._-]{0,31}$/;
            my $atl = $r->{acked_ttl} // '1h';
            my $sec = _parse_duration($atl);
            die "acked_ttl='$atl' must be > 0 (parsed as ${sec}s)"
                unless $sec > 0;
            $r->{_acked_ttl_secs} = $sec;
        }
    }
    $match = '.*' unless defined $match;
    my $re = _compile_re($match);
    $r->{_re} = $re;

    # Duration parse. Default 30d for BLE first-seen; 0 for chat_message.
    # Periodic ignores dedup entirely — the `every` interval IS the
    # rate limit; forcing dedup_ttl=0 keeps every fire unconditional
    # even if someone copies a dedup_ttl= from a first-seen rule.
    my $default_ttl = $trigger eq 'bitchat_peer_first_seen' ? '30d' : '0';
    my $ttl = $trigger eq 'periodic' ? '0' : ($r->{dedup_ttl} // $default_ttl);
    $r->{dedup_ttl} = _parse_duration($ttl);
    return 1;
}

sub _compile_re {
    my ($src) = @_;
    my $re;
    local $SIG{ALRM} = sub { die "regex compile timeout\n" };
    alarm(2);
    # `use re 'strict'` (experimental pragma) turns dubious constructs
    # into hard errors so a rule file typo fails at load, not mid-flight.
    # Wrapped in a no-warnings scope so we don't spam every parent load.
    my $ok = eval {
        no warnings 'experimental::re_strict';
        use re 'strict';
        $re = qr/$src/;
        1;
    };
    alarm(0);
    die "bad regex /$src/: $@" unless $ok;
    return $re;
}

sub _parse_duration {
    my ($s) = @_;
    return 0 unless defined $s;
    $s =~ s/^\s+|\s+$//g;
    return 0 if $s eq '' || $s eq '0';
    return $1 * 604800 if $s =~ /^(\d+)w$/i;
    return $1 * 86400  if $s =~ /^(\d+)d$/i;
    return $1 * 3600   if $s =~ /^(\d+)h$/i;
    return $1 * 60     if $s =~ /^(\d+)m$/i;
    return $1 + 0      if $s =~ /^(\d+)s?$/i;
    die "bad duration '$s' (use e.g. 30d, 5m, 90s, 0)\n";
}

sub usage {
    my ($rc) = @_;
    print STDERR <<'USAGE';
net-chat-autoresponder — rule-driven reactor for net-chat.

  net-chat-autoresponder [--config FILE] [--listen H:P] [--once] [--dry-run]
  net-chat-autoresponder --gui [--file FILE] [--listen H:P]

Flags:
  --gui          launch the Tk rule editor + live tester (needs perl-Tk).
                 --file names the primary config (same file the daemon
                 reads); --listen names the daemon whose bitchat_peers /
                 chat_messages / chat_sessions the tester snapshots.
  --config FILE  primary INI (default /etc/net-mgr/net-chat-autoresponder.conf)
                 Overlays in <primary>.d/*.conf are loaded after in sort order.
                 (--file is accepted as an alias, for --gui users.)
  --listen H:P   override [global].listen
  --once         process one row then exit (smoke test)
  --dry-run      log what would be posted, don't actually contact the daemon

See etc/net-chat-autoresponder.conf.sample for the rule grammar.
USAGE
    exit($rc // 0);
}

# ---- --gui dispatch --------------------------------------------------------
# Lazy Tk require is important: the daemon path (the common case) must
# not pay Tk's compile-time cost or fail to start when perl-Tk isn't
# installed on the host. Tk brings a handful of widget subclasses in via
# separate .pm files; each installs the corresponding constructor method
# on Tk parent widgets, so we require them all before entering the run
# loop. Tk->import into main:: makes MainWindow visible as a bareword
# for the nested package's file-scope skeleton code.
sub cmd_gui {
    my (%opt) = @_;
    eval {
        require Tk;
        Tk->import;
        require Tk::ROText;
        require Tk::DialogBox;
        require Tk::Optionmenu;
        require Tk::BrowseEntry;
        1;
    } or die <<MSG;
net-chat-autoresponder --gui needs perl-Tk. Install with:
  Debian/Ubuntu:  sudo apt install perl-tk
  RHEL/Fedora:    sudo dnf install perl-Tk
MSG
    NetChatAutoresponderGui::run(\%opt);
}

# ---- SeenFile ---------------------------------------------------------------
# Append-only 'key\tepoch\n' log. hit(key, ttl) returns 1 if key was seen
# with age <= ttl, otherwise records and returns 0. prune() rewrites the
# file when >2x live entries have expired. flock during writes.
package SeenFile;

use strict;
use warnings;
use Fcntl qw(:flock O_RDWR O_CREAT O_APPEND);

sub open {   ## no critic (Subroutines::ProhibitBuiltinHomonyms)
    my ($class, $path) = @_;
    # Ensure parent dir exists — systemd StateDirectory=net-mgr already
    # creates /var/lib/net-mgr/, but a hand-run smoke test off-service
    # deserves a sensible error.
    (my $parent = $path) =~ s{/[^/]+$}{};
    if (length $parent && !-d $parent) {
        mkdir $parent
            or warn "[autoresponder] mkdir $parent: $! "
                  . "(state persistence disabled)\n";
    }
    my $self = bless { path => $path, mem => {}, dirty => 0 }, $class;
    $self->_load;
    return $self;
}

sub _load {
    my ($self) = @_;
    return unless -e $self->{path};
    CORE::open(my $fh, '<', $self->{path})
        or do {
            warn "[autoresponder] open $self->{path}: $!\n";
            return;
        };
    while (<$fh>) {
        chomp;
        next unless length;
        # Parse from the RIGHT: last tab is the ts delimiter, everything
        # before it is the (possibly multi-tab) key. Keys such as
        # 'wifi-broadcast\tacked\tPID_HEX16' would otherwise be split at
        # the first tab and silently dropped by the /^\d+$/ guard.
        my $idx = rindex($_, "\t");
        next if $idx < 0;
        my $k = substr($_, 0, $idx);
        my $t = substr($_, $idx + 1);
        next unless $t =~ /^\d+$/;
        # Later record wins on duplicate keys.
        $self->{mem}{$k} = $t + 0;
    }
    close $fh;
}

sub check {
    my ($self, $key, $ttl) = @_;
    my $prev = $self->{mem}{$key};
    return defined $prev && (time - $prev) <= $ttl;
}

sub record {
    my ($self, $key) = @_;
    my $now = time;
    $self->{mem}{$key} = $now;
    $self->_append($key, $now);
}

sub _append {
    my ($self, $key, $ts) = @_;
    my $fh;
    unless (sysopen $fh, $self->{path},
            O_RDWR | O_CREAT | O_APPEND)
    {
        warn "[autoresponder] open $self->{path}: $! "
           . "(dedup not persisted this round)\n";
        return;
    }
    flock $fh, LOCK_EX;
    print $fh "$key\t$ts\n";
    flock $fh, LOCK_UN;
    close $fh;
    $self->{dirty}++;
}

# Called on every loop tick; cheap unless the file has grown a lot.
sub prune {
    my ($self) = @_;
    return unless $self->{dirty} >= 32;  # rate-limit rewrites
    return unless -f $self->{path};

    # Count expired vs live from the ON-DISK log (not %mem, which is
    # dedup'd). If >2x expired-vs-live, rewrite.
    CORE::open(my $fh, '<', $self->{path}) or return;
    my $live = 0;
    my $expired = 0;
    my $now = time;
    my %latest;
    while (<$fh>) {
        chomp;
        # Parse from the RIGHT (see _load): multi-tab keys must survive.
        my $idx = rindex($_, "\t");
        next if $idx < 0;
        my $k = substr($_, 0, $idx);
        my $t = substr($_, $idx + 1);
        next unless $t =~ /^\d+$/;
        $latest{$k} = $t + 0;
    }
    close $fh;
    for my $t (values %latest) {
        # We can't know per-key TTL here — assume 30d as the outer bound.
        # An entry stays "live" for the coarse window and is compacted
        # once that window elapses. Any newer hit resets it.
        if ($now - $t <= 30 * 86400) { $live++ } else { $expired++ }
    }
    return unless $expired > $live;   # >50% expired = compact

    my $tmp = $self->{path} . ".tmp.$$";
    if (CORE::open(my $out, '>', $tmp)) {
        for my $k (sort keys %latest) {
            next if $now - $latest{$k} > 30 * 86400;
            print $out "$k\t$latest{$k}\n";
        }
        close $out;
        rename $tmp, $self->{path}
            or warn "[autoresponder] rename $tmp -> $self->{path}: $!\n";
        $self->{dirty} = 0;
    } else {
        warn "[autoresponder] compact open $tmp: $!\n";
    }
}

# ---- NetChatAutoresponderGui ----------------------------------------------
# Tk editor + live tester for the rule set this daemon reads. Split out
# from the historical bin/net-autoresponder-gui script; folded in here so
# the two surfaces share a name and there's one config-format loader/writer
# to keep aligned. Entered via `net-chat-autoresponder --gui`; the daemon
# path never reaches this package (cmd_gui exits before returning).
#
# Reads /etc/net-mgr/net-chat-autoresponder.conf plus every overlay in the
# adjacent .d/ directory, in filename-sort order, mirroring load_config()
# above. Each rule is tracked against the file it was last defined in
# (last-write-wins per rule name across overlays) so save-back writes to
# the SAME file — you don't accidentally move a site-override rule out of
# its overlay back into the packaged default.
#
# Rule enable/disable is persisted by prefixing every line of the rule
# section (header + body kv) with '; '. The daemon's INI reader treats
# those as comments so a disabled rule is a no-op at load; the GUI
# restores the rule by stripping that prefix.
#
# Test pane: for the selected rule, sample recent rows from the table
# its trigger consumes (bitchat_peers / chat_messages) via
# NetMgr::Client->snapshot on --listen, then re-run the rule's match /
# from / session filters against each row and show what would fire, with
# the resolved target/body after ${...} substitution. Periodic rules
# have no history to sample; the tester synthesises a single tick
# context and just shows the resolved wire post.
#
# NOTE: the daemon reads its config exactly once at startup. There is no
# SIGHUP handler and no `service_restart` REPAIR action today. After
# Save the GUI shows a reminder to
# `systemctl restart net-chat-autoresponder` — automating that from here
# would need SSH or a new REPAIR action, neither worth the complexity.

package NetChatAutoresponderGui;

use strict;
use warnings;
use File::Copy   ();
use File::Basename qw(basename dirname);
use POSIX          qw(strftime);
use NetMgr::Client;
use NetMgr::Config;

# --- module-scope state (was file-scope in bin/net-autoresponder-gui) -----
our $listen;
our $file;
our %S;
our @KNOWN_SESSIONS;
our $save_btn;
our %SHARED_WIFI;
our @SHARED_WIFI_LABELS;
our %DISPLAY_TO_LABEL;
our $SHARED_WIFI_CONF = '/etc/net-mgr/shared-wifi.conf';

# Tk widget refs live at package scope so all handler subs can reach them.
our ($mw, $top_bar, $body_frame, $test_frame, $action_bar, $status_lbl);
our ($left_frame, $right_frame, $rules_list, $left_btns);
our (%E, $editor_frame);
our ($test_top, $test_text);
our $sample_n = 50;
our ($listen_var, $file_var);
our $HOST_CACHED;

# Re-entry guard: Tk::Optionmenu fires its -command during construction
# when -variable is initially set to match one of its options, and the
# on_change closures for Trigger/Channel both call build_editor_form,
# which would recurse infinitely as each rebuilt Optionmenu fires again.
# The guard turns those nested calls into no-ops; only the outermost
# invocation (from Load / operator-driven change / do_add_rule) rebuilds.
our $BUILDING_FORM = 0;

# --- entry point ----------------------------------------------------------
sub run {
    my ($opt) = @_;
    $listen = $opt->{listen} // $ENV{NET_MGR_LISTEN} // '127.0.0.1:7531';
    # `--file` is the historical GUI name for the primary config; `--config`
    # is the daemon name. Both work here so operators can pass whichever
    # they already have muscle memory for.
    $file = $opt->{file} // $opt->{config}
                        // '/etc/net-mgr/net-chat-autoresponder.conf';

    %S = (
        rules   => [],
        files   => {},
        order   => [],
        primary => $file,
        sel_idx => undef,
    );

    # --- Tk skeleton (net-cluster-gui:139-150 layout) --------------------
    $mw = MainWindow->new(-title => "net-autoresponder-gui ($file)");
    $mw->geometry('1100x760');

    $top_bar    = $mw->Frame(-relief => 'groove', -bd => 1)
                     ->pack(-side => 'top', -fill => 'x');
    $body_frame = $mw->Frame->pack(-side => 'top', -fill => 'both', -expand => 1);
    $test_frame = $mw->Frame(-relief => 'sunken', -bd => 1)
                     ->pack(-side => 'top', -fill => 'both', -expand => 1, -pady => 2);
    $action_bar = $mw->Frame->pack(-side => 'bottom', -fill => 'x');
    $status_lbl = $mw->Label(-anchor => 'w', -relief => 'sunken')
                     ->pack(-side => 'bottom', -fill => 'x');

    # --- Top bar: daemon target + config file + Load ---------------------
    $top_bar->Label(-text => 'Target daemon:')->pack(-side => 'left', -padx => 4);
    $listen_var = $listen;
    $top_bar->Entry(-textvariable => \$listen_var, -width => 22)
            ->pack(-side => 'left', -padx => 4);
    $top_bar->Label(-text => '   Config:')->pack(-side => 'left');
    $file_var = $file;
    $top_bar->Entry(-textvariable => \$file_var, -width => 44)
            ->pack(-side => 'left', -padx => 4);
    $top_bar->Button(-text => 'Load', -command => \&do_load)
            ->pack(-side => 'left', -padx => 4);
    $top_bar->Button(-text => 'Restart hint', -command => \&show_restart_hint)
            ->pack(-side => 'right', -padx => 4);

    # --- Body: LEFT rule list, RIGHT editor ------------------------------
    $left_frame  = $body_frame->Frame(-relief => 'groove', -bd => 1)
                              ->pack(-side => 'left', -fill => 'y', -padx => 2);
    $right_frame = $body_frame->Frame(-relief => 'groove', -bd => 1)
                              ->pack(-side => 'left', -fill => 'both',
                                     -expand => 1, -padx => 2);

    $left_frame->Label(-text => 'Rules',
                       -font => '{Helvetica} 9 bold')
               ->pack(-side => 'top', -anchor => 'w', -padx => 4, -pady => 2);
    $rules_list = $left_frame->Scrolled('Listbox',
        -scrollbars => 'oe',
        -width      => 32,
        -height     => 20,
        -font       => '{Monospace} 10',
        -selectmode => 'browse',
    )->pack(-side => 'top', -fill => 'y', -expand => 1, -padx => 4, -pady => 2);
    $rules_list->bind('<<ListboxSelect>>', \&on_rule_pick);

    $left_btns = $left_frame->Frame->pack(-side => 'top', -fill => 'x', -pady => 2);
    $left_btns->Button(-text => '+ Add',    -command => \&do_add_rule)
              ->pack(-side => 'left',  -padx => 2);
    $left_btns->Button(-text => 'Toggle',   -command => \&do_toggle_enabled)
              ->pack(-side => 'left',  -padx => 2);
    $left_btns->Button(-text => 'Delete',   -command => \&do_delete_rule)
              ->pack(-side => 'left',  -padx => 2);

    build_editor_shell();

    # --- Test pane (bottom half) ----------------------------------------
    $test_top = $test_frame->Frame->pack(-side => 'top', -fill => 'x', -pady => 2);
    $test_top->Label(-text => 'Test pane', -font => '{Helvetica} 9 bold')
             ->pack(-side => 'left', -padx => 4);
    $test_top->Label(-text => '   Sample size:')->pack(-side => 'left');
    $sample_n = 50;
    $test_top->Entry(-textvariable => \$sample_n, -width => 5)
             ->pack(-side => 'left', -padx => 2);
    $test_top->Button(-text => 'Fetch + test selected rule',
                      -command => \&do_test)
             ->pack(-side => 'left', -padx => 6);
    $test_top->Label(-text => '(uses editor state, not the saved rule)',
                     -foreground => '#666')
             ->pack(-side => 'left', -padx => 8);

    $test_text = $test_frame->Scrolled('ROText',
        -scrollbars => 'osoe',
        -wrap       => 'none',
        -font       => '{Monospace} 9',
        -height     => 14,
    )->pack(-side => 'top', -fill => 'both', -expand => 1, -padx => 4, -pady => 2);
    $test_text->tagConfigure('hit',    -foreground => '#040');
    $test_text->tagConfigure('miss',   -foreground => '#888');
    $test_text->tagConfigure('bold',   -font       => '{Monospace} 9 bold');
    $test_text->tagConfigure('err',    -foreground => '#a00');
    $test_text->tagConfigure('resolved', -foreground => '#005');

    # --- Action bar -----------------------------------------------------
    $save_btn = $action_bar->Button(-text => 'Save rule',
                                    -command => \&do_save_rule)
                           ->pack(-side => 'left', -padx => 4);
    update_save_state();
    $action_bar->Button(-text => 'Reload from disk',
                        -command => \&do_load)
               ->pack(-side => 'left', -padx => 4);
    $action_bar->Button(-text => 'Quit', -command => sub { exit 0 })
               ->pack(-side => 'right', -padx => 4);

    do_load();
    MainLoop();
    return;
}

# ====================================================================
# Actions
# ====================================================================

sub do_load {
    $file = $file_var;
    $S{primary} = $file;
    $S{files}   = {};
    $S{order}   = [];
    $S{rules}   = [];
    $S{sel_idx} = undef;

    # Refresh the chat_sessions cache alongside the config reload so
    # the session/target BrowseEntry dropdowns reflect the daemon's
    # current sessions. Failure is non-fatal — dropdown is just empty
    # and the operator can still type any name.
    @KNOWN_SESSIONS = fetch_chat_sessions();

    # Refresh the shared-WiFi picker cache. Missing file / parse
    # error is fine — the dropdown shows a hint item instead and
    # the operator can still type the WIFI: URI by hand.
    load_shared_wifi();

    my @paths = overlay_paths($file);
    unless (@paths) {
        set_status("No config found: $file (and no $file.d/*.conf)");
        refresh_rules_list();
        clear_editor();
        return;
    }
    my %by_name;
    my @name_order;
    for my $p (@paths) {
        my @lines = slurp_lines($p);
        $S{files}{$p} = \@lines;
        push @{$S{order}}, $p;
        parse_rules_from($p, \@lines, \%by_name, \@name_order);
    }
    $S{rules} = [ map { $by_name{$_} } @name_order ];
    refresh_rules_list();
    if (@{$S{rules}}) {
        $rules_list->selectionSet(0);
        $S{sel_idx} = 0;
        load_editor_from_rule( $S{rules}[0] );
    } else {
        clear_editor();
    }
    set_status(sprintf "Loaded %d rule(s) from %d file(s)",
               scalar @{$S{rules}}, scalar @paths);
}

sub on_rule_pick {
    my @sel = $rules_list->curselection;
    return unless @sel;
    my $i = $sel[0];
    $S{sel_idx} = $i;
    load_editor_from_rule($S{rules}[$i]);
}

sub do_add_rule {
    my $dlg = $mw->DialogBox(-title => 'New rule',
                             -buttons => ['OK', 'Cancel']);
    # Seed trigger empty so the operator is FORCED to pick one — no
    # accidental "chat_message with defaults" rule from a blind OK.
    my %v = (name => '', trigger => '');
    $dlg->add('Label', -text => 'Rule name ([A-Za-z][A-Za-z0-9._-]{0,31}):')
        ->pack(-anchor => 'w', -padx => 8, -pady => 2);
    my $e = $dlg->add('Entry', -textvariable => \$v{name}, -width => 32)
                ->pack(-padx => 8, -pady => 2);
    $e->focus;
    $dlg->add('Label', -text => 'Trigger:')
        ->pack(-anchor => 'w', -padx => 8, -pady => 2);
    $dlg->add('Optionmenu',
              -options  => [ [ '(pick one)'              => '' ],
                             [ 'chat_message'            => 'chat_message' ],
                             [ 'bitchat_peer_first_seen' => 'bitchat_peer_first_seen' ],
                             [ 'periodic'                => 'periodic' ] ],
              -variable => \$v{trigger},
    )->pack(-anchor => 'w', -padx => 8, -pady => 2);
    my $ans = $dlg->Show // 'Cancel';
    return unless $ans eq 'OK' || $ans eq 'Ok';
    $v{name} =~ s/^\s+|\s+$//g;
    return msg('Bad name', 'Rule name must match [A-Za-z][A-Za-z0-9._-]{0,31}.')
        unless $v{name} =~ /^[A-Za-z][A-Za-z0-9._-]{0,31}$/;
    return msg('No trigger', 'Pick a trigger before creating the rule.')
        unless length $v{trigger};
    for my $r (@{$S{rules}}) {
        return msg('Duplicate', "A rule named '$v{name}' already exists in "
                              . $r->{source} . ".")
            if $r->{name} eq $v{name};
    }
    # New rules append to the primary file. If the primary doesn't yet
    # exist, create it (empty) so the append target is well-defined.
    my $dest = $S{primary};
    if (!exists $S{files}{$dest}) {
        $S{files}{$dest} = [];
        push @{$S{order}}, $dest;
    }
    # Don't seed channel/target/body/session — the operator must fill
    # them in explicitly. Save stays disabled until channel is picked.
    my $starter_kv = { trigger => $v{trigger} };
    my $new = {
        name    => $v{name},
        enabled => 1,
        source  => $dest,
        kv      => $starter_kv,
        # start_ln/end_ln get assigned when we write, not now.
    };
    push @{$S{rules}}, $new;
    $S{sel_idx} = $#{ $S{rules} };
    refresh_rules_list();
    $rules_list->selectionClear(0, 'end');
    $rules_list->selectionSet($S{sel_idx});
    load_editor_from_rule($new);
    set_status("New rule '$v{name}' — edit + Save to write it to $dest");
}

sub do_toggle_enabled {
    my $r = current_rule() or return;
    $r->{enabled} = $r->{enabled} ? 0 : 1;
    my $body = editor_kv_dump();
    write_rule_back($r, $body);
    refresh_rules_list();
    reselect_current();
    set_status(($r->{enabled} ? "enabled" : "disabled")
             . " '$r->{name}' in " . basename($r->{source}));
}

sub do_delete_rule {
    my $r = current_rule() or return;
    my $ans = $mw->messageBox(
        -title   => 'Delete rule',
        -message => "Delete '$r->{name}' from " . $r->{source} . "?",
        -type    => 'OKCancel',
        -icon    => 'question',
        -default => 'cancel',
    );
    return unless $ans eq 'Ok' || $ans eq 'OK';
    delete_rule_from_file($r);
    # Drop from the in-memory rules list + reload the file we edited.
    reload_file( $r->{source} );
    refresh_rules_list();
    clear_editor();
    set_status("deleted '$r->{name}' from " . basename($r->{source}));
}

sub do_save_rule {
    my $r = current_rule() or return msg('No rule', 'Pick a rule to save.');
    my $kv = editor_kv_dump();
    # Cheap client-side validation before the write. The daemon will
    # re-validate on next load; this just catches shape errors early.
    if (my $err = validate_kv($kv)) {
        return msg('Invalid rule', $err);
    }
    $r->{kv} = $kv;
    write_rule_back($r, $kv);
    refresh_rules_list();
    reselect_current();
    set_status("saved '$r->{name}' to " . $r->{source}
             . "  (restart net-chat-autoresponder to apply)");
}

sub show_restart_hint {
    my $body = <<'MSG';
net-chat-autoresponder reads its config once at startup.
Apply saved changes with one of:

  sudo systemctl restart net-chat-autoresponder

Or, for a smoke test without touching systemd:

  sudo -u root net-chat-autoresponder --once --dry-run

There is no in-band SIGHUP / REPAIR action for this today.
MSG
    $mw->messageBox(-title => 'Restart the autoresponder',
                    -message => $body, -type => 'OK', -icon => 'info');
}

# ====================================================================
# Editor form (right pane) — dynamic per trigger
# ====================================================================

# Persistent shell: create $editor_frame plus the always-present name +
# trigger row. Trigger-specific rows are torn down and rebuilt whenever
# the trigger changes.
sub build_editor_shell {
    $right_frame->Label(-text => 'Rule editor',
                        -font => '{Helvetica} 9 bold')
                ->pack(-side => 'top', -anchor => 'w', -padx => 4, -pady => 2);
    $editor_frame = $right_frame->Frame->pack(-side => 'top', -fill => 'both',
                                              -expand => 1, -padx => 4, -pady => 2);
    build_editor_form();
}

# Render form rows from scratch based on $E{trigger}. Field values live
# in $E{fields}{<key>} so save can serialize them without asking the
# widgets. Unset $E{fields} at build time so a trigger flip drops keys
# that don't belong to the new trigger.
sub build_editor_form {
    return if $BUILDING_FORM;
    local $BUILDING_FORM = 1;
    $_->destroy for $editor_frame->children;
    $E{fields} //= {};
    # Empty trigger means "unpicked" — trigger-specific rows are not
    # rendered until the operator picks a real trigger.
    my $trig = $E{trigger} // '';
    my $chan = $E{fields}{channel} // '';

    row_entry( $editor_frame, 'Name:',    'name',    32 );
    row_option($editor_frame, 'Trigger:', 'trigger',
        [ [ '(pick one)'                => '' ],
          [ 'chat_message'              => 'chat_message' ],
          [ 'bitchat_peer_first_seen'   => 'bitchat_peer_first_seen' ],
          [ 'periodic'                  => 'periodic' ] ],
        sub {
            $E{trigger} = $E{fields}{trigger};
            build_editor_form();
        },
    );
    row_option($editor_frame, 'Channel:', 'channel',
        [ [ '(pick one)' => '' ],
          [ 'bitchat_dm' => 'bitchat_dm' ],
          [ 'chat_post'  => 'chat_post' ],
          [ 'noop'       => 'noop' ] ],
        sub {
            # Channel change swaps the Target row between a plain Entry
            # (bitchat_dm/noop, freeform peer_id / ${var}) and a
            # BrowseEntry backed by chat_sessions (chat_post).
            build_editor_form();
        },
    );
    # Target row: BrowseEntry backed by chat_sessions when
    # channel=chat_post (target IS a session name in that case); plain
    # Entry otherwise (bitchat_dm wants a 16-hex peer_id or ${var}).
    if ($chan eq 'chat_post') {
        row_browse_entry($editor_frame, 'Target:', 'target', 48, \@KNOWN_SESSIONS);
    } else {
        row_entry( $editor_frame, 'Target:', 'target', 48 );
    }
    # Shared-WiFi picker sits ABOVE the body field so an operator
    # composing a rule.wifi-fanout style greeting can pick a
    # credential set and drop the WIFI: URI into the body without
    # typing the escaping by hand. The generated URI shape matches
    # net-bitchat-bridge:531-534 (same escape set) so QR readers
    # parse the greeting identically whichever surface produced it.
    row_shared_wifi($editor_frame);
    row_multi( $editor_frame, 'Body:',      'body' );
    row_entry( $editor_frame, 'Dedup TTL:', 'dedup_ttl', 12 );

    if ($trig eq 'bitchat_peer_first_seen') {
        row_entry( $editor_frame, 'Match:', 'match', 48 );
    } elsif ($trig eq 'chat_message') {
        row_browse_entry($editor_frame, 'Session:', 'session', 32, \@KNOWN_SESSIONS);
        row_entry( $editor_frame, 'Match:',      'match',      48 );
        row_entry( $editor_frame, 'From:',       'from',       32 );
        row_entry( $editor_frame, 'Ack target:', 'ack_target', 32 );
    } elsif ($trig eq 'periodic') {
        row_entry( $editor_frame, 'Every:',      'every',      12 );
        row_option($editor_frame, 'Mode:',       'mode',
            [ [ '(single-fire)' => '' ],
              [ 'fanout_bitchat_peers' => 'fanout_bitchat_peers' ] ],
        );
        row_entry( $editor_frame, 'Ack key:',    'ack_key',    32 );
        row_entry( $editor_frame, 'Acked TTL:',  'acked_ttl',  12 );
    }

    my $meta = $editor_frame->Frame->pack(-side => 'top', -fill => 'x', -pady => 4);
    $E{source_label} = $meta->Label(
        -text => 'Source file: (unsaved)',
        -foreground => '#444',
        -anchor => 'w',
    )->pack(-side => 'left', -padx => 4);

    # Toggle Save enable/disable based on whether trigger + channel
    # are both non-blank now that we've refreshed the widget state.
    update_save_state();
}

sub row_entry {
    my ($parent, $label, $key, $width) = @_;
    my $row = $parent->Frame->pack(-side => 'top', -fill => 'x', -pady => 1);
    $row->Label(-text => $label, -width => 12, -anchor => 'w')
        ->pack(-side => 'left');
    $E{fields}{$key} //= '';
    $row->Entry(-textvariable => \$E{fields}{$key}, -width => $width)
        ->pack(-side => 'left', -fill => 'x', -expand => 1);
}

sub row_multi {
    my ($parent, $label, $key) = @_;
    my $row = $parent->Frame->pack(-side => 'top', -fill => 'x', -pady => 1);
    $row->Label(-text => $label, -width => 12, -anchor => 'nw')
        ->pack(-side => 'left');
    my $t = $row->Scrolled('Text',
        -height     => 4,
        -width      => 60,
        -wrap       => 'word',
        -scrollbars => 'oe',
        -font       => '{Monospace} 10',
    )->pack(-side => 'left', -fill => 'x', -expand => 1);
    $E{_multi}{$key} = $t;
    my $init = $E{fields}{$key} // '';
    $t->delete('1.0', 'end');
    $t->insert('end', $init);
    $t->bind('<KeyRelease>', sub {
        $E{fields}{$key} = $t->get('1.0', 'end-1c');
    });
    $E{fields}{$key} = $init;
}

sub row_option {
    my ($parent, $label, $key, $options, $on_change) = @_;
    my $row = $parent->Frame->pack(-side => 'top', -fill => 'x', -pady => 1);
    $row->Label(-text => $label, -width => 12, -anchor => 'w')
        ->pack(-side => 'left');
    # Default to the empty sentinel (never auto-pick the first entry).
    # Every option list that reaches here has '' as a valid value —
    # either as the '(pick one)' sentinel (trigger, channel) or the
    # legitimate '(single-fire)' mode. So a fresh rule shows a picker
    # that requires an explicit selection instead of silently seeding
    # bitchat_dm / chat_message and validating on Save.
    $E{fields}{$key} //= '';
    my %ok = map { $_->[1] => 1 } @$options;
    $E{fields}{$key} = ''
        unless defined $E{fields}{$key} && $ok{ $E{fields}{$key} };
    $row->Optionmenu(
        -options  => $options,
        -variable => \$E{fields}{$key},
        ($on_change ? (-command => sub { $on_change->() }) : ()),
    )->pack(-side => 'left');
}

# BrowseEntry variant for fields that map to chat_sessions.name — a
# combo-box: dropdown of known session names for pick-with-mouse, but
# still typeable so an operator can name a session that doesn't yet
# exist (autoresponder chat_opens on first fire).
sub row_browse_entry {
    my ($parent, $label, $key, $width, $choices_ref) = @_;
    my $row = $parent->Frame->pack(-side => 'top', -fill => 'x', -pady => 1);
    $row->Label(-text => $label, -width => 12, -anchor => 'w')
        ->pack(-side => 'left');
    $E{fields}{$key} //= '';
    my $be = $row->BrowseEntry(
        -variable  => \$E{fields}{$key},
        -width     => $width,
        -listwidth => 40,
    )->pack(-side => 'left', -fill => 'x', -expand => 1);
    for my $s (@{ $choices_ref // [] }) {
        my $name = ref($s) ? $s->{name} : $s;
        next unless defined $name && length $name;
        $be->insert('end', $name);
    }
}

# Shared-WiFi picker row. BrowseEntry lists every [wifi.LABEL] section
# discovered by load_shared_wifi() as "LABEL (SSID)"; two buttons handle
# insert-URI and insert-URI-plus-note into the body Text widget at the
# cursor (or replacing the current selection). When no shared-wifi.conf
# is present the dropdown carries a single hint item and the buttons
# silently no-op — a bare empty picker looked confusingly broken.
sub row_shared_wifi {
    my ($parent) = @_;
    my $row = $parent->Frame->pack(-side => 'top', -fill => 'x', -pady => 1);
    $row->Label(-text => 'Share WiFi:', -width => 12, -anchor => 'w')
        ->pack(-side => 'left');
    $E{fields}{_wifi_pick} //= '';
    my $be = $row->BrowseEntry(
        -variable  => \$E{fields}{_wifi_pick},
        -width     => 32,
        -listwidth => 48,
        -browsecmd => sub { _wifi_insert_from_pick(0) },
    )->pack(-side => 'left', -padx => 2);
    if (@SHARED_WIFI_LABELS) {
        for my $label (@SHARED_WIFI_LABELS) {
            my $entry = $SHARED_WIFI{$label} or next;
            my $ssid  = $entry->{ssid} // '?';
            my $disp  = "$label ($ssid)";
            $be->insert('end', $disp);
        }
    } else {
        $be->insert('end',
            '(no shared-wifi.conf — see etc/shared-wifi.conf.sample)');
    }
    $row->Button(-text => 'Insert',
                 -command => sub { _wifi_insert_from_pick(0) })
        ->pack(-side => 'left', -padx => 2);
    $row->Button(-text => 'Insert w/ note',
                 -command => sub { _wifi_insert_from_pick(1) })
        ->pack(-side => 'left', -padx => 2);
}

# Look up the pick variable, resolve display → label, generate URI, and
# insert into the body Text at the cursor (or replace selection). No-op
# when the pick is the "(no shared-wifi.conf...)" hint or empty.
sub _wifi_insert_from_pick {
    my ($with_note) = @_;
    my $disp  = $E{fields}{_wifi_pick} // '';
    return unless length $disp;
    my $label = $DISPLAY_TO_LABEL{$disp};
    return unless defined $label;      # hint item / stale display string
    my $entry = $SHARED_WIFI{$label} or return;
    my $text  = _wifi_uri($entry);
    if ($with_note && length($entry->{note} // '')) {
        $text .= "\n" . $entry->{note};
    }
    my $t = $E{_multi}{body} or return;
    my @sel = $t->tagRanges('sel');
    if (@sel) {
        $t->delete($sel[0], $sel[1]);
        $t->insert($sel[0], $text);
    } else {
        $t->insert('insert', $text);
    }
    # Sync scalar so save picks it up without waiting for a KeyRelease.
    $E{fields}{body} = $t->get('1.0', 'end-1c');
    $t->focus;
}

# Build a WIFI: QR-code URI from a shared-wifi entry hashref. Field order
# and escape set match net-bitchat-bridge:531-534 so QR readers parse a
# GUI-inserted URI identically to the wifi-onramp DM. auth values other
# than nopass emit ;P:<pass>; auth=nopass omits P: entirely — what QR
# readers expect for open networks. hidden=true adds ;H:true;.
sub _wifi_uri {
    my ($entry) = @_;
    my $ssid   = $entry->{ssid}     // '';
    my $auth   = uc($entry->{auth}  // 'WPA');
    my $pass   = $entry->{password} // '';
    my $hidden = ($entry->{hidden}  // '') =~ /^(1|true|yes)$/i;
    my $uri = 'WIFI:T:' . $auth
            . ';S:' . _wifi_esc($ssid);
    $uri .= ';P:' . _wifi_esc($pass) if $auth ne 'NOPASS';
    $uri .= ';H:true' if $hidden;
    $uri .= ';;';
    return $uri;
}

# Escape the five WIFI: URI reserved characters, matching the closure at
# net-bitchat-bridge:531-533 exactly so operators can't tell whether a
# body came from the bridge onramp or the GUI picker.
sub _wifi_esc {
    my $s = shift // '';
    $s =~ s/([\\;,"'])/\\$1/g;
    return $s;
}

# Slurp /etc/net-mgr/shared-wifi.conf (+ shared-wifi.d/*.conf overlays)
# via NetMgr::Config's built-in overlay loader — same code path the main
# daemon uses for its own overlays, so operators only learn one story.
# Section names are lowercased by the loader, so LABEL casing is folded
# — that's fine, labels are just picker keys. Missing file / parse
# failure is non-fatal: we leave %SHARED_WIFI empty and the picker will
# render the "no shared-wifi.conf" hint.
sub load_shared_wifi {
    %SHARED_WIFI       = ();
    @SHARED_WIFI_LABELS = ();
    %DISPLAY_TO_LABEL   = ();
    my $has_primary = -e $SHARED_WIFI_CONF;
    (my $dotd = $SHARED_WIFI_CONF) =~ s/\.conf$/.d/;
    my $has_overlay = 0;
    if (-d $dotd && opendir(my $dh, $dotd)) {
        my @f = grep { /\.conf$/ } readdir $dh;
        closedir $dh;
        $has_overlay = scalar @f;
    }
    return unless $has_primary || $has_overlay;

    my $cfg = eval { NetMgr::Config->load($SHARED_WIFI_CONF) };
    if ($@ || !$cfg) {
        my $err = $@ || 'unknown';
        chomp $err;
        warn "[shared-wifi] parse failed: $err\n";
        return;
    }
    for my $section (sort keys %$cfg) {
        next unless $section =~ /^wifi\.(.+)$/;
        my $label = $1;
        my $entry = $cfg->{$section};
        next unless ref $entry eq 'HASH';
        next unless defined $entry->{ssid} && length $entry->{ssid};
        $SHARED_WIFI{$label} = {
            ssid     => $entry->{ssid},
            auth     => $entry->{auth}     // 'WPA',
            password => $entry->{password} // '',
            hidden   => $entry->{hidden}   // '',
            note     => $entry->{note}     // '',
        };
        push @SHARED_WIFI_LABELS, $label;
        my $disp = "$label ($entry->{ssid})";
        $DISPLAY_TO_LABEL{$disp} = $label;
    }
}

sub load_editor_from_rule {
    my ($r) = @_;
    # Reset field storage; take trigger from the rule so build_editor_form
    # knows which trigger-specific rows to render.
    $E{fields} = {};
    $E{trigger} = $r->{kv}{trigger} // '';
    # Pre-seed channel so build_editor_form picks the right Target
    # widget shape (BrowseEntry when chat_post, plain Entry otherwise)
    # before the post-build population loop runs.
    $E{fields}{channel} = $r->{kv}{channel} if defined $r->{kv}{channel};
    build_editor_form();
    # After build, populate every field from $r->{kv} (unknown keys are
    # silently discarded when the trigger changes and their widget goes
    # away — that's fine, save only serialises known keys).
    $E{fields}{name} = $r->{name};
    for my $k (keys %{$r->{kv}}) {
        next if $k eq 'name';
        if (exists $E{fields}{$k}) {
            $E{fields}{$k} = $r->{kv}{$k};
        }
    }
    # Body sits in a Text widget, not a scalar-bound Entry — sync it.
    if (my $t = $E{_multi}{body}) {
        $t->delete('1.0', 'end');
        $t->insert('end', $r->{kv}{body} // '');
        $E{fields}{body} = $r->{kv}{body} // '';
    }
    $E{source_label}->configure(
        -text => "Source file: $r->{source}"
               . (defined $r->{start_ln}
                    ? sprintf("  (lines %d-%d)",
                              $r->{start_ln}+1, ($r->{end_ln}//$r->{start_ln})+1)
                    : "  (unsaved)"),
    );
    update_save_state();
}

sub clear_editor {
    $E{fields} = {};
    $E{trigger} = '';
    build_editor_form();
}

sub editor_kv_dump {
    my %kv;
    # Sync the Text-backed 'body' widget one more time in case the
    # trailing KeyRelease didn't fire.
    if (my $t = $E{_multi}{body}) {
        $E{fields}{body} = $t->get('1.0', 'end-1c');
    }
    for my $k (keys %{ $E{fields} }) {
        next if $k eq 'name';
        # UI-only scratch fields (underscore-prefixed) never make it
        # into a rule kv — e.g. the Share-WiFi picker's _wifi_pick
        # holds the display string, not something the daemon reads.
        next if $k =~ /^_/;
        my $v = $E{fields}{$k};
        next unless defined $v && length $v;
        $kv{$k} = $v;
    }
    # Rule NAME lives on $r->{name}; the editor's 'name' scalar
    # rewrites $r->{name} at save time — see do_save_rule / write_rule_back.
    return \%kv;
}

sub current_rule {
    return undef unless defined $S{sel_idx};
    return $S{rules}[ $S{sel_idx} ];
}

# ====================================================================
# File parsing + save-back
# ====================================================================

# Load order matches the daemon (load_config above): the primary file
# first, then <primary>.d/*.conf sorted. Primary that doesn't exist
# yet is fine — we're editing to create it.
sub overlay_paths {
    my ($primary) = @_;
    (my $overlay = $primary) =~ s/\.conf$//;
    $overlay .= '.d';
    my @paths;
    push @paths, $primary if -e $primary;
    if (-d $overlay) {
        opendir my $dh, $overlay or return @paths;
        push @paths, map { "$overlay/$_" }
                     sort grep { /\.conf$/ && !/^\./ } readdir $dh;
        closedir $dh;
    }
    return @paths;
}

sub slurp_lines {
    my ($path) = @_;
    open my $fh, '<', $path or return ();
    my @lines = <$fh>;
    close $fh;
    chomp @lines;
    return @lines;
}

# Extract every [rule.NAME] / disabled `; [rule.NAME]` section from
# @$lines and stash into $out{name}. Rule sections spans from their
# header line down to (but excluding) the next [section] header of any
# kind, or EOF. Trailing blank lines are trimmed off the range so
# save-back doesn't devour blank separators between rules.
sub parse_rules_from {
    my ($path, $lines, $out, $order) = @_;
    my @secs;
    my $cur;
    for (my $i = 0; $i <= $#$lines; $i++) {
        my $line = $lines->[$i];
        if ($line =~ /^\s*\[([^\]]+)\]\s*$/) {
            _finish_section($cur, $i - 1, $lines) if $cur;
            my $header = $1;
            if ($header =~ /^rule\.([A-Za-z][A-Za-z0-9._-]{0,31})$/) {
                $cur = { name => $1, enabled => 1, source => $path,
                         kv => {}, start_ln => $i };
                push @secs, $cur;
            } else {
                $cur = undef;
            }
            next;
        }
        if ($line =~ /^\s*[;#]\s*\[([^\]]+)\]\s*$/) {
            _finish_section($cur, $i - 1, $lines) if $cur;
            my $header = $1;
            if ($header =~ /^rule\.([A-Za-z][A-Za-z0-9._-]{0,31})$/) {
                $cur = { name => $1, enabled => 0, source => $path,
                         kv => {}, start_ln => $i };
                push @secs, $cur;
            } else {
                $cur = undef;
            }
            next;
        }
        next unless $cur;
        # Body kv accumulation. Disabled rules have every line prefixed
        # with '; ' by our writer, so match that shape for kv extraction.
        if ($cur->{enabled}) {
            if ($line =~ /^\s*([\w.-]+)\s*=\s*(.*?)\s*$/) {
                $cur->{kv}{$1} = $2;
            }
        } else {
            if ($line =~ /^\s*[;#]\s*([\w.-]+)\s*=\s*(.*?)\s*$/) {
                $cur->{kv}{$1} //= $2;
            }
        }
    }
    _finish_section($cur, $#$lines, $lines) if $cur;
    for my $s (@secs) {
        my $name = $s->{name};
        push @$order, $name unless exists $out->{$name};
        # Last-write-wins (later overlay REPLACES earlier definition),
        # mirroring the daemon's load_config().
        $out->{$name} = $s;
    }
}

sub _finish_section {
    my ($sec, $end, $lines) = @_;
    return unless $sec;
    while ($end > $sec->{start_ln} && $lines->[$end] =~ /^\s*$/) {
        $end--;
    }
    $sec->{end_ln} = $end;
}

# Serialize a rule to file text. Header + key=value lines in a canonical
# order (mirrors the shape of the sample file so diffs stay readable).
sub render_rule {
    my ($r, $kv) = @_;
    my @out;
    my $prefix = $r->{enabled} ? '' : '; ';
    push @out, "$prefix\[rule.$r->{name}\]";
    my @order = qw(trigger session match from ack_target every mode
                   ack_key acked_ttl dedup_ttl channel target body);
    my %seen;
    for my $k (@order) {
        next unless exists $kv->{$k};
        my $v = $kv->{$k};
        next unless defined $v && length $v;
        $seen{$k} = 1;
        push @out, "$prefix$k = $v";
    }
    for my $k (sort keys %$kv) {
        next if $seen{$k};
        my $v = $kv->{$k};
        next unless defined $v && length $v;
        push @out, "$prefix$k = $v";
    }
    return @out;
}

# Replace an existing rule's line range (or append when start_ln
# undefined) with freshly-rendered content, then rewrite the file.
sub write_rule_back {
    my ($r, $kv) = @_;
    # Editor may have renamed the rule; keep $r->{name} in sync.
    if (defined $E{fields}{name} && length $E{fields}{name}
        && $E{fields}{name} =~ /^[A-Za-z][A-Za-z0-9._-]{0,31}$/)
    {
        $r->{name} = $E{fields}{name};
    }
    $r->{kv} = $kv;
    my $path  = $r->{source};
    my $lines = $S{files}{$path} //= [];
    my @new_body = render_rule($r, $kv);

    if (defined $r->{start_ln}) {
        my $start = $r->{start_ln};
        my $end   = $r->{end_ln} // $start;
        splice @$lines, $start, ($end - $start + 1), @new_body;
    } else {
        # Append; add a blank separator if the file isn't empty.
        push @$lines, '' if @$lines && $lines->[-1] ne '';
        push @$lines, @new_body;
    }
    write_file_atomic($path, $lines);
    # Full reparse of the file we touched so start_ln/end_ln stay valid
    # for the next edit. Reparsing every file would drop any yet-unsaved
    # edits on other rules — cheap and correct to only redo the one.
    reload_file($path);
    # Reload_file may have re-created the rule hash — find it by name
    # and re-select so the editor + list stay pointing at it.
    for my $i (0 .. $#{ $S{rules} }) {
        if ($S{rules}[$i]{name} eq $r->{name}
            && $S{rules}[$i]{source} eq $path)
        {
            $S{sel_idx} = $i;
            last;
        }
    }
}

sub delete_rule_from_file {
    my ($r) = @_;
    return unless defined $r->{start_ln};
    my $lines = $S{files}{ $r->{source} } or return;
    my $start = $r->{start_ln};
    my $end   = $r->{end_ln} // $start;
    # Also swallow a leading blank line so we don't leave a double-gap.
    if ($start > 0 && $lines->[$start-1] =~ /^\s*$/) {
        $start--;
    }
    splice @$lines, $start, ($end - $start + 1);
    write_file_atomic($r->{source}, $lines);
}

# Refresh %S{rules} for one file: reparse and merge back into the ordered
# list. Preserves rules from OTHER files unchanged.
sub reload_file {
    my ($path) = @_;
    my @lines = slurp_lines($path);
    $S{files}{$path} = \@lines;
    # Rebuild %S{rules} from all files (cheap; O(files*lines)).
    my %by_name; my @name_order;
    for my $p (@{$S{order}}) {
        my $ls = $S{files}{$p} // [];
        parse_rules_from($p, $ls, \%by_name, \@name_order);
    }
    $S{rules} = [ map { $by_name{$_} } @name_order ];
}

sub write_file_atomic {
    my ($path, $lines) = @_;
    my $dir = dirname($path);
    unless (-d $dir) {
        # Mostly for the .d/ overlay directory on a fresh install.
        mkdir $dir or return msg('mkdir failed', "mkdir $dir: $!");
    }
    my $tmp = "$path.tmp.$$";
    if (open my $fh, '>', $tmp) {
        print {$fh} join("\n", @$lines);
        print {$fh} "\n" if @$lines && $lines->[-1] ne '';
        close $fh or return msg('close failed', "close $tmp: $!");
    } else {
        return msg('open failed', "open $tmp: $!");
    }
    if (-e $path) {
        File::Copy::copy($path, "$path.bak")
            or warn "backup $path: $!";
    }
    rename $tmp, $path or return msg('rename failed', "rename $tmp: $!");
    return 1;
}

sub refresh_rules_list {
    $rules_list->delete(0, 'end');
    for my $r (@{ $S{rules} }) {
        my $mark = $r->{enabled} ? '[x]' : '[ ]';
        my $src  = basename( $r->{source} );
        my $trig = $r->{kv}{trigger} // '?';
        $rules_list->insert('end',
            sprintf("%s %-20s %-24s %s", $mark, $r->{name}, $trig, $src));
    }
}

sub reselect_current {
    return unless defined $S{sel_idx};
    $rules_list->selectionClear(0, 'end');
    $rules_list->selectionSet($S{sel_idx});
    load_editor_from_rule( $S{rules}[ $S{sel_idx} ] );
}

# ====================================================================
# Rule validation (cheap client-side; daemon re-validates)
# ====================================================================

sub validate_kv {
    my ($kv) = @_;
    my $trig = $kv->{trigger} // '';
    return "trigger= required" unless length $trig;
    return "bad trigger '$trig'"
        unless $trig =~ /^(bitchat_peer_first_seen|chat_message|periodic)$/;
    my $ch = $kv->{channel} // '';
    return "channel= required" unless length $ch;
    return "bad channel '$ch'"
        unless $ch =~ /^(bitchat_dm|chat_post|noop)$/;
    if ($ch ne 'noop') {
        return "target= required for channel=$ch"
            unless defined $kv->{target} && length $kv->{target};
        return "body= required for channel=$ch"
            unless defined $kv->{body};
    }
    if ($ch eq 'bitchat_dm'
        && defined $kv->{target}
        && $kv->{target} !~ /\$\{/
        && $kv->{target} !~ /^[0-9a-f]{16}$/i)
    {
        return "channel=bitchat_dm target must be 16 lowercase hex (got '$kv->{target}')";
    }
    if ($trig eq 'chat_message') {
        return "chat_message: session= required"
            unless defined $kv->{session} && length $kv->{session};
        return "chat_message: session has forbidden chars"
            unless $kv->{session} =~ /^[A-Za-z0-9._-]{1,64}$/;
        return "chat_message: match= required"
            unless defined $kv->{match} && length $kv->{match};
        if (defined $kv->{ack_target} && length $kv->{ack_target}) {
            return "ack_target= requires channel=noop"
                unless $ch eq 'noop';
            return "ack_target has forbidden chars"
                unless $kv->{ack_target} =~ /^[A-Za-z][A-Za-z0-9._-]{0,31}$/;
        }
    }
    if ($trig eq 'periodic') {
        return "periodic: every= required"
            unless defined $kv->{every} && length $kv->{every};
        return "periodic does not accept match="
            if defined $kv->{match} && length $kv->{match};
        my $mode = $kv->{mode} // '';
        if (length $mode && $mode ne 'fanout_bitchat_peers') {
            return "unknown mode '$mode'";
        }
        if ($mode eq 'fanout_bitchat_peers') {
            return "fanout_bitchat_peers requires channel=bitchat_dm"
                unless $ch eq 'bitchat_dm';
            return "fanout_bitchat_peers requires ack_key="
                unless defined $kv->{ack_key} && length $kv->{ack_key};
        }
    }
    return undef;
}

sub starter_kv_for_trigger {
    my ($trig) = @_;
    if ($trig eq 'bitchat_peer_first_seen') {
        return {
            channel   => 'bitchat_dm',
            match     => '.*',
            dedup_ttl => '15m',
            target    => '${peer_id}',
            body      => 'hello ${nickname}',
        };
    } elsif ($trig eq 'periodic') {
        return {
            channel => 'chat_post',
            every   => '5m',
            target  => 'ops',
            body    => 'periodic ping from ${host} at ${now}',
        };
    } else {   # chat_message
        return {
            channel => 'chat_post',
            session => 'ops',
            match   => '(?i)^!hello\b',
            target  => '${session}',
            body    => 'hi ${sender}',
        };
    }
}

# ====================================================================
# Test pane
# ====================================================================

sub do_test {
    my $kv = editor_kv_dump();
    my $name = $E{fields}{name} // '(unnamed)';
    if (my $err = validate_kv($kv)) {
        _test_clear();
        _test_line("cannot test: $err\n", 'err');
        return;
    }
    my $trig = $kv->{trigger};
    _test_clear();
    _test_line("Testing rule '$name' (trigger=$trig, channel=$kv->{channel})\n", 'bold');
    _test_line(" listen=$listen_var  N=$sample_n\n");

    if    ($trig eq 'bitchat_peer_first_seen') { _test_ble($name, $kv) }
    elsif ($trig eq 'chat_message')            { _test_chat($name, $kv) }
    elsif ($trig eq 'periodic')                { _test_periodic($name, $kv) }
    set_status("Test complete.");
}

sub _test_ble {
    my ($name, $kv) = @_;
    my $rows = _snapshot('bitchat_peers') // return;
    _test_line(sprintf("  sampled %d bitchat_peers row(s)\n", scalar @$rows));
    my $re = _try_compile($kv->{match} // '.*') // return;
    my $n_shown = 0;
    my $n_hit = 0;
    my @sorted = sort { ($b->{last_seen}//0) cmp ($a->{last_seen}//0) } @$rows;
    my $n = @sorted; my $limit = $sample_n;
    $limit = $n if $n < $limit;
    for my $r (@sorted[0..$limit-1]) {
        $n_shown++;
        my $nick = $r->{nickname} // '';
        my $pid  = $r->{peer_id} // '';
        if ($nick =~ $re) {
            $n_hit++;
            my %cap = %+;
            my $ctx = { peer_id => $pid, nickname => $nick,
                        sender  => 'bitchat-relay', session => '',
                        map { ("cap.$_" => $cap{$_}) } keys %cap };
            _test_line(sprintf("  HIT peer=%s nick=%s\n", $pid, $nick), 'hit');
            _test_line(sprintf("      -> %s '%s'\n",
                               _subst($kv->{target}, $ctx),
                               _subst($kv->{body}, $ctx)), 'resolved');
        } else {
            _test_line(sprintf("  --- peer=%s nick=%s\n", $pid, $nick), 'miss');
        }
    }
    _test_line(sprintf("\n%d row(s) sampled, %d matched\n", $n_shown, $n_hit),
               'bold');
}

sub _test_chat {
    my ($name, $kv) = @_;
    my $sess = $kv->{session} // '';
    (my $q = $sess) =~ s/'/''/g;
    my $where = "session = '$q'";
    my $rows = _snapshot('chat_messages', where => $where) // return;
    _test_line(sprintf("  sampled %d chat_messages row(s) in session=%s\n",
                       scalar @$rows, $sess));
    my $re = _try_compile($kv->{match} // '.*') // return;
    my @sorted = sort { ($b->{ts}//0) cmp ($a->{ts}//0) } @$rows;
    my $n = @sorted; my $limit = $sample_n;
    $limit = $n if $n < $limit;
    my $n_shown = 0; my $n_hit = 0;
    for my $r (@sorted[0..$limit-1]) {
        $n_shown++;
        my $sender = $r->{sender} // '';
        my $body   = $r->{body}   // '';
        my $matched_from = !defined $kv->{from}
                        || !length $kv->{from}
                        || $kv->{from} eq $sender;
        my $matched_re   = $body =~ $re;
        if ($matched_from && $matched_re) {
            $n_hit++;
            my %cap = %+;
            my $ctx = { peer_id => ($cap{peer_id} // ''),
                        nickname => '',
                        sender  => $sender, session => $sess,
                        map { ("cap.$_" => $cap{$_}) } keys %cap };
            _test_line(sprintf("  HIT sender=%s body=%s\n",
                               $sender, _truncate($body, 60)), 'hit');
            if (($kv->{channel} // '') eq 'noop') {
                _test_line("      -> (noop; no wire post; ack recorded)\n",
                           'resolved');
            } else {
                _test_line(sprintf("      -> %s '%s'\n",
                                   _subst($kv->{target}, $ctx),
                                   _subst($kv->{body}, $ctx)), 'resolved');
            }
        } else {
            _test_line(sprintf("  --- sender=%s body=%s%s\n",
                               $sender, _truncate($body, 60),
                               (!$matched_from ? "  [from!=$kv->{from}]" : '')),
                       'miss');
        }
    }
    _test_line(sprintf("\n%d row(s) sampled, %d matched\n", $n_shown, $n_hit),
               'bold');
}

sub _test_periodic {
    my ($name, $kv) = @_;
    _test_line("periodic rule — no history to sample; showing a synthetic tick.\n");
    my $mode = $kv->{mode} // '';
    if ($mode eq 'fanout_bitchat_peers') {
        my $rows = _snapshot('bitchat_peers') // return;
        _test_line(sprintf("  %d BLE peer(s) known — would DM each unless acked\n",
                           scalar @$rows));
        my $limit = $sample_n;
        $limit = @$rows if $limit > @$rows;
        for my $r (@{$rows}[0..$limit-1]) {
            my $pid  = $r->{peer_id}  // '';
            my $nick = $r->{nickname} // '';
            my $ctx = { peer_id => $pid, nickname => $nick,
                        sender  => 'net-chat-autoresponder', session => '' };
            _test_line(sprintf("  -> DM %s (%s): '%s'\n",
                               $pid, $nick,
                               _subst($kv->{body}, $ctx)), 'resolved');
        }
    } else {
        my $ctx = { peer_id => '', nickname => 'net-chat-autoresponder',
                    sender => 'net-chat-autoresponder', session => '' };
        _test_line(sprintf("  target -> %s\n", _subst($kv->{target}, $ctx)),
                   'resolved');
        _test_line(sprintf("  body   -> %s\n", _subst($kv->{body},   $ctx)),
                   'resolved');
    }
}

# Snapshot chat_sessions from the target daemon so the session/target
# BrowseEntry dropdowns can offer known names. Returns a list of
# hashrefs sorted by name; empty list on any failure (daemon down,
# table missing on a fresh install, etc). Deliberately quiet — the
# fallback (empty dropdown, freeform typing) is a fine degraded mode.
sub fetch_chat_sessions {
    my $cli = eval {
        NetMgr::Client->new(listen => $listen_var, timeout => 5);
    };
    return () unless $cli;
    my $ok = eval { $cli->hello(consumer => "autoresponder-gui.$$"); 1 };
    unless ($ok) {
        eval { $cli->bye };
        return ();
    }
    my $rows = eval { $cli->snapshot(1, 'chat_sessions') };
    eval { $cli->bye };
    return () unless ref($rows) eq 'ARRAY';
    for my $r (@$rows) {
        delete @{$r}{qw(op sub table mode)};
    }
    return sort { ($a->{name} // '') cmp ($b->{name} // '') } @$rows;
}

# Enable Save only when trigger AND channel are both explicitly picked
# (non-blank). The empty '(pick one)' sentinel value fails this check
# so a fresh rule can't be Saved without the operator picking both
# sinks — the click just silently no-ops instead of firing an
# 'Invalid rule' dialog for a trivially unfinished form. Guarded on
# $save_btn because build_editor_form runs during the Tk skeleton
# setup, before the action bar has been created.
sub update_save_state {
    return unless defined $save_btn;
    my $trig = $E{fields}{trigger} // '';
    my $chan = $E{fields}{channel} // '';
    my $state = (length $trig && length $chan) ? 'normal' : 'disabled';
    $save_btn->configure(-state => $state);
}

sub _snapshot {
    my ($table, %args) = @_;
    my $cli = eval {
        NetMgr::Client->new(listen => $listen_var, timeout => 5);
    };
    if (!$cli) {
        _test_line("connect $listen_var failed: $@\n", 'err');
        return undef;
    }
    my $ok = eval { $cli->hello(consumer => "autoresponder-gui.$$"); 1 };
    if (!$ok) {
        _test_line("HELLO failed: $@\n", 'err');
        eval { $cli->bye }; return undef;
    }
    my $rows = eval { $cli->snapshot(1, $table, %args) };
    if ($@ || !defined $rows) {
        my $e = $@; chomp $e;
        _test_line("snapshot $table failed: $e\n", 'err');
        eval { $cli->bye }; return undef;
    }
    # Client->snapshot leaves the wire envelope on each row; strip so
    # rule fields see just the columns (Multi::snapshot_all:198-200).
    for my $r (@$rows) {
        delete @{$r}{qw(op sub table mode)};
    }
    eval { $cli->bye };
    return $rows;
}

# Substitution mirroring the daemon's subst(). Kept small — only the
# token vocabulary the rule engine supports.
sub _subst {
    my ($s, $ctx) = @_;
    return '' unless defined $s;
    $s =~ s/\$\$/\x01/g;
    $s =~ s/
        \$\{
          ( peer_id | nickname | sender | session | now | host
          | cap\.[A-Za-z_][A-Za-z0-9_]*
          )
        \}
    / _subst_val($1, $ctx) /gex;
    $s =~ s/\x01/\$/g;
    return $s;
}

sub _subst_val {
    my ($tok, $ctx) = @_;
    if ($tok eq 'now') {
        my @t = gmtime;
        return sprintf('%02d:%02d:%02d', $t[2], $t[1], $t[0]);
    }
    if ($tok eq 'host') {
        unless (defined $HOST_CACHED) {
            require Sys::Hostname;
            $HOST_CACHED = Sys::Hostname::hostname() // '';
        }
        return $HOST_CACHED;
    }
    return defined $ctx->{$tok} ? $ctx->{$tok} : '';
}

sub _try_compile {
    my ($src) = @_;
    my $re;
    local $SIG{ALRM} = sub { die "timeout\n" };
    alarm 2;
    my $ok = eval { $re = qr/$src/; 1 };
    alarm 0;
    unless ($ok) {
        _test_line("regex compile failed: $@\n", 'err');
        return undef;
    }
    return $re;
}

sub _test_clear { $test_text->delete('1.0', 'end') }

sub _test_line {
    my ($t, @tags) = @_;
    $test_text->insert('end', $t, @tags ? [ @tags ] : ());
}

sub _truncate {
    my ($s, $n) = @_;
    return $s unless defined $s && length $s > $n;
    return substr($s, 0, $n) . '...';
}

# ====================================================================
# Misc helpers
# ====================================================================

sub set_status { $status_lbl->configure(-text => " $_[0]") }
sub msg {
    my ($title, $body) = @_;
    $mw->messageBox(-title => $title, -message => $body,
                    -type => 'OK', -icon => 'info');
    return undef;
}

1;
