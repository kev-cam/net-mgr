#!/usr/bin/perl
# net-report — query the net-mgr database via the manager socket.
#
# Usage:
#   net-report <table> [WHERE ...]      Snapshot a table (any of:
#                                       machines, hostnames, interfaces,
#                                       addresses, ports, aps, associations,
#                                       dhcp_leases, events).
#   net-report events --tail [WHERE ...] Stream events as they happen.
#   net-report --listen HOST:PORT       Override manager address.
#   net-report --columns COL,COL,...    Limit output columns.
#
# Examples:
#   net-report aps
#   net-report interfaces "online = 1"
#   net-report addresses "addr LIKE '192.168.15.%'"
#   net-report events --tail "type IN ('device_new','interface_offline')"

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling pass_through);
use NetMgr::Client;
use NetMgr::Protocol qw(parse_line);

my $listen;
my $tail;
my $columns;
my $absolute_time;
GetOptions(
    'listen=s'    => \$listen,
    'tail|f'      => \$tail,
    'columns=s'   => \$columns,
    'absolute|a'  => \$absolute_time,
) or die "bad options\n";

my @TABLES = qw(machines hostnames interfaces addresses ports aps
                associations dhcp_leases events);

# Column names hidden from the default-columns set (still selectable
# via --columns). Declared here, BEFORE the main flow calls print_table —
# `my %X = (...)` is runtime-initialized, so subs that close over it would
# see an empty hash if the assignment hadn't executed yet.
my %SKIP_BY_DEFAULT = (sub => 1, table => 1, op => 1, family => 1);

# Datetime-shaped column names — formatted as relative time unless
# --absolute was given. last_observed renders "never" when NULL —
# the column means "last live signal", so a paper-only entry has
# never been observed at all.
my %TIME_COL = map { $_ => 1 }
    qw(last_seen first_seen last_observed ts expires created_at applied_at);
my %TIME_COL_NEVER = (last_observed => 1);

my $table = shift @ARGV or die usage();
unless (grep { $_ eq $table } @TABLES) {
    die "unknown table '$table'\n\n" . usage();
}
my $where = @ARGV ? join(' ', @ARGV) : undef;
my @cols  = $columns ? split(/,/, $columns) : ();

sub usage {
    return "usage:\n"
         . "  net-report <table> [WHERE ...]\n"
         . "  net-report events --tail [WHERE ...]\n"
         . "  net-report <table> --columns COL,COL,...\n"
         . "  net-report --absolute <table>      # show absolute timestamps\n"
         . "  net-report --listen HOST:PORT <table>\n"
         . "\n"
         . "tables:\n"
         . "  " . join(', ', @TABLES) . "\n"
         . "\n"
         . "Default columns hide `family` (rows are almost always v4); pass it\n"
         . "explicitly via --columns to include it. Datetime columns (last_seen,\n"
         . "first_seen, ts, expires, created_at) are shown as relative ages\n"
         . "(`5m`, `2h`, `3d`); use --absolute to see the raw timestamp.\n"
         . "\n"
         . "examples:\n"
         . "  net-report aps\n"
         . "  net-report interfaces \"online = 1\"\n"
         . "  net-report addresses \"addr LIKE '192.168.15.%'\"\n"
         . "  net-report events --tail \"type IN ('device_new','interface_offline')\"\n";
}

my $cli = NetMgr::Client->new(listen => $listen);
$cli->hello(consumer => "net-report.$$");

if ($tail) {
    # Stream subscribe — print rows as they arrive.
    my $line = "SUBSCRIBE sub=1 mode=stream FROM $table";
    $line .= " WHERE $where" if defined $where;
    $cli->send_line($line);
    $| = 1;
    while (defined(my $reply = $cli->recv_line)) {
        my $cmd = parse_line($reply);
        next unless $cmd;
        if ($cmd->{verb} eq 'ROW') { print_row($cmd->{kv}, \@cols) }
        elsif ($cmd->{verb} eq 'ERR') { warn "ERR $cmd->{msg}\n"; last }
        # ignore OK
    }
} else {
    my $rows = $cli->snapshot(1, $table, defined $where ? (where => $where) : ());
    enrich_with_machine_names($cli, $rows) if rows_have_mac($rows);
    sort_rows_by_ip($rows);
    print_table($rows, \@cols);
}

$cli->bye;

# True if every row has a 'mac' column — then we can join to a machine name.
sub rows_have_mac {
    my ($rows) = @_;
    return 0 unless @$rows;
    return defined $rows->[0]{mac};
}

# Mutates $rows in place: adds 'machine' column with the linked machine's
# primary_name (looked up via interfaces.machine_id → machines.primary_name).
# Two extra snapshots — fine at our scale (small LAN, no streaming).
sub enrich_with_machine_names {
    my ($cli, $rows) = @_;
    my $ifaces = $cli->snapshot(101, 'interfaces');
    my $machs  = $cli->snapshot(102, 'machines');
    my %iface_by_mac = map { lc $_->{mac} => $_ } @$ifaces;
    my %name_by_id   = map { $_->{id} => $_->{primary_name} } @$machs;
    for my $r (@$rows) {
        my $mac = lc($r->{mac} // '');
        my $iface = $iface_by_mac{$mac} or next;
        my $name  = $name_by_id{ $iface->{machine_id} // '' };
        $r->{machine} = $name if defined $name && length $name;
    }
}

# If rows have an addr (or ip) column, sort them numerically by it.
# Non-IP values sort to the end. No-op if neither column is present.
sub sort_rows_by_ip {
    my ($rows) = @_;
    return unless @$rows;
    my $field;
    for my $f (qw(addr ip)) {
        if (grep { defined $_->{$f} } @$rows) { $field = $f; last }
    }
    return unless $field;
    @$rows = sort {
        ip_sort_key($a->{$field}) cmp ip_sort_key($b->{$field})
    } @$rows;
}

sub ip_sort_key {
    my $v = shift // '';
    return '9' x 16 unless $v =~ /^(\d+)\.(\d+)\.(\d+)\.(\d+)$/;
    return sprintf "%03d.%03d.%03d.%03d", $1, $2, $3, $4;
}

sub print_table {
    my ($rows, $cols) = @_;
    return unless @$rows;

    # Column set: explicit, else union of keys (minus protocol noise + family)
    my @keys;
    if (@$cols) {
        @keys = @$cols;
    } else {
        my %seen;
        for my $r (@$rows) {
            for my $k (sort keys %$r) {
                next if $SKIP_BY_DEFAULT{$k};
                $seen{$k} = 1;
            }
        }
        @keys = sort keys %seen;
    }

    # In-place: format datetime columns as relative ages (with "never"
    # for last_observed when null)
    unless ($absolute_time) {
        for my $r (@$rows) {
            for my $k (@keys) {
                next unless $TIME_COL{$k};
                $r->{$k} = relative_time($r->{$k}, $k);
            }
        }
    }

    # Compute widths
    my %w = map { $_ => length $_ } @keys;
    for my $r (@$rows) {
        for my $k (@keys) {
            my $v = $r->{$k} // '';
            $w{$k} = length $v if length $v > $w{$k};
        }
    }
    my $fmt = join('  ', map { "%-$w{$_}s" } @keys) . "\n";
    printf $fmt, @keys;
    printf $fmt, map { '-' x $w{$_} } @keys;
    for my $r (@$rows) {
        printf $fmt, map { $r->{$_} // '' } @keys;
    }
}

# "2026-04-26 22:43:20" → "5m" (or whatever fits). Returns the original
# string if it doesn't look like a DATETIME, and undef-or-empty pass through.
sub relative_time {
    my ($v, $col) = @_;
    if (!defined $v || $v eq '') {
        return 'never' if $col && $TIME_COL_NEVER{$col};
        return '';
    }
    return $v unless $v =~ /^(\d{4})-(\d\d)-(\d\d) (\d\d):(\d\d):(\d\d)/;
    require Time::Local;
    my $epoch = eval { Time::Local::timelocal($6, $5, $4, $3, $2-1, $1) };
    return $v unless defined $epoch;
    my $age = time() - $epoch;
    return age_str($age);
}

sub age_str {
    my $s = shift;
    if ($s < 0)         { return sprintf "in %s", age_str(-$s) }
    if ($s <  60)       { return "${s}s" }
    if ($s <  60*60)    { return sprintf "%dm", int($s/60) }
    if ($s <  24*3600)  { return sprintf "%dh", int($s/3600) }
    if ($s < 365*86400) { return sprintf "%dd", int($s/86400) }
    return sprintf "%dy", int($s/(365*86400));
}

sub print_row {
    my ($r, $cols) = @_;
    my @keys = @$cols ? @$cols
                      : grep { !$SKIP_BY_DEFAULT{$_} } sort keys %$r;
    my @out;
    for my $k (@keys) {
        my $v = $r->{$k};
        $v = relative_time($v, $k) if !$absolute_time && $TIME_COL{$k};
        push @out, defined $v ? "$k=$v" : "$k=";
    }
    print join(' ', @out), "\n";
}
