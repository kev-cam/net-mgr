#!/usr/bin/perl
# net-ssh — drop-in `ssh` wrapper that resolves the destination host
# via net-lookup before invoking real ssh.  Useful when ~/.ssh/config
# has a Hostname rewrite that no longer resolves (split-horizon DNS,
# stale alias, etc.) but net-mgr knows the host's current IP.
#
# Walks the same arg vector ssh does, identifies the [user@]host (the
# first non-option), and rewrites the host part to an IP looked up via
# `net-lookup HOST.*`.  If no user is supplied on the command line,
# `ssh -G HOST` is consulted so the original alias's User= directive is
# still honoured (otherwise rewriting the host to an IP would lose it).
# Falls through unchanged if the destination is already a numeric IP,
# net-lookup can't find a match, or there's no destination at all.

use strict;
use warnings;

# Single-letter ssh flags whose following token is an argument.  Pulled
# from ssh(1) — the rest are standalone flags.  Long-form options use
# -o, which is in this list.
my %ARG_FLAGS = map { ('-' . $_) => 1 }
    qw(B b c D E e F I i J L l m O o p Q R S W w);

my @new_argv;
my $dest;
my $i = 0;
while ($i < @ARGV) {
    my $a = $ARGV[$i];
    if (!defined $dest) {
        # Attached arg form: -iFILE, -pPORT, -oOpt=Val.  Pass through.
        if ($a =~ /^-[BbcDEeFIiJLlmOopQRSWw].+$/) {
            push @new_argv, $a;
            $i++; next;
        }
        # Detached arg form: -i FILE, -p PORT, -o Opt=Val.
        if ($ARG_FLAGS{$a}) {
            push @new_argv, $a, $ARGV[$i+1] // '';
            $i += 2; next;
        }
        # Standalone flag.
        if ($a =~ /^-/) {
            push @new_argv, $a;
            $i++; next;
        }
        # First non-option token: the destination.
        $dest = $a;
        push @new_argv, resolve_dest($a);
        $i++; next;
    }
    push @new_argv, $a;
    $i++;
}

if (!defined $dest) {
    # No destination — covers `ssh --version` etc.  Pass through unchanged.
    exec 'ssh', @ARGV;
    die "exec ssh: $!\n";
}

exec 'ssh', @new_argv;
die "exec ssh: $!\n";

sub resolve_dest {
    my ($d) = @_;
    my ($user, $host);
    if ($d =~ /^([^@]+)\@(.+)$/) { ($user, $host) = ($1, $2) }
    else                         {                  $host = $d }

    # Numeric IPv4 literal — nothing to resolve.
    return $d if $host =~ /^\d+\.\d+\.\d+\.\d+\z/;

    # net-lookup takes a regex; 'HOST.*' covers the bare name and any
    # FQDN form that starts with it.  First IPv4 in the reply wins;
    # net-lookup already filters to live hosts by default.
    my $ip;
    if (open my $fh, '-|', 'net-lookup', "$host.*") {
        while (my $line = <$fh>) {
            chomp $line;
            next unless $line =~ /^(\d+\.\d+\.\d+\.\d+)\z/;
            $ip = $1;
            last;
        }
        close $fh;
    }
    return $d unless defined $ip;

    # No user on the command line → pull one from ssh config so a
    # 'Host zmc1\n  User wdkc' stanza still wins after the rewrite.
    if (!defined $user) {
        if (open my $fh, '-|', 'ssh', '-G', $host) {
            while (my $line = <$fh>) {
                chomp $line;
                if ($line =~ /^user\s+(\S+)$/) { $user = $1; last }
            }
            close $fh;
        }
    }
    return defined $user ? "$user\@$ip" : $ip;
}
