#!/usr/bin/perl
# net-diag — host-level network diagnostics. Four modes:
#
#   net-diag                       # local: introspect THIS host
#                                  # (no daemon contact)
#   net-diag --remote HOST[:PORT]  # remote: same introspection done
#                                  # by the daemon there, via
#                                  # POLL host-debug
#   net-diag NAME-OR-IP            # DB lookup: dump everything the
#                                  # local daemon knows about that
#                                  # machine (snapshots its tables)
#   net-diag --watch               # periodic-check mode: sample every
#                                  # 5s, report to stdout / chat / ...
#                                  # optionally --repair on failure
#
# The local + remote modes don't need any DB knowledge — they ask
# the host (or its daemon) about its own interfaces, routes, DNS
# resolver config, DHCP client/server state, and listeners on the
# usual network ports. Useful when chasing rogue DHCP, DNS confusion,
# missing default routes, etc.
#
# DB-lookup mode (the original net-diag) treats the argument as an
# IP if it parses as one (v4 or v6), otherwise as a Perl regex
# anchored to the full name and matched against machines.primary_name,
# hostnames, aliases, and friendly_names. Multiple matches are
# printed in turn.
#
# --watch mode is a resident diagnostic. Each 5s tick (see --interval):
#   - looks up the default v4 gateway (ip -4 route show default),
#   - pings gateway + 8.8.8.8,
#   - runs a fresh DNS lookup (dig +time=2 +tries=1 against the gateway
#     for a random-labeled probe under example.invalid) so caches
#     never mask a broken resolver — same discipline as clevo's
#     watcher,
#   - captures wifi bssid / signal / nmcli state when the default
#     iface is wifi,
#   - assigns a verdict (ok | degraded | down) from those samples.
# With --repair, K consecutive 'down' verdicts trigger a reconnect:
# wifi -> `nmcli device disconnect <iface> && nmcli device connect
# <iface>`; ethernet -> `ip link set <iface> down/up` (or dhclient
# -r/-1 if we have it). 60s cooldown between repairs. --report=<sink>
# publishes each tick's line to stdout (default), a chat session,
# a file, or syslog — multiple --report flags fan out to all.
#
# Options:
#   --remote HOST[:PORT]    run host-debug against a remote daemon
#   --listen HOST[:PORT]    daemon endpoint (DB mode + --report=chat)
#                           (default 127.0.0.1:7531)
#   --no-dns                DB mode: skip local-resolver lookups
#   --no-rdns               DB mode: skip reverse DNS only
#   --raw                   DB mode: don't translate '<ip>:<method>'
#                           source fields to '<hostname>:<method>'
#   --watch                 enter periodic-check mode (5s default)
#   --interval=N            watch cadence in seconds (>=2, default 5)
#   --repair                on K=2 consecutive 'down' verdicts,
#                           attempt an interface reconnect
#   --report=SPEC           publish each tick to a sink; repeatable.
#                           SPEC := KIND[:TARGET].  KINDs:
#                             stdout             (default)
#                             chat:SESSION       via loopback daemon
#                             file:PATH          appended, line-buffered
#                             syslog[:FACILITY]  logger(1), default user
#   -h / --help
#
# Exit: 0 on success · 1 on no match (DB mode) · 2 on bad args
#       · 4 on daemon connection failure (--remote)

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use Socket qw(inet_pton inet_ntop AF_INET AF_INET6);
use Time::HiRes qw(time sleep);
use POSIX ();

use NetMgr::Client;

my ($listen, $remote, $no_dns, $no_rdns, $raw, $help);
my ($watch, $interval, $repair);
my @report_specs;
GetOptions(
    'listen=s'  => \$listen,
    'remote=s'  => \$remote,
    'no-dns'    => \$no_dns,
    'no-rdns'   => \$no_rdns,
    'raw'       => \$raw,
    'watch'     => \$watch,
    'interval=i'=> \$interval,
    'repair'    => \$repair,
    'report=s'  => \@report_specs,
    'help|h'    => \$help,
) or usage(2);
usage(0) if $help;
usage(2) if @ARGV > 1;

# --watch is only meaningful without a positional DB-lookup arg.
# --repair / --interval / --report only make sense with --watch (or
# implicitly with the local/remote no-arg modes, but we scope them
# to --watch to keep the one-shot modes unchanged).
if (@ARGV && ($watch || $repair || defined $interval || @report_specs)) {
    print STDERR "net-diag: --watch/--repair/--interval/--report are "
               . "incompatible with a positional NAME|IP argument.\n";
    usage(2);
}
if (!$watch && ($repair || defined $interval || @report_specs)) {
    print STDERR "net-diag: --repair/--interval/--report require --watch.\n";
    usage(2);
}
if (defined $interval && $interval < 2) {
    print STDERR "net-diag: --interval must be >= 2 seconds (got $interval)\n";
    usage(2);
}

# Mode dispatch:
#   --watch                     → cmd_watch (loop, sinks, optional repair)
#   no positional + no --remote → local host introspection (one-shot)
#   no positional + --remote     → remote-via-daemon host introspection
#   one positional               → DB lookup against local daemon
#                                  (--remote ignored — they're orthogonal)
if ($watch) {
    cmd_watch(
        interval => ($interval // 5),
        repair   => $repair,
        specs    => (@report_specs ? \@report_specs : ['stdout']),
        listen   => $listen,
    );
    exit 0;
}
if (!@ARGV) {
    if (defined $remote) {
        do_remote_host_debug($remote);
    } else {
        do_local_host_debug();
    }
    exit 0;
}

my $arg = $ARGV[0];

# ---- pull snapshots --------------------------------------------------

my %args; $args{listen} = $listen if defined $listen;
my $cli = NetMgr::Client->new(%args, timeout => 5);
$cli->hello(consumer => "net-diag.$$");

my $machines    = $cli->snapshot(1, 'machines');
my $ifaces      = $cli->snapshot(2, 'interfaces');
my $addresses   = $cli->snapshot(3, 'addresses');
my $hostnames   = $cli->snapshot(4, 'hostnames');
my $aliases     = $cli->snapshot(5, 'aliases');
my $friendly    = $cli->snapshot(6, 'friendly_names');
my $associations= $cli->snapshot(7, 'associations');
my $dhcp_leases = $cli->snapshot(8, 'dhcp_leases');
my $ports       = $cli->snapshot(9, 'ports');
$cli->bye;

# ---- indexes --------------------------------------------------------

my %machine_by_id  = map { $_->{id} => $_ } @$machines;
my %name_by_id     = map { $_->{id} => $_->{primary_name} }
                     grep { defined $_->{primary_name} } @$machines;
my %iface_by_mac;
my %ifaces_by_mid;
for my $i (@$ifaces) {
    next unless $i->{mac};
    $iface_by_mac{ lc $i->{mac} } = $i;
    if (defined $i->{machine_id} && length $i->{machine_id}) {
        push @{ $ifaces_by_mid{ $i->{machine_id} } }, $i;
    }
}
my %addrs_by_mac;
push @{ $addrs_by_mac{ lc $_->{mac} } }, $_ for grep { $_->{mac} } @$addresses;
my %hostnames_by_mid;
push @{ $hostnames_by_mid{ $_->{machine_id} } }, $_ for grep { defined $_->{machine_id} } @$hostnames;
my %aliases_by_mid;
push @{ $aliases_by_mid{ $_->{machine_id} } }, $_ for grep { defined $_->{machine_id} } @$aliases;
my %friendly_by_mid;
push @{ $friendly_by_mid{ $_->{machine_id} } }, $_ for grep { defined $_->{machine_id} } @$friendly;
my %assoc_by_client;
push @{ $assoc_by_client{ lc $_->{client_mac} } }, $_ for grep { $_->{client_mac} } @$associations;
my %lease_by_mac;
push @{ $lease_by_mac{ lc $_->{mac} } }, $_ for grep { $_->{mac} } @$dhcp_leases;
my %ports_by_mac;
push @{ $ports_by_mac{ lc $_->{mac} } }, $_ for grep { $_->{mac} } @$ports;

# IP → hostname lookup table (for translating source field).
my %name_for_ip;
for my $a (@$addresses) {
    next unless $a->{addr} && $a->{mac};
    my $i = $iface_by_mac{ lc $a->{mac} } or next;
    next unless defined $i->{machine_id};
    my $n = $name_by_id{ $i->{machine_id} } or next;
    $name_for_ip{ $a->{addr} } //= $n;
}

# ---- resolve $arg → list of machine_ids -----------------------------

my @mids;
if (my ($fam, $canon) = parse_ip($arg)) {
    my $af = $fam eq 'v4' ? AF_INET : AF_INET6;
    my %seen;
    for my $a (@$addresses) {
        next unless $a->{addr};
        my $bin = inet_pton($af, $a->{addr}) or next;
        next unless inet_ntop($af, $bin) eq $canon;
        my $i = $iface_by_mac{ lc $a->{mac} } or next;
        next unless defined $i->{machine_id};
        push @mids, $i->{machine_id} unless $seen{ $i->{machine_id} }++;
    }
} else {
    my $rx = eval { qr/^(?:$arg)$/ };
    die "bad regex '$arg': $@\n" if $@;
    my %seen;
    for my $m (@$machines) {
        next unless $m->{primary_name};
        push @mids, $m->{id} if $m->{primary_name} =~ $rx && !$seen{ $m->{id} }++;
    }
    for my $row (@$hostnames, @$aliases, @$friendly) {
        next unless $row->{name} && defined $row->{machine_id};
        push @mids, $row->{machine_id}
            if $row->{name} =~ $rx && !$seen{ $row->{machine_id} }++;
    }
}

unless (@mids) {
    print STDERR "net-diag: no machine matches '$arg'\n";
    exit 1;
}

for my $mid (@mids) { print_machine($mid) }
exit 0;

# =====================================================================
# Per-machine report
# =====================================================================

sub print_machine {
    my ($mid) = @_;
    my $m = $machine_by_id{$mid};
    unless ($m) {
        printf "==[ (machine_id=%d, no row) ]==\n", $mid;
        return;
    }

    printf "\n==[ %s  (machine_id=%d) ]==\n",
        $m->{primary_name} // '(no primary_name)', $mid;
    printf "  online=%s  last_seen=%s%s\n",
        ($m->{online} ? 'yes' : 'no'),
        ($m->{last_seen} // '(never)'),
        ($m->{notes} ? "  notes=\"$m->{notes}\"" : '');

    # Interfaces + their addresses + AP association.
    my @if = sort { ($a->{kind}//'') cmp ($b->{kind}//'')
                 || ($a->{mac}//'') cmp ($b->{mac}//'') }
             @{ $ifaces_by_mid{$mid} || [] };
    if (!@if) {
        print "  (no interfaces)\n";
    } else {
        printf "\nInterfaces (%d):\n", scalar @if;
        for my $i (@if) {
            print_iface($i);
        }
    }

    print_names($mid, $m);
    print_ports($mid, \@if);
    print_dns($mid, $m, \@if) unless $no_dns;
}

sub print_iface {
    my ($i) = @_;
    printf "  %s  %-9s  %-20s  online=%-3s  last_observed=%s\n",
        $i->{mac}, ($i->{kind} // '?'), trunc($i->{vendor} // '', 20),
        ($i->{online} ? 'yes' : 'no'),
        ($i->{last_observed} // '(never)');

    my @a = sort { ($a->{family}//'') cmp ($b->{family}//'')
                || ($a->{addr}//'') cmp ($b->{addr}//'') }
            @{ $addrs_by_mac{ lc $i->{mac} } || [] };
    for my $aa (@a) {
        my $src = $aa->{source} // '(unknown)';
        $src = pretty_source($src) unless $raw;
        printf "    %-39s  source=%-32s  last_observed=%s",
            $aa->{addr}, $src, ($aa->{last_observed} // '(never)');
        if (defined $aa->{last_rtt_ms}) {
            printf "  rtt=%.1fms", $aa->{last_rtt_ms};
            printf "(min %.1f)", $aa->{min_rtt_ms} if defined $aa->{min_rtt_ms};
        }
        print "\n";
    }

    # WiFi association (this iface as the client side).
    if (lc($i->{kind} // '') eq 'wifi') {
        for my $as (@{ $assoc_by_client{ lc $i->{mac} } || [] }) {
            my $ap_iface = $iface_by_mac{ lc $as->{ap_mac} };
            my $ap_name  = $ap_iface && defined $ap_iface->{machine_id}
                         ? ($name_by_id{ $ap_iface->{machine_id} } // '?')
                         : '?';
            printf "    associated → AP %s (%s)  signal=%-4s  ssid=%-16s  last_seen=%s\n",
                $as->{ap_mac}, $ap_name,
                (defined $as->{signal} ? "$as->{signal}dBm" : '?'),
                ($as->{ssid} // '?'),
                ($as->{last_seen} // '?');
        }
    }

    # DHCP lease (live record from the lease table).
    for my $L (@{ $lease_by_mac{ lc $i->{mac} } || [] }) {
        my $via_ap = $L->{ap_mac} ? " via AP $L->{ap_mac}" : '';
        printf "    DHCP lease %s%s%s  expires=%s  last_seen=%s\n",
            ($L->{ip} // '?'),
            ($L->{hostname} ? " (hostname=$L->{hostname})" : ''),
            $via_ap,
            ($L->{expires} // '?'),
            ($L->{last_seen} // '?');
    }
}

sub print_names {
    my ($mid, $m) = @_;
    my @h = map { "$_->{name} (src=$_->{source})" }
            @{ $hostnames_by_mid{$mid} || [] };
    my @a = map {
        my $cidr = $_->{prefer_subnet_cidr};
        $cidr ? "$_->{name} → $cidr" : $_->{name};
    } @{ $aliases_by_mid{$mid} || [] };
    my @f = map { $_->{name} } @{ $friendly_by_mid{$mid} || [] };

    print "\nNames known to net-mgr:\n";
    printf "  primary    %s\n", $m->{primary_name} // '(none)';
    printf "  hostnames  %s\n", @h ? join(', ', @h) : '(none)';
    printf "  aliases    %s\n", @a ? join(', ', @a) : '(none)';
    printf "  friendly   %s\n", @f ? join(', ', @f) : '(none)';
}

sub print_ports {
    my ($mid, $ifs) = @_;
    my %p;
    for my $i (@$ifs) {
        for my $row (@{ $ports_by_mac{ lc $i->{mac} } || [] }) {
            my $key = "$row->{port}/$row->{proto}";
            $p{$key} //= {
                port => $row->{port}, proto => $row->{proto},
                service => $row->{service}, last_seen => $row->{last_seen},
            };
        }
    }
    return unless %p;
    my @rows = sort {
        $a->{port} <=> $b->{port} || $a->{proto} cmp $b->{proto}
    } values %p;
    printf "\nKnown open ports (%d):\n", scalar @rows;
    for my $r (@rows) {
        printf "  %5d/%-3s  %-16s  last_seen=%s\n",
            $r->{port}, $r->{proto}, ($r->{service} // '-'),
            ($r->{last_seen} // '?');
    }
}

sub print_dns {
    my ($mid, $m, $ifs) = @_;

    # Names to resolve forward: primary + every hostname + every alias.
    my @names;
    push @names, $m->{primary_name} if $m->{primary_name};
    push @names, $_->{name} for @{ $hostnames_by_mid{$mid} || [] };
    push @names, $_->{name} for @{ $aliases_by_mid{$mid} || [] };
    push @names, $_->{name} for @{ $friendly_by_mid{$mid} || [] };
    my %seen;
    @names = grep { !$seen{$_}++ } @names;

    # IPs to resolve reverse: every address on every interface.
    my @ips;
    for my $i (@$ifs) {
        for my $a (@{ $addrs_by_mac{ lc $i->{mac} } || [] }) {
            push @ips, $a->{addr} if $a->{addr};
        }
    }
    my %seen_i; @ips = grep { !$seen_i{$_}++ } @ips;

    print "\nDNS view (this host's resolver):\n";
    print "  forward:\n";
    for my $n (@names) {
        my @r = dns_forward($n);
        printf "    %-30s → %s\n",
            $n, @r ? join(', ', @r) : '(no record)';
    }
    unless ($no_rdns) {
        print "  reverse:\n";
        for my $ip (@ips) {
            my $name = dns_reverse($ip);
            printf "    %-39s → %s\n",
                $ip, $name // '(no PTR)';
        }
    }
}

# =====================================================================
# Helpers
# =====================================================================

sub pretty_source {
    my ($s) = @_;
    return $s unless $s =~ /^(\d+\.\d+\.\d+\.\d+):(.+)$/;
    my ($ip, $tail) = ($1, $2);
    my $name = $name_for_ip{$ip} // return $s;
    return "$name:$tail";
}

sub parse_ip {
    my ($s) = @_;
    return unless defined $s && length $s;
    if (my $b = inet_pton(AF_INET, $s))  { return ('v4', inet_ntop(AF_INET, $b)) }
    if (my $b = inet_pton(AF_INET6, $s)) { return ('v6', inet_ntop(AF_INET6, $b)) }
    return;
}

sub dns_forward {
    my ($name) = @_;
    return () unless defined $name && length $name;
    my @r = gethostbyname($name);
    return () unless @r >= 5;
    my @addrs;
    for my $a (@r[4..$#r]) {
        next unless defined $a && length($a) == 4;
        push @addrs, inet_ntop(AF_INET, $a);
    }
    return @addrs;
}

sub dns_reverse {
    my ($ip) = @_;
    my $bin = inet_pton(AF_INET, $ip) or return undef;
    my $name = gethostbyaddr($bin, AF_INET);
    return $name && length $name ? $name : undef;
}

sub trunc {
    my ($s, $n) = @_;
    return $s if length($s) <= $n;
    return substr($s, 0, $n - 1) . '…';
}

sub do_local_host_debug {
    require NetMgr::HostDebug;
    print NetMgr::HostDebug::format_report();
}

sub do_remote_host_debug {
    my ($spec) = @_;
    my %a;
    $a{listen} = $spec if defined $spec && length $spec;
    my $cli = eval { NetMgr::Client->new(%a, timeout => 8) };
    if ($@ || !$cli) {
        my $msg = $@ // 'connect failed';
        $msg =~ s/\s+at\s+\S+\s+line\s+\d+\.?$//;
        print STDERR "net-diag: cannot reach daemon at $spec: $msg\n";
        exit 4;
    }
    $cli->hello(consumer => "net-diag.$$");
    my $out = eval { $cli->poll('host-debug') };
    if ($@ || !defined $out) {
        my $msg = $@ // 'no output';
        $msg =~ s/\s+at\s+\S+\s+line\s+\d+\.?$//;
        print STDERR "net-diag: POLL host-debug failed: $msg\n";
        exit 4;
    }
    eval { $cli->bye };
    print $out;
}

# =====================================================================
# --watch mode
# =====================================================================

# Watch-mode thresholds. Kept as constants so operators can eyeball
# them here rather than digging through per-tick code.
use constant {
    WATCH_DOWNS_FOR_REPAIR   => 2,     # K consecutive downs -> repair
    WATCH_REPAIR_COOLDOWN_S  => 60,    # min gap between repair attempts
    WATCH_RTT_DEGRADED_MS    => 250,   # elevated but non-loss RTT
    WATCH_DNS_DEGRADED_MS    => 500,
    WATCH_PING_TIMEOUT_S     => 1,     # -W arg to ping (per-tick budget)
    WATCH_DNS_TIMEOUT_S      => 2,     # dig +time=
};

sub cmd_watch {
    my (%a) = @_;
    my $interval = $a{interval};
    my $do_repair = $a{repair};
    my @sinks = map { _open_sink($_, $a{listen}) } @{ $a{specs} };

    if ($do_repair && $> != 0) {
        _emit_all(\@sinks,
            "[net-diag] --repair as non-root: link/DHCP cycles will be "
          . "delegated to the loopback daemon's REPAIR verb "
          . "(direct ip/nmcli shell-outs would fail without CAP_NET_ADMIN).");
    }

    my $hostname = _watch_hostname();
    _emit_all(\@sinks, sprintf("[net-diag] watch start host=%s interval=%ds%s",
        $hostname, $interval, ($do_repair ? " repair=on" : "")));

    my $consecutive_downs = 0;
    my $last_repair_ts    = 0;

    local $SIG{INT}  = sub { _emit_all(\@sinks, "[net-diag] SIGINT — exiting");
                             _close_sinks(\@sinks); exit 0 };
    local $SIG{TERM} = sub { _emit_all(\@sinks, "[net-diag] SIGTERM — exiting");
                             _close_sinks(\@sinks); exit 0 };

    while (1) {
        my $tick = _watch_tick();
        _emit_all(\@sinks, _watch_format_line($tick));

        my $v = $tick->{verdict} // 'down';
        if ($v eq 'down') { $consecutive_downs++ }
        else              { $consecutive_downs = 0 }

        if ($do_repair
            && $consecutive_downs >= WATCH_DOWNS_FOR_REPAIR
            && (time() - $last_repair_ts) >= WATCH_REPAIR_COOLDOWN_S)
        {
            my $verb = _watch_repair($tick, \@sinks);
            $last_repair_ts = time();
            $consecutive_downs = 0;
            # After a repair, wait one full interval before the next
            # check so DHCP / association has a chance to converge.
            _emit_all(\@sinks,
                "[net-diag/repair] $verb — settling ${interval}s before "
              . "next check");
        }

        sleep $interval;
    }
}

# One tick's worth of measurements. All fields optional; verdict is
# derived at the end.
sub _watch_tick {
    my %t;
    $t{ts} = POSIX::strftime('%Y-%m-%d %H:%M:%S', localtime);

    my ($gw_ip, $gw_iface, $iface_kind) = _watch_default_route();
    $t{gw_ip}         = $gw_ip;
    $t{iface_default} = $gw_iface;
    $t{iface_kind}    = $iface_kind;

    my $gw_probe   = _watch_ping($gw_ip);
    my $inet_probe = _watch_ping('8.8.8.8');
    my $dns_probe  = _watch_dns($gw_ip);

    $t{gw_rtt_ms}   = $gw_probe->{rtt_ms};
    $t{gw_ok}       = $gw_probe->{ok};
    $t{inet_rtt_ms} = $inet_probe->{rtt_ms};
    $t{inet_ok}     = $inet_probe->{ok};
    $t{dns_ms}      = $dns_probe->{rtt_ms};
    $t{dns_ok}      = $dns_probe->{ok};

    if (defined $gw_iface && defined $iface_kind && $iface_kind eq 'wifi') {
        my $w = _watch_wifi_info($gw_iface);
        $t{wifi_bssid}  = $w->{bssid};
        $t{wifi_signal} = $w->{signal};
    }
    $t{nm_state} = _watch_nm_state();

    # Verdict:
    #   down     if gateway is unreachable, or both inet + dns fail
    #   degraded if any single probe fails, or RTT elevated
    #   ok       otherwise
    my $fails =    ($gw_probe->{ok}   ? 0 : 1)
                 + ($inet_probe->{ok} ? 0 : 1)
                 + ($dns_probe->{ok}  ? 0 : 1);
    if (!$gw_probe->{ok} || $fails >= 2) {
        $t{verdict} = 'down';
    } elsif ($fails == 1) {
        $t{verdict} = 'degraded';
    } elsif ((defined $t{gw_rtt_ms}   && $t{gw_rtt_ms}   > WATCH_RTT_DEGRADED_MS)
          || (defined $t{inet_rtt_ms} && $t{inet_rtt_ms} > WATCH_RTT_DEGRADED_MS)
          || (defined $t{dns_ms}      && $t{dns_ms}      > WATCH_DNS_DEGRADED_MS)) {
        $t{verdict} = 'degraded';
    } else {
        $t{verdict} = 'ok';
    }
    return \%t;
}

sub _watch_format_line {
    my ($t) = @_;
    my @bits;
    push @bits, "[$t->{ts}]";
    push @bits, "verdict=$t->{verdict}";
    push @bits, "iface=" . ($t->{iface_default} // '?')
              . "(" . ($t->{iface_kind} // '?') . ")";
    push @bits, "gw="   . ($t->{gw_ip} // '?')
              . "=" . _watch_fmt_rtt($t->{gw_ok},   $t->{gw_rtt_ms});
    push @bits, "inet=" . _watch_fmt_rtt($t->{inet_ok}, $t->{inet_rtt_ms});
    push @bits, "dns="  . _watch_fmt_rtt($t->{dns_ok},  $t->{dns_ms});
    if (defined $t->{wifi_bssid} || defined $t->{wifi_signal}) {
        my $w = "wifi=" . ($t->{wifi_bssid} // '?');
        $w .= "/" . $t->{wifi_signal} if defined $t->{wifi_signal};
        push @bits, $w;
    }
    push @bits, "nm=$t->{nm_state}" if defined $t->{nm_state};
    return join(' ', @bits);
}

sub _watch_fmt_rtt {
    my ($ok, $rtt) = @_;
    return 'LOSS' unless $ok;
    return defined $rtt ? sprintf("%.1fms", $rtt) : 'ok';
}

# Default v4 route → (gw_ip, iface, kind). Kind derived by
# reusing NetMgr::HostDebug::_classify_iface so wifi/ethernet
# classification matches what the one-shot report uses.
sub _watch_default_route {
    my $out = `ip -4 route show default 2>/dev/null`;
    return (undef, undef, undef) unless defined $out;
    # 'default via 192.168.15.252 dev wlp3s0 proto dhcp metric 20101'
    my ($via)  = $out =~ /\bvia\s+(\S+)/;
    my ($dev)  = $out =~ /\bdev\s+(\S+)/;
    return (undef, undef, undef) unless $via && $dev;
    require NetMgr::HostDebug;
    my $kind = NetMgr::HostDebug::_classify_iface($dev, []);
    return ($via, $dev, $kind);
}

sub _watch_ping {
    my ($target) = @_;
    return { ok => 0, rtt_ms => undef, note => 'no target' }
        unless defined $target && length $target;
    my $tout = WATCH_PING_TIMEOUT_S;
    my $out  = `ping -c 1 -W $tout -n -q $target 2>&1`;
    my $rc   = $? >> 8;
    if ($rc == 0) {
        # 'rtt min/avg/max/mdev = X/Y/Z/W ms'
        if ($out =~ m{rtt[^=]*=\s*[\d.]+/([\d.]+)/}) {
            return { ok => 1, rtt_ms => $1 + 0 };
        }
        return { ok => 1, rtt_ms => undef };
    }
    return { ok => 0, rtt_ms => undef };
}

# Fresh DNS lookup against the gateway. Uses a random label under
# example.invalid so no resolver ever answers from cache — same
# discipline as clevo's watcher.  A NXDOMAIN answer counts as a
# working resolver (we care about the round-trip, not the record).
sub _watch_dns {
    my ($gw) = @_;
    return { ok => 0, rtt_ms => undef, note => 'no gw' }
        unless defined $gw && length $gw;
    my $rand = sprintf("probe-%08x", int(rand(0xffffffff)));
    my $label = "$rand.example.invalid";
    my $tout  = WATCH_DNS_TIMEOUT_S;
    my $t0    = time();
    my $out   = `dig +time=$tout +tries=1 \@$gw $label A 2>&1`;
    my $rc    = $? >> 8;
    my $elapsed_ms = (time() - $t0) * 1000;
    # dig exit 0 = got a reply (even NXDOMAIN). 9 = no reply.
    # Try to parse ';; Query time: N msec' first — it's the
    # server-observed RTT and more accurate than wall-clock.
    if ($rc == 0) {
        my $q = ($out =~ /Query time:\s*(\d+)\s*msec/) ? $1 + 0 : $elapsed_ms;
        return { ok => 1, rtt_ms => $q };
    }
    return { ok => 0, rtt_ms => undef };
}

sub _watch_wifi_info {
    my ($iface) = @_;
    my %r;
    my $out = `iw dev $iface link 2>/dev/null`;
    if ($out) {
        ($r{bssid})  = $out =~ /Connected to\s+([0-9a-f:]{17})/i;
        ($r{signal}) = $out =~ /signal:\s*(-?\d+)/;
        $r{signal} = "$r{signal}dBm" if defined $r{signal};
    }
    return \%r;
}

sub _watch_nm_state {
    return undef unless _watch_have('nmcli');
    my $out = `nmcli -t -f STATE general 2>/dev/null`;
    return undef unless defined $out;
    chomp $out;
    return $out || undef;
}

sub _watch_have {
    my ($cmd) = @_;
    for my $dir (split /:/, ($ENV{PATH} // '')) {
        return 1 if -x "$dir/$cmd";
    }
    return 0;
}

sub _watch_hostname {
    chomp(my $h = `hostname 2>/dev/null`);
    return $h || 'unknown';
}

# --- repair ladder ---------------------------------------------------
#
# Called only when K consecutive 'down' verdicts have accumulated AND
# the cooldown has elapsed. Picks wifi vs ethernet from the default
# iface's classification. Returns a short verb ('wifi cycle',
# 'ethernet cycle', 'no default iface — nothing to repair') for the
# post-repair log message.
sub _watch_repair {
    my ($tick, $sinks) = @_;
    my $iface = $tick->{iface_default};
    my $kind  = $tick->{iface_kind};
    unless (defined $iface && length $iface) {
        _emit_all($sinks,
            "[net-diag/repair] no default route — nothing to cycle");
        return "no-op (no default iface)";
    }

    # Non-root delegates to the loopback daemon's REPAIR verb (which has
    # CAP_NET_ADMIN and enforces its own per-action [repair] gates). Root
    # keeps the direct shell-out path — no need to bounce through the daemon
    # when we can flip the interface ourselves. A daemon delegation failure
    # falls through to the direct shell-out ladder below so a wedged /
    # pre-REPAIR-verb daemon can't strand a stalled interface.
    my $via_daemon = ($> != 0);
    my $path_tag   = $via_daemon ? 'via-daemon' : 'direct-shell';

    if (defined $kind && $kind eq 'wifi') {
        _emit_all($sinks,
            "[net-diag/repair] wifi cycle iface=$iface ($path_tag)");
        if ($via_daemon) {
            my $ok = _watch_repair_via_daemon($sinks, 'wifi_cycle',
                                              iface => $iface);
            return "wifi cycle ($iface) via daemon" if $ok;
            _emit_all($sinks,
                "[net-diag/repair]   daemon delegation failed — "
              . "falling back to direct shell-out");
        }
        _watch_run($sinks, 'nmcli', 'device', 'disconnect', $iface);
        sleep 2;
        _watch_run($sinks, 'nmcli', 'device', 'connect', $iface);
        return "wifi cycle ($iface)";
    }
    # ethernet (or unclassified — treat like ethernet).
    _emit_all($sinks,
        "[net-diag/repair] ethernet cycle iface=$iface ($path_tag)");
    if ($via_daemon) {
        # ethernet_cycle is link down/up on the daemon; follow with a
        # dhcp_cycle so the interface actually gets a fresh lease. Only try
        # dhcp_cycle when the link cycle succeeded — if the daemon refused
        # the link cycle, the fall-through below runs the full local ladder.
        my $ok = _watch_repair_via_daemon($sinks, 'ethernet_cycle',
                                          iface => $iface);
        if ($ok) {
            _watch_repair_via_daemon($sinks, 'dhcp_cycle', iface => $iface);
            return "ethernet cycle ($iface) via daemon";
        }
        _emit_all($sinks,
            "[net-diag/repair]   daemon delegation failed — "
          . "falling back to direct shell-out");
    }
    _watch_run($sinks, 'ip', 'link', 'set', $iface, 'down');
    sleep 1;
    _watch_run($sinks, 'ip', 'link', 'set', $iface, 'up');
    if (_watch_have('dhclient')) {
        _watch_run($sinks, 'dhclient', '-r', $iface);
        _watch_run($sinks, 'dhclient', '-1', $iface);
    } elsif (_watch_have('dhcpcd')) {
        _watch_run($sinks, 'dhcpcd', '-k', $iface);
        _watch_run($sinks, 'dhcpcd', $iface);
    }
    return "ethernet cycle ($iface)";
}

# Delegate one REPAIR action to the loopback daemon. Returns true on OK,
# false on any failure (connect refused, HELLO refused, ERR reply, croak).
# All failure reasons are emitted to the sinks so the operator sees WHY
# delegation fell through to the direct shell ladder.
sub _watch_repair_via_daemon {
    my ($sinks, $action, %kv) = @_;
    my $cli = eval {
        NetMgr::Client->new(listen => '127.0.0.1:7531', timeout => 15);
    };
    if ($@ || !$cli) {
        my $e = $@ // 'connect failed';
        chomp $e;
        _emit_all($sinks, "[net-diag/repair]   daemon connect: $e");
        return 0;
    }
    my $ok = eval {
        $cli->hello(consumer => "net-diag-repair.$$");
        my $reply = $cli->repair(action => $action, %kv);
        _emit_all($sinks,
            "[net-diag/repair]   daemon $action -> $reply");
        1;
    };
    my $err = $@;
    eval { $cli->bye };
    if (!$ok) {
        chomp $err;
        _emit_all($sinks,
            "[net-diag/repair]   daemon $action failed: $err");
        return 0;
    }
    return 1;
}

sub _watch_run {
    my ($sinks, @cmd) = @_;
    my $out = `@cmd 2>&1`;
    my $rc  = $? >> 8;
    my $summary = "[net-diag/repair]   \$ @cmd  -> rc=$rc";
    _emit_all($sinks, $summary);
    if (defined $out && length $out) {
        for my $line (split /\n/, $out) {
            _emit_all($sinks, "[net-diag/repair]     $line");
        }
    }
    return $rc == 0;
}

# =====================================================================
# --report sinks
# =====================================================================
#
# Each sink is a hashref { emit => sub($text), close => sub() }.
# emit() may split on \n and post one message per line if the
# transport is line-oriented (chat, syslog); file/stdout write the
# whole string.
sub _open_sink {
    my ($spec, $listen) = @_;
    $spec //= 'stdout';
    my ($kind, $target) = split /:/, $spec, 2;
    $target //= '';
    return _open_sink_stdout()               if $kind eq 'stdout';
    return _open_sink_file($target)          if $kind eq 'file';
    return _open_sink_syslog($target)        if $kind eq 'syslog';
    return _open_sink_chat($target, $listen) if $kind eq 'chat';
    die "net-diag: unknown --report kind '$kind' "
      . "(expected chat:SESSION, file:PATH, syslog[:FACILITY], stdout)\n";
}

sub _open_sink_stdout {
    $| = 1;
    return {
        emit  => sub { my $t = shift; $t =~ s/\n?\z/\n/; print $t },
        close => sub { },
    };
}

sub _open_sink_file {
    my ($path) = @_;
    die "net-diag: --report=file: needs a PATH\n"
        unless defined $path && length $path;
    open my $fh, '>>', $path
        or die "net-diag: cannot open $path: $!\n";
    my $old = select $fh; $| = 1; select $old;
    return {
        emit  => sub { my $t = shift; $t =~ s/\n?\z/\n/; print $fh $t },
        close => sub { close $fh },
    };
}

sub _open_sink_syslog {
    my ($facility) = @_;
    $facility = 'user.info' unless defined $facility && length $facility;
    return {
        emit  => sub {
            my ($text) = @_;
            for my $line (split /\n/, $text) {
                next unless length $line;
                system('logger', '-t', 'net-diag', '-p', $facility, '--', $line);
            }
        },
        close => sub { },
    };
}

# Chat sink. On startup: open a NetMgr::Client on loopback, HELLO
# with a distinctive consumer id, and call chat_open on the target
# session (idempotent — same pattern as net-bitchat-bridge:234). Each
# emit() splits on newlines and chat_posts one message per line —
# net-chat has a documented multi-line bug so single-line-per-message
# is safest.
sub _open_sink_chat {
    my ($session, $listen) = @_;
    die "net-diag: --report=chat: needs a SESSION name\n"
        unless defined $session && length $session;
    chomp(my $hostname = `hostname 2>/dev/null`);
    $hostname ||= 'unknown';
    my $as = "net-diag\@$hostname";
    my %args; $args{listen} = $listen if defined $listen && length $listen;
    my $cli = eval {
        my $c = NetMgr::Client->new(%args, timeout => 5, as => $as);
        $c->hello(consumer => "net-diag.watch.$$");
        $c;
    };
    if ($@ || !$cli) {
        my $msg = $@ // 'connect failed';
        $msg =~ s/\s+at\s+\S+\s+line\s+\d+\.?$//;
        warn "net-diag: chat sink open failed ($msg); falling back "
           . "to stdout for this sink\n";
        return _open_sink_stdout();
    }
    eval { $cli->chat_open(name => $session) };
    warn "net-diag: chat_open($session) failed: $@" if $@;
    # Startup marker — visible confirmation the sink is live.
    eval { $cli->chat_post(session => $session,
                           body    => "[net-diag] watch online host=$hostname",
                           as      => $as) };
    return {
        emit => sub {
            my ($text) = @_;
            for my $line (split /\n/, $text) {
                next unless length $line;
                eval { $cli->chat_post(session => $session,
                                       body    => $line,
                                       as      => $as) };
                # Silently swallow post errors — the daemon might be
                # restarting; we don't want a chat blip to crash the
                # watcher.
            }
        },
        close => sub { eval { $cli->bye } },
    };
}

sub _emit_all {
    my ($sinks, $text) = @_;
    for my $s (@$sinks) { $s->{emit}->($text) }
}

sub _close_sinks {
    my ($sinks) = @_;
    for my $s (@$sinks) { $s->{close}->() }
}

sub usage {
    my ($rc) = @_;
    print STDERR <<"EOF";
Usage:
  net-diag                       # introspect THIS host (no daemon)
  net-diag --remote HOST[:PORT]  # introspect a remote host via its
                                 # net-mgr daemon (POLL host-debug)
  net-diag [opts] <name|IP>      # DB lookup against the local daemon
  net-diag --watch [--repair]    # periodic-check mode (gw/inet/dns
       [--interval N]            # ping every N s, K=2 downs -> repair)
       [--report=SPEC ...]

Local + remote modes report: interfaces (mac/kind/addrs/flags),
routes (v4 + v6), DNS resolver config (resolv.conf + resolvectl),
DHCP client/server processes + lease files, listeners on usual
ports, and active/enabled state of the common DHCP/DNS units.

DB-lookup mode (positional NAME or IP) reports what the daemon's
DB knows: interfaces, addresses with their source fields, WiFi AP
association, DHCP lease records, all known names, open ports, and
a fresh local-resolver DNS view.

Watch mode samples gateway + internet + DNS every --interval (5s
default) and reports a compact verdict line via each --report sink.
With --repair, 2 consecutive 'down' verdicts trigger a wifi or
ethernet cycle (60s cooldown). --report=SPEC is 'stdout',
'chat:SESSION', 'file:PATH', or 'syslog[:FACILITY]'; repeat to
publish to several sinks. --repair calls ip/nmcli/dhclient — run
under sudo or the repair path will no-op.

Options (DB-lookup mode):
  --listen HOST[:PORT]   daemon to query (default 127.0.0.1:7531)
  --no-dns               skip local-resolver DNS lookups
  --no-rdns              skip reverse DNS only
  --raw                  don't translate IP-shaped source prefixes
                         to hostnames

Options (watch mode):
  --watch                enter periodic-check mode
  --interval N           tick cadence in seconds (>=2, default 5)
  --repair               reconnect on K=2 consecutive 'down' verdicts
  --report=SPEC          repeatable sink; SPEC := KIND[:TARGET]
                         (stdout | chat:SESSION | file:PATH |
                          syslog[:FACILITY])
  --listen HOST[:PORT]   loopback daemon for --report=chat:*

Exit: 0 ok · 1 DB no-match · 2 bad args · 4 daemon connect.
EOF
    exit($rc // 0);
}
