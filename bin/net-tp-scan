#!/usr/bin/perl
# net-tp-scan — discover TP-Link Kasa smart plugs/strips on the network,
# query each for its outlet aliases + on/off state, and update net-mgr's
# DB:
#
#   * wifi_sockets gets one row per outlet (controller, outlet#,
#     name, state, controller_type).
#   * friendly_names gets the alias for single plugs (skipping
#     placeholder names like "TP-LINK_Power Strip_42").
#
# Replaces the older /usr/local/bin/tp-scan, which only printed and
# numbered strips inconsistently. Output mirrors tp-scan's per-outlet
# layout, with [1] / [0] marking on/off:
#
#   pwrplug0     192.168.15.200  1+ psu [1]                          (HS110)
#   pwrstrip0    192.168.15.190  TP-LINK_Power Strip_0CBF            (HS300)
#                                  1: Patio Network         [0]
#                                  2: Patio DVD             [0]
#                                  3: Patio Computer        [0]
#                                  ...
#
# Probes via hsx(1): without -tapo it execs hs100 (legacy abyss for
# HS100/HS110/HS300); with -tapo it runs the kasa Python CLI.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use JSON::PP qw(decode_json);
use NetMgr::Config;
use NetMgr::DB;
use NetMgr::Client;

my $listen;
my $dry_run;
my $force;
my $filter = 'pwr(plug|strip)';
my $help;
GetOptions(
    'listen=s'  => \$listen,
    'dry-run|n' => \$dry_run,
    'force'     => \$force,
    'filter=s'  => \$filter,
    'help|h'    => \$help,
) or die "bad options\n";

if ($help) {
    print <<'EOT';
net-tp-scan — query TP-Link plugs and pin aliases / outlet state.

  net-tp-scan                  Auto: find pwr(plug|strip)*, scan, update DB.
  net-tp-scan IP [IP ...]      Just these IPs (skips DB candidate lookup).
  net-tp-scan --filter REGEX   Custom auto-find regex (against primary_name).
  net-tp-scan --dry-run        Print but don't write to the DB.
  net-tp-scan --force          Overwrite friendly_names (default skips them
                               if already set; wifi_sockets is always
                               refreshed since state changes over time).
EOT
    exit 0;
}

# Build candidate list -----------------------------------------------

my $cli = NetMgr::Client->new(listen => $listen);
$cli->hello(consumer => "net-tp-scan.$$");
my $machines  = $cli->snapshot(1, 'machines');
my $ifaces    = $cli->snapshot(2, 'interfaces');
my $addresses = $cli->snapshot(3, 'addresses', where => "family = 'v4'");
my $friendly  = $cli->snapshot(4, 'friendly_names');
$cli->bye;

my %friendly_by_id = map { $_->{machine_id} => $_->{name} } @$friendly;
my %iface_by_machine;
push @{ $iface_by_machine{$_->{machine_id}} }, $_
    for grep { defined $_->{machine_id} } @$ifaces;
my %addr_by_mac;
push @{ $addr_by_mac{$_->{mac}} }, $_->{addr} for @$addresses;
my %machine_by_id = map { $_->{id} => $_ } @$machines;

my %id_by_ip;
for my $a (@$addresses) {
    next unless $a->{mac} && $a->{addr};
    my @ifs = grep { $_->{mac} eq $a->{mac} } @$ifaces;
    next unless @ifs && defined $ifs[0]{machine_id};
    $id_by_ip{$a->{addr}} //= $ifs[0]{machine_id};
}

my @candidates;
if (@ARGV) {
    for my $ip (@ARGV) {
        my $id = $id_by_ip{$ip};
        my $name = $id ? $machine_by_id{$id}{primary_name} // '' : '';
        push @candidates, { id => $id, name => $name, ip => $ip };
    }
} else {
    my $re = qr/$filter/i;
    for my $m (@$machines) {
        next unless $m->{primary_name} && $m->{primary_name} =~ $re;
        my $ifs = $iface_by_machine{$m->{id}} or next;
        my $ip;
        for my $i (@$ifs) {
            for my $a (@{ $addr_by_mac{$i->{mac}} || [] }) {
                next unless $a =~ /^\d+\.\d+\.\d+\.\d+$/;
                $ip = $a;
                last;
            }
            last if $ip;
        }
        next unless $ip;
        push @candidates, { id => $m->{id}, name => $m->{primary_name}, ip => $ip };
    }
}

if (!@candidates) {
    print "no candidates (filter: $filter)\n";
    exit 0;
}

# Probe + write ------------------------------------------------------

my $db;
unless ($dry_run) {
    my $cfg = NetMgr::Config->load(
        $ENV{NET_MGR_CONF} // '/etc/net-mgr/config');
    my $mycnf = (-r "$ENV{HOME}/.my.cnf") ? "$ENV{HOME}/.my.cnf"
              : (-r '/root/.my.cnf')      ? '/root/.my.cnf'
              : die "no readable .my.cnf for the [net-mgr] section\n";
    $db = NetMgr::DB->new(
        defaults_file => $mycnf,
        section       => $cfg->{mysql}{section},
        db            => $cfg->{mysql}{db},
    );
    $db->connect;
}

my $devices = 0; my $outlets_total = 0; my $silent = 0;
for my $c (sort { $a->{name} cmp $b->{name} } @candidates) {
    my $r = probe($c->{ip});
    if (!$r) {
        printf "  %-12s %-15s no response\n", $c->{name}, $c->{ip};
        $silent++;
        next;
    }
    $devices++;
    my $model = $r->{model} // '';
    if ($r->{type} eq 'plug') {
        printf "  %-12s %-15s %-30s [%s]  (%s)\n",
            $c->{name}, $c->{ip}, $r->{alias},
            (defined $r->{state} ? $r->{state} : '?'),
            $model;
        $outlets_total++;
        next unless $c->{id};
        if (!$dry_run) {
            $db->upsert_wifi_socket(
                machine_id      => $c->{id}, outlet => 0,
                name            => $r->{alias},
                state           => $r->{state},
                controller_type => $model,
            );
            # Single-outlet alias is a good display name unless the
            # user already pinned one.
            if (length $r->{alias}
                && $r->{alias} !~ /^(Strip_\d+|TP-LINK_(?:Power|Smart Plug))/
                && ($force || !exists $friendly_by_id{$c->{id}}))
            {
                $db->upsert_friendly_name(
                    machine_id => $c->{id},
                    name       => $r->{alias},
                    notes      => "from net-tp-scan ($c->{ip})",
                );
            }
        }
    } else {
        printf "  %-12s %-15s %-30s      (%s, %d outlets)\n",
            $c->{name}, $c->{ip}, $r->{alias}, $model,
            scalar @{ $r->{outlets} };
        for my $o (@{ $r->{outlets} }) {
            printf "  %-12s %-15s %2d: %-26s [%s]\n",
                '', '', $o->{outlet}, $o->{name},
                (defined $o->{state} ? $o->{state} : '?');
            $outlets_total++;
            next unless $c->{id};
            if (!$dry_run) {
                $db->upsert_wifi_socket(
                    machine_id      => $c->{id},
                    outlet          => $o->{outlet},
                    name            => $o->{name},
                    state           => $o->{state},
                    controller_type => $model,
                );
            }
        }
        # Don't pin the strip's own alias as friendly_name when it's
        # the placeholder. The primary_name (pwrstrip0) is more useful.
    }
}
printf "\n%d device(s), %d outlet(s) recorded, %d no-response\n",
       $devices, $outlets_total, $silent;

# ---- helpers -------------------------------------------------------

# Returns either:
#   { type => 'plug',  model, alias, state }
#   { type => 'strip', model, alias, outlets => [{outlet, name, state}, ...] }
# or undef on failure.
sub probe {
    my ($ip) = @_;

    # Try the JSON path first (hsx without -tapo execs hs100, which
    # speaks the abyss protocol used by HS100/HS110/HS300).
    my $out = `timeout 5 hsx \Q$ip\E info 2>/dev/null` // '';
    if (length $out) {
        my $j = eval { decode_json($out) };
        my $info = $j && $j->{system} && $j->{system}{get_sysinfo};
        if ($info) {
            my $alias = $info->{alias} // '';
            my $model = $info->{model} // '';
            $model =~ s/\(US\)$//;   # 'HS110(US)' → 'HS110'
            if ($info->{children} && ref $info->{children} eq 'ARRAY') {
                my @outlets;
                my $i = 1;
                for my $c (@{ $info->{children} }) {
                    push @outlets, {
                        outlet => $i++,
                        name   => $c->{alias} // "outlet$i",
                        state  => (defined $c->{state} ? $c->{state} + 0 : undef),
                    };
                }
                return {
                    type    => 'strip', model => $model,
                    alias   => $alias,  outlets => \@outlets,
                };
            }
            return {
                type  => 'plug',
                model => $model,
                alias => $alias,
                state => (defined $info->{relay_state}
                         ? $info->{relay_state} + 0 : undef),
            };
        }
    }

    # Fall back to tapo (kasa-python via hsx -tapo). Output is text
    # rather than JSON; keep it best-effort.
    $out = `timeout 8 hsx -tapo \Q$ip\E discover 2>/dev/null` // '';
    return undef unless length $out;
    my @blocks = split /(?=^==\s)/m, $out;
    return undef unless @blocks;
    # First block = device; subsequent ones = outlets if multi.
    my $first = shift @blocks;
    return undef unless $first =~ /==\s+(.+?)\s+(?:-\s+(\S+)\s+)?==/;
    my ($d_alias, $d_model) = ($1, $2 // '');
    if (!@blocks) {
        # Single device, parse Device state
        my $state;
        $state = 1 if $first =~ /Device state:\s+True/i;
        $state = 0 if $first =~ /Device state:\s+False/i;
        return { type => 'plug', model => $d_model,
                 alias => $d_alias, state => $state };
    }
    my @outlets;
    my $i = 1;
    for my $b (@blocks) {
        my ($alias) = $b =~ /==\s+(.+?)\s+(?:\(.*?\)\s+)?==/;
        next unless $alias;
        my $state;
        $state = 1 if $b =~ /State \(state\)[^:]*:\s+True/i
                   || $b =~ /Device state:\s+True/i;
        $state = 0 if $b =~ /State \(state\)[^:]*:\s+False/i
                   || $b =~ /Device state:\s+False/i;
        push @outlets, { outlet => $i++, name => $alias, state => $state };
    }
    return { type => 'strip', model => $d_model,
             alias => $d_alias, outlets => \@outlets };
}
