#!/usr/bin/perl
# net-lookup — regex name → best IP, picked from this caller's POV;
# also reverse: if the argument parses as an IPv4 or IPv6 address,
# returns the host's name(s).
#
# Usage:
#   net-lookup [--all] [--family v4|v6] [--listen HOST:PORT|--server NAME] <name-regex|IP>
#
# Forward (name → IP): the pattern is a Perl regex; net-lookup wraps
# it as ^(?:...)$ before matching, so 'nas3(|-.*)' matches nas3,
# nas3-up, nas3-down, nas3-dwn2. As a convenience, '=' anywhere in
# the pattern is rewritten to '.*' before compilation, so 'clevo='
# behaves like 'clevo.*' without needing shell quoting. Names searched:
# machines.primary_name, friendly_names, hostnames, aliases.
#
# Reverse (IP → name): when the argument is a valid v4 or v6 address,
# net-lookup looks it up in the addresses table, follows the MAC into
# interfaces.machine_id, and prints machines.primary_name (default)
# or every name we know for that machine (with --all). --family is
# inferred from the input. Paper-only addresses are honored on
# reverse — the user typed the IP explicitly.
#
# Each candidate IP is scored on path quality from this host:
#   +4  same /24 as one of our interface addresses (direct L2)
#   +2  the address is on a wired (ethernet) interface
#   +1  kernel-reachable (a route exists, even if via default)
#   +1  IP falls inside an alias's prefer_subnet_cidr (the user's
#       explicit hint)
# Ties are broken by min observed RTT (lower wins) then dotted quad.
# So the typical "wired same-/24" address at 7 beats a wifi same-/24
# address at 5; both beat a far-side wired at 3.
#
# Default output is the single best IP. --all prints every matching
# IP, highest-scored first, deduplicated.
#
# Exit codes: 0 = at least one match · 1 = no match · 2 = bad args.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use Socket qw(inet_pton inet_ntop AF_INET AF_INET6);
use Time::Local qw(timegm);
use IPC::Open2 qw(open2);

use NetMgr::Client;
use NetMgr::Config;

my $listen;
my $server;
my $all;
my $family = 'v4';
my $verify;
my $ping_only;
my $within = 3600;
my $include_stale;
my $verbose;
my $probe;
my $record_key;
my $keyname;
my $help;
GetOptions(
    'listen=s'      => \$listen,
    'server=s'      => \$server,
    'all|a'         => \$all,
    'family=s'      => \$family,
    'verify|v'      => \$verify,
    'ping-only'     => \$ping_only,
    'within=i'      => \$within,
    'include-stale' => \$include_stale,
    'verbose'       => \$verbose,
    'probe'         => \$probe,
    'record-key'    => \$record_key,
    'keyname=s'     => \$keyname,
    'help|h'        => \$help,
) or usage(2);
usage(0) if $help;

# Server resolution mirrors net-chat: --listen wins, else --server names a
# [servers] entry, else $NET_MGR_LISTEN, else the configured default, else
# loopback. (~/.config/net-mgr/config — see NetMgr::Config.)
if (!defined $listen) {
    if (defined $server) {
        $listen = NetMgr::Config->resolve_server($server)
            or die "net-lookup: unknown server '$server' (configure it in "
                 . (NetMgr::Config->user_path // '~/.config/net-mgr/config')
                 . " [servers])\n";
    } else {
        $listen = $ENV{NET_MGR_LISTEN}
               // NetMgr::Config->resolve_server(undef)
               // '127.0.0.1:7531';
    }
}
# --record-key <ip>: keyscan the IP and record its SSH host key(s) to the
# daemon (kind=ssh_host_key), optionally against --keyname NAME. net-ssh uses
# this after it resolves an alias; also runnable standalone.
if ($record_key) {
    usage(2) unless @ARGV == 1;
    exit(_record_host_keys($ARGV[0], $keyname, undef) ? 0 : 1);
}

usage(2) if @ARGV != 1;

my $pattern = $ARGV[0];

# If the argument parses as a v4 or v6 address, switch to the reverse
# branch: addresses → interfaces → machines → name(s). Returns and
# exits from inside; never falls through.
if (my ($fam, $canon) = _parse_ip($pattern)) {
    do_reverse($fam, $canon);
}

# MAC address — interfaces table lookup. Returns the addresses
# owned by that MAC (one per line), with --verbose appending the
# resolved host name(s) just like the regex path does.
if (my $mac = _parse_mac($pattern)) {
    do_mac($mac);
}

# Shorthand: '=' in the pattern stands in for '.*'. Lets the common
# prefix-match case ('clevo=' for 'clevo.*') skip the shell-quoting
# you'd otherwise need around '.*'. '=' isn't a regex metacharacter
# so the substitution is unambiguous.
(my $rx_src = $pattern) =~ s/=/.*/g;
my $rx = eval { qr/^(?:$rx_src)$/ };
die "bad regex '$pattern': $@\n" if $@;

# --- caller's local /24s --------------------------------------------
my @local_nets;     # list of [net_int, mask_int]
for my $line (`ip -br -4 addr show 2>/dev/null`) {
    chomp $line;
    my ($iface, undef, @addrs) = split ' ', $line;
    next if !$iface || $iface eq 'lo';
    for my $a (@addrs) {
        next unless $a =~ m{^(\d+\.\d+\.\d+\.\d+)/(\d+)$};
        my ($ip, $pl) = ($1, $2);
        my $ipi = _ip2int($ip) // next;
        my $m   = $pl == 0 ? 0 : ((0xffffffff << (32 - $pl)) & 0xffffffff);
        push @local_nets, [ $ipi & $m, $m ];
    }
}

# --- snapshot the tables we need ------------------------------------
my $cli = NetMgr::Client->new(listen => $listen, timeout => 5);
$cli->hello(consumer => "net-lookup.$$");
my $machines  = $cli->snapshot(1, 'machines');
my $hostnames = $cli->snapshot(2, 'hostnames');
my $friendly  = $cli->snapshot(3, 'friendly_names');
my $aliases   = $cli->snapshot(4, 'aliases');
my $ifaces    = $cli->snapshot(5, 'interfaces');
# Skip addresses that net-mgr has only ever heard about from
# dhcp.master / config imports (last_observed IS NULL). Those are
# "paper-only" entries — the IP exists in config but no producer has
# ever actually seen the device respond on it, so they're usually
# stale. --include-stale brings them back into the candidate pool.
my $where = "family = '$family'"
          . ($include_stale ? '' : ' AND last_observed IS NOT NULL');
my $addresses = $cli->snapshot(6, 'addresses', where => $where);
$cli->bye;

# --- index ----------------------------------------------------------
my %name2mids;        # name → arrayref of machine_id
my %alias_pref;       # alias name → prefer_subnet_cidr (when set)

for my $m (@$machines) {
    push @{ $name2mids{ $m->{primary_name} } }, $m->{id}
        if $m->{primary_name};
}
for my $f (@$friendly) {
    push @{ $name2mids{ $f->{name} } }, $f->{machine_id};
}
for my $h (@$hostnames) {
    push @{ $name2mids{ $h->{name} } }, $h->{machine_id};
}
for my $a (@$aliases) {
    push @{ $name2mids{ $a->{name} } }, $a->{machine_id};
    $alias_pref{ $a->{name} } = $a->{prefer_subnet_cidr}
        if $a->{prefer_subnet_cidr};
}

# Find machines whose name matches the regex, plus the prefer_subnet_cidr
# hint when it came in via an alias row. Keep the matched-name list
# per mid too — --verbose uses it to print "IP\tname1,name2,…".
my %matched_mids;             # mid => 1
my %matched_names_by_mid;     # mid => [names]
my @prefer_cidrs;             # explicit hints from matched aliases
for my $name (sort keys %name2mids) {
    next unless $name =~ $rx;
    for my $mid (@{ $name2mids{$name} }) {
        $matched_mids{$mid} = 1;
        push @{ $matched_names_by_mid{$mid} }, $name;
    }
    push @prefer_cidrs, $alias_pref{$name} if $alias_pref{$name};
}

if (!%matched_mids) {
    exit 1;
}

my %macs_by_mid;
push @{ $macs_by_mid{ $_->{machine_id} } }, $_->{mac}
    for grep { defined $_->{machine_id} && $_->{machine_id} } @$ifaces;
# kind per mac (ethernet / wifi / virtual / unknown). Used in scoring
# to prefer wired interfaces over wireless.
my %kind_by_mac = map { lc $_->{mac} => ($_->{kind} // 'unknown') }
                  grep { $_->{mac} } @$ifaces;
# Per-address metadata so scoring can consult RTT / loss without
# refetching. Keyed by the address string.
my %meta_by_addr;
my %addrs_by_mac;
for my $a (@$addresses) {
    next unless defined $a->{addr} && defined $a->{mac};
    push @{ $addrs_by_mac{ $a->{mac} } }, $a->{addr};
    $meta_by_addr{ $a->{addr} } = {
        mac           => lc $a->{mac},
        min_rtt_ms    => $a->{min_rtt_ms},
        last_rtt_ms   => $a->{last_rtt_ms},
        loss_pct      => $a->{loss_pct},
        last_observed => $a->{last_observed},
    };
}

my %seen;
my @candidates;       # list of [score, rtt_for_tiebreak, ip, mid, last_observed]
for my $mid (keys %matched_mids) {
    for my $mac (@{ $macs_by_mid{$mid} || [] }) {
        for my $ip (@{ $addrs_by_mac{$mac} || [] }) {
            next if $seen{$ip}++;
            my $score = _score($ip, \@prefer_cidrs, \%kind_by_mac, \%meta_by_addr);
            my $meta  = $meta_by_addr{$ip} || {};
            my $rtt   = $meta->{min_rtt_ms} // 9999;
            my $lo    = $meta->{last_observed} // '';
            push @candidates, [ $score, $rtt, $ip, $mid, $lo ];
        }
    }
}

if (!@candidates) {
    exit 1;
}

# Sort: score desc, then most-recently-observed first (so a device that moved
# DHCP lease resolves to its current address, not the stale one with the same
# score), then RTT asc (fastest path), then IP asc as a deterministic tiebreak.
# last_observed is ISO "YYYY-MM-DD HH:MM:SS" so string cmp orders it by time.
@candidates = sort {
       $b->[0] <=> $a->[0]
    || ($b->[4] // '') cmp ($a->[4] // '')
    || $a->[1] <=> $b->[1]
    || _ipkey($a->[2]) cmp _ipkey($b->[2])
} @candidates;

# --verify: keep only IPs confirmed reachable. An address counts as reachable
# if the fleet observed it within --within seconds (cheap, and authoritative
# even from a host that can't reach it) OR it answers a live 1 s ping (catches
# a host that's reachable now but stale in the DB). Freshness is checked first
# so reachable hosts usually skip the ping. --ping-only forces a live ping for
# every candidate. Stops at the first responder unless --all is set.
my %ping_ms;          # ip -> live RTT (ms) when a verify ping got a reply
if ($verify) {
    my @alive;
    for my $c (@candidates) {
        my $ip = $c->[2];
        my ($ok, $rtt);
        if ($ping_only) {
            $rtt = _ping_time($ip);
            $ok  = defined $rtt;
        } else {
            my $fresh = _fresh($ip);
            # Ping to confirm reachability when stale, and always under
            # --verbose so we can report the time even for fresh hosts.
            $rtt = _ping_time($ip) if !$fresh || $verbose;
            $ok  = $fresh || defined $rtt;
        }
        next unless $ok;
        $ping_ms{$ip} = $rtt if defined $rtt;
        push @alive, $c;
        last unless $all;
    }
    @candidates = @alive;
    exit 1 unless @candidates;
}

my @to_print = $all ? @candidates : ($candidates[0]);
for my $c (@to_print) {
    if ($verbose) {
        my %seen_name;
        my @names = grep { !$seen_name{$_}++ }
                    @{ $matched_names_by_mid{ $c->[3] } || [] };
        my $line = sprintf "%s\t%s", $c->[2], join(',', @names);
        # --verify --verbose: annotate with the live ping time, or "# fresh"
        # when the address was kept on the fleet's observation, not a reply.
        if ($verify) {
            my $rtt = $ping_ms{ $c->[2] };
            $line .= defined $rtt ? sprintf("\t# %s ms", $rtt) : "\t# fresh";
        }
        print "$line\n";
    } else {
        print "$c->[2]\n";
    }
}
exit 0;

# Live RTT to $ip in ms, or undef if no reply within ~1 s. Forks (no shell)
# and silences stderr.
sub _ping_time {
    my ($ip) = @_;
    my $pid = open(my $fh, '-|');
    return undef unless defined $pid;
    if ($pid == 0) {
        open STDERR, '>', '/dev/null';
        exec('ping', '-c', '1', '-W', '1', '-n', $ip);
        exit 127;
    }
    my $rtt;
    while (my $l = <$fh>) {
        if ($l =~ /\btime[=<]([\d.]+)\s*ms/) { $rtt = $1 + 0; last }
    }
    close $fh;
    # A 0.000 ms "reply" to a remote IP is a slirp/NAT local fake (the giveaway
    # is time=0.000, icmp_seq stuck at 0, DUP!), not a real round trip — treat
    # it as no reply so verify doesn't keep phantom hosts.
    return ($rtt && $rtt > 0) ? $rtt : undef;
}

sub _ping_ok { return defined _ping_time($_[0]) }

# True when the daemon last observed $ip responding within --within seconds.
# last_observed is stored UTC ("YYYY-MM-DD HH:MM:SS[.ffffff]"); a missing or
# unparseable stamp counts as not-fresh.
sub _fresh {
    my ($ip) = @_;
    my $lo = ($meta_by_addr{$ip} || {})->{last_observed} or return 0;
    my @t = $lo =~ /^(\d+)-(\d+)-(\d+)[ T](\d+):(\d+):(\d+)/ or return 0;
    my $epoch = eval { timegm($t[5], $t[4], $t[3], $t[2], $t[1] - 1, $t[0]) };
    return 0 unless defined $epoch;
    return (time() - $epoch) <= $within;
}

# --probe: when the DB can't reverse-resolve an IP, ask the wire. Get its MAC
# (live ARP, else the MAC the DB already has for the address), ask it its own
# name over SSH, print whatever resolves, and OBSERVE kind=host back to the
# daemon so the MAC/address/name correlate for next time. Exits 0 on any hit.
sub _probe_ip {
    my ($ip, $db_macs, $ifaces, $machines) = @_;
    my $hit = 0;

    # MAC via live ARP (only works on the target's own L2 segment), else the
    # MAC the DB already associates with this address.
    system("ping -c 1 -W 1 -q -n $ip >/dev/null 2>&1");
    my $mac;
    for my $line (`ip neigh show $ip 2>/dev/null`) {
        if ($line =~ /\blladdr\s+([0-9a-f:]{17})/i) { $mac = lc $1; last }
    }
    $mac //= (@$db_macs ? lc $db_macs->[0] : undef);
    print STDERR "probe: $ip mac="
        . ($mac // 'unknown (no ARP entry on this segment)') . "\n";

    if (defined $mac) {
        my @n = _names_for_mac($mac, $ifaces, $machines);
        if (@n) { print "$_\n" for @n; $hit = 1 }
    }

    # Ask the host its own name over SSH (key auth only, fail fast).
    my $hn = _ssh_hostname($ip);
    print STDERR "probe: ssh hostname="
        . (defined $hn && length $hn ? $hn : '(unreachable / no key auth)') . "\n";
    if (defined $hn && length $hn) { print "$hn\n"; $hit = 1 }

    # Feed it back so net-mgr correlates the MAC/address (+name when we got one).
    if (defined $mac) {
        my $host = `hostname 2>/dev/null`; chomp $host; $host ||= 'net-lookup';
        my %obs = (kind => 'host', mac => $mac, ip => $ip,
                   source => "$host:probe");
        if (defined $hn && length $hn) {
            $obs{name} = $hn; $obs{name_source} = 'ssh';
        }
        my $cli = eval { NetMgr::Client->new(listen => $listen, timeout => 5) };
        if ($cli) {
            eval { $cli->hello(consumer => "net-lookup-probe.$$") };
            my $r = eval { $cli->observe(%obs) };
            eval { $cli->bye };
            if ($r && $r =~ /^ERR/) {
                print STDERR "probe: DB update rejected: $r\n";
            } else {
                print STDERR "probe: recorded $mac on $ip"
                    . (defined $obs{name} ? " as '$obs{name}'" : '')
                    . " to the daemon\n";
            }
        }
    }

    # SSH host key — a stable identity that survives IP/MAC changes, read with
    # no auth. Record it; if the daemon already knew this fingerprint, the IP
    # now resolves to its machine even when SSH auth and the MAC told us nothing.
    my $recorded = _record_host_keys($ip, (defined $hn && length $hn ? $hn : undef), $mac);
    if ($recorded && !$hit) {
        my $name = _resolve_ip_name($ip);
        if (defined $name && length $name) {
            print "$name\n";
            print STDERR "probe: identified $ip as '$name' via its SSH host key\n";
            $hit = 1;
        }
    }

    exit($hit ? 0 : 1);
}

sub _names_for_mac {
    my ($mac, $ifaces, $machines) = @_;
    my %mids;
    for my $i (@$ifaces) {
        $mids{ $i->{machine_id} } = 1
            if defined $i->{mac} && lc $i->{mac} eq $mac
            && defined $i->{machine_id} && length $i->{machine_id};
    }
    my (@names, %seen);
    for my $m (@$machines) {
        push @names, $m->{primary_name}
            if defined $m->{id} && $mids{ $m->{id} }
            && defined $m->{primary_name} && length $m->{primary_name}
            && !$seen{ $m->{primary_name} }++;
    }
    return @names;
}

# Ask $ip its own hostname over SSH — key auth only, short timeout, and don't
# touch known_hosts. Returns the trimmed name, or undef if SSH didn't answer.
sub _ssh_hostname {
    my ($ip) = @_;
    my $out = `ssh -o BatchMode=yes -o ConnectTimeout=3 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null $ip hostname 2>/dev/null`;
    return undef unless defined $out;
    $out =~ s/\s+//g;
    return length $out ? $out : undef;
}

# Normalise an ssh key-type token (ssh-ed25519, ecdsa-sha2-nistp256, ssh-rsa)
# to a short family name.
sub _normtype {
    my ($t) = @_;
    return 'ed25519' if $t =~ /ed25519/;
    return 'ecdsa'   if $t =~ /ecdsa/;
    return 'rsa'     if $t =~ /rsa/;
    return 'dsa'     if $t =~ /ds[sa]/;
    ($t //= '') =~ s/^ssh-//;
    return $t;
}

# Fingerprint "type b64" to its SHA256 id via ssh-keygen -lf - (no shell).
sub _fingerprint {
    my ($type, $b64) = @_;
    my ($out, $in);
    my $pid = eval { open2($out, $in, 'ssh-keygen', '-lf', '-') } or return undef;
    print {$in} "$type $b64\n";
    close $in;
    my $line = <$out>;
    close $out;
    waitpid($pid, 0);
    return ($line && $line =~ /\b(SHA256:\S+)/) ? $1 : undef;
}

# ssh-keyscan $ip and fingerprint each key — no auth, the host key is public.
# Returns ({ key_id => "SHA256:…", key_type => "ed25519" }, …). Forks rather
# than shelling out so an arbitrary $ip can't be injected, and silences
# ssh-keyscan's "# host SSH-2.0-…" banner (it goes to stderr).
sub _host_keys {
    my ($ip) = @_;
    my @keys;
    my $pid = open(my $ks, '-|');
    return @keys unless defined $pid;
    if ($pid == 0) {
        open STDERR, '>', '/dev/null';
        exec('ssh-keyscan', '-T', '3', $ip);
        exit 127;
    }
    while (my $line = <$ks>) {
        chomp $line;
        next if $line =~ /^\s*#/ || $line !~ /\S/;
        my (undef, $type, $b64) = split ' ', $line, 3;
        next unless $type && $b64;
        my $fp = _fingerprint($type, $b64) or next;
        push @keys, { key_id => $fp, key_type => _normtype($type) };
    }
    close $ks;
    return @keys;
}

# Keyscan $ip and OBSERVE each host key to the daemon (kind=ssh_host_key).
# $name (optional) is the machine the keys belong to (net-ssh knows the alias);
# $mac (optional) ties the address. Returns the number of keys recorded.
sub _record_host_keys {
    my ($ip, $name, $mac) = @_;
    my @keys = _host_keys($ip);
    unless (@keys) {
        print STDERR "host-key: ssh-keyscan got nothing from $ip\n";
        return 0;
    }
    my $cli = eval { NetMgr::Client->new(listen => $listen, timeout => 5) };
    unless ($cli) { print STDERR "host-key: cannot reach daemon\n"; return 0 }
    eval { $cli->hello(consumer => "net-lookup-hostkey.$$") };
    my $n = 0;
    for my $k (@keys) {
        my %obs = (kind => 'ssh_host_key', key_id => $k->{key_id},
                   key_type => $k->{key_type}, ip => $ip);
        $obs{mac}  = $mac  if defined $mac && length $mac;
        if (defined $name && length $name) {
            $obs{name} = $name; $obs{name_source} = 'ssh-keyscan';
        }
        my $r = eval { $cli->observe(%obs) };
        if ($r && $r =~ /^ERR/) {
            print STDERR "host-key: $k->{key_id} rejected: $r\n";
        } else {
            print STDERR "host-key: recorded $k->{key_type} $k->{key_id}"
                . (defined $name && length $name ? " for '$name'" : '') . " ($ip)\n";
            $n++;
        }
    }
    eval { $cli->bye };
    return $n;
}

# Fresh reverse lookup of $ip → primary_name (or undef). Used after a host-key
# OBSERVE to see whether the daemon just correlated the address.
sub _resolve_ip_name {
    my ($ip) = @_;
    my $cli = eval { NetMgr::Client->new(listen => $listen, timeout => 5) } or return undef;
    eval { $cli->hello(consumer => "net-lookup-reresolve.$$") };
    my $addresses = eval { $cli->snapshot(1, 'addresses', where => "addr = '$ip'") } || [];
    my $ifaces    = eval { $cli->snapshot(2, 'interfaces') } || [];
    my $machines  = eval { $cli->snapshot(3, 'machines') } || [];
    eval { $cli->bye };
    my %macs = map { lc $_->{mac} => 1 } grep { $_->{mac} } @$addresses;
    my %mids;
    for my $i (@$ifaces) {
        $mids{ $i->{machine_id} } = 1
            if $i->{mac} && $macs{ lc $i->{mac} }
            && defined $i->{machine_id} && length $i->{machine_id};
    }
    for my $m (@$machines) {
        return $m->{primary_name}
            if defined $m->{id} && $mids{ $m->{id} }
            && defined $m->{primary_name} && length $m->{primary_name};
    }
    return undef;
}

# --- reverse lookup -------------------------------------------------

# Returns (family, canonical-string) for v4 or v6, or empty list if
# the input isn't an IP address. Canonicalising via inet_ntop lets us
# compare across cosmetic differences ('::1' vs '0:0:...:1', upper vs
# lower hex, leading zeros).
sub _parse_ip {
    my ($s) = @_;
    return unless defined $s && length $s;
    if (my $bin = inet_pton(AF_INET, $s)) {
        return ('v4', inet_ntop(AF_INET, $bin));
    }
    if (my $bin = inet_pton(AF_INET6, $s)) {
        return ('v6', inet_ntop(AF_INET6, $bin));
    }
    return;
}

# Accepts MAC in any of the common forms:
#   aa:bb:cc:dd:ee:ff
#   AA-BB-CC-DD-EE-FF
#   aabbccddeeff
# Returns the canonical lowercase colon-separated form, or undef.
sub _parse_mac {
    my ($s) = @_;
    return undef unless defined $s;
    (my $hex = $s) =~ s/[:.-]//g;
    return undef unless $hex =~ /^[0-9a-fA-F]{12}$/;
    $hex = lc $hex;
    return join(':', $hex =~ /(..)/g);
}

# MAC → IPs (and names with --verbose). Same output shape as the
# name-regex path so the caller can pipe / parse uniformly.
sub do_mac {
    my ($mac) = @_;

    my $cli = NetMgr::Client->new(listen => $listen, timeout => 5);
    $cli->hello(consumer => "net-lookup.$$");
    my $ifaces    = $cli->snapshot(1, 'interfaces');
    my $addresses = $cli->snapshot(2, 'addresses', where => "family = 'v4'");
    my $machines  = $cli->snapshot(3, 'machines');
    my ($hostnames, $friendly, $aliases);
    if ($verbose) {
        $hostnames = $cli->snapshot(4, 'hostnames');
        $friendly  = $cli->snapshot(5, 'friendly_names');
        $aliases   = $cli->snapshot(6, 'aliases');
    }
    $cli->bye;

    my ($iface) = grep { defined $_->{mac} && lc $_->{mac} eq $mac } @$ifaces;
    exit 1 unless $iface;

    my @rows = grep { defined $_->{mac} && lc $_->{mac} eq $mac
                   && defined $_->{addr} } @$addresses;
    exit 1 unless @rows;

    # Freshest first (most recently observed — a device that changed DHCP
    # lease leaves an older address behind), then lowest IP as a stable
    # tiebreak. last_observed is ISO "YYYY-MM-DD HH:MM:SS" so string cmp
    # orders it chronologically.
    @rows = sort {
           ($b->{last_observed} // '') cmp ($a->{last_observed} // '')
        || _ipkey($a->{addr}) cmp _ipkey($b->{addr})
    } @rows;
    my @ips = map { $_->{addr} } @rows;
    @ips = ($ips[0]) unless $all;

    if (!$verbose) {
        print "$_\n" for @ips;
        exit 0;
    }

    # --verbose: print "IP<TAB>name1,name2,…". Names are all the
    # names we know for the machine that owns this MAC.
    my $mid = $iface->{machine_id};
    my %seen;
    my @names;
    for my $m (@$machines) {
        next unless defined $m->{id} && defined $mid && $m->{id} == $mid;
        push @names, $m->{primary_name}
            if defined $m->{primary_name} && length $m->{primary_name}
            && !$seen{$m->{primary_name}}++;
    }
    for my $row (@$hostnames, @$friendly, @$aliases) {
        my $rmid = $row->{machine_id};
        next unless defined $rmid && defined $mid && $rmid == $mid;
        push @names, $row->{name}
            if defined $row->{name} && length $row->{name}
            && !$seen{$row->{name}}++;
    }
    my $name_str = join(',', @names);
    print "$_\t$name_str\n" for @ips;
    exit 0;
}

sub do_reverse {
    my ($fam, $canon) = @_;
    my $af = $fam eq 'v4' ? AF_INET : AF_INET6;

    my $cli = NetMgr::Client->new(listen => $listen, timeout => 5);
    $cli->hello(consumer => "net-lookup.$$");
    my $addresses = $cli->snapshot(1, 'addresses', where => "family = '$fam'");
    my $ifaces    = $cli->snapshot(2, 'interfaces');
    my $machines  = $cli->snapshot(3, 'machines');
    my ($hostnames, $friendly, $aliases);
    if ($all) {
        $hostnames = $cli->snapshot(4, 'hostnames');
        $friendly  = $cli->snapshot(5, 'friendly_names');
        $aliases   = $cli->snapshot(6, 'aliases');
    }
    $cli->bye;

    # MACs that own this address (per the DB).
    my %macs;
    for my $a (@$addresses) {
        next unless defined $a->{addr} && defined $a->{mac};
        my $bin = inet_pton($af, $a->{addr}) or next;
        $macs{ $a->{mac} } = 1 if inet_ntop($af, $bin) eq $canon;
    }

    # Machine ids those MACs belong to, then the names of those machines
    # (primary_name; with --all also hostnames/friendly/aliases).
    my %mids;
    for my $i (@$ifaces) {
        next unless defined $i->{mac} && defined $i->{machine_id}
                                      && length $i->{machine_id};
        $mids{ $i->{machine_id} } = 1 if $macs{ $i->{mac} };
    }
    my @names;
    for my $m (@$machines) {
        next unless defined $m->{id} && $mids{ $m->{id} };
        push @names, $m->{primary_name}
            if defined $m->{primary_name} && length $m->{primary_name};
    }
    if ($all) {
        for my $row (@$hostnames, @$friendly, @$aliases) {
            my $mid = $row->{machine_id};
            next unless defined $mid && $mids{$mid};
            push @names, $row->{name}
                if defined $row->{name} && length $row->{name};
        }
    }
    my %seen;
    @names = grep { length && !$seen{$_}++ } @names;

    if (@names) {
        if ($all) { print "$_\n" for @names }
        else      { print "$names[0]\n" }
        exit 0;
    }

    # Nothing usable in the DB. With --probe, hit the wire: live ARP for the
    # MAC (else the DB-known one), an SSH hostname query, then record what we
    # learn back to the daemon so the orphan correlates next time.
    _probe_ip($canon, [ keys %macs ], $ifaces, $machines) if $probe;
    exit 1;
}

# --- helpers --------------------------------------------------------

sub _ip2int {
    my ($ip) = @_;
    return undef unless defined $ip
                    && $ip =~ /^(\d+)\.(\d+)\.(\d+)\.(\d+)$/;
    return ($1 << 24) | ($2 << 16) | ($3 << 8) | $4;
}

sub _ipkey {
    my $ip = shift // '';
    return '999.999.999.999' unless $ip =~ /^(\d+)\.(\d+)\.(\d+)\.(\d+)$/;
    return sprintf '%03d.%03d.%03d.%03d', $1, $2, $3, $4;
}

sub _score {
    my ($ip, $prefer, $kind_by_mac, $meta_by_addr) = @_;
    my $ipi = _ip2int($ip);
    return 0 unless defined $ipi;

    my $score = 0;

    # +4: same /24 as one of our local addresses → direct L2 access.
    # Strongest signal — same broadcast domain, no router hop.
    for my $n (@local_nets) {
        if (($ipi & $n->[1]) == $n->[0]) { $score += 4; last }
    }

    # +2: address is on a wired (ethernet) interface. Wired beats
    # WiFi for both throughput and reliability; this preference
    # matters when a host has both (e.g. nas3-up wired vs nas3-air
    # wifi, both on the same /24).
    my $meta = $meta_by_addr->{$ip};
    if ($meta && $kind_by_mac->{ $meta->{mac} } &&
        lc($kind_by_mac->{ $meta->{mac} }) eq 'ethernet') {
        $score += 2;
    }

    # +1: kernel knows how to route to it (even if not on our /24).
    # Trumps unreachable but loses to direct.
    if (_has_route($ip)) {
        $score += 1;
    }

    # +1: alias matched and pinned a preferred subnet that contains
    # this address. Lets `prefer_subnet_cidr` win when explicit.
    for my $cidr (@$prefer) {
        next unless $cidr =~ m{^(\d+\.\d+\.\d+\.\d+)/(\d+)$};
        my $ni = _ip2int($1) // next;
        my $m  = $2 == 0 ? 0 : ((0xffffffff << (32 - $2)) & 0xffffffff);
        if (($ipi & $m) == ($ni & $m)) { $score += 1; last }
    }
    return $score;
}

# Best-effort: does the kernel know how to send a packet to $ip ?
# `ip route get` returns non-zero (and the line 'unreachable …') when
# there's no route. Cached per process.
my %_route_cache;
sub _has_route {
    my ($ip) = @_;
    return $_route_cache{$ip} if exists $_route_cache{$ip};
    my $out = `ip route get $ip 2>&1`;
    my $rc  = $? >> 8;
    return $_route_cache{$ip} = ($rc == 0 && $out !~ /unreachable/) ? 1 : 0;
}

sub usage {
    my ($code) = @_;
    print <<USAGE;
net-lookup — resolve a regex name to the best IP for this caller, or
            an IP to its host name.

Usage:
  net-lookup [--all] [--verify [--ping-only] [--within SECONDS]]
             [--include-stale] [--verbose]
             [--family v4|v6] [--listen HOST:PORT | --server NAME]
             <name-regex|IP>

Forward (name → IP):
  net-lookup nas3                      # exact name
  net-lookup 'nas3(|-.*)'              # nas3, nas3-up, nas3-down, nas3-dwn2
  net-lookup clevo=                    # shorthand for 'clevo.*'
  net-lookup --all 'wndr.*'            # every IP for every wndr-* host
  net-lookup --verify gateway3=        # keep only reachable (ping on-subnet,
                                       #   else fleet-observed freshness)
  net-lookup --verbose nas3=           # IP<TAB>matched-name(s), one per line

The pattern is a Perl regex; net-lookup wraps it as ^(?:...)\$ before
matching against machines.primary_name, friendly_names, hostnames,
and aliases. As a shorthand, '=' anywhere in the pattern is rewritten
to '.*' before compilation — handy because '.*' usually needs shell
quoting.

Scoring (highest wins; ties broken by min RTT, then dotted quad):
  +4  same /24 as one of this host's interfaces (direct L2)
  +2  the address is on a wired (ethernet) interface
  +1  kernel-reachable (route exists)
  +1  IP is inside an alias's prefer_subnet_cidr (when the alias matched)

By default, paper-only addresses (last_observed IS NULL — known from
dhcp.master config but never actually seen on the wire) are excluded.
--include-stale brings them back into the pool.

--verify keeps only candidates confirmed reachable: an address is kept
if the fleet observed it within --within seconds (default 3600 — cheap,
and authoritative even from a host that can't reach it itself) OR it
answers a live 1 s ping (catches a host reachable now but stale in the
DB). Freshness is checked first, so reachable hosts usually skip the
ping. --ping-only forces a live ping for every candidate; --within tunes
the freshness window. Without --all, --verify stops at the first responder.
A 0.000 ms reply (a slirp/NAT local fake — DUP!, icmp_seq stuck at 0) is
not treated as reachable. With --verbose, each verified line is annotated
with the live ping time ("# 2.98 ms"), or "# fresh" when it was kept on
the fleet's observation rather than a live reply.

Default prints one IP. --all prints every match, best-scored first.
--verbose appends a TAB and the matching name(s) (comma-separated
when one IP matched via several names like primary_name + alias).

Reverse (IP → name):
  net-lookup 192.168.15.104            # primary_name for that machine
  net-lookup --all 192.168.15.104      # every name we know for it
  net-lookup 2001:db8::1               # IPv6 works the same way
  net-lookup --probe 192.168.223.93    # if the DB can't, ask the wire

Family is inferred from the input. The address is canonicalised with
inet_pton/inet_ntop so '::1' and '0:0:...:1' compare equal. Reverse
ignores --include-stale and --verify (the user typed the IP directly,
so we resolve regardless of liveness signal).

--probe is a wire fallback for a reverse lookup the DB can't answer (an
IP that's live but uncorrelated). It pings to learn the MAC (live ARP,
else the MAC the DB already has for the address), asks the host its own
name over SSH (key auth, 3 s), records the host's SSH host key (no auth)
so a fingerprint already on file resolves the IP straight to its machine,
prints whatever resolves, and OBSERVEs back to the daemon so it correlates
next time. MAC / SSH / host-key diagnostics go to stderr; names to stdout.

--record-key <ip> [--keyname NAME] keyscans the IP (no auth) and records
its SSH host key(s) against NAME via OBSERVE kind=ssh_host_key. A host key
is stable across IP and MAC changes, so this is the identity anchor for a
machine on a floating IP. net-ssh runs this automatically against the
alias it just resolved, seeding the map on normal use.

MAC (MAC → IP[+name]):
  net-lookup 00:e0:4c:68:00:b4         # IP(s) bound to that MAC
  net-lookup --all aa:bb:cc:dd:ee:ff   # every address for the MAC
  net-lookup --verbose 00e04c6800b4    # IP<TAB>name1,name2,…
                                        # (mac may be colon-, dash-, or
                                        #  unseparated; case-insensitive)

Exit 0 = found · 1 = no match · 2 = bad args.
USAGE
    exit($code // 0);
}
