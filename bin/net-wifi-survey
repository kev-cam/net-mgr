#!/usr/bin/perl
# net-wifi-survey — ssh into each known AP, run an RF survey, store
# the visible neighbours in wifi_scan_results, and print a channel-
# conflict report.
#
# Tries scan tools in order until one returns results:
#   1. wl -i wlN scan + sleep + wl -i wlN scanresults    (Broadcom/DD-WRT)
#   2. iw dev IFACE scan                                  (mac80211/Linux)
#   3. site_survey wlN                                    (older DD-WRT)
#
# APs whose firmware doesn't support any of those are skipped with a
# notice but don't fail the whole run.
#
# Usage:
#   net-wifi-survey [--ap HOST]   scan all (or one) AP; save to DB
#                                 and print conflict report
#   net-wifi-survey --no-save     skip the DB write
#   net-wifi-survey --from-db     don't re-scan; report from cached rows
#   net-wifi-survey --json        machine-readable output
#   net-wifi-survey --rssi-strong N    threshold for 'strong' (default -70)
#   net-wifi-survey --rssi-moderate N  threshold for 'moderate' (default -80)

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use NetMgr::Config;
use NetMgr::DB;
use IO::Select;
use Storable qw(nfreeze thaw);

my $only_ap;
my $no_save;
my $from_db;
my $json;
my $verbose;
my $ssh_user    = 'root';
my $ssh_timeout = 8;
my $rssi_strong   = -70;
my $rssi_moderate = -80;
my $help;
GetOptions(
    'ap=s'           => \$only_ap,
    'no-save'        => \$no_save,
    'from-db'        => \$from_db,
    'json'           => \$json,
    'verbose|v'      => \$verbose,
    'ssh-user=s'     => \$ssh_user,
    'ssh-timeout=i'  => \$ssh_timeout,
    'rssi-strong=i'  => \$rssi_strong,
    'rssi-moderate=i'=> \$rssi_moderate,
    'help|h'         => \$help,
) or usage(2);
usage(0) if $help;

sub usage {
    my ($rc) = @_;
    print <<'EOT';
net-wifi-survey — scan each known AP for neighbours; report channel conflicts.

  net-wifi-survey [--ap HOST]
  net-wifi-survey --no-save      don't update wifi_scan_results
  net-wifi-survey --from-db      skip live scan; report from DB cache
  net-wifi-survey --json         machine-readable output
  net-wifi-survey -v, --verbose  also list each individual neighbour

  --rssi-strong N   conflict if neighbour signal >= N dBm (default -70)
  --rssi-moderate N moderate threshold (default -80)
EOT
    exit $rc;
}

my $cfg = NetMgr::Config->load(
    $ENV{NET_MGR_CONF} // '/etc/net-mgr/config');
my $mycnf = (-r "$ENV{HOME}/.my.cnf") ? "$ENV{HOME}/.my.cnf"
          : (-r '/root/.my.cnf')      ? '/root/.my.cnf'
          : die "no readable .my.cnf for the [net-mgr] section\n";
my $db = NetMgr::DB->new(
    defaults_file => $mycnf,
    section       => $cfg->{mysql}{section},
    db            => $cfg->{mysql}{db},
);
$db->connect;

# -- AP inventory ---------------------------------------------------------
# Pull every AP from net-mgr's aps table, joined with addresses for the
# ssh-able IP.  --ap HOST scopes to one (name or IP).
sub list_aps {
    # GROUP BY mac to coalesce APs with multiple v4 addresses on the
    # same MAC — otherwise an AP that has both eth0 and a bridge
    # address recorded would show up (and get scanned) twice.  MIN(addr)
    # gives a stable pick across runs.
    my $rows = $db->dbh->selectall_arrayref(<<'SQL', { Slice => {} });
SELECT a.mac, MIN(a.ssid) AS ssid, MIN(ad.addr) AS addr,
       (SELECT primary_name FROM machines m
          JOIN interfaces i ON i.machine_id = m.id
         WHERE i.mac = a.mac LIMIT 1) AS name
  FROM aps a
  JOIN addresses ad ON ad.mac = a.mac AND ad.family = 'v4'
 GROUP BY a.mac
 ORDER BY MIN(ad.addr)
SQL
    return $rows;
}

my $aps = list_aps();
if (defined $only_ap) {
    $aps = [ grep {
        ($_->{name} // '') eq $only_ap
     || $_->{addr}             eq $only_ap
     || ($_->{mac} // '')      eq lc $only_ap
    } @$aps ];
    @$aps or die "net-wifi-survey: no AP matches '$only_ap'\n";
}

# -- live scan ------------------------------------------------------------
my $REMOTE_SCRIPT = <<'SH';
echo ===META===
hostname 2>/dev/null
echo ===WL_IFACES===
nvram show 2>/dev/null | grep -E '^wl[0-9]+_ifname=' || true
echo ===METHOD_WL===
for w in wl0 wl1; do
    bssid=$(wl -i $w bssid 2>/dev/null)
    if [ -n "$bssid" ] && [ "${bssid#wl:}" = "$bssid" ]; then
        echo IFACE $w
        wl -i $w scan >/dev/null 2>&1
        sleep 4
        wl -i $w scanresults 2>/dev/null
        echo ENDRESULTS
    fi
done
echo ===METHOD_IW===
for d in /sys/class/net/wl*; do
    [ -e "$d" ] || continue
    name=$(basename "$d")
    if iw dev "$name" info >/dev/null 2>&1; then
        echo IFACE $name
        iw dev "$name" scan 2>/dev/null
        echo ENDRESULTS
    fi
done
echo ===METHOD_SS===
# DD-WRT's site_survey with NO interface argument dumps the scan
# cache for every radio in one structured listing:
#   [ N] SSID[ name] BSSID[xx:xx:...] channel[ N] frequency[NNNN] ...
# Quirks to handle:
#   * the binary writes its output to STDERR, not stdout — capture 2>&1
#   * per-iface invocations ('site_survey wl0') often return count=0
#     even when results exist, so always use the bare form
#   * 'count=[0]' header means no results; skip in that case
out=$(site_survey 2>&1)
case "$out" in
  *"count=[0]"*) : ;;       # empty cache — nothing to report
  "") : ;;                  # nothing came back at all
  *)
    echo IFACE all
    echo "$out"
    echo ENDRESULTS
    ;;
esac
echo ===END===
SH

sub ssh_scan {
    my ($host) = @_;
    # Use net-ssh if installed alongside (rewrites the destination via
    # net-lookup so primary_name → live IP); plain ssh otherwise.
    my $net_ssh = "$FindBin::Bin/net-ssh";
    my $tool    = (-x $net_ssh) ? $net_ssh : 'net-ssh';
    my @cmd = ($tool,
        '-o', 'BatchMode=yes',
        '-o', 'LogLevel=ERROR',                # quiets the ssh client
        '-o', "ConnectTimeout=$ssh_timeout",
        '-o', 'StrictHostKeyChecking=accept-new',
        '-n', "$ssh_user\@$host",
        $REMOTE_SCRIPT,
    );
    # Fork-exec form so we can drop stderr — DD-WRT prints its motd
    # banner ('DD-WRT v3.0-r... / Release: ... / Board: ...') on stderr
    # of the remote shell and it leaks straight into the user's terminal
    # otherwise.  We don't need stderr from the scan itself either.
    my $pid = open(my $fh, '-|');
    return undef unless defined $pid;
    if ($pid == 0) {
        open STDERR, '>', '/dev/null';
        exec { $cmd[0] } @cmd;
        exit 127;
    }
    local $/;
    my $raw = <$fh>;
    close $fh;
    return $raw;
}

# Section-based dispatcher.  Each METHOD_* section emits one or more
# 'IFACE <name>' blocks followed by raw output, ended by ENDRESULTS.
# Whichever method produces non-empty parsed results wins per-iface.
sub parse_scan {
    my ($raw, $scanner_mac) = @_;
    return [] unless defined $raw;
    my @lines = split /\n/, $raw;

    my %by_iface_method;     # iface → method → [ {bssid,...}, ... ]
    my $section;
    my $cur_iface;
    my @block;
    my $flush = sub {
        return unless defined $cur_iface;
        my @parsed;
        if    ($section eq 'METHOD_WL') { @parsed = parse_wl_results(\@block) }
        elsif ($section eq 'METHOD_IW') { @parsed = parse_iw_scan(\@block)    }
        elsif ($section eq 'METHOD_SS') { @parsed = parse_site_survey(\@block)}
        $by_iface_method{$cur_iface}{$section} = \@parsed if @parsed;
        @block      = ();
        $cur_iface  = undef;
    };

    for my $ln (@lines) {
        if ($ln =~ /^===([A-Z_]+)===\s*$/) {
            $flush->();
            $section = $1;
            next;
        }
        next unless defined $section;
        if ($section =~ /^METHOD_/ && $ln =~ /^IFACE\s+(\S+)/) {
            $flush->();
            $cur_iface = $1;
            next;
        }
        if ($section =~ /^METHOD_/ && $ln eq 'ENDRESULTS') {
            $flush->();
            next;
        }
        push @block, $ln if defined $cur_iface;
    }
    $flush->();

    # Prefer methods in order: WL > IW > SS (matches the remote script's
    # detection order; the earliest that produced results is most
    # specific to the hardware).  For the site_survey path the iface
    # is recorded as 'all' since the bare invocation returns every
    # radio's results in one listing — split into wl0 / wl1 by band
    # so the per-radio report blocks remain meaningful.
    my @results;
    for my $iface (sort keys %by_iface_method) {
        my $m = $by_iface_method{$iface};
        my ($pick, $picked_method);
        for my $name (qw(METHOD_WL METHOD_IW METHOD_SS)) {
            if ($m->{$name} && @{ $m->{$name} }) {
                $pick = $m->{$name}; $picked_method = $name; last;
            }
        }
        next unless $pick;
        for my $r (@$pick) {
            my $assigned_iface = $iface;
            if ($iface eq 'all' && $picked_method eq 'METHOD_SS') {
                my $b = $r->{band} // '';
                $assigned_iface = $b eq '2.4GHz' ? 'wl0'
                                : $b eq '5GHz'   ? 'wl1'
                                : $b eq '6GHz'   ? 'wl2'
                                :                  'wl?';
            }
            $r->{scanner_iface} = $assigned_iface;
            $r->{scanner_mac}   = $scanner_mac;
            push @results, $r;
        }
    }
    return \@results;
}

# Broadcom wl scanresults format:
#   SSID: "foo"
#   Mode: Managed    RSSI: -75 dBm   ...   Channel: 6
#   BSSID: 00:11:22:33:44:55    Capability: ESS WEP
#   ... (multi-line block)
sub parse_wl_results {
    my ($lines) = @_;
    my @out;
    my %cur;
    my $flush = sub {
        push @out, { %cur } if $cur{bssid};
        %cur = ();
    };
    for my $ln (@$lines) {
        if ($ln =~ /^SSID:\s*"(.*?)"/) {
            $flush->();
            $cur{ssid} = $1;
        }
        elsif ($ln =~ /RSSI:\s*(-?\d+)/) { $cur{rssi_dbm} = $1 + 0 }
        if ($ln =~ /Channel:\s*(\d+)/)   { $cur{channel}  = $1 + 0 }
        if ($ln =~ /BSSID:\s*([0-9A-Fa-f:]{17})/) { $cur{bssid} = lc $1 }
        if ($ln =~ /Capability:.*\b(WPA2|WPA3|WPA|WEP)\b/) {
            $cur{encryption} //= $1;
        }
        if ($ln =~ /Channel width:\s*(\d+)/) { $cur{bandwidth_mhz} = $1 + 0 }
    }
    $flush->();
    for my $r (@out) {
        $r->{band} = guess_band($r->{channel});
    }
    return @out;
}

# `iw dev IFACE scan` format:
#   BSS xx:xx:xx:xx:xx:xx(on IFACE)
#       freq: 2412
#       signal: -75.00 dBm
#       SSID: foo
#       ... HT capabilities mark 2.4 or 5
sub parse_iw_scan {
    my ($lines) = @_;
    my @out;
    my %cur;
    my $flush = sub {
        push @out, { %cur } if $cur{bssid};
        %cur = ();
    };
    for my $ln (@$lines) {
        if ($ln =~ /^BSS\s+([0-9A-Fa-f:]{17})/) {
            $flush->();
            $cur{bssid} = lc $1;
        }
        elsif ($ln =~ /^\s+freq:\s+(\d+)/) {
            $cur{channel} = freq_to_channel($1 + 0);
            $cur{band}    = $cur{channel} && $cur{channel} <= 14
                            ? '2.4GHz' : '5GHz';
        }
        elsif ($ln =~ /^\s+signal:\s+(-?\d+(?:\.\d+)?)/) {
            $cur{rssi_dbm} = int($1);
        }
        elsif ($ln =~ /^\s+SSID:\s+(.*)$/) {
            $cur{ssid} = $1;
        }
        elsif ($ln =~ /\bRSN:|WPA2/) { $cur{encryption} //= 'WPA2' }
        elsif ($ln =~ /\bWPA:/)      { $cur{encryption} //= 'WPA'  }
    }
    $flush->();
    return @out;
}

# DD-WRT site_survey (bracketed-fields format).  One result per line:
#   [ N] SSID[ name ] BSSID[xx:xx:xx:xx:xx:xx] channel[ N] frequency[NNNN]
#        numsta[N] rssi[-NN] noise[-NN] beacon[NNN] cap[XXXX] dtim[N]
#        rate[NNN] enc[Group-... PSK2 ...]
# Each [ ... ] field can have leading/trailing whitespace inside the
# brackets; we strip it.  Band is derived from frequency, not channel —
# both 2.4GHz and 5GHz scan results come back in the same call.
sub parse_site_survey {
    my ($lines) = @_;
    my @out;
    for my $ln (@$lines) {
        next unless $ln =~ /^\s*\[\s*\d+\]\s/;
        my %f;
        while ($ln =~ /(\w+)\[\s*([^\]]*?)\s*\]/g) {
            $f{$1} = $2;
        }
        next unless $f{BSSID} && $f{BSSID} =~ /^[0-9A-Fa-f:]{17}$/;
        my $freq = $f{frequency};
        my $band;
        if (defined $freq && $freq =~ /^\d+$/) {
            $band = $freq < 3000 ? '2.4GHz'
                  : $freq < 6000 ? '5GHz'
                  :                '6GHz';
        }
        push @out, {
            bssid      => lc $f{BSSID},
            ssid       => $f{SSID},
            channel    => defined $f{channel}   ? $f{channel}   + 0 : undef,
            rssi_dbm   => defined $f{rssi}      ? $f{rssi}      + 0 : undef,
            band       => $band,
            encryption => $f{enc},
        };
    }
    return @out;
}

sub guess_band {
    my ($c) = @_;
    return undef unless defined $c;
    return '2.4GHz' if $c >= 1   && $c <= 14;
    return '5GHz'   if $c >= 32  && $c <= 177;
    return '6GHz'   if $c >= 200;
    return undef;
}

sub freq_to_channel {
    my ($f) = @_;
    return int(($f - 2407) / 5)           if $f >= 2412 && $f <= 2484;
    return 14                              if $f == 2484;
    return int(($f - 5000) / 5)            if $f >= 5160 && $f <= 5885;
    return int(($f - 5950) / 5)            if $f >= 5955 && $f <= 7115;
    return undef;
}

# -- scan + persist + report ----------------------------------------------
sub scan_one_ap_live {
    my ($ap) = @_;
    my $host = $ap->{name} || $ap->{addr};
    my $raw  = ssh_scan($host) or return [];
    return parse_scan($raw, $ap->{mac});
}

# Fork-and-collect: spawn one child per AP, each does its own ssh +
# scan + parse, ships parsed results back through a pipe.  Parent
# multiplexes the pipes via IO::Select, then writes everything to
# the DB once all children have answered.  Each AP scan is dominated
# by the ~4-second wl-scan sleep, so wall-clock time stays roughly
# constant regardless of fleet size.
sub scan_all_aps_parallel {
    my ($aps) = @_;
    my $sel = IO::Select->new;
    my %fh_to_ap;
    my %pid_to_fh;
    for my $ap (@$aps) {
        pipe(my $rfh, my $wfh) or die "pipe: $!";
        my $pid = fork;
        die "fork: $!" unless defined $pid;
        if ($pid == 0) {
            close $rfh;
            # Re-open DB in the child would be required for upsert, but
            # we batch writes in the parent — child only does the slow
            # I/O work.  Don't let inherited handles leak.
            my $results = eval { scan_one_ap_live($ap) } // [];
            my $blob    = nfreeze($results);
            syswrite($wfh, $blob);
            close $wfh;
            exit 0;
        }
        close $wfh;
        $sel->add($rfh);
        $fh_to_ap{ fileno($rfh) }   = $ap;
        $pid_to_fh{ $pid }          = $rfh;
        print STDERR "scanning " . ($ap->{name} || $ap->{addr})
                   . " ($ap->{mac}, pid $pid) ...\n" unless $json;
    }
    my %results;
    my %buf;
    while ($sel->count) {
        for my $fh ($sel->can_read(0.5)) {
            my $fd = fileno($fh);     # capture before close() invalidates it
            my $n  = sysread($fh, my $chunk, 65536);
            if (!defined $n || $n == 0) {
                $sel->remove($fh);
                my $ap     = $fh_to_ap{$fd};
                my $blob   = $buf{$fd} // '';
                close $fh;
                my $parsed = eval { thaw($blob) } || [];
                $results{ $ap->{mac} } = $parsed;
                next;
            }
            $buf{$fd} .= $chunk;
        }
    }
    waitpid($_, 0) for keys %pid_to_fh;
    return \%results;
}

sub save_results {
    my ($results) = @_;
    return if $no_save;
    for my $r (@$results) {
        $db->upsert_wifi_scan_result(
            scanner_mac   => $r->{scanner_mac},
            scanner_iface => $r->{scanner_iface},
            bssid         => $r->{bssid},
            ssid          => $r->{ssid},
            channel       => $r->{channel},
            band          => $r->{band},
            rssi_dbm      => $r->{rssi_dbm},
            encryption    => $r->{encryption},
            bandwidth_mhz => $r->{bandwidth_mhz},
        );
    }
}

# Build the report for one AP.  Two views per radio:
#   * busyness  — score per channel sorted busiest→quietest, with a
#                 simple bar chart so 'where to move' is obvious
#   * neighbours — individual visible APs (printed only with --verbose)
#
# Busyness score per channel:  sum over visible foreign APs of
#   max(0, rssi_dbm - NOISE_FLOOR)   where NOISE_FLOOR = -95
# Then for 2.4GHz, half-weight is added to channels within ±2 of each
# observed channel and quarter-weight to channels within ±4, modelling
# the carrier overlap.  5GHz channels are treated as non-overlapping
# (true for 20MHz; wider channels would need refinement).
my $NOISE_FLOOR  = -95;
my @CH_24G       = (1..14);
my @CH_24G_BEST  = (1, 6, 11);          # canonical non-overlapping set
my @CH_5G_COMMON = (36, 40, 44, 48, 149, 153, 157, 161, 165);

sub busyness_for_neighbours {
    my ($neighbours, $band) = @_;
    my %score;     # channel → score
    my %count;     # channel → AP count
    my %strongest; # channel → rssi_dbm of strongest neighbour
    # Valid channel range for adjacency spill (drop spill outside the
    # band's usable channels — otherwise the chart sprouts ghosts at
    # ch -1, ch 15, etc.).
    my ($lo, $hi);
    if (($band // '') eq '2.4GHz') { ($lo, $hi) = (1, 13) }
    else                            { ($lo, $hi) = (1, 999) }
    my $add = sub {
        my ($ch, $w) = @_;
        return if $ch < $lo || $ch > $hi;
        $score{$ch} += $w;
    };
    for my $n (@$neighbours) {
        my $ch = $n->{channel} or next;
        my $r  = defined $n->{rssi_dbm} ? $n->{rssi_dbm} : $NOISE_FLOOR;
        my $w  = $r - $NOISE_FLOOR;
        $w = 0 if $w < 0;
        # Direct hit (always counted, even if it falls outside the
        # canonical range — neighbours genuinely observed on ch 14
        # are valid in some regulatory domains).
        $score{$ch} += $w;
        $count{$ch}++;
        $strongest{$ch} = $r
            if !defined $strongest{$ch} || $r > $strongest{$ch};
        # 2.4GHz adjacency spill, clamped to 1..13.
        if (($band // '') eq '2.4GHz') {
            for my $d (1, 2) { $add->($ch + $d, $w * 0.5);
                               $add->($ch - $d, $w * 0.5); }
            for my $d (3, 4) { $add->($ch + $d, $w * 0.25);
                               $add->($ch - $d, $w * 0.25); }
        }
    }
    return (\%score, \%count, \%strongest);
}

sub report_for_ap {
    my ($ap, $results, $own_bssids) = @_;
    my %by_iface;
    push @{ $by_iface{ $_->{scanner_iface} } }, $_ for @$results;

    my @blocks;
    for my $iface (sort keys %by_iface) {
        my @neighbours = grep { !$own_bssids->{ $_->{bssid} } }
                              @{ $by_iface{$iface} };
        # Pick the band: take whichever band most foreign APs reported,
        # fall back to inferring from any neighbour's channel.
        my %band_votes;
        $band_votes{ $_->{band} // '' }++ for @neighbours;
        my ($band) = sort { $band_votes{$b} <=> $band_votes{$a} }
                          grep { length } keys %band_votes;

        my ($score, $count, $strongest)
            = busyness_for_neighbours(\@neighbours, $band);
        # Channels we care about for sorting + recommendation.  Include
        # any channel we observed *and* the canonical sets for the band
        # so quiet recommendations still show.
        my %ch_set = map { $_ => 1 } keys %$score;
        $ch_set{$_} = 1 for ($band && $band eq '5GHz' ? @CH_5G_COMMON
                                                       : @CH_24G);
        my @channels = sort { ($score->{$b} // 0) <=> ($score->{$a} // 0)
                           || $a <=> $b } keys %ch_set;

        # Recommendation:
        #   2.4GHz → quietest of {1,6,11}, ties broken low-channel-first
        #   5GHz   → quietest channel with score==0 if any, else
        #            quietest of CH_5G_COMMON
        my $reco;
        if (($band // '') eq '2.4GHz') {
            ($reco) = sort { ($score->{$a} // 0) <=> ($score->{$b} // 0)
                          || $a <=> $b } @CH_24G_BEST;
        } else {
            my @cands = grep { !($score->{$_} // 0) } @CH_5G_COMMON;
            ($reco) = @cands ? sort { $a <=> $b } @cands
                             : sort { ($score->{$a} // 0)
                                     <=> ($score->{$b} // 0) } @CH_5G_COMMON;
        }

        push @blocks, {
            iface       => $iface,
            band        => $band,
            channels    => \@channels,
            score       => $score,
            count       => $count,
            strongest   => $strongest,
            recommended => $reco,
            neighbours  => \@neighbours,
        };
    }
    return \@blocks;
}

# -- driver ---------------------------------------------------------------
my %results_by_mac;
if ($from_db) {
    for my $ap (@$aps) {
        $results_by_mac{ lc $ap->{mac} } = $db->dbh->selectall_arrayref(
            "SELECT * FROM wifi_scan_results WHERE scanner_mac = ?",
            { Slice => {} }, lc $ap->{mac}
        );
    }
} else {
    %results_by_mac = %{ scan_all_aps_parallel($aps) };
    # Persist after all children come back.
    for my $mac (keys %results_by_mac) {
        save_results($results_by_mac{$mac});
    }
}

# Build own-BSSID set once — every MAC across the AP fleet counts as
# 'us', so foreign-AP filtering doesn't double-count siblings.
my %own;
$own{ lc $_->{mac} } = 1 for @$aps;

my @report;
for my $ap (@$aps) {
    my $r = $results_by_mac{ lc $ap->{mac} } // [];
    push @report, {
        ap     => $ap,
        blocks => report_for_ap($ap, $r, \%own),
    };
}

if ($json) {
    require JSON::PP;
    print JSON::PP::encode_json(\@report), "\n";
    exit 0;
}

# Text output.  Per-AP per-radio: sorted channel-busyness chart, plus
# the recommended channel.  --verbose adds a neighbour-by-neighbour
# listing under each block.
my $any = 0;
for my $r (@report) {
    my $ap = $r->{ap};
    my $name = $ap->{name} || $ap->{addr};
    next unless @{ $r->{blocks} };
    $any = 1;
    print "== $name ($ap->{addr}) ==\n";
    for my $b (@{ $r->{blocks} }) {
        my $total = scalar @{ $b->{neighbours} };
        printf "  %s (%s): %d foreign AP%s visible\n",
            $b->{iface}, $b->{band} // '?', $total,
            $total == 1 ? '' : 's';

        # Find max score for bar-chart scaling.  Skip channels with
        # zero score except for those in the recommendation context.
        my $max = 0;
        for my $c (@{ $b->{channels} }) {
            my $s = $b->{score}{$c} // 0;
            $max = $s if $s > $max;
        }
        if ($max > 0) {
            print "    channel busyness (most → least):\n";
            for my $c (@{ $b->{channels} }) {
                my $s = $b->{score}{$c} // 0;
                next if $s == 0;
                my $bars = int(($s / $max) * 24 + 0.5);
                my $bar  = '#' x $bars;
                my $cnt  = $b->{count}{$c} // 0;
                my $rmax = $b->{strongest}{$c};
                my $tail;
                if ($cnt > 0 && defined $rmax) {
                    $tail = sprintf '%d AP%s on ch, strongest %d dBm',
                                    $cnt, $cnt == 1 ? '' : 's', $rmax;
                } else {
                    $tail = 'adjacent spill';
                }
                printf "      ch %3d  %-24s  %4d  (%s)\n",
                    $c, $bar, $s, $tail;
            }
        } else {
            print "    channel busyness: (nothing measurable)\n";
        }
        printf "    recommended: ch %d%s\n",
            $b->{recommended} // 0,
            (($b->{band} // '') eq '2.4GHz'
                ? ' (quietest of 1/6/11)'
                : '');

        if ($verbose) {
            my @sorted = sort {
                ($b->{strongest}{ $b->{channel} // 0 } // -200)
                <=> ($a->{strongest}{ $a->{channel} // 0 } // -200)
            } @{ $b->{neighbours} };
            for my $n (sort { ($b->{rssi_dbm} // -200)
                              <=> ($a->{rssi_dbm} // -200) }
                       @{ $b->{neighbours} }) {
                printf "      ch %-3s %4d dBm  %-30s  %s\n",
                    $n->{channel} // '?', $n->{rssi_dbm} // 0,
                    $n->{ssid} // '(hidden)', $n->{bssid};
            }
        }
    }
}
print "(no scan data — APs may not support the survey tools available)\n"
    unless $any;
exit 0;
