#!/usr/bin/perl
# net-reserve — manage permanent DHCP reservations and dynamic-pool ranges
# straight from the net-mgr DB (schema v24: dhcp_reservations + dhcp_ranges),
# replacing hand-edited host { fixed-address } blocks in dhcp.master. Both
# tables are cluster-replicated, so a reservation made here relays to every
# peer and net-gen-dnsmasq can generate from the DB.
#
# Talks to the daemon over the socket (snapshot + OBSERVE), so it runs from any
# host without DB credentials — like net-show / net-chat. A non-loopback daemon
# is AUTH'd automatically with your SSH key.
#
# Usage:
#   net-reserve list [SUBNET]        colour-coded address map (free/reserved/pool)
#   net-reserve free [SUBNET] [-n N] list the next free static IPs
#   net-reserve ranges               list the dynamic DHCP pools
#   net-reserve reserve IP MAC [--name N] [--group G] [--notes '..'] [--push]
#                                    --push also surfaces just this one as a
#                                    never-seen net-lookup name (needs --name)
#   net-reserve release IP           remove a reservation
#   net-reserve autoname [SUBNET]    fill missing reservation host names
#   net-reserve add-range CIDR START END [--zone Z]
#   net-reserve del-range CIDR START
#   net-reserve --push [SUBNET]      push named reservations into net-lookup as
#                                    never-seen hosts (kind=host, last_observed
#                                    NULL); --dry-run previews the observations
#   net-reserve --gui [SUBNET]       Perl/Tk map: click a cell to select it
#                                    (centres its reservation in the side list);
#                                    click it again to reserve (pick the target
#                                    address from a menu), move, or release;
#                                    +/- keep or ignore subnets in the picker;
#                                    reopens on the last subnet you viewed
#                                    ([net-reserve] show/ignore/last in user config)
#
#   --listen HOST:PORT   daemon address (overrides --server and config)
#   --server NAME        a server from [servers] in ~/.config/net-mgr/config
#   --auth / --no-auth   force / suppress the SSH-key handshake
#   --key-id ID / --key-file PATH   identity for AUTH
#
# A "free static" IP is one that is NOT inside any dynamic range, NOT already
# reserved, and (for `free`) not currently observed in use — i.e. exactly the
# pool you allocate permanent addresses from.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling pass_through);
use NetMgr::Addr   qw(local_addrs);
use NetMgr::Client;
use NetMgr::Config;
use NetMgr::Protocol qw(parse_line format_kv);
use Sys::Hostname qw(hostname);

# Render tables. Defined up here (not lower in the file) because the dispatch
# runs before any later statement would — a `my` initialised below the
# $handler->() call is still empty when the handlers fire.
my %COLOR = (   # ANSI background per state
    reserved => "\e[41m",        # red    — permanent reservation, not seen now
    active   => "\e[45m",        # purple — reserved AND currently in use
    assigned => "\e[44m",        # blue   — inside a DHCP dynamic range
    'in-use' => "\e[48;5;208m",  # orange — occupied (lease/observed), unreserved
    free     => "\e[42m",        # green  — allocatable static
);
my $RESET = "\e[0m";
# Distinct one-char glyphs for the no-colour (piped) map.
my %GLYPH = (
    reserved => 'R', active => '*', assigned => '-', 'in-use' => '!', free => '.',
);

my ($listen, $server, $force_auth, $no_auth, $key_id, $key_file);
my ($gui, $describe, $opt_name, $opt_group, $opt_notes, $opt_zone, $limit, $opt_force);
my ($opt_push, $opt_dry);
GetOptions(
    'listen=s'   => \$listen,
    'server=s'   => \$server,
    'auth'       => \$force_auth,
    'no-auth'    => \$no_auth,
    'key-id=s'   => \$key_id,
    'key-file=s' => \$key_file,
    'gui'        => \$gui,
    'push'       => \$opt_push,
    'dry-run'    => \$opt_dry,
    'describe'   => \$describe,
    'force'      => \$opt_force,
    'name=s'     => \$opt_name,
    'group=s'    => \$opt_group,
    'notes=s'    => \$opt_notes,
    'zone=s'     => \$opt_zone,
    'n=i'        => \$limit,
) or die "bad options\n";

if ($describe) {
    print "name: net-reserve\n";
    print "description: manage DHCP reservations + dynamic ranges in the net-mgr DB\n";
    exit 0;
}

my $cmd = shift @ARGV;

# Server resolution mirrors net-chat: --listen wins, then --server (config
# [servers]), then $NET_MGR_LISTEN, then the configured default, then loopback.
if (!defined $listen) {
    if (defined $server) {
        $listen = NetMgr::Config->resolve_server($server)
            or die "net-reserve: unknown server '$server'\n";
    } else {
        $listen = $ENV{NET_MGR_LISTEN}
               // NetMgr::Config->resolve_server(undef)
               // '127.0.0.1:7531';
    }
}

# With the --gui flag, the subnet is the leftover positional, already shifted
# into $cmd above (not still on @ARGV).
my %DISPATCH = (
    list      => \&cmd_list,
    map       => \&cmd_list,    # alias
    free      => \&cmd_free,
    ranges    => \&cmd_ranges,
    reserve   => \&cmd_reserve,
    release   => \&cmd_release,
    move       => \&cmd_move,
    reallocate => \&cmd_move,   # alias
    autoname   => \&cmd_autoname,
    'add-range' => \&cmd_add_range,
    'del-range' => \&cmd_del_range,
    gui       => sub { cmd_gui(shift @ARGV) },
);

if ($gui) { cmd_gui($cmd); exit 0; }
# --push standalone: `net-reserve --push [SUBNET]` pushes every named
# reservation (the leftover positional is in $cmd, like --gui). When --push
# rides a subcommand instead (e.g. `reserve IP MAC --name N --push`), it's a
# per-command modifier handled by that subcommand — so only run the standalone
# push when $cmd isn't a known subcommand.
if ($opt_push && (!defined $cmd || !exists $DISPATCH{$cmd})) { cmd_push($cmd); exit 0; }
usage() unless defined $cmd;
my $handler = $DISPATCH{$cmd} or usage("unknown command '$cmd'");
$handler->();
exit 0;

# ---- connection ------------------------------------------------------

sub connect_client {
    my %opt = @_;
    my $cli = eval { NetMgr::Client->new(listen => $listen, timeout => 10) }
        or die "net-reserve: cannot reach daemon at $listen: $@";
    my ($host) = NetMgr::Client::split_hostport($listen); $host //= '';
    my $is_loopback = $host =~ /^(?:127\.\d+\.\d+\.\d+|::1|localhost)$/;
    my $do_auth = $force_auth || (!$is_loopback && !$no_auth);
    $do_auth = $opt{want_auth} if exists $opt{want_auth};
    $do_auth = 0 if $no_auth;
    if ($do_auth) {
        eval {
            $cli->auth(
                (defined $key_id   ? (key_id   => $key_id)   : ()),
                (defined $key_file ? (key_file => $key_file) : ()),
            );
        };
        die "net-reserve: AUTH failed: $@" if $@;
    }
    $cli->hello(consumer => "net-reserve.$$");
    return $cli;
}

# ---- IP / subnet math ------------------------------------------------

sub ip2int {
    my @o = split /\./, ($_[0] // '');
    return undef unless @o == 4 && !grep { $_ !~ /^\d+$/ || $_ > 255 } @o;
    return ($o[0] << 24) + ($o[1] << 16) + ($o[2] << 8) + $o[3];
}
sub int2ip { my $n = $_[0]; join '.', ($n >> 24) & 255, ($n >> 16) & 255,
                                       ($n >> 8) & 255, $n & 255 }

# Canonical dotted-quad key for model lookups. The DB can hold an address in a
# non-canonical form — leading-zero octets ("10.0.223.005"), an inet "/32"
# suffix, or stray whitespace — but the grid and pop-up look addresses up by
# int2ip()'s strict form. Key the model the same way or those lookups miss: the
# cell shows 'free' and the pop-up shows no occupant even though the row is
# present (it still appears in the side list, which iterates values). Falls back
# to the trimmed original when it can't be parsed as IPv4.
sub canon_ip {
    my ($s) = @_;
    return $s unless defined $s;
    (my $t = $s) =~ s/^\s+|\s+$//g;   # trim
    $t =~ s!/\d+$!!;                  # drop a /len suffix
    my $i = ip2int($t);
    return defined $i ? int2ip($i) : $t;
}

# Parse "A.B.C.D/len" → (network_int, len, first_host_int, last_host_int).
sub cidr_parts {
    my ($cidr) = @_;
    my ($net, $len) = split m{/}, $cidr;
    $len = 24 unless defined $len && length $len;
    my $ni = ip2int($net);
    return unless defined $ni;
    my $mask = $len == 0 ? 0 : (0xFFFFFFFF << (32 - $len)) & 0xFFFFFFFF;
    my $network = $ni & $mask;
    my $bcast   = $network | (~$mask & 0xFFFFFFFF);
    my $first   = $len >= 31 ? $network : $network + 1;     # skip .0
    my $last    = $len >= 31 ? $bcast   : $bcast - 1;       # skip .255
    return ($network, $len, $first, $last);
}
sub subnet_of { my $i = ip2int($_[0]); defined $i ? int2ip($i & 0xFFFFFF00) . "/24" : undef }
# A pool range as bare host octets (90-109) when start and end share a /24 — the
# subnet header already names the network. Falls back to full start-end if the
# range spans the /24.
sub range_short {
    my ($start, $end) = @_;
    my ($sp, $so) = ($start // '') =~ /^(\d+\.\d+\.\d+)\.(\d+)$/;
    my ($ep, $eo) = ($end   // '') =~ /^(\d+\.\d+\.\d+)\.(\d+)$/;
    return "$so-$eo" if defined $sp && defined $ep && $sp eq $ep;
    return ($start // '') . '-' . ($end // '');
}

# Normalise a user-typed subnet ("192.168.20", "192.168.20.5/24", ...) to a
# canonical "network/len" CIDR, or undef if it doesn't parse. Bare input
# without a /len defaults to /24.
sub normalize_cidr {
    my ($s) = @_;
    return undef unless defined $s;
    $s =~ s/^\s+|\s+$//g;
    return undef unless length $s;
    my ($net, $len) = split m{/}, $s;
    $len = 24 unless defined $len && length $len;
    return undef unless $len =~ /^\d+$/ && $len >= 0 && $len <= 32;
    # Pad a short dotted form: "192.168.20" -> "192.168.20.0".
    my @o = split /\./, ($net // '');
    return undef unless @o >= 1 && @o <= 4;
    push @o, 0 while @o < 4;
    $net = join '.', @o;
    my ($network) = cidr_parts("$net/$len");
    return undef unless defined $network;
    return int2ip($network) . "/$len";
}

# Subnets this machine is directly attached to (from `ip -o -4 addr`), as
# canonical CIDRs — used to seed the GUI subnet picker so your own LANs show
# up even before the DB has any rows for them. Loopback/link-local skipped.
sub local_subnets {
    my (@out, %seen);
    open my $fh, '-|', 'ip', '-o', '-4', 'addr', 'show'
        or return [];
    while (<$fh>) {
        next unless /\binet\s+(\d+\.\d+\.\d+\.\d+)\/(\d+)/;
        my ($ip, $len) = ($1, $2);
        next if $ip =~ /^127\./ || $ip =~ /^169\.254\./;
        my $c = normalize_cidr("$ip/$len") or next;
        push @out, $c unless $seen{$c}++;
    }
    close $fh;
    return \@out;
}

# Persistent subnet show/ignore lists for the GUI picker, kept in the per-user
# config's [net-reserve] section (show = / ignore =, comma-separated CIDRs;
# also last = CIDR, the subnet the GUI reopens on). Read merges the system +
# user config; writes go to the user file.
sub _read_cidr_list {
    my ($key) = @_;
    my %set;
    for my $p ($ENV{NET_MGR_CONF} // '/etc/net-mgr/config', NetMgr::Config->user_path) {
        next unless defined $p && -r $p;
        my $cfg = eval { NetMgr::Config->load($p) } or next;
        my $v = $cfg->{'net-reserve'}{$key} // next;
        for my $c (split /[,\s]+/, $v) {
            my $n = normalize_cidr($c) or next;
            $set{$n} = 1;
        }
    }
    return \%set;
}
sub _write_cidr_list {
    my ($key, $set) = @_;
    my @c = sort { (ip2int((split m{/}, $a)[0]) // 0)
               <=> (ip2int((split m{/}, $b)[0]) // 0) } keys %$set;
    eval { NetMgr::Config->save_user_value('net-reserve', $key, join(', ', @c)); 1 };
}

# The GUI reopens on the last subnet you viewed. Persisted as a single CIDR in
# the same [net-reserve] section as show/ignore (key `last`); user file wins.
sub _read_last_subnet {
    for my $p (NetMgr::Config->user_path, $ENV{NET_MGR_CONF} // '/etc/net-mgr/config') {
        next unless defined $p && -r $p;
        my $cfg = eval { NetMgr::Config->load($p) } or next;
        my $v = $cfg->{'net-reserve'}{last} // next;
        my $n = normalize_cidr($v) or next;
        return $n;
    }
    return undef;
}
sub _write_last_subnet {
    my ($cidr) = @_;
    my $n = normalize_cidr($cidr // '') or return;
    eval { NetMgr::Config->save_user_value('net-reserve', 'last', $n); 1 };
}

# Ask the local net-mgr-relay's REFRESH proxy to pull this subnet's rows
# from the elected master into the local DB before we read it — current
# view on demand, while the relay's subscribe-stream stays the lazy
# default. Best-effort: silently a no-op when the target daemon isn't
# local, the proxy isn't running, or this host is itself the master.
# Returns a human-readable note (for the GUI status bar) or undef.
sub maybe_refresh {
    my ($subnet) = @_;
    return undef unless defined $subnet && length $subnet;
    my ($host) = NetMgr::Client::split_hostport($listen); $host //= '';
    return undef
        unless $host =~ /^(?:127\.\d+\.\d+\.\d+|::1|localhost)$/;
    # On the cluster master / a sole node there is nothing to pull — REFRESH is
    # a no-op there, and the relay proxy may not even be running. Ask the local
    # daemon's role first and skip the proxy round-trip (and its timeout) when
    # we're the source of truth.
    my $role = eval {
        my $d  = NetMgr::Client->new(listen => $listen, timeout => 3);
        my $st = $d->status; eval { $d->bye };
        $st ? $st->{cluster_role} : undef;
    };
    return 'already current (this host is the master)'
        if defined $role && ($role eq 'master' || $role eq 'auto');
    my $cfg = eval {
        NetMgr::Config->load($ENV{NET_MGR_CONF} // '/etc/net-mgr/config') };
    my $addr = ($cfg && $cfg->{cluster}{proxy_listen}) // '127.0.0.1:7532';
    return undef if lc($addr) eq 'none';
    my $reply = eval {
        my $px = NetMgr::Client->new(listen => $addr, timeout => 8);
        $px->send_recv("REFRESH " . format_kv(subnet => $subnet));
    };
    return undef unless defined $reply && $reply =~ /^OK\b/;
    my $kv = eval { parse_line($reply)->{kv} } || {};
    return 'already current (this host is the master)'
        if ($kv->{role} // '') eq 'master';
    return sprintf('refreshed %s from %s (%s rows)',
                   $subnet, $kv->{master} // 'master', $kv->{rows} // '?');
}

# ---- gather the world from the daemon --------------------------------
#
# Returns a model: { ranges=>[..], resv=>{ip=>row}, leased=>{ip=>row},
#                    observed=>{ip=>row}, mac_name=>{mac=>name}, subnets=>[cidr,..] }
sub gather {
    my ($cli) = @_;
    my $ranges = eval { $cli->snapshot(1, 'dhcp_ranges') }        || [];
    my $resv   = eval { $cli->snapshot(2, 'dhcp_reservations') }  || [];
    my $leases = eval { $cli->snapshot(3, 'dhcp_leases') }        || [];
    my $addrs  = eval { $cli->snapshot(4, 'addresses',
                          where => "family = 'v4'") }             || [];
    # MAC -> machine name, so observed/leased addresses can show who's there
    # (the same name net-lookup gives), not just a bare MAC.
    my $ifaces   = eval { $cli->snapshot(5, 'interfaces') } || [];
    my $machines = eval { $cli->snapshot(6, 'machines') }   || [];

    # Key by the canonical address (see canon_ip): the DB may store a
    # non-canonical form, but classify()/occupant() look up by int2ip()'s form.
    my %resv     = map { canon_ip($_->{ip})   => $_ } grep { defined $_->{ip} } @$resv;
    # Key by IP, but when an address has several leases over time (DHCP reuse —
    # the same IP handed to different MACs) keep the one with the latest expiry,
    # i.e. the current holder. Plain last-wins would surface a months-old stale
    # lease and hide the device that actually holds the address now. ALSO drop
    # leases whose expires is already in the past — a DHCP-expired lease isn't
    # 'in-use', and net-mgr-relay doesn't necessarily prune them from the table,
    # so without this filter long-departed devices keep colouring their old
    # cells orange. NULL/empty expires is kept (treated as a static binding).
    # MySQL DATETIME compares lexically when stored in the same timezone.
    require POSIX;
    my $now_iso = POSIX::strftime('%Y-%m-%d %H:%M:%S', localtime);
    my %leased;
    for my $l (grep { $_->{ip} } @$leases) {
        my $exp = $l->{expires} // '';
        next if length $exp && $exp lt $now_iso;       # expired -> not in-use
        my $ip  = canon_ip($l->{ip});
        my $cur = $leased{$ip};
        $leased{$ip} = $l if !$cur || $exp gt ($cur->{expires} // '');
    }
    my %observed = map { canon_ip($_->{addr}) => $_ } grep { $_->{addr} } @$addrs;

    my %name_of_mid = map { ($_->{id} => $_->{primary_name}) }
                      grep { defined $_->{primary_name} && length $_->{primary_name} } @$machines;
    my %mac_name;
    for my $i (@$ifaces) {
        next unless $i->{mac} && $i->{machine_id};
        my $n = $name_of_mid{ $i->{machine_id} } or next;
        $mac_name{ lc $i->{mac} } = $n;
    }
    # MAC -> where it currently is (lease/observed) and where it's reserved, so
    # the UI can flag a device that's been given a new address but hasn't moved
    # there yet.
    my (%mac_cur_ip, %mac_resv_ip);
    for my $ip (sort keys %leased)   { my $m=$leased{$ip}{mac};   $mac_cur_ip{lc $m} //= $ip if $m }
    for my $ip (sort keys %observed) { my $m=$observed{$ip}{mac}; $mac_cur_ip{lc $m} //= $ip if $m }
    for my $ip (keys %resv)          { my $m=$resv{$ip}{mac};     $mac_resv_ip{lc $m} //= $ip if $m }

    my %subnets;
    $subnets{ $_->{subnet_cidr} } = 1 for @$ranges;
    for my $ip (keys %resv, keys %leased, keys %observed) {
        my $s = subnet_of($ip) or next;
        $subnets{$s} = 1;
    }
    my @subnets = sort {
        (ip2int((split m{/}, $a)[0]) // 0) <=> (ip2int((split m{/}, $b)[0]) // 0)
    } keys %subnets;

    return {
        ranges => $ranges, resv => \%resv, leased => \%leased,
        observed => \%observed, mac_name => \%mac_name,
        mac_cur_ip => \%mac_cur_ip, mac_resv_ip => \%mac_resv_ip,
        subnets => \@subnets,
    };
}

# Is $ip_int inside any dynamic range of $cidr?
sub in_pool {
    my ($model, $ip_int) = @_;
    for my $r (@{ $model->{ranges} }) {
        my $lo = ip2int($r->{start_ip}); my $hi = ip2int($r->{end_ip});
        next unless defined $lo && defined $hi;
        return 1 if $ip_int >= $lo && $ip_int <= $hi;
    }
    return 0;
}

# Classify one host address → state keyword. An address inside a DHCP
# dynamic range is 'assigned' (managed by DHCP) regardless of whether a
# host currently holds it — you don't allocate statics from there anyway.
# 'in-use' is reserved for an address occupied *outside* any pool and not
# reserved: a real, unmanaged occupant worth noticing.
sub classify {
    my ($model, $ip) = @_;
    my $i = ip2int($ip);
    if ($model->{resv}{$ip}) {
        # reserved AND currently occupied -> 'active' (the reservation is in
        # effect); reserved but not seen -> 'reserved' (pending/vacant).
        return ($model->{leased}{$ip} || $model->{observed}{$ip})
               ? 'active' : 'reserved';
    }
    # An occupied address shows as in-use even INSIDE a DHCP pool — otherwise a
    # device that took a dynamic lease from the pool (e.g. the KP200 smart plug)
    # blends into the pool colour and looks like free space.
    return 'in-use'   if $model->{leased}{$ip} || $model->{observed}{$ip};
    return 'assigned' if in_pool($model, $i);
    return 'free';
}

# Suggest a cell to highlight when the user lands on (or switches to) a subnet,
# so they're not staring at a flat grid wondering where to act. Preferred
# target: this machine's own IPv4 on $cidr (most likely thing the operator
# wants to inspect/reserve — "where am I in this subnet?"). Falls back to the
# first 'free' IP if we have no presence on the subnet. Returns undef when the
# subnet has neither — leave the grid un-hinted in that case rather than
# pointing at something arbitrary. Pure: takes the gather()'d model, no IO
# beyond NetMgr::Addr's `ip -br -4 addr show` (already cheap and used widely).
sub _gui_default_pick {
    my ($model, $cidr) = @_;
    return undef unless defined $cidr;
    for my $ip (local_addrs('v4', $cidr)) {
        return $ip if defined $ip && length $ip;
    }
    my (undef, undef, $first, $last) = cidr_parts($cidr);
    return undef unless defined $first && defined $last;
    for (my $i = $first; $i <= $last; $i++) {
        my $ip = int2ip($i);
        return $ip if classify($model, $ip) eq 'free';
    }
    return undef;
}

# ---- CLI: colour + rendering ----------------------------------------

sub use_color { -t STDOUT }

sub state_label {
    my %L = (reserved => 'reserved', active => '+ in use',
             assigned => 'DHCP assigned', 'in-use' => 'in use',
             free => 'free static');
    return $L{$_[0]} // $_[0];
}

sub cmd_list {
    my $cli = connect_client(want_auth => 0);
    my $only = shift @ARGV;
    maybe_refresh(normalize_cidr($only)) if defined $only;
    my $model = gather($cli);
    my @subnets = $only ? (grep { $_ eq $only || index($_, "$only/") == 0
                                  || (split m{/}, $_)[0] eq $only }
                                @{ $model->{subnets} })
                        : @{ $model->{subnets} };
    @subnets = @{ $model->{subnets} } if $only && !@subnets && $only =~ m{/};
    unless (@subnets) {
        print "no subnets known to the daemon yet "
            . "(seed ranges with `net-reserve add-range` or net-import-dhcp)\n";
        return;
    }
    my $c = use_color();
    for my $cidr (@subnets) {
        my ($net, $len, $first, $last) = cidr_parts($cidr);
        next unless defined $net;
        printf "\n%s  (%s)\n", $cidr, pool_summary($model, $cidr);
        # 16-wide grid of last octet for /24; generic otherwise.
        my $col = 0;
        for (my $i = $first; $i <= $last; $i++) {
            my $ip = int2ip($i);
            my $st = classify($model, $ip);
            my $oct = $i & 0xFF;
            if ($c) {
                printf "%s%3d%s ", $COLOR{$st}, $oct, $RESET;
            } else {
                printf "%3d%s ", $oct, ($GLYPH{$st} // '?');
            }
            if (++$col % 16 == 0) { print "\n" }
        }
        print "\n" if $col % 16;
        # Reservations in this subnet, grouped.
        my @mine = sort { ip2int($a->{ip}) <=> ip2int($b->{ip}) }
                   grep { ($_->{subnet_cidr} // subnet_of($_->{ip}) // '') eq $cidr }
                   values %{ $model->{resv} };
        if (@mine) {
            print "  reservations:\n";
            my %by_grp;
            push @{ $by_grp{ $_->{grp} // '(ungrouped)' } }, $_ for @mine;
            for my $g (sort keys %by_grp) {
                print "    [$g]\n";
                for my $r (@{ $by_grp{$g} }) {
                    printf "      %-15s %-17s %s\n",
                        $r->{ip}, $r->{mac}, ($r->{name} // '');
                }
            }
        }
    }
    if ($c) {
        print "\nlegend: ";
        print "$COLOR{$_}$RESET ", state_label($_), "  " for
            qw(free assigned in-use reserved active);
        print "\n";
    }
}

sub pool_summary {
    my ($model, $cidr) = @_;
    my @r = grep { $_->{subnet_cidr} eq $cidr } @{ $model->{ranges} };
    return "no dynamic range defined" unless @r;
    return join ", ", map { "$_->{start_ip}-$_->{end_ip}" } @r;
}

sub cmd_free {
    my $cli = connect_client(want_auth => 0);
    my $only = shift @ARGV;
    maybe_refresh(normalize_cidr($only)) if defined $only;
    my $model = gather($cli);
    my $want = $limit || 10;
    my @subnets = $only ? (grep { (split m{/}, $_)[0] eq $only || $_ eq $only }
                                @{ $model->{subnets} })
                        : @{ $model->{subnets} };
    @subnets = ($only) if $only && !@subnets && $only =~ m{/};
    for my $cidr (@subnets) {
        my ($net, $len, $first, $last) = cidr_parts($cidr);
        next unless defined $net;
        my @free;
        for (my $i = $first; $i <= $last && @free < $want; $i++) {
            push @free, int2ip($i) if classify($model, int2ip($i)) eq 'free';
        }
        printf "%s: %s\n", $cidr, (@free ? join(' ', @free) : '(none free)');
    }
}

sub cmd_ranges {
    my $cli = connect_client(want_auth => 0);
    my $rows = eval { $cli->snapshot(1, 'dhcp_ranges') } || [];
    unless (@$rows) { print "no dynamic ranges defined\n"; return }
    printf "%-20s %-15s %-15s %s\n", 'SUBNET', 'START', 'END', 'ZONE';
    for my $r (sort { $a->{subnet_cidr} cmp $b->{subnet_cidr} } @$rows) {
        printf "%-20s %-15s %-15s %s\n",
            $r->{subnet_cidr}, $r->{start_ip}, $r->{end_ip}, ($r->{zone} // '');
    }
}

sub cmd_reserve {
    my $ip  = shift @ARGV or usage("reserve needs IP MAC");
    my $mac = shift @ARGV or usage("reserve needs IP MAC");
    die "net-reserve: bad IP '$ip'\n"  unless defined ip2int($ip);
    die "net-reserve: bad MAC '$mac'\n" unless $mac =~ /^[0-9a-fA-F:]{17}$/;
    my $cli = connect_client();
    # Pull this subnet's current view first, then warn (don't block) if
    # the chosen IP sits inside a dynamic pool.
    maybe_refresh(subnet_of($ip));
    my $model = gather($cli);
    my $st = classify($model, $ip);
    warn "net-reserve: note: $ip is inside a DHCP dynamic range — "
       . "it may also be auto-leased; consider a free static instead\n"
        if $st eq 'assigned';
    my $r = $cli->observe(
        kind => 'dhcp_reservation', ip => $ip, mac => lc $mac,
        (defined $opt_name  ? (name  => $opt_name)  : ()),
        subnet_cidr => subnet_of($ip),
        (defined $opt_group ? (grp   => $opt_group) : ()),
        (defined $opt_notes ? (notes => $opt_notes) : ()),
        ($opt_force ? (force => 1) : ()),
    );
    # The daemon refuses a 2nd reservation for a MAC already reserved elsewhere;
    # `net-reserve move OLD NEW` relocates it, or --force adds it anyway.
    die "net-reserve: $r\n" if !defined $r || $r =~ /^ERR/;
    print "reserved $ip -> $mac",
          (defined $opt_name ? " ($opt_name)" : ''),
          (defined $opt_group ? " [$opt_group]" : ''), "\n";
    # --push: also surface just this one reservation as a never-seen net-lookup
    # name (so its tile/name resolves right away), without pushing the rest.
    if ($opt_push) {
        if (defined $opt_name && length $opt_name) {
            my $ok = _push_host($cli, ip => $ip, mac => lc $mac, name => $opt_name);
            print "pushed $ip -> $opt_name into net-lookup (never-seen)\n"
                if $ok && !$opt_dry;
        } else {
            warn "net-reserve: --push needs a --name to resolve; "
               . "reservation made, nothing pushed\n";
        }
    }
}

sub cmd_release {
    my $ip = shift @ARGV or usage("release needs IP");
    my $cli = connect_client();
    my $r = $cli->observe(kind => 'dhcp_reservation_delete', ip => $ip);
    die "net-reserve: $r\n" if !defined $r || $r =~ /^ERR/;
    print "released $ip\n";
}

sub cmd_move {
    my $old = shift @ARGV or usage("move needs OLD_IP NEW_IP");
    my $new = shift @ARGV or usage("move needs OLD_IP NEW_IP");
    die "net-reserve: bad IP\n" unless defined ip2int($old) && defined ip2int($new);
    my $cli = connect_client();
    maybe_refresh(subnet_of($new));
    my $model = gather($cli);
    warn "net-reserve: note: $new is inside a DHCP dynamic range\n"
        if classify($model, $new) eq 'assigned';
    my $r = $cli->observe(kind => 'dhcp_reservation_move', ip => $old, new_ip => $new);
    die "net-reserve: $r\n" if !defined $r || $r =~ /^ERR/;
    print "moved $old -> $new\n";
}

# Backfill host names on reservations that lack one: re-observe each nameless
# reservation (preserving its fields) so the daemon fills the name from the
# MAC's correlated machine. Optional SUBNET limits the scope.
sub cmd_autoname {
    my $subnet = shift @ARGV;
    my $want   = defined $subnet ? normalize_cidr($subnet) : undef;
    die "net-reserve: bad subnet '$subnet'\n" if defined $subnet && !defined $want;
    my $cli = connect_client();
    my $model = gather($cli);
    my @resv = grep { !defined $_->{name} || $_->{name} eq '' }
               values %{ $model->{resv} };
    @resv = grep { (subnet_of($_->{ip}) // '') eq $want } @resv if defined $want;
    unless (@resv) { print "no reservations missing a name\n"; return }
    for my $r (sort { ip2int($a->{ip}) <=> ip2int($b->{ip}) } @resv) {
        my $resp = $cli->observe(kind => 'dhcp_reservation',
            ip => $r->{ip}, mac => $r->{mac},
            subnet_cidr => ($r->{subnet_cidr} // subnet_of($r->{ip})),
            (defined $r->{grp}   && length $r->{grp}   ? (grp   => $r->{grp})   : ()),
            (defined $r->{notes} && length $r->{notes} ? (notes => $r->{notes}) : ()));
        warn "net-reserve: $r->{ip}: $resp\n" if !defined $resp || $resp =~ /^ERR/;
    }
    my $after = gather($cli);
    my ($named, @unknown) = (0);
    for my $r (sort { ip2int($a->{ip}) <=> ip2int($b->{ip}) } @resv) {
        my $now = $after->{resv}{ $r->{ip} };
        if ($now && defined $now->{name} && $now->{name} ne '') {
            $named++;
            printf "  %-15s %s -> %s\n", $r->{ip}, $r->{mac}, $now->{name};
        } else {
            push @unknown, $r->{ip};
        }
    }
    print "named $named of ", scalar(@resv), " reservation(s)\n";
    print "still unnamed (MAC not correlated to a machine): @unknown\n" if @unknown;
}

# Push ONE reservation into net-lookup as a never-seen kind=host entry: the
# daemon promotes the name to a machine and records interface+address with
# last_observed NULL (paper record). Honors --dry-run. Returns 1 ok, 0 fail.
sub _push_host {
    my ($cli, %r) = @_;
    my $my_host = (split /\./, hostname())[0] || 'localhost';
    my %kv = (
        kind        => 'host',
        mac         => lc $r{mac},
        ip          => $r{ip},
        family      => 'v4',
        (defined $r{name} && length $r{name} ? (name => $r{name}) : ()),
        name_source => 'dhcp_reservation',
        source      => "$my_host:net-reserve",
        live        => 0,   # paper record: never-seen, like a dhcp.master import
    );
    if ($opt_dry) { print "OBSERVE ", format_kv(%kv), "\n"; return 1; }
    my $resp = $cli->observe(%kv);
    if (!defined $resp || $resp =~ /^ERR/) {
        warn "net-reserve: push $r{ip}"
           . (defined $r{name} ? " ($r{name})" : '') . ": "
           . ($resp // 'no response') . "\n";
        return 0;
    }
    return 1;
}

# --push: surface reservations as names net-lookup can resolve. Each named
# reservation is pushed to the daemon as a kind=host observation with live=0 —
# a paper record (last_observed stays NULL, "never seen"), just like a
# dhcp.master import but sourced from the DB reservations instead of a file.
# net-lookup's MAC path (do_mac) resolves the name regardless of liveness, so
# the name shows up (e.g. on the soil dashboard) without falsely marking the
# device online. Optional SUBNET limits scope; --dry-run prints the
# observations instead of sending them.
sub cmd_push {
    my ($subnet) = @_;
    my $want = defined $subnet ? normalize_cidr($subnet) : undef;
    die "net-reserve: bad subnet '$subnet'\n" if defined $subnet && !defined $want;

    my $cli     = connect_client();
    my $model   = gather($cli);

    my @resv = grep { defined $_->{name} && length $_->{name}
                   && defined $_->{mac}  && length $_->{mac}
                   && defined $_->{ip}   && length $_->{ip} }
               values %{ $model->{resv} };
    @resv = grep { (subnet_of($_->{ip}) // '') eq $want } @resv if defined $want;
    @resv = sort { ip2int($a->{ip}) <=> ip2int($b->{ip}) } @resv;

    unless (@resv) {
        print "no named reservations to push", (defined $want ? " in $want" : ''), "\n";
        return;
    }

    my ($pushed, $failed) = (0, 0);
    for my $r (@resv) {
        if (_push_host($cli, ip => $r->{ip}, mac => $r->{mac}, name => $r->{name})) {
            printf "  pushed %-15s %s -> %s\n", $r->{ip}, lc $r->{mac}, $r->{name}
                unless $opt_dry;
            $pushed++;
        } else {
            $failed++;
        }
    }
    return if $opt_dry;
    print "pushed $pushed name(s) into net-lookup as never-seen hosts",
          ($failed ? " ($failed failed)" : ''), "\n";
}

sub cmd_add_range {
    my $cidr  = shift @ARGV or usage("add-range needs CIDR START END");
    my $start = shift @ARGV or usage("add-range needs CIDR START END");
    my $end   = shift @ARGV or usage("add-range needs CIDR START END");
    my $cli = connect_client();
    my $r = $cli->observe(kind => 'dhcp_range', subnet_cidr => $cidr,
        start_ip => $start, end_ip => $end,
        (defined $opt_zone ? (zone => $opt_zone) : ()));
    die "net-reserve: $r\n" if !defined $r || $r =~ /^ERR/;
    print "added range $cidr $start-$end\n";
}

sub cmd_del_range {
    my $cidr  = shift @ARGV or usage("del-range needs CIDR START");
    my $start = shift @ARGV or usage("del-range needs CIDR START");
    my $cli = connect_client();
    my $r = $cli->observe(kind => 'dhcp_range_delete',
        subnet_cidr => $cidr, start_ip => $start);
    die "net-reserve: $r\n" if !defined $r || $r =~ /^ERR/;
    print "deleted range $cidr $start\n";
}

# ---- DHCP-range / server helpers (GUI "DHCP servers" mode) -----------
# Each dynamic pool is served by some DHCP server (an AP or gateway). The
# importer stamps that on the range's notes as "dnsmasq:<host>"; fall back to
# the zone, then 'unknown'.
sub server_of_range {
    my ($r) = @_;
    return $1 if defined $r->{notes} && $r->{notes} =~ /dnsmasq:(\S+)/;
    return $r->{zone} if defined $r->{zone} && length $r->{zone};
    return 'unknown';
}
# Best-guess management address for the AP/gateway that serves a pool, so the UI
# can deep-link to its web admin. Match a reservation named after the DHCP
# server (exact, then loose substring), preferring one in the same subnet as the
# server's own pools (a dual-homed AP has up/down hosts); fall back to DNS.
# Returns undef when nothing is known — the caller leaves the name unlinked.
sub server_host_ip {
    my ($model, $srv) = @_;
    return undef if !defined $srv || $srv eq '' || lc $srv eq 'unknown';
    my %srv_net;        # subnets this server actually hands out in
    for my $r (@{ $model->{ranges} }) {
        next unless lc(server_of_range($r)) eq lc $srv;
        my $s = subnet_of($r->{start_ip}); $srv_net{$s} = 1 if $s;
    }
    my $pick = sub {        # prefer a candidate reachable in one of those subnets
        my @c = @_;  return undef unless @c;
        for my $r (@c) { my $s = subnet_of($r->{ip}); return $r->{ip} if $s && $srv_net{$s}; }
        return $c[0]{ip};
    };
    my @resv = grep { defined $_->{ip} && length($_->{name} // '') } values %{ $model->{resv} };
    my $ip = $pick->( grep { lc $_->{name} eq lc $srv } @resv );
    $ip  //= $pick->( grep { $_->{name} =~ /\Q$srv\E/i || $srv =~ /\Q$_->{name}\E/i } @resv );
    return $ip if $ip;
    my @h = gethostbyname($srv);    # system resolver appends the search domain
    return join('.', unpack('C4', $h[4])) if @h >= 5 && length($h[4]) == 4;
    return undef;
}
# Resolve a DHCP-server tag to its IP via net-lookup — the same alias-aware,
# POV-scored resolver net-ssh used to reach the AP when it imported the pool
# (the tag is the AP's *self-name*, not a hostname nas3 knows, so plain DNS /
# reservation matching misses it; net-lookup's friendly_names/aliases catch it).
# Cached per server (resolution is stable) so we don't fork on every redraw;
# '' cached means "couldn't resolve" — don't retry. Bounded so a slow daemon
# can't stall the GUI.
sub server_link_ip {
    my ($S, $srv) = @_;
    return undef if !defined $srv || $srv eq '' || lc $srv eq 'unknown';
    my $cache = $S->{srv_ip} ||= {};
    return ($cache->{$srv} || undef) if exists $cache->{$srv};
    my $bin = (-x "$FindBin::Bin/net-lookup") ? "$FindBin::Bin/net-lookup" : 'net-lookup';
    my $listen = $S->{listen} // '127.0.0.1:7531';
    my $ip = '';
    eval {
        local $SIG{ALRM} = sub { die "timeout\n" };
        alarm 3;
        if (open my $fh, '-|', $bin, '--family', 'v4', '--listen', $listen, "=$srv") {
            while (<$fh>) { if (/(\d+\.\d+\.\d+\.\d+)/) { $ip = $1; last } }
            close $fh;
        }
        alarm 0;
    };
    alarm 0;
    $cache->{$srv} = $ip;
    return $ip || undef;
}
# A clickable web-admin URL for a DHCP server, plus the IP to show (if any).
# Always returns a URL so every server is linkable: net-lookup's address, else
# the model's reservation/DNS guess, else an FQDN the browser can try.
sub server_url {
    my ($S, $model, $srv) = @_;
    my $ip = server_link_ip($S, $srv) // server_host_ip($model, $srv);
    return ("http://$ip/", $ip) if $ip;
    my $dom  = $S->{domain};
    my $host = (defined $dom && length $dom) ? "$srv.$dom" : $srv;
    return ("http://$host/", undef);
}
# Cluster/DNS domain, for FQDN-guessing a server link when no address is known.
sub gui_domain {
    my ($cli) = @_;
    my $d = eval { my $s = $cli->status; $s->{cluster_domain} || $s->{cluster_name} } // '';
    $d = '' unless $d =~ /[A-Za-z]/;        # ignore empty / IP-ish values
    unless (length $d) {
        $d = eval { NetMgr::Config->load($ENV{NET_MGR_CONF} // '/etc/net-mgr/config')
                        ->{dns}{domain} } // '';
    }
    $d =~ s/^\s+|\s+$//g if defined $d;
    return $d // '';
}
# Spawn the first of several candidate commands that exists, detached from the
# GUI. Each arg is a full argv arrayref; exec only returns on failure, so it
# falls through to the next. Double-fork so the app is reparented to init (no
# zombie). Use POSIX::_exit, NEVER exit/CORE::exit, in the forked children: a
# normal exit runs Perl global destruction here, and Tk's XS cleanup then dumps
# its SVs (REFCNT/FLAGS/IV) to the terminal and can disturb the parent's X
# connection. Redirect the std fds before the second fork so neither child can
# write to the terminal regardless.
sub _spawn_first {
    my (@cmds) = @_;
    require POSIX;
    my $pid = fork();
    return unless defined $pid;
    if ($pid == 0) {
        open STDIN,  '<', '/dev/null';
        open STDOUT, '>', '/dev/null';
        open STDERR, '>', '/dev/null';
        my $p2 = fork();
        POSIX::_exit(127) unless defined $p2;
        POSIX::_exit(0)   if $p2;               # intermediate child exits at once
        for my $c (@cmds) { next unless @$c; no warnings; exec { $c->[0] } @$c; }
        POSIX::_exit(127);
    }
    waitpid($pid, 0);                           # reap the intermediate child
}

# Open $url in the user's browser.
sub open_url {
    my ($url) = @_;
    return unless defined $url && length $url;
    _spawn_first(map { [$_, $url] }
        qw(xdg-open sensible-browser x-www-browser firefox chromium google-chrome));
}

# Play a media URL (rtsp://…) in VLC.
sub launch_vlc {
    my ($url) = @_;
    return unless defined $url && length $url;
    _spawn_first(['vlc', $url], ['cvlc', $url], ['xdg-open', $url]);
}

# Run @cmd (e.g. ssh/telnet to a host) in a terminal emulator. Terminals differ
# in how they take the command, so try the common ones with their own flag.
sub launch_terminal {
    my (@cmd) = @_;
    return unless @cmd;
    _spawn_first(
        ['x-terminal-emulator', '-e', @cmd],
        ['gnome-terminal', '--', @cmd],
        ['konsole', '-e', @cmd],
        ['xfce4-terminal', '-x', @cmd],
        ['alacritty', '-e', @cmd],
        ['kitty', @cmd],
        ['xterm', '-e', @cmd],
    );
}
# The dhcp_range row whose [start_ip, end_ip] covers $ip, or undef.
sub range_at {
    my ($model, $ip) = @_;
    my $i = ip2int($ip);
    return undef unless defined $i;
    # Smallest (most specific) covering range wins, so a pool nested inside a
    # bigger one still renders instead of being hidden by the first match.
    my ($best, $bestw);
    for my $r (@{ $model->{ranges} }) {
        my $lo = ip2int($r->{start_ip}); my $hi = ip2int($r->{end_ip});
        next unless defined $lo && defined $hi && $i >= $lo && $i <= $hi;
        my $w = $hi - $lo;
        ($best, $bestw) = ($r, $w) if !defined $bestw || $w < $bestw;
    }
    return $best;
}
# Every range covering $ip — used to flag overlaps. Disjoint pools (the goal:
# an address maps to exactly one server) cover any IP at most once; 2+ means
# the address would be handed out by multiple servers.
sub ranges_at {
    my ($model, $ip) = @_;
    my $i = ip2int($ip);
    return () unless defined $i;
    grep {
        my $lo = ip2int($_->{start_ip}); my $hi = ip2int($_->{end_ip});
        defined $lo && defined $hi && $i >= $lo && $i <= $hi;
    } @{ $model->{ranges} };
}
# Stable server -> colour map over the model's ranges (sorted by server name).
# The palette is declared inside the sub on purpose: a file-scoped `my` here
# would never be initialised under `--gui` (the script enters Tk's MainLoop from
# the dispatch above, before execution ever reaches a later top-level `my`).
sub server_colors {
    my ($model) = @_;
    # No red in this palette: red is reserved for flagging overlapping pools (a
    # conflict) — see the '#f00' fill in draw_cell. '#d62728' (brick red) was
    # replaced with a teal so a server's pool can never be mistaken for a clash.
    my @colours = ('#1f77b4','#ff7f0e','#2ca02c','#17a589','#9467bd',
                   '#8c564b','#e377c2','#17becf','#bcbd22','#7f7f7f');
    my %srv; $srv{ server_of_range($_) } = 1 for @{ $model->{ranges} };
    my %c; my $i = 0;
    $c{$_} = $colours[$i++ % @colours] for sort keys %srv;
    return \%c;
}

# ---- Perl/Tk GUI -----------------------------------------------------

sub cmd_gui {
    my ($want_subnet) = @_;
    eval { require Tk; Tk->import; require Tk::DialogBox; require Tk::BrowseEntry;
           require Tk::ROText; 1 }   # explicit: silences Scrolled's "Assuming require" note
        or die "net-reserve: Perl/Tk not available: $@";

    my $cli = connect_client();   # auth on remote so reserve/release work
    my %S = (subnet => undef, model => gather($cli), cur => undef, pinned => {},
             show => _read_cidr_list('show'), ignore => _read_cidr_list('ignore'),
             listen => $listen, domain => gui_domain($cli), srv_ip => {});
    # Seed the picker with this machine's own attached subnets, so your LANs
    # are pickable even before the DB has ranges/leases for them.
    $S{pinned}{$_} = 1 for @{ local_subnets() };
    # An explicit `--gui SUBNET` opens straight to it, even with no data yet.
    if (defined $want_subnet) {
        my $n = normalize_cidr($want_subnet);
        if ($n) { $S{subnet} = $n; $S{pinned}{$n} = 1; }
    }
    # No explicit --gui SUBNET → reopen on the last subnet you viewed (pin it so
    # it's pickable even if undiscovered), then fall back to a discovered subnet.
    if (!defined $S{subnet}) {
        my $last = _read_last_subnet();
        if (defined $last) { $S{subnet} = $last; $S{pinned}{$last} = 1; }
    }
    $S{subnet} //= $S{model}{subnets}[0] // (sort keys %{ $S{pinned} })[0];

    my $mw = Tk::MainWindow->new(-title => "net-reserve — $listen");
    $S{anchor} = $mw;             # dialogs parent off the main window
    my $fs = 10;
    $mw->fontCreate('nrui',   -size => $fs);
    $mw->fontCreate('nrmono', -family => 'Courier', -size => $fs);
    $mw->optionAdd('*font' => 'nrui', 81);

    my $top = $mw->Frame->pack(-side => 'top', -fill => 'x', -pady => 2);
    $top->Label(-text => 'Subnet:')->pack(-side => 'left');
    # Forward-declared so the widget callbacks below close over them; the
    # coderefs are assigned further down but only ever *called* at event time.
    my ($subnet_be, $status, $canvas, $resv_text, $redraw, $refresh_subnets,
        $sync_now);

    # About box — client build info plus live daemon STATUS (schema, role, mesh).
    my $about = sub {
        my $w = $mw->Toplevel(-title => 'About net-reserve');
        $w->transient($mw);
        my @st    = stat($0);
        my $built = @st ? scalar localtime($st[9]) : '(unknown)';
        my $s     = eval { $cli->status } || {};
        my $start = $s->{started_at} ? scalar localtime(int $s->{started_at}) : '?';
        my @lines = (
            'net-reserve — DHCP reservations + dynamic ranges',
            '',
            'Client',
            sprintf('  program    %s', $0),
            sprintf('  installed  %s', $built),
            sprintf('  perl       %vd', $^V),
            sprintf('  Tk         %s', $Tk::VERSION // '?'),
            sprintf('  host       %s', eval { hostname() } // '?'),
            '',
            "Daemon  ($listen)",
            (%$s
                ? ( sprintf('  schema     v%s', $s->{schema_version} // '?'),
                    sprintf('  role       %s', $s->{cluster_role}    // '?'),
                    sprintf('  master     %s', $s->{cluster_master}  // '?'),
                    sprintf('  cluster    %s', $s->{cluster_name} || $s->{cluster_domain} || '(unnamed)'),
                    sprintf('  clients    %s', $s->{clients} // '?'),
                    sprintf('  started    %s', $start),
                    sprintf('  mesh       %s', $s->{cluster_mesh} || '(none)') )
                : ('  (unreachable)') ),
        );
        my $body = join("\n", @lines);
        my $txt = $w->Scrolled('ROText', -scrollbars => 'oe', -wrap => 'none',
                               -width => 64, -height => scalar(@lines) + 1,
                               -font => 'nrmono')
                    ->pack(-fill => 'both', -expand => 1, -padx => 6, -pady => 6);
        $txt->insert('end', $body);
        $w->Button(-text => 'Close', -command => sub { $w->destroy })
          ->pack(-side => 'bottom', -pady => 4);
    };

    # The picker offers the union of discovered subnets, any pinned
    # (manually-entered) ones, the persistent "show" list, and the current
    # selection — minus the persistent "ignore" list (the current subnet is
    # kept visible regardless, so you can un-ignore it). See [net-reserve] in
    # the per-user config; the + / - buttons edit it.
    my $all_subnets = sub {
        my %u;
        $u{$_} = 1 for @{ $S{model}{subnets} };
        $u{$_} = 1 for keys %{ $S{pinned} };
        $u{$_} = 1 for keys %{ $S{show} };
        $u{ $S{subnet} } = 1 if defined $S{subnet} && length $S{subnet};
        delete $u{$_} for grep { $_ ne ($S{subnet} // '') } keys %{ $S{ignore} };
        return [ sort { (ip2int((split m{/}, $a)[0]) // 0)
                    <=> (ip2int((split m{/}, $b)[0]) // 0) } keys %u ];
    };
    # Explicit user actions (open / jump / Reload) want CURRENT data:
    # nudge the relay's REFRESH proxy to pull this subnet from the master
    # into the local DB, then re-read. The periodic tick stays lazy.
    $sync_now = sub {
        my $note = maybe_refresh($S{subnet});
        $S{model} = gather($cli);
        $refresh_subnets->();
        $redraw->();
        $status->configure(-text => " $note") if $note;
        _write_last_subnet($S{subnet});   # remember it; --gui reopens here next time
    };
    # Jump to (and pin) a typed/selected subnet; silently ignores junk.
    my $set_subnet = sub {
        my $n = normalize_cidr($S{subnet});
        return unless defined $n;
        $S{subnet} = $n;
        $S{pinned}{$n} = 1;
        $sync_now->();
    };
    # + : remember the current subnet (always show it); - : ignore it (drop it
    # from the picker). Both persist to [net-reserve] in the per-user config.
    my $show_subnet = sub {
        my $n = $S{subnet} or return;
        $S{show}{$n} = 1; delete $S{ignore}{$n};
        _write_cidr_list('show', $S{show}); _write_cidr_list('ignore', $S{ignore});
        $refresh_subnets->();
        $status->configure(-text => " keep $n in the list");
    };
    my $hide_subnet = sub {
        my $n = $S{subnet} or return;
        my @vis = grep { $_ ne $n } @{ $all_subnets->() };   # before we change subnet
        $S{ignore}{$n} = 1; delete $S{show}{$n};
        _write_cidr_list('ignore', $S{ignore}); _write_cidr_list('show', $S{show});
        if (@vis) { $S{subnet} = $vis[0]; $sync_now->() } else { $refresh_subnets->() }
        $status->configure(-text => " ignore $n");
    };
    # Backfill host names on every reservation that lacks one (all subnets):
    # re-observe each so the daemon names it from the MAC's machine.
    my $autoname = sub {
        my @resv = grep { !defined $_->{name} || $_->{name} eq '' }
                   values %{ $S{model}{resv} };
        unless (@resv) {
            $status->configure(-text => ' no reservations missing a name'); return;
        }
        $status->configure(-text => ' naming ' . scalar(@resv) . ' reservation(s)...');
        $S{anchor}->update;
        for my $r (@resv) {
            $cli->observe(kind => 'dhcp_reservation', ip => $r->{ip}, mac => $r->{mac},
                subnet_cidr => ($r->{subnet_cidr} // subnet_of($r->{ip})),
                (defined $r->{grp}   && length $r->{grp}   ? (grp   => $r->{grp})   : ()),
                (defined $r->{notes} && length $r->{notes} ? (notes => $r->{notes}) : ()));
        }
        $S{model} = gather($cli); $redraw->();
        my @still = grep { !defined $_->{name} || $_->{name} eq '' }
                    values %{ $S{model}{resv} };
        $status->configure(-text => sprintf(' named %d of %d (%d still unknown)',
            scalar(@resv) - scalar(@still), scalar(@resv), scalar(@still)));
    };

    $subnet_be = $top->BrowseEntry(
        -variable  => \$S{subnet},
        -choices   => $all_subnets->(),
        -width     => 18,
        -browsecmd => sub { $sync_now->() },      # picked from the dropdown
    )->pack(-side => 'left');
    # +/- remember (always show) or ignore (hide) the current subnet, persisted.
    $top->Button(-text => '+', -width => 2, -command => sub { $show_subnet->() })
        ->pack(-side => 'left');
    $top->Button(-text => '-', -width => 2, -command => sub { $hide_subnet->() })
        ->pack(-side => 'left', -padx => 2);
    # Typing a CIDR + Enter (or Go) jumps to it, adding it to the list if new.
    $subnet_be->Subwidget('entry')->bind('<Return>', sub { $set_subnet->() });
    $top->Button(-text => 'Go', -command => sub { $set_subnet->() })
        ->pack(-side => 'left', -padx => 2);
    $top->Button(-text => 'Reload', -command => sub { $sync_now->() })
        ->pack(-side => 'left', -padx => 4);
    # DHCP-servers mode toggle, with the white "assigned" swatch beside it (the
    # legend no longer repeats it): colour the grid by the AP/gateway serving each
    # pool and list those servers in the right pane (instead of the reservations).
    $top->Label(-text => '  ', -background => '#fff', -relief => 'solid', -borderwidth => 1)
        ->pack(-side => 'left', -padx => 2);
    $top->Checkbutton(-text => 'DHCP assigned', -variable => \$S{range_mode},
        -command => sub {
            delete @S{qw(armed_ip armed_subnet range_start range_subnet)};
            $redraw->();
            $status->configure(-text => $S{range_mode}
                ? ' DHCP servers — pools coloured by AP/gateway; red = overlap (pools must be disjoint); click free START then END to add a pool; click a pool (grid) or a range (right pane) to remove'
                : ' reservation mode');
        })->pack(-side => 'left');
    $top->Button(-text => 'About', -command => sub { $about->() })
        ->pack(-side => 'right', -padx => 4);

    # legend
    my %CELL = (
        reserved => '#d33', active => '#90c',
        assigned => '#fff',          # DHCP dynamic range — left uncolored (auto)
        'in-use' => '#e8821e', free => '#3a3',
    );
    my $leg = $top->Frame->pack(-side => 'right');
    for my $st (qw(free in-use reserved active)) {     # 'assigned' lives on the toggle
        $leg->Label(-text => '  ', -background => $CELL{$st},
                    -relief => 'solid', -borderwidth => 1)->pack(-side => 'left');
        $leg->Label(-text => state_label($st) . ' ')->pack(-side => 'left');
    }

    my $body = $mw->Frame->pack(-side => 'top', -fill => 'both', -expand => 1);
    $canvas = $body->Canvas(-width => 16*34, -height => 16*22, -background => '#fff')
        ->pack(-side => 'left', -fill => 'both', -expand => 1, -padx => 4, -pady => 4);
    my $side = $body->Frame->pack(-side => 'right', -fill => 'y');
    $S{side_title} = 'Reservations';
    $side->Label(-textvariable => \$S{side_title})->pack(-side => 'top', -anchor => 'w');
    # Vertical scrollbar always present ('e', not optional 'oe'): otherwise it
    # appears/disappears with the row count — e.g. when toggling to the DHCP-range
    # view, which has fewer rows — and the pane visibly resizes each time.
    $resv_text = $side->Scrolled('ROText', -width => 38, -height => 24,
        -font => 'nrmono', -scrollbars => 'e')->pack(-side => 'top', -fill => 'y', -expand => 1);
    $S{resv_text} = $resv_text;     # so a cell click can centre this pane on its IP

    # -width => 1 so a long status string (e.g. the DHCP-mode help) can't drive
    # the window wider — it just clips. Otherwise toggling to DHCP mode widened
    # the window (the grid grew with it) until the periodic tick reset the text.
    # -fill => x still stretches it to the real window width.
    $status = $mw->Label(-anchor => 'w', -relief => 'sunken', -width => 1)
        ->pack(-side => 'bottom', -fill => 'x');

    $refresh_subnets = sub {
        my $list = $all_subnets->();
        $subnet_be->delete(0, 'end');
        $subnet_be->insert('end', $_) for @$list;
    };

    $redraw = sub {
        my $cidr = $S{subnet};
        my @yv = $resv_text->yview;       # remember scroll; the wipe below resets it to the top
        $canvas->delete('all');
        $resv_text->delete('1.0', 'end');
        unless (defined $cidr) { $status->configure(-text => ' no subnets'); return }
        my ($net, $len, $first, $last) = cidr_parts($cidr);
        unless (defined $net) { $status->configure(-text => " bad subnet $cidr"); return }
        # A selection only belongs to the subnet it was made in; drop it on a switch.
        delete @S{qw(armed_ip armed_subnet)}
            if defined $S{armed_ip} && ($S{armed_subnet} // '') ne $cidr;
        delete @S{qw(range_start range_subnet)}
            if defined $S{range_start} && ($S{range_subnet} // '') ne $cidr;
        # A 'hint' IP — visual-only secondary highlight that points at a sensible
        # default cell whenever the user has no manual selection on this subnet:
        # this machine's own IP if present, else the first 'free' IP. Rendered
        # by draw_cell with a distinct outline so it's obviously a SUGGESTION,
        # not a click. Suppressed when something is armed (avoids two outlines
        # competing) or in range_mode (DHCP-pool flow has its own range_start
        # selection). Recomputed every redraw so the hint isn't stale after
        # someone else reserves the previously-free cell — _gui_default_pick is
        # O(/24) classify calls + one cached `ip -br -4 addr show`, negligible
        # compared to the 5-s gather() that already runs. Skipped when the model
        # is empty (first tick, replication blip) — would otherwise mis-claim
        # the router (.1) as 'first free'.
        my $prev_hint_ip = $S{hint_ip};
        if ($S{range_mode} || defined $S{armed_ip}) {
            delete @S{qw(hint_ip hint_subnet)};
        } else {
            my $model = $S{model};
            my $have_state = $model && (
                   keys(%{ $model->{resv}     // {} })
                || keys(%{ $model->{leased}   // {} })
                || keys(%{ $model->{observed} // {} })
                || @{ $model->{ranges} // [] }
            );
            $S{hint_ip}     = $have_state ? _gui_default_pick($model, $cidr) : undef;
            $S{hint_subnet} = $cidr;
        }
        my $model = $S{model};
        # "DHCP servers" mode: colour each pool by its serving AP/gateway and list
        # those servers in the side pane instead of the reservations.
        $S{side_title} = $S{range_mode} ? 'DHCP servers' : 'Reservations';
        my $srv_color  = $S{range_mode} ? server_colors($model) : {};
        # Fixed-size cells. For a /24 (or smaller) the whole subnet fits in one
        # 256-block, so position every cell by its last octet — column = low
        # nibble, row = high nibble — giving a regular 16-wide grid you can read
        # by address. Larger subnets fall back to sequential fixed boxes.
        my ($cw, $ch, $pad) = (30, 22, 1);
        my ($hx, $hy) = (24, 16);        # left + top header gutters
        my $octet_mode = $len >= 24;
        my $ncol = $S{grid_cols} || 16;  # boxes per row; toggled via the corner slot
        my $overlap_n = 0;               # addresses covered by 2+ pools (range mode)
        my $draw_cell = sub {
            my ($i, $x, $y) = @_;
            my $ip = int2ip($i);
            my $st = classify($model, $ip);
            my $fill = $CELL{$st};
            # DHCP-servers mode: a neutral pick surface — every box drawn blank so
            # you can pick a range; colour the WHOLE of each pool by its serving
            # server. Keyed on range membership (ranges_at), not classify — a
            # reservation or lease inside a pool otherwise classifies as
            # reserved/in-use and punches a hole in the colour (fragmented pool).
            # An address in 2+ pools is an overlap — pools must be disjoint so a
            # device's IP identifies one server — flag those red.
            if ($S{range_mode}) {
                my @rs = ranges_at($model, $ip);
                if    (@rs >= 2) { $fill = '#f00'; $overlap_n++; }
                elsif (@rs == 1) { $fill = $srv_color->{ server_of_range($rs[0]) } // '#fff'; }
                else             { $fill = '#fff'; }
            }
            # Outline the selected cell: the armed reservation, or the pool start.
            # A 'hint' IP (this machine's own, or first free) gets a distinct
            # blue outline so it's clearly a SUGGESTION the user can ignore —
            # only drawn when nothing is armed on this subnet.
            my $sel = $S{range_mode}
                    ? (defined $S{range_start} && $ip eq $S{range_start})
                    : (defined $S{armed_ip}    && $ip eq $S{armed_ip});
            my $hint = !$sel
                    && !defined $S{armed_ip}
                    && defined $S{hint_ip}
                    && $ip eq $S{hint_ip};
            my $outline = $sel ? '#000' : ($hint ? '#39c' : '#999');
            my $width   = ($sel || $hint) ? 2 : 1;
            my $r = $canvas->createRectangle($x, $y, $x + $cw - 2, $y + $ch - 2,
                -fill => $fill, -outline => $outline, -width => $width);
            my $t = $canvas->createText($x + ($cw - 2) / 2, $y + ($ch - 2) / 2,
                -text => ($i & 0xFF), -font => 'nrmono');
            for my $item ($r, $t) {
                $canvas->bind($item, '<Button-1>',
                    [ sub { cell_click($cli, \%S, $ip, $redraw, $status) } ]);
            }
        };
        if ($octet_mode) {
            # Corner toggle (the 0/0 header slot): flip the grid between 16 and 10
            # boxes per row. Shows the current count; click to switch. Re-fit the
            # canvas after, since 10-wide is taller/narrower than 16-wide.
            my $cr = $canvas->createRectangle(0, 0, $hx - 2, $hy - 1,
                -fill => '#eee', -outline => '#bbb');
            my $ct = $canvas->createText(($hx - 2) / 2, ($hy - 1) / 2,
                -text => $ncol, -font => 'nrmono', -fill => '#444');
            for my $item ($cr, $ct) {
                $canvas->bind($item, '<Button-1>', [ sub {
                    $S{grid_cols} = $ncol == 16 ? 10 : 16;
                    $redraw->(); _fit_canvas_to_grid($canvas);
                } ]);
                $canvas->bind($item, '<Enter>', sub { $canvas->configure(-cursor => 'hand2') });
                $canvas->bind($item, '<Leave>', sub { $canvas->configure(-cursor => '') });
            }
            # column headers (0..ncol-1; hex digits when 16-wide so A-F line up)
            for my $c (0 .. $ncol - 1) {
                $canvas->createText($hx + $c * $cw + ($cw - 2) / 2, $hy / 2,
                    -text => ($ncol == 16 ? sprintf('%X', $c) : $c),
                    -font => 'nrmono', -fill => '#888');
            }
            my %rows;  $rows{ int(($_ & 0xFF) / $ncol) } = 1 for ($first .. $last);
            # ... row labels (base octet of each used row)
            for my $rr (sort { $a <=> $b } keys %rows) {
                $canvas->createText($hx - 3, $hy + $rr * $ch + ($ch - 2) / 2,
                    -text => $rr * $ncol, -font => 'nrmono', -fill => '#888',
                    -anchor => 'e');
            }
            for my $i ($first .. $last) {
                my $oct = $i & 0xFF;
                $draw_cell->($i, $hx + ($oct % $ncol)   * $cw + $pad,
                                 $hy + int($oct / $ncol) * $ch + $pad);
            }
        } else {
            my $col = 0; my $rown = 0;
            for my $i ($first .. $last) {
                $draw_cell->($i, ($col % $ncol) * $cw + $pad, $rown * $ch + $pad);
                $rown++ if ++$col % $ncol == 0;
            }
        }
        if ($S{range_mode}) {
            # DHCP pools grouped by SUBNET. The current subnet's pools show in
            # full colour; other subnets are greyed and their headers click
            # through to that subnet. Each pool lists its serving AP/gateway as a
            # link to the box's web admin and the range (click to delete).
            my %by_net;
            for my $r (@{ $model->{ranges} }) {
                my $net = $r->{subnet_cidr} || subnet_of($r->{start_ip}) || '(unknown)';
                push @{ $by_net{$net} }, $r;
            }
            $resv_text->insert('end', "  (no DHCP ranges yet)\n") unless %by_net;
            my @nets = sort {
                (ip2int((split m{/}, $a)[0]) // 0) <=> (ip2int((split m{/}, $b)[0]) // 0)
            } keys %by_net;
            my $ri = 0;
            for my $net (@nets) {
                my $here = ($net eq $cidr);
                # subnet header — current in black; others a link that jumps there
                (my $ntag = "net_$net") =~ s/\W/_/g;
                $resv_text->insert('end',
                    $net . ($here ? '  (current)' : '  → view') . "\n", $ntag);
                $resv_text->tagConfigure($ntag,
                    -foreground => ($here ? '#000' : '#36c'),
                    ($here ? () : (-underline => 1)));
                unless ($here) {
                    $resv_text->tagBind($ntag, '<Button-1>', sub {
                        $S{subnet} = $net; $S{pinned}{$net} = 1; $sync_now->(); });
                    $resv_text->tagBind($ntag, '<Enter>',
                        sub { $resv_text->configure(-cursor => 'hand2'); });
                    $resv_text->tagBind($ntag, '<Leave>',
                        sub { $resv_text->configure(-cursor => ''); });
                }
                for my $r (sort { ip2int($a->{start_ip}) <=> ip2int($b->{start_ip}) }
                           @{ $by_net{$net} }) {
                    my $srv = server_of_range($r);
                    my $grey = $here ? undef : '#9a9a9a';
                    # colour swatch (muted for greyed subnets)
                    (my $stag = "sw$ri") =~ s/\W/_/g;
                    $resv_text->tagConfigure($stag, -background =>
                        ($here ? ($srv_color->{$srv} // '#fff') : '#e6e6e6'));
                    $resv_text->insert('end', '    ');
                    $resv_text->insert('end', '  ', $stag);
                    # server name -> link to its web admin (every server linkable)
                    my ($url, $iptxt) = server_url(\%S, $model, $srv);
                    # Mis-homed pool: the serving device lives in a different /24
                    # than the pool it hands out (e.g. Nighthawk @ 192.168.15.151
                    # tagged to a 192.168.223.x pool) — almost always a stale or
                    # mis-imported dhcp-range. Flag it on the line below.
                    my $offnet;
                    if ($iptxt) {
                        my $ssub = subnet_of($iptxt);
                        my $psub = subnet_of($r->{start_ip});
                        $offnet = $ssub if defined $ssub && defined $psub && $ssub ne $psub;
                    }
                    (my $htag = "host$ri") =~ s/\W/_/g;
                    $resv_text->insert('end', " $srv", $htag);
                    $resv_text->tagConfigure($htag,
                        -foreground => ($here ? '#06c' : '#9ab'), -underline => 1);
                    $resv_text->tagBind($htag, '<Button-1>', sub { open_url($url) });
                    $resv_text->tagBind($htag, '<Enter>',
                        sub { $resv_text->configure(-cursor => 'hand2'); });
                    $resv_text->tagBind($htag, '<Leave>',
                        sub { $resv_text->configure(-cursor => ''); });
                    # the range itself -> click to delete; flag overlaps
                    my $ov = grep { $_ != $r
                            && ip2int($_->{end_ip})   >= ip2int($r->{start_ip})
                            && ip2int($_->{start_ip}) <= ip2int($r->{end_ip}) }
                        @{ $model->{ranges} };
                    (my $rtag = "rng$ri") =~ s/\W/_/g;
                    $resv_text->insert('end', sprintf("  %s%s%s%s\n",
                        range_short($r->{start_ip}, $r->{end_ip}),
                        ($iptxt ? "  ($iptxt)" : ''),
                        ($offnet ? "  *** server on $offnet" : ''),
                        ($ov ? '  *** overlap' : '')),
                        $rtag);
                    $resv_text->tagConfigure($rtag, -foreground => $grey) if $grey;
                    $resv_text->tagBind($rtag, '<Button-1>',
                        sub { range_delete_dialog($cli, \%S, $r, $redraw, $status) });
                    $resv_text->tagBind($rtag, '<Enter>', sub {
                        $resv_text->configure(-cursor => 'hand2');
                        $resv_text->tagConfigure($rtag, -background => '#fdd'); });
                    $resv_text->tagBind($rtag, '<Leave>', sub {
                        $resv_text->configure(-cursor => '');
                        $resv_text->tagConfigure($rtag, -background => ''); });
                    $ri++;
                }
            }
        } else {
            # side list, grouped (reservations)
            my @mine = sort { ip2int($a->{ip}) <=> ip2int($b->{ip}) }
                       grep { ($_->{subnet_cidr} // subnet_of($_->{ip}) // '') eq $cidr }
                       values %{ $model->{resv} };
            my %by_grp; push @{ $by_grp{ $_->{grp} // '(ungrouped)' } }, $_ for @mine;
            for my $g (sort keys %by_grp) {
                $resv_text->insert('end', "[$g]\n");
                for my $rr (@{ $by_grp{$g} }) {
                    $resv_text->insert('end',
                        sprintf("  %-15s %s\n", $rr->{ip}, ($rr->{name} // $rr->{mac})));
                }
            }
            # Active addresses: leased/observed but not reserved (e.g. the KP200,
            # which took a dynamic lease). List them by name so they're not just
            # an in-use cell with no label in the pane.
            my %active;
            for my $src ($model->{leased}, $model->{observed}) {
                for my $aip (keys %$src) {
                    next if $model->{resv}{$aip};
                    next unless (subnet_of($aip) // '') eq $cidr;
                    my $mac = $src->{$aip}{mac} or next;
                    $active{$aip} //= $mac;
                }
            }
            if (%active) {
                $resv_text->insert('end', "[in use]\n");
                for my $aip (sort { ip2int($a) <=> ip2int($b) } keys %active) {
                    my $mac  = $active{$aip};
                    my $name = $model->{mac_name}{ lc $mac }
                            // ($model->{leased}{$aip} ? $model->{leased}{$aip}{hostname} : undef)
                            // $mac;
                    $resv_text->insert('end', sprintf("  %-15s %s\n", $aip, $name));
                }
            }
        }
        if ($S{range_mode} && $overlap_n) {
            $status->configure(-text => sprintf(
                " %s — %d address(es) in OVERLAPPING pools (red); pools must be disjoint",
                $cidr, $overlap_n));
        } else {
            $status->configure(-text => sprintf(" %s — %s", $cidr, pool_summary($model, $cidr)));
        }
        # Track the side-pane focus to a CHANGED hint, but only when the hint
        # is a real reservation (scrolling for a free cell would just yank to
        # the nearest other row — noise). Also: only fire on CHANGE, so a
        # subnet-revisit doesn't trample the user's manually-centred row.
        # Deferred to here so the side text widget is already populated when
        # side_focus_ip's _resv_index lookup runs (without this, the lookup
        # hits an empty widget and falls through to _nearest_reserved, which
        # happens to recover the right answer for resv-hint but only by
        # coincidence). On undef hint (no IP picked at all) clear stale focus.
        my $new_hint_ip = $S{hint_ip};
        if (($prev_hint_ip // '') ne ($new_hint_ip // '')) {
            if (defined $new_hint_ip && $S{model}{resv}{$new_hint_ip}) {
                side_focus_ip(\%S, $new_hint_ip);
            } elsif (!defined $new_hint_ip) {
                delete @S{qw(focus_ip focus_exact)};
                $resv_text->tagRemove('nrhit', '1.0', 'end');
            }
            # Hint defined but not a reservation: leave focus_ip alone — the
            # trailing _focus_show restores the prior yview, no jolt.
        }
        # The wipe above cleared the highlight AND scrolled to the top. Re-centre
        # on the focused IP (also re-highlights); if it isn't in this view, just
        # put the scroll back where it was instead of leaving it at the top.
        _focus_show(\%S) or $resv_text->yviewMoveto($yv[0]);
    };

    $sync_now->();      # open with a forced pull of the initial subnet
    _fit_canvas_to_grid($canvas);   # size the window to show the whole grid on launch
    # Name any nameless reservations on launch (was the "Name unnamed" button);
    # scheduled so the window paints first. A no-op when nothing needs naming.
    $mw->after(300, sub { $autoname->() });
    # periodic refresh: lazy (local DB only) — explicit actions force-sync
    my $tick; $tick = sub {
        $S{model} = gather($cli); $refresh_subnets->(); $redraw->();
        $mw->after(5000, $tick);
    };
    $mw->after(5000, $tick);
    Tk::MainLoop();
}

# Click handler — two-step, so a stray click can't pop a dialog. The first click
# on a box selects it: centres/highlights its right-pane entry and outlines the
# cell, but takes no action. A second click on the SAME box opens the pop-up
# (free → reserve dialog; reserved → release/edit dialog). Clicking a different
# box just moves the selection there (a fresh first click).
sub cell_click {
    my ($cli, $S, $ip, $redraw, $status) = @_;
    return range_click($cli, $S, $ip, $redraw, $status) if $S->{range_mode};
    my $model = $S->{model};
    my $st = classify($model, $ip);
    if (($S->{armed_ip} // '') ne $ip) {          # first click: arm + highlight only
        $S->{armed_ip}     = $ip;
        $S->{armed_subnet} = $S->{subnet};        # so a subnet change can drop it
        side_focus_ip($S, $ip);                   # centre the right pane (if reserved)
        $redraw->();                              # repaint so the armed cell is outlined
        eval { $S->{anchor}->idletasks } if $S->{anchor};
        my $near = $S->{focus_ip};      # nearest reservation side_focus_ip landed on
        $status->configure(-text => " $ip selected — click again to "
            . (($st eq 'reserved' || $st eq 'active') ? 'edit / release' : 'reserve')
            . (defined $near && $near ne $ip ? " (nearest reservation: $near)" : ''));
        return;
    }
    delete $S->{armed_ip}; delete $S->{armed_subnet};   # second click: consume + act
    $redraw->();                                  # drop the armed outline before the dialog
    if ($st eq 'reserved' || $st eq 'active') {   # both are reservations
        my $r = $model->{resv}{$ip};
        release_dialog($cli, $S, $ip, $r, $redraw, $status);
    } else {
        # prefill MAC if the address is currently leased/observed
        my $mac = '';
        $mac = $model->{leased}{$ip}{mac}   if $model->{leased}{$ip};
        $mac = $model->{observed}{$ip}{mac} if !$mac && $model->{observed}{$ip};
        reserve_dialog($cli, $S, $ip, $mac, $redraw, $status);
    }
}

# DHCP-servers mode click: click inside an existing pool to remove it; otherwise
# click the pool START then the END to assign a new range to an AP/gateway.
sub range_click {
    my ($cli, $S, $ip, $redraw, $status) = @_;
    if (my $r = range_at($S->{model}, $ip)) {           # inside a pool -> remove
        delete @{$S}{qw(range_start range_subnet)}; $redraw->();
        range_delete_dialog($cli, $S, $r, $redraw, $status);
        return;
    }
    if (!defined $S->{range_start}) {                   # first click: pool start
        $S->{range_start}  = $ip;
        $S->{range_subnet} = $S->{subnet};
        $redraw->();
        $status->configure(-text => " DHCP pool start $ip — click the END address");
        return;
    }
    my ($a, $b) = (ip2int($S->{range_start}), ip2int($ip));   # second click: end
    ($a, $b) = ($b, $a) if $a > $b;
    delete @{$S}{qw(range_start range_subnet)};
    range_assign_dialog($cli, $S, int2ip($a), int2ip($b), $redraw, $status);
}

# Assign a new pool start-end to a DHCP server (AP/gateway).
sub range_assign_dialog {
    my ($cli, $S, $start, $end, $redraw, $status) = @_;
    my $cidr = $S->{subnet};
    my $dlg = ($S->{anchor} // $status)->DialogBox(
        -title => "DHCP pool $start - $end", -buttons => ['Assign', 'Cancel']);
    $dlg->add('Label', -justify => 'left',
        -text => "Assign a DHCP pool in $cidr:\n    $start  ->  $end\n")
        ->pack(-padx => 8, -pady => 4);
    my %v = (server => '');
    my %srv; $srv{ server_of_range($_) } = 1 for @{ $S->{model}{ranges} };
    my $row = $dlg->add('Frame')->pack(-fill => 'x', -pady => 2);
    $row->Label(-text => 'Server:', -width => 8, -anchor => 'w')->pack(-side => 'left');
    $row->Entry(-textvariable => \$v{server}, -width => 22)->pack(-side => 'left');
    if (grep { $_ ne 'unknown' } keys %srv) {
        my $r2 = $dlg->add('Frame')->pack(-fill => 'x');
        $r2->Label(-text => '', -width => 8)->pack(-side => 'left');
        for my $s (sort grep { $_ ne 'unknown' } keys %srv) {
            $r2->Button(-text => $s, -command => sub { $v{server} = $s })->pack(-side => 'left');
        }
    }
    my $ans = $dlg->Show // 'Cancel';
    return unless $ans eq 'Assign';
    my $r = $cli->observe(kind => 'dhcp_range', subnet_cidr => $cidr,
        start_ip => $start, end_ip => $end,
        ($v{server} ne '' ? (notes => "dnsmasq:$v{server}", zone => $v{server}) : ()));
    if (!defined $r || $r =~ /^ERR/) { $status->configure(-text => " $r"); return }
    $S->{model} = gather($cli); $redraw->();
    $status->configure(-text => " assigned DHCP pool $start-$end"
        . ($v{server} ne '' ? " -> $v{server}" : ''));
}

# Remove an existing DHCP pool.
sub range_delete_dialog {
    my ($cli, $S, $r, $redraw, $status) = @_;
    my $ans = lc(($S->{anchor} // $status)->messageBox(
        -type => 'yesno', -icon => 'question', -title => 'Remove DHCP pool',
        -message => "Remove DHCP pool\n$r->{subnet_cidr}  $r->{start_ip} - $r->{end_ip}"
            . "  (" . server_of_range($r) . ")?"));
    return unless $ans eq 'yes';
    my $resp = $cli->observe(kind => 'dhcp_range_delete',
        subnet_cidr => $r->{subnet_cidr}, start_ip => $r->{start_ip});
    if (!defined $resp || $resp =~ /^ERR/) { $status->configure(-text => " $resp"); return }
    $S->{model} = gather($cli); $redraw->();
    $status->configure(-text => " removed DHCP pool $r->{start_ip}-$r->{end_ip}");
}

# Scroll the right-hand Reservations pane so the line for $ip is centred and
# briefly highlighted. A no-op when $ip has no reservation line (free / in-use /
# pool address): those don't appear in the list, so there's nothing to centre on.
sub side_focus_ip {
    my ($S, $ip) = @_;
    my $t = $S->{resv_text} or return;
    # Highlight the clicked address if it's itself a reservation; otherwise the
    # nearest reserved address in the same subnet, so clicking a free box still
    # points you at the closest reservation. undef => the subnet has none.
    my $target = defined _resv_index($t, $ip) ? $ip : _nearest_reserved($S, $ip);
    if (!defined $target) {
        delete @{$S}{qw(focus_ip focus_exact)};
        $t->tagRemove('nrhit', '1.0', 'end');
        return;
    }
    $S->{focus_ip}    = $target;            # remember so redraw can restore it
    $S->{focus_exact} = ($target eq $ip) ? 1 : 0;   # exact click vs nearest fallback
    _focus_show($S);
}

# Nearest reserved address (by numeric distance) to $ip among the current
# subnet's reservations, or undef if there are none. Ties go to the lower IP.
sub _nearest_reserved {
    my ($S, $ip) = @_;
    my $n = ip2int($ip);
    return undef unless defined $n;
    my $cidr = $S->{subnet} // '';
    my ($best, $bestd);
    for my $r (values %{ $S->{model}{resv} }) {
        next unless ($r->{subnet_cidr} // subnet_of($r->{ip}) // '') eq $cidr;
        my $ri = ip2int($r->{ip});
        next unless defined $ri;
        my $d = abs($ri - $n);
        next if defined $bestd
            && ($d > $bestd || ($d == $bestd && $ri >= ip2int($best)));
        ($best, $bestd) = ($r->{ip}, $d);
    }
    return $best;
}

# Grow the canvas to fit every drawn box, so the whole subnet shows on launch
# (the grid is otherwise clipped to the canvas's fixed request size, and there's
# no canvas scrollbar). Capped to the screen so a large subnet can't open an
# off-screen window. Returns the (width, height) it settled on, or () if empty.
sub _fit_canvas_to_grid {
    my ($canvas) = @_;
    my @bb = $canvas->bbox('all') or return ();   # extent of all drawn items
    my $w = $bb[2] + 6;                            # right/bottom edge + small margin
    my $h = $bb[3] + 6;
    my $maxw = $canvas->screenwidth  - 360;        # leave room for the side pane + WM
    my $maxh = $canvas->screenheight - 140;
    $w = $maxw if $maxw > 0 && $w > $maxw;
    $h = $maxh if $maxh > 0 && $h > $maxh;
    $canvas->configure(-width => $w, -height => $h);
    return ($w, $h);
}

# Centre the focused IP's line in the pane and highlight it. Re-run at the end
# of every redraw: the periodic refresh rebuilds the list (delete + reinsert),
# which both wipes the nrhit tag AND scrolls the view back to the top — so
# without this the highlight vanishes and the pane jumps to the top after ~5s.
# Returns true if the focused IP was found and shown, false otherwise.
sub _focus_show {
    my ($S) = @_;
    my $t = $S->{resv_text} or return 0;
    $t->tagRemove('nrhit', '1.0', 'end');
    my $ip = $S->{focus_ip};
    return 0 unless defined $ip;
    my $idx = _resv_index($t, $ip) or return 0;     # focused IP not in this view
    my ($line)  = $t->index($idx)      =~ /^(\d+)/;
    my ($total) = $t->index('end -1c') =~ /^(\d+)/;
    $total ||= 1;
    my $vis = eval { $t->cget('-height') } || 24;   # visible rows (no wrap here)
    my $top = $line - int($vis / 2);  $top = 1 if $top < 1;
    $t->yviewMoveto(($top - 1) / $total);           # keep the line near the middle
    # Amber when it's the exact IP you clicked; a cooler blue when it's only the
    # nearest reservation to an unreserved box you clicked.
    my $color = (defined $S->{focus_exact} && !$S->{focus_exact}) ? '#a8d1ff' : '#ffd24d';
    $t->tagConfigure('nrhit', -background => $color);
    $t->tagAdd('nrhit', "$idx linestart", "$idx lineend");
    return 1;
}

# Text index of the side-list line for $ip, or undef. Exact match, but rejects a
# prefix hit (so 10.0.0.5 won't land on 10.0.0.50): the char right after the IP
# must not be another digit. stopIndex 'end' keeps the scan from wrapping.
sub _resv_index {
    my ($t, $ip) = @_;
    my $from = '1.0';
    while (1) {
        my $idx = $t->search('-exact', '--', $ip, $from, 'end');
        return undef unless defined $idx && length $idx;
        my $after = $t->get("$idx + " . length($ip) . " chars",
                            "$idx + " . (length($ip) + 1) . " chars");
        return $idx unless defined $after && $after =~ /\d/;
        $from = "$idx + 1 chars";
    }
}

sub reserve_dialog {
    my ($cli, $S, $ip, $mac, $redraw, $status) = @_;
    my $dlg = ($S->{anchor} // $status)->DialogBox(-title => "Reserve $ip",
        -buttons => ['Probe', 'Reserve', 'Reserve+Push', 'Cancel']);
    # Default the name to what we already know the device by — its machine name,
    # or failing that the hostname it gave over DHCP — so reserving a device uses
    # its own name when none other is given (e.g. KP200 from its lease).
    my $known = $S->{model}{mac_name}{ lc($mac // '') };
    $known //= $S->{model}{leased}{$ip}{hostname} if $S->{model}{leased}{$ip};
    my %v = (ip => $ip, mac => $mac, name => ($known // ''), group => '');
    # known groups for convenience
    my %groups; $groups{ $_->{grp} } = 1 for grep { $_->{grp} } values %{ $S->{model}{resv} };
    # Target address: a menu of the subnet's addresses with the occupant
    # (MAC/name) beside each, colour-coded — green free, blue for the auto-DHCP
    # dynamic ranges, red otherwise-taken. The "DHCP pool / assigned" toggle
    # hides the blue rows so the list is just static candidates. Editable, so any
    # address can be typed; defaults to the clicked cell.
    my $show_pool = 1;
    my ($be, $lb);
    my $rebuild = sub {
        my (@labels, @colors);
        my ($net, $len, $first, $last) = cidr_parts(subnet_of($ip));
        for (my $i = $first; defined $first && $i <= $last; $i++) {
            my $a  = int2ip($i);
            my $st = classify($S->{model}, $a);
            next if !$show_pool && $st eq 'assigned';       # hide the pool
            push @labels,
                (sprintf("%-15s %-7s %s", $a, $st, occupant($S->{model}, $a)) =~ s/\s+$//r);
            push @colors, menu_color($st);
        }
        return unless $be;
        $be->delete(0, 'end');                              # delete/insert leave
        $be->insert('end', @labels) if @labels;             #   the IP value alone
        eval { $lb->itemconfigure($_, -foreground => $colors[$_]) } for 0 .. $#colors;
    };
    {
        my $row = $dlg->add('Frame')->pack(-fill => 'x', -pady => 1);
        $row->Label(-text => 'IP:', -width => 7, -anchor => 'w')->pack(-side => 'left');
        # No -listwidth/-autolistwidth: the drop-down then matches the widget's
        # own width (entry edge to arrow) instead of shrinking to the text.
        $be = $row->BrowseEntry(-variable => \$v{ip}, -width => 60,
            -listheight => 32,         # show 32 rows in the drop-down
            # the listbox rows carry "IP state occupant"; keep just the IP
            -browsecmd => sub { ($v{ip}) = ($_[-1] // '') =~ /(\d+\.\d+\.\d+\.\d+)/ });
        $be->pack(-side => 'left', -fill => 'x', -expand => 1);
        $lb = eval { $be->Subwidget('slistbox')->Subwidget('listbox') };
        eval { $lb->configure(-font => 'Courier 10 bold') } if $lb;  # bold = contrast
    }
    {
        my $row = $dlg->add('Frame')->pack(-fill => 'x');
        $row->Label(-text => '', -width => 7)->pack(-side => 'left');
        $row->Checkbutton(-text => 'show DHCP pool / assigned',
            -variable => \$show_pool, -command => sub { $rebuild->() })
            ->pack(-side => 'left');
    }
    $rebuild->();
    $v{ip} = $ip;                      # editable default = the clicked cell
    if (my $seen = last_seen_str($S->{model}, $ip)) {   # context for the clicked cell
        my $row = $dlg->add('Frame')->pack(-fill => 'x', -pady => 1);
        $row->Label(-text => 'seen:', -width => 7, -anchor => 'w')->pack(-side => 'left');
        $row->Label(-text => "$ip last seen $seen", -anchor => 'w')->pack(-side => 'left');
    }
    for my $f (['MAC', 'mac'], ['Name', 'name'], ['Group', 'group']) {
        my ($lbl, $key) = @$f;
        my $row = $dlg->add('Frame')->pack(-fill => 'x', -pady => 1);
        $row->Label(-text => "$lbl:", -width => 7, -anchor => 'w')->pack(-side => 'left');
        $row->Entry(-textvariable => \$v{$key}, -width => 48)
            ->pack(-side => 'left', -fill => 'x', -expand => 1);
    }
    if (keys %groups) {
        my $row = $dlg->add('Frame')->pack(-fill => 'x');
        $row->Label(-text => '', -width => 7)->pack(-side => 'left');
        for my $g (sort keys %groups) {
            $row->Button(-text => $g, -command => sub { $v{group} = $g })
                ->pack(-side => 'left');
        }
    }
    # Loop so Probe can pop the read-only detail dialog (on the current IP/MAC,
    # which may have been edited) and return here with the form intact.
    my $ans;
    while (1) {
        $ans = $dlg->Show // 'Cancel';
        last unless $ans eq 'Probe';
        my ($pip) = ($v{ip} // '') =~ /(\d+\.\d+\.\d+\.\d+)/;
        probe_dialog($cli, $S, ($pip // $v{ip}),
            { mac => $v{mac}, name => $v{name}, grp => $v{group} });
    }
    return unless $ans eq 'Reserve' || $ans eq 'Reserve+Push';
    ($v{ip}) = $v{ip} =~ /(\d+\.\d+\.\d+\.\d+)/ ? ($1) : ($v{ip});  # tolerate a label
    unless (defined ip2int($v{ip})) {
        $status->configure(-text => " bad IP '$v{ip}' — not reserved"); return;
    }
    unless ($v{mac} =~ /^[0-9a-fA-F:]{17}$/) {
        $status->configure(-text => " bad MAC '$v{mac}' — not reserved"); return;
    }
    # One reservation per MAC. If this device is already reserved elsewhere,
    # offer to move it rather than create a second (duplicate) reservation.
    my $force = 0;
    my ($dup) = grep { lc($_->{mac}) eq lc($v{mac}) && $_->{ip} ne $v{ip} }
                values %{ $S->{model}{resv} };
    if ($dup) {
        my $ans = lc(($S->{anchor} // $status)->messageBox(
            -type => 'yesnocancel', -icon => 'warning', -title => 'Already reserved',
            -message => "$v{mac} is already reserved at $dup->{ip}"
                . (defined $dup->{name} && length $dup->{name} ? " ($dup->{name})" : '')
                . ".\n\nYes: move that reservation to $v{ip}\n"
                . "No: keep both (add a second reservation)\nCancel: do nothing"));
        return if $ans eq 'cancel';
        if ($ans eq 'yes') {
            my $resp = $cli->observe(kind => 'dhcp_reservation_move',
                ip => $dup->{ip}, new_ip => $v{ip});
            if (!defined $resp || $resp =~ /^ERR/) { $status->configure(-text => " $resp"); return }
            $S->{model} = gather($cli); $redraw->();
            $status->configure(-text => " moved $dup->{ip} -> $v{ip}");
            return;
        }
        $force = 1;          # 'No' — caller insists on a second reservation
    }
    my $r = $cli->observe(kind => 'dhcp_reservation', ip => $v{ip}, mac => lc $v{mac},
        ($v{name}  ne '' ? (name => $v{name})  : ()),
        subnet_cidr => subnet_of($v{ip}),
        ($v{group} ne '' ? (grp  => $v{group}) : ()),
        ($force ? (force => 1) : ()));
    if (!defined $r || $r =~ /^ERR/) { $status->configure(-text => " $r"); return }
    my $msg = " reserved $v{ip} -> $v{mac}";
    if ($ans eq 'Reserve+Push') {
        # Also surface this one reservation as a never-seen net-lookup name.
        $msg .= _push_host($cli, ip => $v{ip}, mac => lc $v{mac},
                           ($v{name} ne '' ? (name => $v{name}) : ()))
            ? ' + pushed to net-lookup' : ' (push failed)';
    }
    $S->{model} = gather($cli); $redraw->();
    $status->configure(-text => $msg);
}

# OUI vendor for a MAC from the IEEE oui.csv — fallback when the interface row
# has no stored vendor. Cached; undef if the file/entry isn't present.
my (%OUI, $oui_loaded);
sub oui_vendor {
    my ($mac) = @_;
    return undef unless $mac && $mac =~ /^([0-9a-f]{2}):([0-9a-f]{2}):([0-9a-f]{2}):/i;
    my $oui = uc "$1$2$3";
    if (!$oui_loaded) {
        $oui_loaded = 1;
        my $f = eval { NetMgr::Config->load($ENV{NET_MGR_CONF} // '/etc/net-mgr/config')
                            ->{paths}{oui_csv} } || '/var/lib/ieee-data/oui.csv';
        if (open my $fh, '<', $f) {
            while (<$fh>) { next unless /^MA-L,([0-9A-F]{6}),"?([^",]+)/; $OUI{$1} = $2 }
            close $fh;
        }
    }
    return $OUI{$oui};
}

# A launch action (coderef) for a known service on a port, or undef. $ip is the
# target; default ports drop the :port from the URL.
sub _port_action {
    my ($ip, $port, $svc) = @_;
    $svc = lc($svc // '');
    my $p = (defined $port && $port =~ /^\d+$/) ? $port + 0 : 0;
    if ($svc eq 'http'   || $p == 80)  { my $u = "http://$ip"  . ($p && $p != 80  ? ":$p" : '') . '/'; return sub { open_url($u) } }
    if ($svc eq 'https'  || $p == 443) { my $u = "https://$ip" . ($p && $p != 443 ? ":$p" : '') . '/'; return sub { open_url($u) } }
    if ($svc eq 'rtsp'   || $p == 554) { my $u = "rtsp://$ip"  . ($p && $p != 554 ? ":$p" : '') . '/'; return sub { launch_vlc($u) } }
    if ($svc eq 'ssh'    || $p == 22)  { my @c = ('ssh', ($p && $p != 22 ? ('-p', $p) : ()), $ip);     return sub { launch_terminal(@c) } }
    if ($svc eq 'telnet' || $p == 23)  { my @c = ('telnet', $ip, ($p && $p != 23 ? ($p) : ()));        return sub { launch_terminal(@c) } }
    return undef;
}

# Read-only "everything we know about this host" pop-up: identity, vendor (from
# the MAC), AP board/SSIDs, and the open ports/services we've observed. Known
# services are clickable — http/https open the browser, ssh/telnet a terminal,
# rtsp VLC.
sub probe_dialog {
    my ($cli, $S, $ip, $r) = @_;
    my $mac  = $r->{mac} // '';
    my $macq = ($mac =~ /^[0-9a-f:]{1,17}$/i) ? $mac : '';   # safe to put in a WHERE
    my $seen = last_seen_str($S->{model}, $ip);
    my @head = (
        "IP:        $ip",
        "MAC:       " . ($mac || '(unknown)'),
        "Name:      " . ($r->{name} // ''),
        "Group:     " . ($r->{grp}  // ''),
        "Last seen: " . (length $seen ? $seen : 'never'),
    );
    my $cur = $mac ? $S->{model}{mac_cur_ip}{ lc $mac } : undef;
    push @head, "Seen at:   $cur" if $cur && $cur ne $ip;
    my $ports = [];
    if ($macq) {
        my $ifs = eval { $cli->snapshot(60, 'interfaces', where => "mac = '$macq'") } || [];
        my $vendor = $ifs->[0]{vendor};
        $vendor = oui_vendor($mac) unless defined $vendor && length $vendor;
        push @head, "Vendor:    " . ($vendor // '(unknown)');
        my $aps = eval { $cli->snapshot(61, 'aps', where => "mac = '$macq'") } || [];
        if (@$aps) {
            push @head, "AP board:  $aps->[0]{board}" if $aps->[0]{board};
            push @head, "AP SSIDs:  $aps->[0]{ssid}"  if $aps->[0]{ssid};
        }
        $ports = eval { $cli->snapshot(62, 'ports', where => "mac = '$macq'") } || [];
    }
    my $dlg = ($S->{anchor})->DialogBox(-title => "Probe $ip", -buttons => ['Close']);
    my $txt = $dlg->add('Scrolled', 'ROText', -scrollbars => 'oe',
        -width => 54, -height => 18, -font => 'nrmono', -wrap => 'none')
        ->pack(-padx => 6, -pady => 6, -fill => 'both', -expand => 1);
    $txt->insert('end', join("\n", @head) . "\n\n");
    $txt->insert('end', sprintf('Open ports (%d):', scalar @$ports));
    $txt->insert('end', @$ports ? "   (click to launch)\n" : "\n");
    my $i = 0;
    for my $p (sort { ($a->{port} // 0) <=> ($b->{port} // 0)
                   || ($a->{proto} // '') cmp ($b->{proto} // '') } @$ports) {
        my $line = sprintf('  %5s/%-4s %s',
            $p->{port} // '?', $p->{proto} // '?', $p->{service} // '');
        my $act = _port_action($ip, $p->{port}, $p->{service});
        if ($act) {
            my $tag = 'p' . $i++;
            $txt->insert('end', $line, $tag);
            $txt->insert('end', "\n");
            $txt->tagConfigure($tag, -foreground => '#06c', -underline => 1);
            $txt->tagBind($tag, '<Button-1>', $act);
            $txt->tagBind($tag, '<Enter>', sub { $txt->configure(-cursor => 'hand2') });
            $txt->tagBind($tag, '<Leave>', sub { $txt->configure(-cursor => '') });
        } else {
            $txt->insert('end', "$line\n");
        }
    }
    $txt->insert('end', "  (none observed)\n") unless @$ports;
    $dlg->Show;
}

sub release_dialog {
    my ($cli, $S, $ip, $r, $redraw, $status) = @_;
    my $ans;
    # Loop so 'Probe' can pop the read-only detail dialog and return here.
    while (1) {
        my $dlg = ($S->{anchor} // $status)->DialogBox(-title => "Reservation $ip",
            -buttons => ['Probe', 'Push', 'Move', 'Release', 'Cancel']);
        my $seen = last_seen_str($S->{model}, $ip);
        $dlg->add('Label', -text =>
            sprintf("%s\nMAC:  %s\nName: %s\nGroup: %s\nLast seen: %s",
                $ip, $r->{mac}, ($r->{name} // ''), ($r->{grp} // ''),
                (length $seen ? $seen : 'never')),
            -justify => 'left')->pack(-padx => 8, -pady => 6);
        $ans = $dlg->Show // 'Cancel';
        last unless $ans eq 'Probe';
        probe_dialog($cli, $S, $ip, $r);
    }
    if ($ans eq 'Release') {
        # Use the row's stored IP so the daemon matches the exact record, even
        # when it was stored in a non-canonical form (see canon_ip).
        my $resp = $cli->observe(kind => 'dhcp_reservation_delete', ip => ($r->{ip} // $ip));
        if (!defined $resp || $resp =~ /^ERR/) { $status->configure(-text => " $resp"); return }
        $S->{model} = gather($cli); $redraw->();
        $status->configure(-text => " released $ip");
    } elsif ($ans eq 'Move') {
        move_dialog($cli, $S, $ip, $r, $redraw, $status);
    } elsif ($ans eq 'Push') {
        # Surface this reservation as a never-seen net-lookup name (kind=host).
        my $ok = _push_host($cli, ip => $ip, mac => $r->{mac}, name => $r->{name});
        $S->{model} = gather($cli); $redraw->();
        $status->configure(-text => $ok
            ? " pushed $ip (" . ($r->{name} // $r->{mac}) . ") to net-lookup"
            : " push failed for $ip");
    }
}

# Reallocate an existing reservation to a different IP (default: the next
# free static in the same subnet).
sub move_dialog {
    my ($cli, $S, $ip, $r, $redraw, $status) = @_;
    my $suggest = next_free($S->{model}, subnet_of($ip)) // '';
    my $newip = $suggest;
    my $dlg = ($S->{anchor} // $status)->DialogBox(-title => "Move $ip",
        -buttons => ['Move', 'Cancel']);
    my $row = $dlg->add('Frame')->pack(-fill => 'x', -pady => 4, -padx => 6);
    $row->Label(-text => "$ip ($r->{mac}) -> ")->pack(-side => 'left');
    $row->Entry(-textvariable => \$newip, -width => 16)->pack(-side => 'left');
    my $ans = $dlg->Show // 'Cancel';
    return unless $ans eq 'Move';
    unless (defined ip2int($newip)) { $status->configure(-text => " bad IP '$newip'"); return }
    # Match the stored record by its own IP (may be non-canonical; see canon_ip).
    my $resp = $cli->observe(kind => 'dhcp_reservation_move', ip => ($r->{ip} // $ip), new_ip => $newip);
    if (!defined $resp || $resp =~ /^ERR/) { $status->configure(-text => " $resp"); return }
    $S->{model} = gather($cli); $redraw->();
    $status->configure(-text => " moved $ip -> $newip");
}

# Lowest free static IP in $cidr, or undef.
sub next_free {
    my ($model, $cidr) = @_;
    my ($net, $len, $first, $last) = cidr_parts($cidr);
    return undef unless defined $net;
    for (my $i = $first; $i <= $last; $i++) {
        return int2ip($i) if classify($model, int2ip($i)) eq 'free';
    }
    return undef;
}

# High-contrast colour for a state in the reserve menu: green free, blue for the
# auto-DHCP dynamic range ('assigned'), red for otherwise-taken (in-use/reserved).
sub menu_color {
    my ($st) = @_;
    return '#008000' if $st eq 'free';
    return '#0000cc' if $st eq 'assigned';   # DHCP pool
    return '#9000c0' if $st eq 'active';      # reserved + in use
    return '#cc0000';                          # reserved / in-use (taken)
}

# Last time $ip was actually seen on the wire: the observed address's
# last_observed (a live DHCP/ARP/nmap/ping signal) or a lease's last_seen. ''
# when never seen live (e.g. a paper-only dhcp.master import) — note last_seen
# on the address row is just any DB touch (= import time), so it's NOT used here.
sub last_seen_str {
    my ($model, $ip) = @_;
    if (my $o = $model->{observed}{$ip}) {
        return $o->{last_observed}
            if defined $o->{last_observed} && length $o->{last_observed};
    }
    if (my $l = $model->{leased}{$ip}) {
        return $l->{last_seen} if defined $l->{last_seen} && length $l->{last_seen};
    }
    return '';
}

# Who currently holds $ip: the reservation's name/MAC/group, else the machine
# name for a lease/observed address's MAC (the name net-lookup would give),
# falling back to the MAC. '' when free/unknown.
sub occupant {
    my ($model, $ip) = @_;
    if (my $r = $model->{resv}{$ip}) {
        my $s = join ' ', grep { defined && length }
            $r->{name}, $r->{mac}, ($r->{grp} ? "[$r->{grp}]" : ());
        # reserved here, but the device is currently seen at another address?
        my $cur = $r->{mac} ? $model->{mac_cur_ip}{ lc $r->{mac} } : undef;
        $s .= " (now at $cur)" if $cur && $cur ne $ip;
        return $s;
    }
    my $rec = $model->{leased}{$ip} || $model->{observed}{$ip} or return '';
    my $mac  = $rec->{mac};
    my $name = (defined $mac && length $mac) ? $model->{mac_name}{ lc $mac } : undef;
    $name //= $rec->{hostname} // $rec->{name};        # lease-supplied name, if any
    my $s = join ' ', grep { defined && length } ($name, $mac);
    # here now, but reserved for a different address (assigned, not yet moved)?
    my $rip = (defined $mac && length $mac) ? $model->{mac_resv_ip}{ lc $mac } : undef;
    $s .= " -> reserved $rip" if $rip && $rip ne $ip;
    return $s;
}

sub usage {
    my ($msg) = @_;
    print STDERR "net-reserve: $msg\n\n" if $msg;
    print STDERR <<'USAGE';
usage:
  net-reserve list [SUBNET]              colour-coded address map
  net-reserve free [SUBNET] [-n N]       next free static IPs
  net-reserve ranges                     dynamic DHCP pools
  net-reserve reserve IP MAC [--name N] [--group G] [--notes '..'] [--push]
                                         (--push: also push just this one as a
                                         never-seen net-lookup name; needs --name)
  net-reserve release IP
  net-reserve move OLD_IP NEW_IP         reallocate a reservation
  net-reserve autoname [SUBNET]          fill missing reservation host names
                                         from each MAC's machine
  net-reserve add-range CIDR START END [--zone Z]
  net-reserve del-range CIDR START
  net-reserve --push [SUBNET]            push named reservations into net-lookup
                                         as never-seen hosts (--dry-run previews)
  net-reserve --gui [SUBNET]             Perl/Tk map (click a cell to select it,
                                         click again to reserve, move, or release)

  --listen H:P / --server NAME           daemon address
  --auth / --no-auth / --key-id / --key-file
USAGE
    exit($msg ? 2 : 0);
}
