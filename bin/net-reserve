#!/usr/bin/perl
# net-reserve — manage permanent DHCP reservations and dynamic-pool ranges
# straight from the net-mgr DB (schema v24: dhcp_reservations + dhcp_ranges),
# replacing hand-edited host { fixed-address } blocks in dhcp.master. Both
# tables are cluster-replicated, so a reservation made here relays to every
# peer and net-gen-dnsmasq can generate from the DB.
#
# Talks to the daemon over the socket (snapshot + OBSERVE), so it runs from any
# host without DB credentials — like net-show / net-chat. A non-loopback daemon
# is AUTH'd automatically with your SSH key.
#
# Usage:
#   net-reserve list [SUBNET]        colour-coded address map (free/reserved/pool)
#   net-reserve free [SUBNET] [-n N] list the next free static IPs
#   net-reserve ranges               list the dynamic DHCP pools
#   net-reserve reserve IP MAC [--name N] [--group G] [--notes '..']
#   net-reserve release IP           remove a reservation
#   net-reserve autoname [SUBNET]    fill missing reservation host names
#   net-reserve add-range CIDR START END [--zone Z]
#   net-reserve del-range CIDR START
#   net-reserve --gui [SUBNET]       Perl/Tk map: click a cell to reserve (pick
#                                    the target address from a menu), move, release;
#                                    +/- keep or ignore subnets in the picker
#                                    ([net-reserve] show/ignore in the user config)
#
#   --listen HOST:PORT   daemon address (overrides --server and config)
#   --server NAME        a server from [servers] in ~/.config/net-mgr/config
#   --auth / --no-auth   force / suppress the SSH-key handshake
#   --key-id ID / --key-file PATH   identity for AUTH
#
# A "free static" IP is one that is NOT inside any dynamic range, NOT already
# reserved, and (for `free`) not currently observed in use — i.e. exactly the
# pool you allocate permanent addresses from.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling pass_through);
use NetMgr::Client;
use NetMgr::Config;
use NetMgr::Protocol qw(parse_line format_kv);

# Render tables. Defined up here (not lower in the file) because the dispatch
# runs before any later statement would — a `my` initialised below the
# $handler->() call is still empty when the handlers fire.
my %COLOR = (   # ANSI background per state
    reserved => "\e[41m",        # red    — permanent reservation
    assigned => "\e[44m",        # blue   — inside a DHCP dynamic range
    'in-use' => "\e[48;5;208m",  # orange — actually occupied (lease/observed)
    free     => "\e[42m",        # green  — allocatable static
);
my $RESET = "\e[0m";
# Distinct one-char glyphs for the no-colour (piped) map.
my %GLYPH = (
    reserved => 'R', assigned => '-', 'in-use' => '!', free => '.',
);

my ($listen, $server, $force_auth, $no_auth, $key_id, $key_file);
my ($gui, $describe, $opt_name, $opt_group, $opt_notes, $opt_zone, $limit, $opt_force);
GetOptions(
    'listen=s'   => \$listen,
    'server=s'   => \$server,
    'auth'       => \$force_auth,
    'no-auth'    => \$no_auth,
    'key-id=s'   => \$key_id,
    'key-file=s' => \$key_file,
    'gui'        => \$gui,
    'describe'   => \$describe,
    'force'      => \$opt_force,
    'name=s'     => \$opt_name,
    'group=s'    => \$opt_group,
    'notes=s'    => \$opt_notes,
    'zone=s'     => \$opt_zone,
    'n=i'        => \$limit,
) or die "bad options\n";

if ($describe) {
    print "name: net-reserve\n";
    print "description: manage DHCP reservations + dynamic ranges in the net-mgr DB\n";
    exit 0;
}

my $cmd = shift @ARGV;

# Server resolution mirrors net-chat: --listen wins, then --server (config
# [servers]), then $NET_MGR_LISTEN, then the configured default, then loopback.
if (!defined $listen) {
    if (defined $server) {
        $listen = NetMgr::Config->resolve_server($server)
            or die "net-reserve: unknown server '$server'\n";
    } else {
        $listen = $ENV{NET_MGR_LISTEN}
               // NetMgr::Config->resolve_server(undef)
               // '127.0.0.1:7531';
    }
}

# With the --gui flag, the subnet is the leftover positional, already shifted
# into $cmd above (not still on @ARGV).
if ($gui) { cmd_gui($cmd); exit 0; }
usage() unless defined $cmd;

my %DISPATCH = (
    list      => \&cmd_list,
    map       => \&cmd_list,    # alias
    free      => \&cmd_free,
    ranges    => \&cmd_ranges,
    reserve   => \&cmd_reserve,
    release   => \&cmd_release,
    move       => \&cmd_move,
    reallocate => \&cmd_move,   # alias
    autoname   => \&cmd_autoname,
    'add-range' => \&cmd_add_range,
    'del-range' => \&cmd_del_range,
    gui       => sub { cmd_gui(shift @ARGV) },
);
my $handler = $DISPATCH{$cmd} or usage("unknown command '$cmd'");
$handler->();
exit 0;

# ---- connection ------------------------------------------------------

sub connect_client {
    my %opt = @_;
    my $cli = eval { NetMgr::Client->new(listen => $listen, timeout => 10) }
        or die "net-reserve: cannot reach daemon at $listen: $@";
    my ($host) = NetMgr::Client::split_hostport($listen); $host //= '';
    my $is_loopback = $host =~ /^(?:127\.\d+\.\d+\.\d+|::1|localhost)$/;
    my $do_auth = $force_auth || (!$is_loopback && !$no_auth);
    $do_auth = $opt{want_auth} if exists $opt{want_auth};
    $do_auth = 0 if $no_auth;
    if ($do_auth) {
        eval {
            $cli->auth(
                (defined $key_id   ? (key_id   => $key_id)   : ()),
                (defined $key_file ? (key_file => $key_file) : ()),
            );
        };
        die "net-reserve: AUTH failed: $@" if $@;
    }
    $cli->hello(consumer => "net-reserve.$$");
    return $cli;
}

# ---- IP / subnet math ------------------------------------------------

sub ip2int {
    my @o = split /\./, ($_[0] // '');
    return undef unless @o == 4 && !grep { $_ !~ /^\d+$/ || $_ > 255 } @o;
    return ($o[0] << 24) + ($o[1] << 16) + ($o[2] << 8) + $o[3];
}
sub int2ip { my $n = $_[0]; join '.', ($n >> 24) & 255, ($n >> 16) & 255,
                                       ($n >> 8) & 255, $n & 255 }

# Parse "A.B.C.D/len" → (network_int, len, first_host_int, last_host_int).
sub cidr_parts {
    my ($cidr) = @_;
    my ($net, $len) = split m{/}, $cidr;
    $len = 24 unless defined $len && length $len;
    my $ni = ip2int($net);
    return unless defined $ni;
    my $mask = $len == 0 ? 0 : (0xFFFFFFFF << (32 - $len)) & 0xFFFFFFFF;
    my $network = $ni & $mask;
    my $bcast   = $network | (~$mask & 0xFFFFFFFF);
    my $first   = $len >= 31 ? $network : $network + 1;     # skip .0
    my $last    = $len >= 31 ? $bcast   : $bcast - 1;       # skip .255
    return ($network, $len, $first, $last);
}
sub subnet_of { my $i = ip2int($_[0]); defined $i ? int2ip($i & 0xFFFFFF00) . "/24" : undef }

# Normalise a user-typed subnet ("192.168.20", "192.168.20.5/24", ...) to a
# canonical "network/len" CIDR, or undef if it doesn't parse. Bare input
# without a /len defaults to /24.
sub normalize_cidr {
    my ($s) = @_;
    return undef unless defined $s;
    $s =~ s/^\s+|\s+$//g;
    return undef unless length $s;
    my ($net, $len) = split m{/}, $s;
    $len = 24 unless defined $len && length $len;
    return undef unless $len =~ /^\d+$/ && $len >= 0 && $len <= 32;
    # Pad a short dotted form: "192.168.20" -> "192.168.20.0".
    my @o = split /\./, ($net // '');
    return undef unless @o >= 1 && @o <= 4;
    push @o, 0 while @o < 4;
    $net = join '.', @o;
    my ($network) = cidr_parts("$net/$len");
    return undef unless defined $network;
    return int2ip($network) . "/$len";
}

# Subnets this machine is directly attached to (from `ip -o -4 addr`), as
# canonical CIDRs — used to seed the GUI subnet picker so your own LANs show
# up even before the DB has any rows for them. Loopback/link-local skipped.
sub local_subnets {
    my (@out, %seen);
    open my $fh, '-|', 'ip', '-o', '-4', 'addr', 'show'
        or return [];
    while (<$fh>) {
        next unless /\binet\s+(\d+\.\d+\.\d+\.\d+)\/(\d+)/;
        my ($ip, $len) = ($1, $2);
        next if $ip =~ /^127\./ || $ip =~ /^169\.254\./;
        my $c = normalize_cidr("$ip/$len") or next;
        push @out, $c unless $seen{$c}++;
    }
    close $fh;
    return \@out;
}

# Persistent subnet show/ignore lists for the GUI picker, kept in the per-user
# config's [net-reserve] section (show = / ignore =, comma-separated CIDRs).
# Read merges the system + user config; writes go to the user file.
sub _read_cidr_list {
    my ($key) = @_;
    my %set;
    for my $p ($ENV{NET_MGR_CONF} // '/etc/net-mgr/config', NetMgr::Config->user_path) {
        next unless defined $p && -r $p;
        my $cfg = eval { NetMgr::Config->load($p) } or next;
        my $v = $cfg->{'net-reserve'}{$key} // next;
        for my $c (split /[,\s]+/, $v) {
            my $n = normalize_cidr($c) or next;
            $set{$n} = 1;
        }
    }
    return \%set;
}
sub _write_cidr_list {
    my ($key, $set) = @_;
    my @c = sort { (ip2int((split m{/}, $a)[0]) // 0)
               <=> (ip2int((split m{/}, $b)[0]) // 0) } keys %$set;
    eval { NetMgr::Config->save_user_value('net-reserve', $key, join(', ', @c)); 1 };
}

# Ask the local net-mgr-relay's REFRESH proxy to pull this subnet's rows
# from the elected master into the local DB before we read it — current
# view on demand, while the relay's subscribe-stream stays the lazy
# default. Best-effort: silently a no-op when the target daemon isn't
# local, the proxy isn't running, or this host is itself the master.
# Returns a human-readable note (for the GUI status bar) or undef.
sub maybe_refresh {
    my ($subnet) = @_;
    return undef unless defined $subnet && length $subnet;
    my ($host) = NetMgr::Client::split_hostport($listen); $host //= '';
    return undef
        unless $host =~ /^(?:127\.\d+\.\d+\.\d+|::1|localhost)$/;
    my $cfg = eval {
        NetMgr::Config->load($ENV{NET_MGR_CONF} // '/etc/net-mgr/config') };
    my $addr = ($cfg && $cfg->{cluster}{proxy_listen}) // '127.0.0.1:7532';
    return undef if lc($addr) eq 'none';
    my $reply = eval {
        my $px = NetMgr::Client->new(listen => $addr, timeout => 8);
        $px->send_recv("REFRESH " . format_kv(subnet => $subnet));
    };
    return undef unless defined $reply && $reply =~ /^OK\b/;
    my $kv = eval { parse_line($reply)->{kv} } || {};
    return 'already current (this host is the master)'
        if ($kv->{role} // '') eq 'master';
    return sprintf('refreshed %s from %s (%s rows)',
                   $subnet, $kv->{master} // 'master', $kv->{rows} // '?');
}

# ---- gather the world from the daemon --------------------------------
#
# Returns a model: { ranges=>[..], resv=>{ip=>row}, leased=>{ip=>row},
#                    observed=>{ip=>row}, mac_name=>{mac=>name}, subnets=>[cidr,..] }
sub gather {
    my ($cli) = @_;
    my $ranges = eval { $cli->snapshot(1, 'dhcp_ranges') }        || [];
    my $resv   = eval { $cli->snapshot(2, 'dhcp_reservations') }  || [];
    my $leases = eval { $cli->snapshot(3, 'dhcp_leases') }        || [];
    my $addrs  = eval { $cli->snapshot(4, 'addresses',
                          where => "family = 'v4'") }             || [];
    # MAC -> machine name, so observed/leased addresses can show who's there
    # (the same name net-lookup gives), not just a bare MAC.
    my $ifaces   = eval { $cli->snapshot(5, 'interfaces') } || [];
    my $machines = eval { $cli->snapshot(6, 'machines') }   || [];

    my %resv     = map { $_->{ip}  => $_ } @$resv;
    my %leased   = map { $_->{ip}  => $_ } grep { $_->{ip}  } @$leases;
    my %observed = map { $_->{addr} => $_ } grep { $_->{addr} } @$addrs;

    my %name_of_mid = map { ($_->{id} => $_->{primary_name}) }
                      grep { defined $_->{primary_name} && length $_->{primary_name} } @$machines;
    my %mac_name;
    for my $i (@$ifaces) {
        next unless $i->{mac} && $i->{machine_id};
        my $n = $name_of_mid{ $i->{machine_id} } or next;
        $mac_name{ lc $i->{mac} } = $n;
    }
    # MAC -> where it currently is (lease/observed) and where it's reserved, so
    # the UI can flag a device that's been given a new address but hasn't moved
    # there yet.
    my (%mac_cur_ip, %mac_resv_ip);
    for my $ip (sort keys %leased)   { my $m=$leased{$ip}{mac};   $mac_cur_ip{lc $m} //= $ip if $m }
    for my $ip (sort keys %observed) { my $m=$observed{$ip}{mac}; $mac_cur_ip{lc $m} //= $ip if $m }
    for my $ip (keys %resv)          { my $m=$resv{$ip}{mac};     $mac_resv_ip{lc $m} //= $ip if $m }

    my %subnets;
    $subnets{ $_->{subnet_cidr} } = 1 for @$ranges;
    for my $ip (keys %resv, keys %leased, keys %observed) {
        my $s = subnet_of($ip) or next;
        $subnets{$s} = 1;
    }
    my @subnets = sort {
        (ip2int((split m{/}, $a)[0]) // 0) <=> (ip2int((split m{/}, $b)[0]) // 0)
    } keys %subnets;

    return {
        ranges => $ranges, resv => \%resv, leased => \%leased,
        observed => \%observed, mac_name => \%mac_name,
        mac_cur_ip => \%mac_cur_ip, mac_resv_ip => \%mac_resv_ip,
        subnets => \@subnets,
    };
}

# Is $ip_int inside any dynamic range of $cidr?
sub in_pool {
    my ($model, $ip_int) = @_;
    for my $r (@{ $model->{ranges} }) {
        my $lo = ip2int($r->{start_ip}); my $hi = ip2int($r->{end_ip});
        next unless defined $lo && defined $hi;
        return 1 if $ip_int >= $lo && $ip_int <= $hi;
    }
    return 0;
}

# Classify one host address → state keyword. An address inside a DHCP
# dynamic range is 'assigned' (managed by DHCP) regardless of whether a
# host currently holds it — you don't allocate statics from there anyway.
# 'in-use' is reserved for an address occupied *outside* any pool and not
# reserved: a real, unmanaged occupant worth noticing.
sub classify {
    my ($model, $ip) = @_;
    my $i = ip2int($ip);
    return 'reserved' if $model->{resv}{$ip};
    return 'assigned' if in_pool($model, $i);
    return 'in-use'   if $model->{leased}{$ip} || $model->{observed}{$ip};
    return 'free';
}

# ---- CLI: colour + rendering ----------------------------------------

sub use_color { -t STDOUT }

sub state_label {
    my %L = (reserved => 'reserved', assigned => 'DHCP assigned',
             'in-use' => 'in use', free => 'free static');
    return $L{$_[0]} // $_[0];
}

sub cmd_list {
    my $cli = connect_client(want_auth => 0);
    my $only = shift @ARGV;
    maybe_refresh(normalize_cidr($only)) if defined $only;
    my $model = gather($cli);
    my @subnets = $only ? (grep { $_ eq $only || index($_, "$only/") == 0
                                  || (split m{/}, $_)[0] eq $only }
                                @{ $model->{subnets} })
                        : @{ $model->{subnets} };
    @subnets = @{ $model->{subnets} } if $only && !@subnets && $only =~ m{/};
    unless (@subnets) {
        print "no subnets known to the daemon yet "
            . "(seed ranges with `net-reserve add-range` or net-import-dhcp)\n";
        return;
    }
    my $c = use_color();
    for my $cidr (@subnets) {
        my ($net, $len, $first, $last) = cidr_parts($cidr);
        next unless defined $net;
        printf "\n%s  (%s)\n", $cidr, pool_summary($model, $cidr);
        # 16-wide grid of last octet for /24; generic otherwise.
        my $col = 0;
        for (my $i = $first; $i <= $last; $i++) {
            my $ip = int2ip($i);
            my $st = classify($model, $ip);
            my $oct = $i & 0xFF;
            if ($c) {
                printf "%s%3d%s ", $COLOR{$st}, $oct, $RESET;
            } else {
                printf "%3d%s ", $oct, ($GLYPH{$st} // '?');
            }
            if (++$col % 16 == 0) { print "\n" }
        }
        print "\n" if $col % 16;
        # Reservations in this subnet, grouped.
        my @mine = sort { ip2int($a->{ip}) <=> ip2int($b->{ip}) }
                   grep { ($_->{subnet_cidr} // subnet_of($_->{ip}) // '') eq $cidr }
                   values %{ $model->{resv} };
        if (@mine) {
            print "  reservations:\n";
            my %by_grp;
            push @{ $by_grp{ $_->{grp} // '(ungrouped)' } }, $_ for @mine;
            for my $g (sort keys %by_grp) {
                print "    [$g]\n";
                for my $r (@{ $by_grp{$g} }) {
                    printf "      %-15s %-17s %s\n",
                        $r->{ip}, $r->{mac}, ($r->{name} // '');
                }
            }
        }
    }
    if ($c) {
        print "\nlegend: ";
        print "$COLOR{$_}$RESET ", state_label($_), "  " for
            qw(free assigned in-use reserved);
        print "\n";
    }
}

sub pool_summary {
    my ($model, $cidr) = @_;
    my @r = grep { $_->{subnet_cidr} eq $cidr } @{ $model->{ranges} };
    return "no dynamic range defined" unless @r;
    return join ", ", map { "$_->{start_ip}-$_->{end_ip}" } @r;
}

sub cmd_free {
    my $cli = connect_client(want_auth => 0);
    my $only = shift @ARGV;
    maybe_refresh(normalize_cidr($only)) if defined $only;
    my $model = gather($cli);
    my $want = $limit || 10;
    my @subnets = $only ? (grep { (split m{/}, $_)[0] eq $only || $_ eq $only }
                                @{ $model->{subnets} })
                        : @{ $model->{subnets} };
    @subnets = ($only) if $only && !@subnets && $only =~ m{/};
    for my $cidr (@subnets) {
        my ($net, $len, $first, $last) = cidr_parts($cidr);
        next unless defined $net;
        my @free;
        for (my $i = $first; $i <= $last && @free < $want; $i++) {
            push @free, int2ip($i) if classify($model, int2ip($i)) eq 'free';
        }
        printf "%s: %s\n", $cidr, (@free ? join(' ', @free) : '(none free)');
    }
}

sub cmd_ranges {
    my $cli = connect_client(want_auth => 0);
    my $rows = eval { $cli->snapshot(1, 'dhcp_ranges') } || [];
    unless (@$rows) { print "no dynamic ranges defined\n"; return }
    printf "%-20s %-15s %-15s %s\n", 'SUBNET', 'START', 'END', 'ZONE';
    for my $r (sort { $a->{subnet_cidr} cmp $b->{subnet_cidr} } @$rows) {
        printf "%-20s %-15s %-15s %s\n",
            $r->{subnet_cidr}, $r->{start_ip}, $r->{end_ip}, ($r->{zone} // '');
    }
}

sub cmd_reserve {
    my $ip  = shift @ARGV or usage("reserve needs IP MAC");
    my $mac = shift @ARGV or usage("reserve needs IP MAC");
    die "net-reserve: bad IP '$ip'\n"  unless defined ip2int($ip);
    die "net-reserve: bad MAC '$mac'\n" unless $mac =~ /^[0-9a-fA-F:]{17}$/;
    my $cli = connect_client();
    # Pull this subnet's current view first, then warn (don't block) if
    # the chosen IP sits inside a dynamic pool.
    maybe_refresh(subnet_of($ip));
    my $model = gather($cli);
    my $st = classify($model, $ip);
    warn "net-reserve: note: $ip is inside a DHCP dynamic range — "
       . "it may also be auto-leased; consider a free static instead\n"
        if $st eq 'assigned';
    my $r = $cli->observe(
        kind => 'dhcp_reservation', ip => $ip, mac => lc $mac,
        (defined $opt_name  ? (name  => $opt_name)  : ()),
        subnet_cidr => subnet_of($ip),
        (defined $opt_group ? (grp   => $opt_group) : ()),
        (defined $opt_notes ? (notes => $opt_notes) : ()),
        ($opt_force ? (force => 1) : ()),
    );
    # The daemon refuses a 2nd reservation for a MAC already reserved elsewhere;
    # `net-reserve move OLD NEW` relocates it, or --force adds it anyway.
    die "net-reserve: $r\n" if !defined $r || $r =~ /^ERR/;
    print "reserved $ip -> $mac",
          (defined $opt_name ? " ($opt_name)" : ''),
          (defined $opt_group ? " [$opt_group]" : ''), "\n";
}

sub cmd_release {
    my $ip = shift @ARGV or usage("release needs IP");
    my $cli = connect_client();
    my $r = $cli->observe(kind => 'dhcp_reservation_delete', ip => $ip);
    die "net-reserve: $r\n" if !defined $r || $r =~ /^ERR/;
    print "released $ip\n";
}

sub cmd_move {
    my $old = shift @ARGV or usage("move needs OLD_IP NEW_IP");
    my $new = shift @ARGV or usage("move needs OLD_IP NEW_IP");
    die "net-reserve: bad IP\n" unless defined ip2int($old) && defined ip2int($new);
    my $cli = connect_client();
    maybe_refresh(subnet_of($new));
    my $model = gather($cli);
    warn "net-reserve: note: $new is inside a DHCP dynamic range\n"
        if classify($model, $new) eq 'assigned';
    my $r = $cli->observe(kind => 'dhcp_reservation_move', ip => $old, new_ip => $new);
    die "net-reserve: $r\n" if !defined $r || $r =~ /^ERR/;
    print "moved $old -> $new\n";
}

# Backfill host names on reservations that lack one: re-observe each nameless
# reservation (preserving its fields) so the daemon fills the name from the
# MAC's correlated machine. Optional SUBNET limits the scope.
sub cmd_autoname {
    my $subnet = shift @ARGV;
    my $want   = defined $subnet ? normalize_cidr($subnet) : undef;
    die "net-reserve: bad subnet '$subnet'\n" if defined $subnet && !defined $want;
    my $cli = connect_client();
    my $model = gather($cli);
    my @resv = grep { !defined $_->{name} || $_->{name} eq '' }
               values %{ $model->{resv} };
    @resv = grep { (subnet_of($_->{ip}) // '') eq $want } @resv if defined $want;
    unless (@resv) { print "no reservations missing a name\n"; return }
    for my $r (sort { ip2int($a->{ip}) <=> ip2int($b->{ip}) } @resv) {
        my $resp = $cli->observe(kind => 'dhcp_reservation',
            ip => $r->{ip}, mac => $r->{mac},
            subnet_cidr => ($r->{subnet_cidr} // subnet_of($r->{ip})),
            (defined $r->{grp}   && length $r->{grp}   ? (grp   => $r->{grp})   : ()),
            (defined $r->{notes} && length $r->{notes} ? (notes => $r->{notes}) : ()));
        warn "net-reserve: $r->{ip}: $resp\n" if !defined $resp || $resp =~ /^ERR/;
    }
    my $after = gather($cli);
    my ($named, @unknown) = (0);
    for my $r (sort { ip2int($a->{ip}) <=> ip2int($b->{ip}) } @resv) {
        my $now = $after->{resv}{ $r->{ip} };
        if ($now && defined $now->{name} && $now->{name} ne '') {
            $named++;
            printf "  %-15s %s -> %s\n", $r->{ip}, $r->{mac}, $now->{name};
        } else {
            push @unknown, $r->{ip};
        }
    }
    print "named $named of ", scalar(@resv), " reservation(s)\n";
    print "still unnamed (MAC not correlated to a machine): @unknown\n" if @unknown;
}

sub cmd_add_range {
    my $cidr  = shift @ARGV or usage("add-range needs CIDR START END");
    my $start = shift @ARGV or usage("add-range needs CIDR START END");
    my $end   = shift @ARGV or usage("add-range needs CIDR START END");
    my $cli = connect_client();
    my $r = $cli->observe(kind => 'dhcp_range', subnet_cidr => $cidr,
        start_ip => $start, end_ip => $end,
        (defined $opt_zone ? (zone => $opt_zone) : ()));
    die "net-reserve: $r\n" if !defined $r || $r =~ /^ERR/;
    print "added range $cidr $start-$end\n";
}

sub cmd_del_range {
    my $cidr  = shift @ARGV or usage("del-range needs CIDR START");
    my $start = shift @ARGV or usage("del-range needs CIDR START");
    my $cli = connect_client();
    my $r = $cli->observe(kind => 'dhcp_range_delete',
        subnet_cidr => $cidr, start_ip => $start);
    die "net-reserve: $r\n" if !defined $r || $r =~ /^ERR/;
    print "deleted range $cidr $start\n";
}

# ---- Perl/Tk GUI -----------------------------------------------------

sub cmd_gui {
    my ($want_subnet) = @_;
    eval { require Tk; Tk->import; require Tk::DialogBox; require Tk::BrowseEntry;
           require Tk::ROText; 1 }   # explicit: silences Scrolled's "Assuming require" note
        or die "net-reserve: Perl/Tk not available: $@";

    my $cli = connect_client();   # auth on remote so reserve/release work
    my %S = (subnet => undef, model => gather($cli), cur => undef, pinned => {},
             show => _read_cidr_list('show'), ignore => _read_cidr_list('ignore'));
    # Seed the picker with this machine's own attached subnets, so your LANs
    # are pickable even before the DB has ranges/leases for them.
    $S{pinned}{$_} = 1 for @{ local_subnets() };
    # An explicit `--gui SUBNET` opens straight to it, even with no data yet.
    if (defined $want_subnet) {
        my $n = normalize_cidr($want_subnet);
        if ($n) { $S{subnet} = $n; $S{pinned}{$n} = 1; }
    }
    $S{subnet} //= $S{model}{subnets}[0] // (sort keys %{ $S{pinned} })[0];

    my $mw = Tk::MainWindow->new(-title => "net-reserve — $listen");
    $S{anchor} = $mw;             # dialogs parent off the main window
    my $fs = 10;
    $mw->fontCreate('nrui',   -size => $fs);
    $mw->fontCreate('nrmono', -family => 'Courier', -size => $fs);
    $mw->optionAdd('*font' => 'nrui', 81);

    my $top = $mw->Frame->pack(-side => 'top', -fill => 'x', -pady => 2);
    $top->Label(-text => 'Subnet:')->pack(-side => 'left');
    # Forward-declared so the widget callbacks below close over them; the
    # coderefs are assigned further down but only ever *called* at event time.
    my ($subnet_be, $status, $canvas, $resv_text, $redraw, $refresh_subnets,
        $sync_now);

    # The picker offers the union of discovered subnets, any pinned
    # (manually-entered) ones, the persistent "show" list, and the current
    # selection — minus the persistent "ignore" list (the current subnet is
    # kept visible regardless, so you can un-ignore it). See [net-reserve] in
    # the per-user config; the + / - buttons edit it.
    my $all_subnets = sub {
        my %u;
        $u{$_} = 1 for @{ $S{model}{subnets} };
        $u{$_} = 1 for keys %{ $S{pinned} };
        $u{$_} = 1 for keys %{ $S{show} };
        $u{ $S{subnet} } = 1 if defined $S{subnet} && length $S{subnet};
        delete $u{$_} for grep { $_ ne ($S{subnet} // '') } keys %{ $S{ignore} };
        return [ sort { (ip2int((split m{/}, $a)[0]) // 0)
                    <=> (ip2int((split m{/}, $b)[0]) // 0) } keys %u ];
    };
    # Explicit user actions (open / jump / Reload) want CURRENT data:
    # nudge the relay's REFRESH proxy to pull this subnet from the master
    # into the local DB, then re-read. The periodic tick stays lazy.
    $sync_now = sub {
        my $note = maybe_refresh($S{subnet});
        $S{model} = gather($cli);
        $refresh_subnets->();
        $redraw->();
        $status->configure(-text => " $note") if $note;
    };
    # Jump to (and pin) a typed/selected subnet; silently ignores junk.
    my $set_subnet = sub {
        my $n = normalize_cidr($S{subnet});
        return unless defined $n;
        $S{subnet} = $n;
        $S{pinned}{$n} = 1;
        $sync_now->();
    };
    # + : remember the current subnet (always show it); - : ignore it (drop it
    # from the picker). Both persist to [net-reserve] in the per-user config.
    my $show_subnet = sub {
        my $n = $S{subnet} or return;
        $S{show}{$n} = 1; delete $S{ignore}{$n};
        _write_cidr_list('show', $S{show}); _write_cidr_list('ignore', $S{ignore});
        $refresh_subnets->();
        $status->configure(-text => " keep $n in the list");
    };
    my $hide_subnet = sub {
        my $n = $S{subnet} or return;
        my @vis = grep { $_ ne $n } @{ $all_subnets->() };   # before we change subnet
        $S{ignore}{$n} = 1; delete $S{show}{$n};
        _write_cidr_list('ignore', $S{ignore}); _write_cidr_list('show', $S{show});
        if (@vis) { $S{subnet} = $vis[0]; $sync_now->() } else { $refresh_subnets->() }
        $status->configure(-text => " ignore $n");
    };
    # Backfill host names on every reservation that lacks one (all subnets):
    # re-observe each so the daemon names it from the MAC's machine.
    my $autoname = sub {
        my @resv = grep { !defined $_->{name} || $_->{name} eq '' }
                   values %{ $S{model}{resv} };
        unless (@resv) {
            $status->configure(-text => ' no reservations missing a name'); return;
        }
        $status->configure(-text => ' naming ' . scalar(@resv) . ' reservation(s)...');
        $S{anchor}->update;
        for my $r (@resv) {
            $cli->observe(kind => 'dhcp_reservation', ip => $r->{ip}, mac => $r->{mac},
                subnet_cidr => ($r->{subnet_cidr} // subnet_of($r->{ip})),
                (defined $r->{grp}   && length $r->{grp}   ? (grp   => $r->{grp})   : ()),
                (defined $r->{notes} && length $r->{notes} ? (notes => $r->{notes}) : ()));
        }
        $S{model} = gather($cli); $redraw->();
        my @still = grep { !defined $_->{name} || $_->{name} eq '' }
                    values %{ $S{model}{resv} };
        $status->configure(-text => sprintf(' named %d of %d (%d still unknown)',
            scalar(@resv) - scalar(@still), scalar(@resv), scalar(@still)));
    };

    $subnet_be = $top->BrowseEntry(
        -variable  => \$S{subnet},
        -choices   => $all_subnets->(),
        -width     => 18,
        -browsecmd => sub { $sync_now->() },      # picked from the dropdown
    )->pack(-side => 'left');
    # +/- remember (always show) or ignore (hide) the current subnet, persisted.
    $top->Button(-text => '+', -width => 2, -command => sub { $show_subnet->() })
        ->pack(-side => 'left');
    $top->Button(-text => '-', -width => 2, -command => sub { $hide_subnet->() })
        ->pack(-side => 'left', -padx => 2);
    # Typing a CIDR + Enter (or Go) jumps to it, adding it to the list if new.
    $subnet_be->Subwidget('entry')->bind('<Return>', sub { $set_subnet->() });
    $top->Button(-text => 'Go', -command => sub { $set_subnet->() })
        ->pack(-side => 'left', -padx => 2);
    $top->Button(-text => 'Reload', -command => sub { $sync_now->() })
        ->pack(-side => 'left', -padx => 4);
    $top->Button(-text => 'Name unnamed', -command => sub { $autoname->() })
        ->pack(-side => 'left', -padx => 2);

    # legend
    my %CELL = (
        reserved => '#d33', assigned => '#36c', 'in-use' => '#e8821e',
        free => '#3a3',
    );
    my $leg = $top->Frame->pack(-side => 'right');
    for my $st (qw(free assigned in-use reserved)) {
        $leg->Label(-text => '  ', -background => $CELL{$st})->pack(-side => 'left');
        $leg->Label(-text => state_label($st) . ' ')->pack(-side => 'left');
    }

    my $body = $mw->Frame->pack(-side => 'top', -fill => 'both', -expand => 1);
    $canvas = $body->Canvas(-width => 16*34, -height => 16*22, -background => '#fff')
        ->pack(-side => 'left', -fill => 'both', -expand => 1, -padx => 4, -pady => 4);
    my $side = $body->Frame->pack(-side => 'right', -fill => 'y');
    $side->Label(-text => 'Reservations')->pack(-side => 'top', -anchor => 'w');
    $resv_text = $side->Scrolled('ROText', -width => 38, -height => 24,
        -font => 'nrmono', -scrollbars => 'oe')->pack(-side => 'top', -fill => 'y', -expand => 1);

    $status = $mw->Label(-anchor => 'w', -relief => 'sunken')
        ->pack(-side => 'bottom', -fill => 'x');

    $refresh_subnets = sub {
        my $list = $all_subnets->();
        $subnet_be->delete(0, 'end');
        $subnet_be->insert('end', $_) for @$list;
    };

    $redraw = sub {
        my $cidr = $S{subnet};
        $canvas->delete('all');
        $resv_text->delete('1.0', 'end');
        unless (defined $cidr) { $status->configure(-text => ' no subnets'); return }
        my ($net, $len, $first, $last) = cidr_parts($cidr);
        unless (defined $net) { $status->configure(-text => " bad subnet $cidr"); return }
        my $model = $S{model};
        # Fixed-size cells. For a /24 (or smaller) the whole subnet fits in one
        # 256-block, so position every cell by its last octet — column = low
        # nibble, row = high nibble — giving a regular 16-wide grid you can read
        # by address. Larger subnets fall back to sequential fixed boxes.
        my ($cw, $ch, $pad) = (30, 22, 1);
        my ($hx, $hy) = (24, 16);        # left + top header gutters
        my $octet_mode = $len >= 24;
        my $draw_cell = sub {
            my ($i, $x, $y) = @_;
            my $ip = int2ip($i);
            my $st = classify($model, $ip);
            my $r = $canvas->createRectangle($x, $y, $x + $cw - 2, $y + $ch - 2,
                -fill => $CELL{$st}, -outline => '#999');
            my $t = $canvas->createText($x + ($cw - 2) / 2, $y + ($ch - 2) / 2,
                -text => ($i & 0xFF), -font => 'nrmono');
            for my $item ($r, $t) {
                $canvas->bind($item, '<Button-1>',
                    [ sub { cell_click($cli, \%S, $ip, $redraw, $status) } ]);
            }
        };
        if ($octet_mode) {
            # column headers (low nibble, hex) ...
            for my $c (0 .. 15) {
                $canvas->createText($hx + $c * $cw + ($cw - 2) / 2, $hy / 2,
                    -text => sprintf('%X', $c), -font => 'nrmono', -fill => '#888');
            }
            my %rows;  $rows{ ($_ & 0xFF) >> 4 } = 1 for ($first .. $last);
            # ... row labels (base octet of each used row)
            for my $rr (sort { $a <=> $b } keys %rows) {
                $canvas->createText($hx - 3, $hy + $rr * $ch + ($ch - 2) / 2,
                    -text => $rr * 16, -font => 'nrmono', -fill => '#888',
                    -anchor => 'e');
            }
            for my $i ($first .. $last) {
                my $oct = $i & 0xFF;
                $draw_cell->($i, $hx + ($oct & 0x0F) * $cw + $pad,
                                 $hy + ($oct >> 4)   * $ch + $pad);
            }
        } else {
            my $col = 0; my $rown = 0;
            for my $i ($first .. $last) {
                $draw_cell->($i, ($col % 16) * $cw + $pad, $rown * $ch + $pad);
                $rown++ if ++$col % 16 == 0;
            }
        }
        # side list, grouped
        my @mine = sort { ip2int($a->{ip}) <=> ip2int($b->{ip}) }
                   grep { ($_->{subnet_cidr} // subnet_of($_->{ip}) // '') eq $cidr }
                   values %{ $model->{resv} };
        my %by_grp; push @{ $by_grp{ $_->{grp} // '(ungrouped)' } }, $_ for @mine;
        for my $g (sort keys %by_grp) {
            $resv_text->insert('end', "[$g]\n");
            for my $rr (@{ $by_grp{$g} }) {
                $resv_text->insert('end',
                    sprintf("  %-15s %s\n", $rr->{ip}, ($rr->{name} // $rr->{mac})));
            }
        }
        $status->configure(-text => sprintf(" %s — %s", $cidr, pool_summary($model, $cidr)));
    };

    $sync_now->();      # open with a forced pull of the initial subnet
    # periodic refresh: lazy (local DB only) — explicit actions force-sync
    my $tick; $tick = sub {
        $S{model} = gather($cli); $refresh_subnets->(); $redraw->();
        $mw->after(5000, $tick);
    };
    $mw->after(5000, $tick);
    Tk::MainLoop();
}

# Click handler: free → reserve dialog; reserved → release/edit dialog.
sub cell_click {
    my ($cli, $S, $ip, $redraw, $status) = @_;
    my $model = $S->{model};
    my $st = classify($model, $ip);
    if ($st eq 'reserved') {
        my $r = $model->{resv}{$ip};
        release_dialog($cli, $S, $ip, $r, $redraw, $status);
    } else {
        # prefill MAC if the address is currently leased/observed
        my $mac = '';
        $mac = $model->{leased}{$ip}{mac}   if $model->{leased}{$ip};
        $mac = $model->{observed}{$ip}{mac} if !$mac && $model->{observed}{$ip};
        reserve_dialog($cli, $S, $ip, $mac, $redraw, $status);
    }
}

sub reserve_dialog {
    my ($cli, $S, $ip, $mac, $redraw, $status) = @_;
    my $dlg = ($S->{anchor} // $status)->DialogBox(-title => "Reserve $ip",
        -buttons => ['Reserve', 'Cancel']);
    my %v = (ip => $ip, mac => $mac, name => '', group => '');
    # known groups for convenience
    my %groups; $groups{ $_->{grp} } = 1 for grep { $_->{grp} } values %{ $S->{model}{resv} };
    # Target address: a menu of the subnet's addresses with the occupant
    # (MAC/name) beside each, colour-coded — green free, blue for the auto-DHCP
    # dynamic ranges, red otherwise-taken. The "DHCP pool / assigned" toggle
    # hides the blue rows so the list is just static candidates. Editable, so any
    # address can be typed; defaults to the clicked cell.
    my $show_pool = 1;
    my ($be, $lb);
    my $rebuild = sub {
        my (@labels, @colors);
        my ($net, $len, $first, $last) = cidr_parts(subnet_of($ip));
        for (my $i = $first; defined $first && $i <= $last; $i++) {
            my $a  = int2ip($i);
            my $st = classify($S->{model}, $a);
            next if !$show_pool && $st eq 'assigned';       # hide the pool
            push @labels,
                (sprintf("%-15s %-7s %s", $a, $st, occupant($S->{model}, $a)) =~ s/\s+$//r);
            push @colors, menu_color($st);
        }
        return unless $be;
        $be->delete(0, 'end');                              # delete/insert leave
        $be->insert('end', @labels) if @labels;             #   the IP value alone
        eval { $lb->itemconfigure($_, -foreground => $colors[$_]) } for 0 .. $#colors;
    };
    {
        my $row = $dlg->add('Frame')->pack(-fill => 'x', -pady => 1);
        $row->Label(-text => 'IP:', -width => 7, -anchor => 'w')->pack(-side => 'left');
        # No -listwidth/-autolistwidth: the drop-down then matches the widget's
        # own width (entry edge to arrow) instead of shrinking to the text.
        $be = $row->BrowseEntry(-variable => \$v{ip}, -width => 60,
            -listheight => 32,         # show 32 rows in the drop-down
            # the listbox rows carry "IP state occupant"; keep just the IP
            -browsecmd => sub { ($v{ip}) = ($_[-1] // '') =~ /(\d+\.\d+\.\d+\.\d+)/ });
        $be->pack(-side => 'left', -fill => 'x', -expand => 1);
        $lb = eval { $be->Subwidget('slistbox')->Subwidget('listbox') };
        eval { $lb->configure(-font => 'Courier 10 bold') } if $lb;  # bold = contrast
    }
    {
        my $row = $dlg->add('Frame')->pack(-fill => 'x');
        $row->Label(-text => '', -width => 7)->pack(-side => 'left');
        $row->Checkbutton(-text => 'show DHCP pool / assigned',
            -variable => \$show_pool, -command => sub { $rebuild->() })
            ->pack(-side => 'left');
    }
    $rebuild->();
    $v{ip} = $ip;                      # editable default = the clicked cell
    for my $f (['MAC', 'mac'], ['Name', 'name'], ['Group', 'group']) {
        my ($lbl, $key) = @$f;
        my $row = $dlg->add('Frame')->pack(-fill => 'x', -pady => 1);
        $row->Label(-text => "$lbl:", -width => 7, -anchor => 'w')->pack(-side => 'left');
        $row->Entry(-textvariable => \$v{$key}, -width => 48)
            ->pack(-side => 'left', -fill => 'x', -expand => 1);
    }
    if (keys %groups) {
        my $row = $dlg->add('Frame')->pack(-fill => 'x');
        $row->Label(-text => '', -width => 7)->pack(-side => 'left');
        for my $g (sort keys %groups) {
            $row->Button(-text => $g, -command => sub { $v{group} = $g })
                ->pack(-side => 'left');
        }
    }
    my $ans = $dlg->Show // 'Cancel';
    return unless $ans eq 'Reserve';
    ($v{ip}) = $v{ip} =~ /(\d+\.\d+\.\d+\.\d+)/ ? ($1) : ($v{ip});  # tolerate a label
    unless (defined ip2int($v{ip})) {
        $status->configure(-text => " bad IP '$v{ip}' — not reserved"); return;
    }
    unless ($v{mac} =~ /^[0-9a-fA-F:]{17}$/) {
        $status->configure(-text => " bad MAC '$v{mac}' — not reserved"); return;
    }
    # One reservation per MAC. If this device is already reserved elsewhere,
    # offer to move it rather than create a second (duplicate) reservation.
    my $force = 0;
    my ($dup) = grep { lc($_->{mac}) eq lc($v{mac}) && $_->{ip} ne $v{ip} }
                values %{ $S->{model}{resv} };
    if ($dup) {
        my $ans = lc(($S->{anchor} // $status)->messageBox(
            -type => 'yesnocancel', -icon => 'warning', -title => 'Already reserved',
            -message => "$v{mac} is already reserved at $dup->{ip}"
                . (defined $dup->{name} && length $dup->{name} ? " ($dup->{name})" : '')
                . ".\n\nYes: move that reservation to $v{ip}\n"
                . "No: keep both (add a second reservation)\nCancel: do nothing"));
        return if $ans eq 'cancel';
        if ($ans eq 'yes') {
            my $resp = $cli->observe(kind => 'dhcp_reservation_move',
                ip => $dup->{ip}, new_ip => $v{ip});
            if (!defined $resp || $resp =~ /^ERR/) { $status->configure(-text => " $resp"); return }
            $S->{model} = gather($cli); $redraw->();
            $status->configure(-text => " moved $dup->{ip} -> $v{ip}");
            return;
        }
        $force = 1;          # 'No' — caller insists on a second reservation
    }
    my $r = $cli->observe(kind => 'dhcp_reservation', ip => $v{ip}, mac => lc $v{mac},
        ($v{name}  ne '' ? (name => $v{name})  : ()),
        subnet_cidr => subnet_of($v{ip}),
        ($v{group} ne '' ? (grp  => $v{group}) : ()),
        ($force ? (force => 1) : ()));
    if (!defined $r || $r =~ /^ERR/) { $status->configure(-text => " $r"); return }
    $S->{model} = gather($cli); $redraw->();
    $status->configure(-text => " reserved $v{ip} -> $v{mac}");
}

sub release_dialog {
    my ($cli, $S, $ip, $r, $redraw, $status) = @_;
    my $dlg = ($S->{anchor} // $status)->DialogBox(-title => "Reservation $ip",
        -buttons => ['Move', 'Release', 'Cancel']);
    $dlg->add('Label', -text =>
        sprintf("%s\nMAC:  %s\nName: %s\nGroup: %s",
            $ip, $r->{mac}, ($r->{name} // ''), ($r->{grp} // '')),
        -justify => 'left')->pack(-padx => 8, -pady => 6);
    my $ans = $dlg->Show // 'Cancel';
    if ($ans eq 'Release') {
        my $resp = $cli->observe(kind => 'dhcp_reservation_delete', ip => $ip);
        if (!defined $resp || $resp =~ /^ERR/) { $status->configure(-text => " $resp"); return }
        $S->{model} = gather($cli); $redraw->();
        $status->configure(-text => " released $ip");
    } elsif ($ans eq 'Move') {
        move_dialog($cli, $S, $ip, $r, $redraw, $status);
    }
}

# Reallocate an existing reservation to a different IP (default: the next
# free static in the same subnet).
sub move_dialog {
    my ($cli, $S, $ip, $r, $redraw, $status) = @_;
    my $suggest = next_free($S->{model}, subnet_of($ip)) // '';
    my $newip = $suggest;
    my $dlg = ($S->{anchor} // $status)->DialogBox(-title => "Move $ip",
        -buttons => ['Move', 'Cancel']);
    my $row = $dlg->add('Frame')->pack(-fill => 'x', -pady => 4, -padx => 6);
    $row->Label(-text => "$ip ($r->{mac}) -> ")->pack(-side => 'left');
    $row->Entry(-textvariable => \$newip, -width => 16)->pack(-side => 'left');
    my $ans = $dlg->Show // 'Cancel';
    return unless $ans eq 'Move';
    unless (defined ip2int($newip)) { $status->configure(-text => " bad IP '$newip'"); return }
    my $resp = $cli->observe(kind => 'dhcp_reservation_move', ip => $ip, new_ip => $newip);
    if (!defined $resp || $resp =~ /^ERR/) { $status->configure(-text => " $resp"); return }
    $S->{model} = gather($cli); $redraw->();
    $status->configure(-text => " moved $ip -> $newip");
}

# Lowest free static IP in $cidr, or undef.
sub next_free {
    my ($model, $cidr) = @_;
    my ($net, $len, $first, $last) = cidr_parts($cidr);
    return undef unless defined $net;
    for (my $i = $first; $i <= $last; $i++) {
        return int2ip($i) if classify($model, int2ip($i)) eq 'free';
    }
    return undef;
}

# High-contrast colour for a state in the reserve menu: green free, blue for the
# auto-DHCP dynamic range ('assigned'), red for otherwise-taken (in-use/reserved).
sub menu_color {
    my ($st) = @_;
    return '#008000' if $st eq 'free';
    return '#0000cc' if $st eq 'assigned';
    return '#cc0000';
}

# Who currently holds $ip: the reservation's name/MAC/group, else the machine
# name for a lease/observed address's MAC (the name net-lookup would give),
# falling back to the MAC. '' when free/unknown.
sub occupant {
    my ($model, $ip) = @_;
    if (my $r = $model->{resv}{$ip}) {
        my $s = join ' ', grep { defined && length }
            $r->{name}, $r->{mac}, ($r->{grp} ? "[$r->{grp}]" : ());
        # reserved here, but the device is currently seen at another address?
        my $cur = $r->{mac} ? $model->{mac_cur_ip}{ lc $r->{mac} } : undef;
        $s .= " (now at $cur)" if $cur && $cur ne $ip;
        return $s;
    }
    my $rec = $model->{leased}{$ip} || $model->{observed}{$ip} or return '';
    my $mac  = $rec->{mac};
    my $name = (defined $mac && length $mac) ? $model->{mac_name}{ lc $mac } : undef;
    $name //= $rec->{hostname} // $rec->{name};        # lease-supplied name, if any
    my $s = join ' ', grep { defined && length } ($name, $mac);
    # here now, but reserved for a different address (assigned, not yet moved)?
    my $rip = (defined $mac && length $mac) ? $model->{mac_resv_ip}{ lc $mac } : undef;
    $s .= " -> reserved $rip" if $rip && $rip ne $ip;
    return $s;
}

sub usage {
    my ($msg) = @_;
    print STDERR "net-reserve: $msg\n\n" if $msg;
    print STDERR <<'USAGE';
usage:
  net-reserve list [SUBNET]              colour-coded address map
  net-reserve free [SUBNET] [-n N]       next free static IPs
  net-reserve ranges                     dynamic DHCP pools
  net-reserve reserve IP MAC [--name N] [--group G] [--notes '..']
  net-reserve release IP
  net-reserve move OLD_IP NEW_IP         reallocate a reservation
  net-reserve autoname [SUBNET]          fill missing reservation host names
                                         from each MAC's machine
  net-reserve add-range CIDR START END [--zone Z]
  net-reserve del-range CIDR START
  net-reserve --gui [SUBNET]             Perl/Tk map (click a cell; reserve at a
                                         chosen address, move, or release)

  --listen H:P / --server NAME           daemon address
  --auth / --no-auth / --key-id / --key-file
USAGE
    exit($msg ? 2 : 0);
}
