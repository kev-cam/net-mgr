#!/usr/bin/perl
# net-config-gui — Tk section editor for /etc/net-mgr/config across
# the cluster. Workflow:
#
#   1. Pick a section ([cluster], [manager], [mysql], …) from the
#      dropdown. The list is populated from the source peer's config
#      once you Load.
#   2. Pick a source peer to pull the section from (or skip and type
#      a section from scratch).
#   3. Edit the section body in the text area.
#   4. Tick the peers to push to. "All" toggles every reachable peer.
#   5. Push — each ticked peer gets the section spliced into its
#      existing config (atomic write + .bak), with optional reload.
#
# SSH transport: plain `ssh -o BatchMode=yes root@HOST …`. Assumes
# you already have key-based auth to root on every cluster member.
# No new Perl deps. Net::OpenSSH would be marginally faster but a
# config edit happens at human-typing cadence so the per-call TCP
# handshake doesn't matter.
#
# Usage:
#   net-config-gui [--listen HOST:PORT] [--peers H1,H2,…]
#                  [--user USER] [--path /etc/net-mgr/config]

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use IPC::Open3 qw(open3);
use Symbol qw(gensym);

BEGIN {
    eval { require Tk; 1 } or die <<MSG;
net-config-gui needs perl-Tk. Install with:
  Debian/Ubuntu:  sudo apt install perl-tk
  RHEL/Fedora:    sudo dnf install perl-Tk
MSG
}
use Tk;
use Tk::ROText;
use Tk::DialogBox;
use Tk::Optionmenu;

use NetMgr::Multi;
use NetMgr::Client;

my $listen     = $ENV{NET_MGR_LISTEN} // '127.0.0.1:7531';
my $peers_opt;
my $ssh_user   = 'root';
my $cfg_path   = '/etc/net-mgr/config';
my $help;
GetOptions(
    'listen=s' => \$listen,
    'peers=s'  => \$peers_opt,
    'user=s'   => \$ssh_user,
    'path=s'   => \$cfg_path,
    'help|h'   => \$help,
) or usage(2);
usage(0) if $help;

# --- Peer discovery -------------------------------------------------
# Order of preference for building the peer list:
#   1. --peers H1,H2,…  explicit list, used verbatim
#   2. [cluster] members on the local daemon (NetMgr::Multi::discover)
#   3. local peers table (populated by net-find-peers) — covers the
#      bootstrap case where the user hasn't configured [cluster] yet
#      and is using this GUI precisely to set it up.
# Names are also SSH targets — cluster member names == hostnames by
# design.
my @PEERS = discover_peers();
if (!@PEERS) {
    die "no peers found. Set --peers, or run net-find-peers first to "
      . "populate the daemon's peers table, or start a local daemon.\n";
}

sub discover_peers {
    if ($peers_opt) {
        return grep { length } split /[,\s]+/, $peers_opt;
    }

    # Try [cluster] members via Multi::discover.
    my $multi = eval {
        NetMgr::Multi->discover(
            seed     => $listen,
            timeout  => 3,
            consumer => "net-config-gui.$$",
        );
    };
    if ($multi) {
        my @names = map { $_->{name} } $multi->peers;
        # discover() always seeds with at least self; only worth using
        # if it found additional peers (>1) or if it has a non-self
        # entry. Otherwise fall through to the peers-table scan.
        if (@names > 1) {
            return @names;
        }
    }

    # Fall back: snapshot the local daemon's peers table and resolve
    # each IP to a hostname's first label. Skip unresolvable hosts.
    my $cli = eval {
        NetMgr::Client->new(listen => $listen, timeout => 3);
    };
    return () unless $cli;
    eval { $cli->hello(consumer => "net-config-gui-bootstrap.$$") };
    if ($@) { eval { $cli->bye }; return () }

    my $peers_rows = eval { $cli->snapshot(1, 'peers') } || [];
    my $addrs      = eval { $cli->snapshot(2, 'addresses',
                                           where => "family = 'v4'") } || [];
    my $hostnames  = eval { $cli->snapshot(3, 'hostnames') } || [];
    my $machines   = eval { $cli->snapshot(4, 'machines') } || [];
    my $ifaces     = eval { $cli->snapshot(5, 'interfaces') } || [];
    my $st = eval { $cli->status } || {};
    eval { $cli->bye };

    # Build IP → machine_id → primary_name map.
    my %mac_of_addr  = map { $_->{addr} => $_->{mac} } @$addrs;
    my %mid_of_mac   = map { $_->{mac}  => $_->{machine_id} } @$ifaces;
    my %name_of_mid;
    $name_of_mid{$_->{id}} = $_->{primary_name}
        for grep { defined $_->{id} && defined $_->{primary_name} } @$machines;
    # hostnames fallback when primary_name is empty
    for my $h (@$hostnames) {
        next unless $h->{machine_id} && $h->{name};
        $name_of_mid{ $h->{machine_id} } //= $h->{name};
    }

    my $self_name = $st->{cluster_member} // _local_short_name();
    my %seen;
    my @names = ($self_name);
    $seen{$self_name} = 1;

    for my $row (@$peers_rows) {
        my $ip   = $row->{host}                      or next;
        my $mac  = $mac_of_addr{$ip}                 or next;
        my $mid  = $mid_of_mac{$mac};
        my $name = $mid ? $name_of_mid{$mid} : undef;
        $name //= _ptr_lookup($ip);
        next unless defined $name && length $name;
        $name = lc $name;
        $name =~ s/\..*//;
        next if $seen{$name}++;
        push @names, $name;
    }
    return @names;
}

sub _local_short_name {
    require Sys::Hostname;
    my $h = Sys::Hostname::hostname();
    $h =~ s/\..*//;
    return lc $h;
}

sub _ptr_lookup {
    my ($ip) = @_;
    require Socket;
    my $packed = Socket::inet_aton($ip) or return undef;
    my $name = gethostbyaddr($packed, Socket::AF_INET());
    return undef unless defined $name && length $name;
    return $name;
}

# Sections we always offer in the dropdown even before a Load, so the
# user can create a fresh section (notably [cluster]) on a peer whose
# config doesn't have it yet. Order matches the conceptual reading
# order; sections seen on the source after Load are merged in.
my @KNOWN_SECTIONS = qw(
    cluster manager mysql scanner ap_poll timeouts paths bindings
    dns scheduling dhcp uplinks peers forward
);

# Starter text when the user picks a section that didn't exist on
# the source peer. Trailing newline matters — replace_section trims
# but the editor display reads better with one.
my %SECTION_TEMPLATES = (
    cluster => <<'EOT',
# Roster source. Use either a comma list or auto-discovery:
#   members = host1, host2, host3
#   members = auto              # all reachable net-mgr peers
#   members = auto:DMZ          # peers on a DMZ-zone interface
#   members = auto:Private/lab  # zone_class Private, zone_name 'lab'
members = auto

# auto = participate normally; master = always claim; follower =
# never claim; excluded = ignored by election.
role = auto

# Lower wins. Score = priority − 50 when prefer_lan and not
# internet_facing.
priority   = 100
prefer_lan = 1
# internet_facing = 1   # set on gateway nodes; suppresses LAN bonus
EOT

    manager => <<'EOT',
# 'auto' = bind to every 192.168.*.* address + 127.0.0.1.
listen        = auto
log           = /var/log/net-mgr.log
offline_after = 300
EOT

    scheduling => <<'EOT',
scan-ap    = 0
presence   = 0
discover   = 0
find-peers = 0
EOT
);

# Standard [cluster] profiles. Picked from the dropdown + Set
# replaces the editor with the chosen one. Operator should still
# tweak (e.g. priority offsets when multiple hosts share a profile).
# Adding a profile is just an entry here.
my %CLUSTER_PROFILES = (
    'Gateway' => <<'EOT',
# Internet-facing host (modem-side). Never master — gateways are
# the most exposed and the most churny (link flaps, reboots).
members         = auto
role            = follower
priority        = 200
prefer_lan      = 1
internet_facing = 1
EOT

    'DMZ' => <<'EOT',
# Host bridging DMZ ↔ Private (typically an AP / fileserver on a
# semi-public subnet). Secondary master candidate.
members    = auto:DMZ
role       = auto
priority   = 150
prefer_lan = 1
EOT

    'Private' => <<'EOT',
# Internal LAN host. Preferred master — lowest score wins.
members    = auto:Private
role       = auto
priority   = 50
prefer_lan = 1
EOT

    'NAS / Server' => <<'EOT',
# Internal server (NAS, build host) — capable of being master but
# we'd rather it focus on its workload. Available as fallback.
members    = auto:Private
role       = auto
priority   = 100
prefer_lan = 1
EOT

    'Mobile / Laptop' => <<'EOT',
# Mobile host that roams (laptop, tablet). Opted out of being
# master so it can't claim leadership while disconnected from the
# main LAN. Still participates as a follower for read replication.
members    = auto
role       = excluded
priority   = 300
prefer_lan = 1
EOT
);

# Section → { profile_name => body } map. Add more sections here as
# they get standard profiles.
my %SECTION_PROFILES = (
    cluster => \%CLUSTER_PROFILES,
);
my %SECTION_PROFILE_ORDER = (
    cluster => [ 'Private', 'NAS / Server', 'DMZ', 'Gateway', 'Mobile / Laptop' ],
);

my %S = (
    section          => '',         # currently-selected section name
    sections_known   => [ @KNOWN_SECTIONS ],
    source_peer      => $PEERS[0],
    source_text      => '',         # last-loaded full config from source
    push_targets     => {},         # peer => 1 if ticked
    reload_after     => 0,
);

# --- Tk -------------------------------------------------------------
my $mw = MainWindow->new(-title => "net-config-gui ($cfg_path)");
$mw->geometry('900x650');

# Top: source + section picker
my $top = $mw->Frame->pack(-side => 'top', -fill => 'x', -pady => 2);
$top->Label(-text => 'Pull from:')->pack(-side => 'left');
my $src_combo = $top->Optionmenu(
    -options  => [ map { [ $_ => $_ ] } @PEERS ],
    -variable => \$S{source_peer},
)->pack(-side => 'left', -padx => 4);
$top->Button(-text => 'Load', -command => \&do_load)
   ->pack(-side => 'left', -padx => 4);
$top->Label(-text => '    Section:')->pack(-side => 'left');
my $section_combo;     # populated below in rebuild_section_combo
$top->Button(-text => '+ New…', -command => \&do_new_section)
   ->pack(-side => 'left', -padx => 4);
$top->Button(-text => 'Reload list', -command => \&rebuild_section_combo)
   ->pack(-side => 'right', -padx => 4);

# Middle: text editor
my $editor = $mw->Scrolled('Text',
    -height     => 18,
    -wrap       => 'none',
    -scrollbars => 'osoe',
    -font       => '{Monospace} 10',
)->pack(-side => 'top', -fill => 'both', -expand => 1, -pady => 2);

# Push targets
my $targets_frame = $mw->Frame(-relief => 'groove', -bd => 1)
                       ->pack(-side => 'top', -fill => 'x', -pady => 2);
$targets_frame->Label(-text => 'Push to:',
                      -font => '{Helvetica} 9 bold')
              ->pack(-side => 'left', -padx => 4);
for my $p (@PEERS) {
    $S{push_targets}{$p} = 1;     # default: all
    $targets_frame->Checkbutton(
        -text => $p, -variable => \$S{push_targets}{$p},
    )->pack(-side => 'left', -padx => 2);
}
$targets_frame->Checkbutton(
    -text     => 'also reload net-mgr after push',
    -variable => \$S{reload_after},
)->pack(-side => 'right', -padx => 8);

# Profile picker — only meaningful for sections that have profiles
# defined ([cluster] today). The combo + Set button rebuild whenever
# the section changes; for sections without profiles the row hides.
my $profile_frame = $mw->Frame->pack(-side => 'top', -fill => 'x', -pady => 2);
my $profile_label = $profile_frame->Label(-text => 'Profile:')
                                  ->pack(-side => 'left', -padx => 4);
my $profile_combo;     # rebuilt by rebuild_profile_combo()
my $profile_set_btn;
$S{profile} = '';

# Action bar
my $actions = $mw->Frame->pack(-side => 'bottom', -fill => 'x', -pady => 2);
$actions->Button(-text => 'Push',    -command => \&do_push)
        ->pack(-side => 'left',  -padx => 4);
$actions->Button(-text => 'Test',    -command => \&do_test)
        ->pack(-side => 'left',  -padx => 4);
$actions->Button(-text => 'Diff vs targets', -command => \&do_diff)
        ->pack(-side => 'left',  -padx => 4);
$actions->Button(-text => 'Quit',    -command => sub { exit 0 })
        ->pack(-side => 'right', -padx => 4);

my $status = $mw->Label(-anchor => 'w', -relief => 'sunken')
                ->pack(-side => 'bottom', -fill => 'x');

rebuild_section_combo();
status("Pick a section to edit, or Load a source peer to see its config.");
MainLoop;
exit 0;

# --- Actions --------------------------------------------------------

sub do_load {
    my $peer = $S{source_peer} or return;
    status("Loading $cfg_path from $peer …");
    $mw->update;
    my ($content, $err) = ssh_read($peer, $cfg_path);
    if (!defined $content) {
        msg('Load failed', "Could not read $cfg_path on $peer:\n$err");
        status("Load failed: $err");
        return;
    }
    $S{source_text} = $content;
    my @secs = list_sections($content);
    $S{sections_known} = \@secs;
    rebuild_section_combo();
    # Auto-pick [cluster] if present (the most likely thing you came
    # here to edit), else first section.
    my $pick = (grep { $_ eq 'cluster' } @secs)[0] // $secs[0];
    if (defined $pick) {
        $S{section} = $pick;
        load_section_into_editor($pick);
    }
    status("Loaded $cfg_path from $peer (" . scalar(@secs) . " section(s))");
}

sub rebuild_section_combo {
    $section_combo->destroy if $section_combo;
    # Merge known sections with whatever was seen on the source (if
    # Load has happened). cluster goes first when present so it's the
    # default landing for the most common edit.
    my %seen;
    my @secs;
    for my $s ('cluster', @{ $S{sections_known} || [] }, @KNOWN_SECTIONS) {
        next if $seen{$s}++;
        push @secs, $s;
    }
    $section_combo = $top->Optionmenu(
        -options  => [ map { [ $_ => $_ ] } @secs ],
        -variable => \$S{section},
        -command  => sub {
            load_section_into_editor($S{section});
            rebuild_profile_combo();
        },
    )->pack(-side => 'left', -padx => 4, -after => $top->children->[3]);
    # Trigger the editor for the currently-selected section so the
    # text area reflects what the picker shows.
    $S{section} = $secs[0] unless defined $S{section} && length $S{section};
    load_section_into_editor($S{section});
    rebuild_profile_combo();
}

sub rebuild_profile_combo {
    $profile_combo->destroy   if $profile_combo;
    $profile_set_btn->destroy if $profile_set_btn;
    my $section = $S{section} // '';
    my $profiles = $SECTION_PROFILES{$section};
    if (!$profiles) {
        # No profiles for this section — show a hint, no combo.
        $profile_combo = $profile_frame->Label(
            -text => "(no standard profiles for [$section])",
            -foreground => '#666',
        )->pack(-side => 'left', -padx => 4);
        $profile_set_btn = $profile_frame->Frame->pack(-side => 'left');
        return;
    }
    my @ordered = @{ $SECTION_PROFILE_ORDER{$section}
                     || [ sort keys %$profiles ] };
    $S{profile} = $ordered[0] unless $S{profile} && $profiles->{$S{profile}};
    $profile_combo = $profile_frame->Optionmenu(
        -options  => [ map { [ $_ => $_ ] } @ordered ],
        -variable => \$S{profile},
    )->pack(-side => 'left', -padx => 4);
    $profile_set_btn = $profile_frame->Button(
        -text    => 'Set from profile',
        -command => \&do_set_profile,
    )->pack(-side => 'left', -padx => 4);
}

# Replace the editor body with the chosen profile's text for the
# current section. No SSH, no daemon query — it's pure boilerplate
# the operator can then tweak (typically the priority offset when
# multiple hosts share a profile).
sub do_set_profile {
    my $section = $S{section} // '';
    my $profile = $S{profile} // '';
    my $body    = ($SECTION_PROFILES{$section} || {})->{$profile};
    return msg('No profile', "No profile '$profile' for [$section].")
        unless defined $body;
    $editor->delete('1.0', 'end');
    $editor->insert('end', "[$section]\n");
    $editor->insert('end', $body);
    status("[$section] set from profile '$profile'.");
}

sub load_section_into_editor {
    my ($section) = @_;
    return unless defined $section && length $section;
    my $body = extract_section($S{source_text}, $section);
    if (!length $body && exists $SECTION_TEMPLATES{$section}) {
        # Source has no such section — offer a starter template so
        # the user isn't typing from scratch. The Push path will
        # splice this in alongside whatever else the target has.
        $body = $SECTION_TEMPLATES{$section};
    }
    $editor->delete('1.0', 'end');
    $editor->insert('end', "[$section]\n");
    $editor->insert('end', $body);
}

# "+ New…" button — let the user type an arbitrary section name
# (handy for [uplinks], [bindings] entries we don't pre-template).
sub do_new_section {
    my $d = $mw->DialogBox(-title => 'New section',
                           -buttons => ['OK','Cancel']);
    my $name = '';
    $d->add('Label', -text => 'Section name (e.g. cluster, uplinks):')
      ->pack(-anchor => 'w', -padx => 8, -pady => 4);
    my $entry = $d->add('Entry', -textvariable => \$name, -width => 32)
                 ->pack(-padx => 8, -pady => 4);
    $entry->focus;
    return unless ($d->Show // '') =~ /^OK$/i;
    $name =~ s/^\s+|\s+$//g;
    return if $name eq '';
    push @{ $S{sections_known} }, $name
        unless grep { $_ eq $name } @{ $S{sections_known} };
    rebuild_section_combo();
    $S{section} = $name;
    load_section_into_editor($name);
}

sub do_push {
    my $section = $S{section};
    return msg('Nothing to push', 'Pick a section first.')
        unless defined $section && $section ne '' && $section ne '(load first)';
    my $body = editor_body();
    return msg('Nothing to push', 'The editor is empty.')
        unless defined $body && length $body;
    my @targets = grep { $S{push_targets}{$_} } @PEERS;
    return msg('No targets', 'Tick at least one peer to push to.')
        unless @targets;

    my $r = $mw->messageBox(
        -title   => 'Confirm push',
        -message => "Push [$section] to:\n  "
                  . join("\n  ", @targets)
                  . ($S{reload_after} ? "\n\nAlso reload net-mgr." : ''),
        -type    => 'OKCancel',
        -icon    => 'question',
        -default => 'cancel',
    );
    return unless $r eq 'Ok' || $r eq 'OK';

    my %results;
    for my $peer (@targets) {
        status("Pushing to $peer …");
        $mw->update;
        my ($existing, $rerr) = ssh_read($peer, $cfg_path);
        if (!defined $existing) {
            $results{$peer} = "READ FAILED: $rerr";
            next;
        }
        my $new = replace_section($existing, $section, $body);
        my $werr = ssh_write_atomic($peer, $cfg_path, $new);
        if (defined $werr) {
            $results{$peer} = "WRITE FAILED: $werr";
            next;
        }
        if ($S{reload_after}) {
            my $rrerr = ssh_reload($peer);
            $results{$peer} = defined $rrerr
                ? "wrote + RELOAD FAILED: $rrerr"
                : "wrote + reloaded";
        } else {
            $results{$peer} = "wrote";
        }
    }
    my $report = '';
    for my $p (@targets) {
        $report .= sprintf "%-20s %s\n", $p, $results{$p};
    }
    $mw->messageBox(-title => "Push results",
                    -message => $report, -type => 'OK',
                    -icon => ($report =~ /FAILED/ ? 'warning' : 'info'));
    status("Push complete.");
}

# Test each ticked peer: SSH login works AND the config file is
# writable (we need read on the file and write on its parent dir
# so the atomic-rename push can succeed). Peers that fail are
# unticked and the result reported.
sub do_test {
    my @targets = grep { $S{push_targets}{$_} } @PEERS;
    return msg('No targets', 'Tick at least one peer to test.')
        unless @targets;

    my %results;
    for my $peer (@targets) {
        status("Testing $peer …");
        $mw->update;
        my ($ok, $why) = ssh_test_writable($peer, $cfg_path);
        $results{$peer} = { ok => $ok, why => $why };
        unless ($ok) {
            $S{push_targets}{$peer} = 0;
        }
    }
    my @passed = grep { $results{$_}{ok} } @targets;
    my @failed = grep { !$results{$_}{ok} } @targets;

    my $report = '';
    for my $p (@targets) {
        my $r = $results{$p};
        $report .= sprintf "%-20s %s%s\n",
            $p,
            ($r->{ok} ? 'OK (writable)' : 'FAIL — unticked'),
            ($r->{ok} ? '' : "  [$r->{why}]");
    }
    status(sprintf "Test: %d ok, %d failed (unticked)",
                  scalar @passed, scalar @failed);
    $mw->messageBox(-title => 'Test results',
                    -message => $report, -type => 'OK',
                    -icon => (@failed ? 'warning' : 'info'));
}

# Single SSH round-trip:
#   - command runs at all → login + sudo (if needed) works
#   - file is readable                  → we can Pull / preserve other sections
#   - parent dir is writable            → we can write the .tmp + rename
# Returns (1, undef) on full pass, (0, error) on any failure.
sub ssh_test_writable {
    my ($peer, $path) = @_;
    if (_is_self_peer($peer)) {
        return (0, "NOT_READABLE: $path") unless -r $path;
        (my $dir = $path) =~ s|/[^/]*$||;
        $dir = '.' unless length $dir;
        return (0, "DIR_NOT_WRITABLE: $dir") unless -w $dir;
        return (1, undef);
    }
    my $qp = shellq($path);
    my $remote = qq{
        if [ ! -r $qp ]; then echo "NOT_READABLE: $path"; exit 1; fi;
        d=\$(dirname $qp);
        if [ ! -w "\$d" ]; then echo "DIR_NOT_WRITABLE: \$d"; exit 1; fi;
        echo OK
    };
    my ($in_fh, $out_fh, $err_fh) = (undef, undef, gensym);
    my $pid = eval {
        open3($in_fh, $out_fh, $err_fh, ssh_args($peer, $remote));
    };
    return (0, "open3 failed: $@") unless $pid;
    close $in_fh if $in_fh;
    my $stdout = do { local $/; <$out_fh> } // '';
    my $stderr = do { local $/; <$err_fh> } // '';
    waitpid $pid, 0;
    my $rc = $? >> 8;
    chomp $stdout; chomp $stderr;
    if ($rc != 0) {
        # ssh-side failure (auth, network, etc) — stderr has the why.
        # If stdout has our remote-side rejection (NOT_READABLE etc),
        # prefer that since it's specific.
        my $reason = (length $stdout && $stdout ne 'OK')
                   ? $stdout
                   : ($stderr || "ssh exit $rc");
        $reason =~ s/^\s+|\s+$//g;
        return (0, $reason);
    }
    return (0, "unexpected reply: $stdout") unless $stdout =~ /^OK\s*$/;
    return (1, undef);
}

sub do_diff {
    my $section = $S{section};
    return msg('Nothing to diff', 'Pick a section first.')
        unless defined $section && $section ne '' && $section ne '(load first)';
    my $body = editor_body();
    return msg('Nothing to diff', 'The editor is empty.')
        unless defined $body && length $body;
    my @targets = grep { $S{push_targets}{$_} } @PEERS;
    return msg('No targets', 'Tick at least one peer to diff against.')
        unless @targets;

    my $report = '';
    for my $peer (@targets) {
        my ($content, $err) = ssh_read($peer, $cfg_path);
        $report .= "── $peer ──\n";
        if (!defined $content) {
            $report .= "  ERR $err\n";
            next;
        }
        my $there = extract_section($content, $section);
        my $here  = extract_section_from_text($body, $section);
        # Drop the [section] header so we compare just the body
        $there =~ s/^\s*\[[^\]]+\]\s*\n//;
        $here  =~ s/^\s*\[[^\]]+\]\s*\n//;
        if ($there eq $here) {
            $report .= "  (identical)\n";
        } else {
            $report .= text_diff($there, $here);
        }
    }
    show_text_dialog("Diff [$section]", $report);
}

# --- Editor body helpers -------------------------------------------

# Returns the editor text excluding the leading "[section]\n" header
# we inserted in load_section_into_editor (so replace_section can
# splice cleanly).
sub editor_body {
    my $all = $editor->get('1.0', 'end-1c');
    $all =~ s/^\s*\[[^\]]+\]\s*\n//;
    return $all;
}

# --- Section parse / replace ---------------------------------------

sub list_sections {
    my ($text) = @_;
    my @secs;
    for my $line (split /\n/, $text) {
        push @secs, $1 if $line =~ /^\s*\[([^\]]+)\]\s*$/;
    }
    my %seen;
    return grep { !$seen{$_}++ } @secs;
}

sub extract_section {
    my ($text, $section) = @_;
    my @body;
    my $in = 0;
    for my $line (split /\n/, $text, -1) {
        if ($line =~ /^\s*\[([^\]]+)\]\s*$/) {
            if ($1 eq $section) { $in = 1; next }
            elsif ($in)         { $in = 0; last }
            else                { next }
        }
        push @body, $line if $in;
    }
    return join("\n", @body) . (@body ? "\n" : '');
}

# Same as extract_section but treats the input as a section body that
# already has the [section] header line. (Editor content shape.)
sub extract_section_from_text {
    my ($text, $section) = @_;
    return extract_section("[$section]\n$text", $section);
}

sub replace_section {
    my ($text, $section, $new_body) = @_;
    $new_body =~ s/\n*\z//;
    my @out;
    my $in = 0;
    my $found = 0;
    for my $line (split /\n/, $text, -1) {
        if ($line =~ /^\s*\[([^\]]+)\]\s*$/) {
            if ($1 eq $section) {
                push @out, $line;
                push @out, split(/\n/, $new_body, -1) if length $new_body;
                $in = 1; $found = 1;
                next;
            } elsif ($in) {
                $in = 0;
            }
        }
        next if $in;
        push @out, $line;
    }
    if (!$found) {
        push @out, '', "[$section]";
        push @out, split(/\n/, $new_body, -1) if length $new_body;
    }
    my $joined = join("\n", @out);
    $joined .= "\n" unless $joined =~ /\n\z/;
    return $joined;
}

sub text_diff {
    my ($there, $here) = @_;
    # Minimal line-by-line diff — good enough for config sections.
    my @t = split /\n/, $there, -1;
    my @h = split /\n/, $here,  -1;
    my $out = '';
    my $max = ($#t > $#h) ? $#t : $#h;
    for my $i (0 .. $max) {
        my $tl = $t[$i] // '';
        my $hl = $h[$i] // '';
        if ($tl eq $hl) {
            $out .= "    $tl\n";
        } else {
            $out .= "  - $tl\n" if defined $t[$i];
            $out .= "  + $hl\n" if defined $h[$i];
        }
    }
    return $out;
}

# --- SSH helpers ----------------------------------------------------

# True if this peer name refers to the host we're running on. Lets
# the four SSH helpers short-circuit to local file/proc ops — sshing
# to localhost is needlessly fragile (often no key configured) and
# slower than just doing the work directly.
my $_self_cached;
sub _is_self_peer {
    my ($peer) = @_;
    return 0 unless defined $peer;
    $_self_cached //= _local_short_name();
    return lc($peer) eq $_self_cached;
}

# Read a file locally. Returns ($content, $err); $err undef on success.
sub _local_read {
    my ($path) = @_;
    open my $fh, '<', $path or return (undef, "open $path: $!");
    my $content = do { local $/; <$fh> };
    close $fh;
    return ($content, undef);
}

# Atomic local write with .bak. Returns undef on success or err string.
sub _local_write_atomic {
    my ($path, $content) = @_;
    my $tmp = "$path.tmp.$$";
    open my $fh, '>', $tmp or return "open $tmp: $!";
    print {$fh} $content;
    close $fh or do { my $e = "$!"; unlink $tmp; return "close $tmp: $e" };
    if (-e $path) {
        require File::Copy;
        File::Copy::copy($path, "$path.bak")
            or do { my $e = "$!"; unlink $tmp; return "backup: $e" };
    }
    rename $tmp, $path
        or do { my $e = "$!"; unlink $tmp; return "rename: $e" };
    return undef;
}

# Local systemctl reload. Returns undef on success or err string.
sub _local_reload {
    my $out = `systemctl reload net-mgr 2>&1 || systemctl restart net-mgr 2>&1`;
    my $rc = $? >> 8;
    return undef if $rc == 0;
    chomp $out;
    return length $out ? $out : "local reload exit $rc";
}

sub ssh_args {
    my ($peer, @rest) = @_;
    return ('ssh',
            '-o', 'BatchMode=yes',
            '-o', 'ConnectTimeout=5',
            '-o', 'StrictHostKeyChecking=accept-new',
            $ssh_user . '@' . $peer,
            @rest);
}

# Returns ($content, $err). On success, $err is undef.
sub ssh_read {
    my ($peer, $path) = @_;
    return _local_read($path) if _is_self_peer($peer);
    my ($in_fh, $out_fh, $err_fh) = (undef, undef, gensym);
    my $pid = eval {
        open3($in_fh, $out_fh, $err_fh,
              ssh_args($peer, "cat -- " . shellq($path)));
    };
    if (!$pid) {
        return (undef, "open3: $@");
    }
    close $in_fh if $in_fh;
    my $content = do { local $/; <$out_fh> } // '';
    my $err     = do { local $/; <$err_fh> } // '';
    waitpid $pid, 0;
    my $rc = $? >> 8;
    if ($rc != 0) {
        chomp $err;
        return (undef, length $err ? $err : "ssh exit $rc");
    }
    return ($content, undef);
}

# Returns undef on success or an error string. Writes atomically with
# a .bak of the previous version.
sub ssh_write_atomic {
    my ($peer, $path, $content) = @_;
    return _local_write_atomic($path, $content) if _is_self_peer($peer);
    my $qp = shellq($path);
    my $remote = join(' && ',
        "umask 077",
        "cat > $qp.tmp",
        "cp -p $qp $qp.bak 2>/dev/null || true",
        "mv -f $qp.tmp $qp",
    );
    my ($in_fh, $out_fh, $err_fh) = (undef, undef, gensym);
    my $pid = eval {
        open3($in_fh, $out_fh, $err_fh, ssh_args($peer, $remote));
    };
    if (!$pid) { return "open3: $@" }
    print {$in_fh} $content;
    close $in_fh;
    1 while <$out_fh>;
    my $err = do { local $/; <$err_fh> } // '';
    waitpid $pid, 0;
    my $rc = $? >> 8;
    if ($rc != 0) {
        chomp $err;
        return length $err ? $err : "ssh exit $rc";
    }
    return undef;
}

# Returns undef on success or error string.
sub ssh_reload {
    my ($peer) = @_;
    return _local_reload() if _is_self_peer($peer);
    my $cmd = "systemctl reload net-mgr 2>&1 || systemctl restart net-mgr 2>&1";
    my ($in_fh, $out_fh, $err_fh) = (undef, undef, gensym);
    my $pid = eval { open3($in_fh, $out_fh, $err_fh, ssh_args($peer, $cmd)) };
    if (!$pid) { return "open3: $@" }
    close $in_fh if $in_fh;
    my $combined = (do { local $/; <$out_fh> } // '')
                 . (do { local $/; <$err_fh> } // '');
    waitpid $pid, 0;
    my $rc = $? >> 8;
    if ($rc != 0) {
        chomp $combined;
        return length $combined ? $combined : "ssh exit $rc";
    }
    return undef;
}

sub shellq {
    my ($s) = @_;
    return "''" unless defined $s && length $s;
    return $s if $s =~ m{^[A-Za-z0-9_./=,\@:+-]+$};
    (my $q = $s) =~ s/'/'\\''/g;
    return "'$q'";
}

# --- small UI helpers -----------------------------------------------

sub status { $status->configure(-text => " $_[0]") }

sub msg {
    my ($title, $body) = @_;
    $mw->messageBox(-title => $title, -message => $body, -type => 'OK', -icon => 'info');
}

sub show_text_dialog {
    my ($title, $body) = @_;
    my $d = $mw->Toplevel(-title => $title);
    $d->geometry('800x500');
    my $t = $d->Scrolled('ROText', -font => '{Monospace} 9',
                         -wrap => 'none', -scrollbars => 'osoe')
              ->pack(-fill => 'both', -expand => 1);
    $t->insert('end', $body);
    $d->Button(-text => 'Close', -command => sub { $d->destroy })
      ->pack(-side => 'bottom', -pady => 4);
}

sub usage {
    my ($code) = @_;
    print <<'USAGE';
net-config-gui — Tk section editor for /etc/net-mgr/config across the cluster.

Usage:
  net-config-gui [--listen HOST:PORT] [--peers H1,H2,…]
                 [--user USER] [--path /etc/net-mgr/config]

  --listen HOST:PORT  local daemon for peer discovery (127.0.0.1:7531)
  --peers H1,H2,…     skip discovery; use this list (member names)
  --user USER         SSH login user (default 'root')
  --path PATH         config file to edit (default /etc/net-mgr/config)

Workflow: pick a source peer + Load → pick section → edit → tick
push targets → Push (with optional reload). Writes are atomic with
a .bak of the previous version on each target.
USAGE
    exit($code // 0);
}
