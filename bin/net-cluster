#!/usr/bin/perl
# net-cluster — multi-daemon admin tool. Snapshots/diffs tables and
# fans out OBSERVEs across every peer in the cluster, so you can see
# (and converge) divergence without ssh-ing host to host.
#
# Peer list is autodiscovered from the local daemon's STATUS (its
# [cluster] members), or set explicitly with --peers.
#
# Usage:
#   net-cluster peers                           — show peer connect status
#   net-cluster status                          — STATUS line per peer
#   net-cluster snapshot <table> [--where=…]    — dump rows per peer
#   net-cluster diff <table> [--key=col,…]      — show only divergent rows
#   net-cluster observe kind=K k=v ...          — fan out one OBSERVE
#   net-cluster master kind=K k=v ...           — OBSERVE on master only
#   net-cluster repair action=A k=v ...         — fan out one REPAIR
#                                                 (loopback or may_repair)
#
# Common flags:
#   --listen HOST:PORT     local seed daemon for discovery (default 127.0.0.1)
#   --peers  H1,H2,...     skip discovery, use these peers verbatim
#                          (each "name", "host:port", or "name=host:port")
#   --where  SQL           server-side WHERE clause for snapshot/diff
#   --key    col1,col2     row-identity columns for diff (default 'id')
#   --auth                 ssh-keygen -Y sign every connection (needed
#                          for auth-gated OBSERVEs: peer_cap_set/clear,
#                          isp_link_set, lost_device_delete, …)
#   --timeout SECS         per-peer connect timeout (default 3)
#   --json                 machine-readable output (snapshot/diff/observe)
#
# Exit codes:
#   0  success
#   1  no peers connected, or 'diff' found divergence (set --quiet-diff
#      to suppress that — useful when scripting)
#   2  bad arguments

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);

use NetMgr::Multi;

my $listen     = $ENV{NET_MGR_LISTEN} // '127.0.0.1:7531';
my $peers_opt;
my $timeout    = 3;
my $key_opt;
my $where_opt;
my $ignore_opt;
my $auth;
my $json;
my $quiet_diff;
my $capable_opt;
my $help;
GetOptions(
    'listen=s'   => \$listen,
    'peers=s'    => \$peers_opt,
    'timeout=i'  => \$timeout,
    'key=s'      => \$key_opt,
    'where=s'    => \$where_opt,
    'ignore=s'   => \$ignore_opt,
    'auth'       => \$auth,
    'capable=s'  => \$capable_opt,
    'json'       => \$json,
    'quiet-diff' => \$quiet_diff,
    'help|h'     => \$help,
) or usage(2);
usage(0) if $help;

my $cmd = shift @ARGV;
usage(2) unless defined $cmd;

# `update` fans out the auth-gated self_update OBSERVE — sign by default.
$auth = 1 if $cmd eq 'update' && !$auth;
# `put` writes config — always auth-gated (write_config refuses unauthed peers).
$auth = 1 if $cmd eq 'put' && !$auth;
# `deploy` redeploys just THIS node via its own daemon. Loopback is trusted, so
# it needs no signing — the no-fuss way to update a node when cross-node auth
# (allowed_signers) isn't set up. Run it on each node, or let `update` fan out.
$peers_opt = '127.0.0.1' if $cmd eq 'deploy' && !$peers_opt;
# `repair` fans out a REPAIR verb (wifi/eth/dhcp cycle, conn up/down). Admission
# on the daemon side is loopback OR may_repair, so sign by default — otherwise
# any non-loopback peer refuses. Callers can still --peers 127.0.0.1 to hit the
# local daemon unsigned, same as deploy.
$auth = 1 if $cmd eq 'repair' && !$auth;

# Build the Multi. Auth is wired as an empty hash so NetMgr::Client
# falls back to its default key_id / key_file detection.
my %mk_args = (
    timeout  => $timeout,
    auth     => ($auth ? {} : undef),
    consumer => "net-cluster.$$",
);
my $multi;
if ($peers_opt) {
    my @peers = grep { length } split /[,\s]+/, $peers_opt;
    $multi = NetMgr::Multi->new(peers => \@peers, %mk_args);
} else {
    $multi = NetMgr::Multi->discover(seed => $listen, %mk_args);
}
$multi->connect_all;

# --capable=a,b — filter peers to those whose STATUS advertises ALL the
# named capabilities in node_capabilities. Applied before the command
# dispatch so `--capable=ble status/peers/update/observe/...` all just
# work uniformly. Peers that don't answer STATUS (unreachable) drop out
# — you can't confirm they have BLE, so they don't count as capable.
if (defined $capable_opt && length $capable_opt) {
    my @want = grep { length } split /[,\s]+/, $capable_opt;
    if (@want) {
        my $st = eval { $multi->status_all } || {};
        my @kept;
        for my $p ($multi->peers) {
            my $s = $st->{ $p->{name} } || {};
            my $caps = $s->{node_capabilities} // '';
            my %have = map { $_ => 1 } grep { length } split /,/, $caps;
            my $ok = 1;
            for my $w (@want) { $ok = 0, last unless $have{$w} }
            push @kept, $p if $ok;
        }
        # NetMgr::Multi exposes peers via ->peers (list) but the underlying
        # store is $multi->{peers} — an arrayref of hashrefs. Reassign in
        # place so every downstream method (bye_all, status_all, snapshot_all)
        # sees the filtered set.
        @{ $multi->{peers} } = @kept;
    }
}

my $connected = grep { $_->{client} } $multi->peers;
if (!$connected) {
    warn "net-cluster: no peers connected\n";
    for my $p ($multi->peers) {
        warn "  $p->{name} ($p->{listen}): " . ($p->{error} // 'no client') . "\n";
    }
    exit 1;
}

my $rc = 0;
if    ($cmd eq 'peers')    { cmd_peers($multi) }
elsif ($cmd eq 'status')   { cmd_status($multi) }
elsif ($cmd eq 'snapshot') { cmd_snapshot($multi) }
elsif ($cmd eq 'diff')     { $rc = cmd_diff($multi) }
elsif ($cmd eq 'observe')  { $rc = cmd_observe($multi) }
elsif ($cmd eq 'update')   { unshift @ARGV, 'kind=self_update'; $rc = cmd_observe($multi) }
elsif ($cmd eq 'deploy')   { unshift @ARGV, 'kind=self_update'; $rc = cmd_observe($multi) }
elsif ($cmd eq 'regen')    { unshift @ARGV, 'kind=regen_dnsmasq'; $rc = cmd_observe($multi) }
elsif ($cmd eq 'reset-ble'){ unshift @ARGV, 'kind=reset_ble'; $rc = cmd_observe($multi) }
elsif ($cmd eq 'dnsmasq-switch')
                           { unshift @ARGV, 'kind=dnsmasq_switch'; $rc = cmd_observe($multi) }
elsif ($cmd eq 'dhcp-cycle'){ unshift @ARGV, 'kind=dhcp_cycle'; $rc = cmd_observe($multi) }
elsif ($cmd eq 'poll')     { $rc = cmd_poll($multi) }
elsif ($cmd eq 'put')      { $rc = cmd_put($multi) }
elsif ($cmd eq 'master')   { $rc = cmd_master($multi) }
elsif ($cmd eq 'repair')   { $rc = cmd_repair($multi) }
else { warn "net-cluster: unknown command '$cmd'\n"; usage(2) }

$multi->bye_all;
exit $rc;

# --- commands -------------------------------------------------------

sub cmd_peers {
    my ($m) = @_;
    for my $p ($m->peers) {
        my $state = $p->{client}
                  ? ($p->{authed} ? 'connected+auth'
                                  : ($p->{auth_error} ? "auth-FAILED ($p->{auth_error})"
                                                     : 'connected'))
                  : "down: " . ($p->{error} // 'unknown');
        printf "%-20s  %-30s  %s\n", $p->{name}, $p->{listen}, $state;
    }
}

sub cmd_status {
    my ($m) = @_;
    my $st = $m->status_all;
    # Show the CAPS column only when at least one peer reports something.
    # On older masters (no schema v32) the field is absent and printing an
    # empty column just adds noise.
    my $show_caps = grep { length($_->{node_capabilities} // '') }
                    values %$st;
    if ($show_caps) {
        printf "%-20s %-9s %-4s %-7s %-7s %-10s %-24s %s\n",
            'PEER', 'ROLE', 'PRI', 'REACH', 'QUORUM', 'MASTER', 'CAPS', 'MESH';
    } else {
        printf "%-20s %-9s %-4s %-7s %-7s %-10s %s\n",
            'PEER', 'ROLE', 'PRI', 'REACH', 'QUORUM', 'MASTER', 'MESH';
    }
    for my $p ($m->peers) {
        my $s = $st->{ $p->{name} };
        if (!$s) {
            printf "%-20s %s\n", $p->{name},
                ($p->{error} // 'no status');
            next;
        }
        if ($show_caps) {
            my $caps = $s->{node_capabilities} // '';
            $caps = substr($caps, 0, 21) . '...' if length($caps) > 24;
            printf "%-20s %-9s %-4s %-7s %-7s %-10s %-24s %s\n",
                $p->{name},
                $s->{cluster_role}      // '?',
                $s->{cluster_priority}  // '?',
                $s->{reachable_members} // '?',
                ($s->{quorum_ok} ? 'yes' : 'no'),
                ($s->{cluster_master} // '-') || '-',
                $caps,
                $s->{cluster_mesh}      // '';
        } else {
            printf "%-20s %-9s %-4s %-7s %-7s %-10s %s\n",
                $p->{name},
                $s->{cluster_role}      // '?',
                $s->{cluster_priority}  // '?',
                $s->{reachable_members} // '?',
                ($s->{quorum_ok} ? 'yes' : 'no'),
                ($s->{cluster_master} // '-') || '-',
                $s->{cluster_mesh}      // '';
        }
        # Diagnostics under the row — only printed when present so
        # healthy clusters stay quiet. These are what you need when
        # role stays 'auto' on a peer you expect to be electable.
        if (my $r = $s->{cluster_role_reason}) {
            print "    reason: $r\n" if length $r;
        }
        if (my $a = $s->{cluster_auto_spec}) {
            print "    auto-spec: $a\n";
        }
        if ($s->{cluster_peer_caps_active}) {
            print "    peer_caps: ACTIVE (this daemon's /etc/net-mgr/peers gates eligibility)\n";
        }
    }
}

sub cmd_snapshot {
    my ($m) = @_;
    my $table = shift @ARGV or die "snapshot: need <table>\n";
    my $snap = $m->snapshot_all($table,
                                ($where_opt ? (where => $where_opt) : ()));
    if ($json) {
        require JSON::PP;
        print JSON::PP->new->canonical(1)->pretty->encode($snap);
        return;
    }
    for my $p ($m->peers) {
        my $r = $snap->{ $p->{name} };
        print "── $p->{name} ──\n";
        if (!$r) {
            print "  (not connected)\n";
            next;
        }
        if ($r->{error}) {
            print "  ERR $r->{error}\n";
            next;
        }
        my $rows = $r->{rows} || [];
        if (!@$rows) {
            print "  (no rows)\n";
            next;
        }
        for my $row (@$rows) {
            print "  ",
                  join(' ', map { _kvf($_, $row->{$_}) } sort keys %$row),
                  "\n";
        }
    }
}

sub cmd_diff {
    my ($m) = @_;
    my $table = shift @ARGV or die "diff: need <table>\n";
    my @keys = $key_opt ? (grep { length } split /,/, $key_opt) : ('id');
    my @ignore = $ignore_opt ? (grep { length } split /,/, $ignore_opt) : ();
    my $diffs = $m->diff_table($table,
                               key => \@keys,
                               (@ignore     ? (ignore => \@ignore)    : ()),
                               ($where_opt  ? (where  => $where_opt)  : ()));
    my @div = grep { $_->{diverges} } @$diffs;

    if ($json) {
        require JSON::PP;
        print JSON::PP->new->canonical(1)->pretty->encode(\@div);
        return $quiet_diff ? 0 : (@div ? 1 : 0);
    }

    if (!@div) {
        print "no divergence\n" unless $quiet_diff;
        return 0;
    }

    my @connected = grep { $_->{client} } $m->peers;
    for my $d (@div) {
        my @kparts = split /\0/, $d->{key}, -1;
        my @kv = map { _kvf($keys[$_], $kparts[$_]) } 0 .. $#keys;
        print "── ", join(' ', @kv), " ──\n";
        for my $p (@connected) {
            my $v = $d->{values}{ $p->{name} };
            if (!defined $v) {
                printf "  %-20s MISSING\n", $p->{name};
                next;
            }
            printf "  %-20s %s\n",
                $p->{name},
                join(' ', map { _kvf($_, $v->{$_}) } sort keys %$v);
        }
    }
    return $quiet_diff ? 0 : 1;
}

sub cmd_observe {
    my ($m) = @_;
    my %kv = _parse_kv(@ARGV) or do { warn "observe: need kind=… …\n"; return 2 };
    my $res = $m->observe_all(%kv);
    my $any_err = 0;
    if ($json) {
        require JSON::PP;
        print JSON::PP->new->canonical(1)->pretty->encode($res);
    } else {
        for my $p ($m->peers) {
            my $r = $res->{ $p->{name} } // ($p->{error} // 'down');
            printf "%-20s %s\n", $p->{name}, $r;
            $any_err = 1 if $r !~ /^OK\b/;
        }
    }
    return $any_err ? 1 : 0;
}

sub cmd_poll {
    my ($m) = @_;
    my $name = shift @ARGV
        or do { warn "poll: need <probe> (ipv6, ifaces, routes, netmgr-log, fw_state, ssh_forwards, host-debug)\n"; return 2 };
    my (%out, $any_err);
    for my $p ($m->peers) {
        unless ($p->{client}) {
            $out{$p->{name}} = { error => ($p->{error} // 'not connected') };
            $any_err = 1; next;
        }
        my $text = eval { $p->{client}->poll($name) };
        if (!defined $text) {
            my $e = $@; chomp $e if $e;
            $e =~ s/ at \S+ line \d+\.?\s*$// if $e;   # drop croak location
            $out{$p->{name}} = { error => ($e || 'no reply') };
            $any_err = 1; next;
        }
        $out{$p->{name}} = { output => $text };
    }
    if ($json) {
        require JSON::PP;
        print JSON::PP->new->canonical(1)->pretty->encode(\%out);
        return $any_err ? 1 : 0;
    }
    for my $p ($m->peers) {
        my $r = $out{ $p->{name} } or next;
        print "── $p->{name} ──\n";
        if ($r->{error}) { print "  ERR $r->{error}\n"; next; }
        my $text = $r->{output} // '';
        $text =~ s/\n\z//;
        if (length $text) { print "  ", join("\n  ", split /\n/, $text, -1), "\n" }
        else              { print "  (no output)\n" }
    }
    return $any_err ? 1 : 0;
}

sub cmd_repair {
    my ($m) = @_;
    my %kv = _parse_kv(@ARGV) or do {
        warn "repair: need action=<name> [iface=… | name=…]\n";
        return 2;
    };
    unless (defined $kv{action} && length $kv{action}) {
        warn "repair: need action=<name> "
           . "(wifi_cycle, ethernet_cycle, dhcp_cycle, conn_up, conn_down)\n";
        return 2;
    }
    my $any_err = 0;
    for my $p ($m->peers) {
        unless ($p->{client}) {
            printf "%-20s ERR %s\n",
                $p->{name}, ($p->{error} // 'not connected');
            $any_err = 1; next;
        }
        my $r = eval { $p->{client}->repair(%kv) };
        if ($@) {
            my $e = $@; chomp $e;
            $e =~ s/ at \S+ line \d+\.?\s*$//;   # drop croak location
            printf "%-20s ERR %s\n", $p->{name}, $e;
            $any_err = 1;
        } else {
            printf "%-20s %s\n", $p->{name}, ($r // 'no reply');
            $any_err = 1 if !defined $r || $r !~ /^OK\b/;
        }
    }
    return $any_err ? 1 : 0;
}

sub cmd_put {
    my ($m) = @_;
    my $local = shift @ARGV
        or do { warn "put: usage: net-cluster put <LOCAL-FILE> <REMOTE-PATH> [mode=0644]\n"; return 2 };
    my $remote = shift @ARGV
        or do { warn "put: missing <REMOTE-PATH>\n"; return 2 };
    my %extra = _parse_kv(@ARGV);
    -r $local or do { warn "put: cannot read '$local'\n"; return 2 };
    open(my $fh, '<', $local) or do { warn "put: open $local: $!\n"; return 2 };
    binmode $fh; local $/; my $bytes = <$fh>; close $fh;
    require MIME::Base64;
    require Digest::SHA;
    my $b64       = MIME::Base64::encode_base64($bytes, '');   # no newlines
    my $local_sha = Digest::SHA::sha1_hex($bytes);
    my %kv = (kind => 'write_config', path => $remote,
              content_b64 => $b64, %extra);
    # `put` is always auth-gated; force --auth on like `update` does.
    if (!$m->{auth}) { warn "put: --auth required\n"; return 2 }
    my $res = $m->observe_all(%kv);
    require NetMgr::Protocol;
    my $any_err = 0;
    for my $p ($m->peers) {
        my $raw = $res->{ $p->{name} };
        if (!defined $raw || !length $raw) {
            printf "%-20s no reply\n", $p->{name}; $any_err = 1; next;
        }
        if ($raw =~ /^ERR /) {
            my $msg = $raw; $msg =~ s/^ERR\s+//;
            printf "%-20s ERR %s\n", $p->{name}, $msg;
            $any_err = 1; next;
        }
        my $cmd = eval { NetMgr::Protocol::parse_line($raw) };
        my $kv  = ($cmd && ref($cmd) eq 'HASH') ? ($cmd->{kv} || {}) : {};
        my $verify = ($kv->{sha1} && $kv->{sha1} eq $local_sha) ? "verified" : "SHA-MISMATCH";
        printf "%-20s OK  %s (%d bytes, mode=%s) %s\n",
            $p->{name}, $kv->{path} // $remote,
            $kv->{size} // length($bytes),
            $kv->{mode} // '?', $verify;
        $any_err = 1 if $verify ne 'verified';
    }
    return $any_err ? 1 : 0;
}

sub cmd_master {
    my ($m) = @_;
    my %kv = _parse_kv(@ARGV) or do { warn "master: need kind=… …\n"; return 2 };
    my $master = $m->master;
    if (!$master) {
        warn "master: no peer reports cluster_role=master\n";
        return 1;
    }
    my $r = $m->observe_one($master->{name}, %kv);
    if ($json) {
        require JSON::PP;
        print JSON::PP->new->canonical(1)->pretty->encode(
            { master => $master->{name}, reply => $r });
    } else {
        printf "%-20s %s\n", $master->{name} . ' (master)', $r;
    }
    return ($r =~ /^OK\b/) ? 0 : 1;
}

# --- helpers --------------------------------------------------------

sub _parse_kv {
    my %kv;
    for my $a (@_) {
        return () unless $a =~ /^([\w.-]+)=(.*)$/;
        $kv{$1} = $2;
    }
    return %kv;
}

# k=v formatter that quotes values containing whitespace or '=' so the
# output round-trips back through _parse_kv-style consumers.
sub _kvf {
    my ($k, $v) = @_;
    $v = '' unless defined $v;
    if ($v =~ /[\s=]/) {
        $v =~ s/"/\\"/g;
        return qq{$k="$v"};
    }
    return "$k=$v";
}

sub usage {
    my ($code) = @_;
    print <<'USAGE';
net-cluster — fan-out admin across the net-mgr cluster.

Usage:
  net-cluster peers
  net-cluster status
  net-cluster snapshot <table> [--where=SQL]
  net-cluster diff <table> [--key=col1,col2] [--ignore=col,col]
                           [--where=SQL] [--quiet-diff]
  net-cluster observe kind=K k=v ...    (fan out to every connected peer)
  net-cluster poll <probe>              (read-only state from every peer;
                                         probes: ipv6 ifaces routes netmgr-log
                                         fw_state ssh_forwards host-debug —
                                         gated by [debug] enabled+allowed_debug)
  net-cluster put <LOCAL> <REMOTE> [mode=0644]
                                        (write a config file on every peer over
                                         the mesh; --auth REQUIRED; allow-list:
                                         /etc/net-mgr/config, .../config.d/*.conf,
                                         .../secrets/*, .../allowed_*; secrets
                                         forced mode 0600)
  net-cluster master  kind=K k=v ...    (send only to cluster master)
  net-cluster update                    (pull+reinstall+re-exec EVERY peer;
                                         needs [manager] repo + cross-node auth)
  net-cluster deploy                    (same, but just THIS node via loopback —
                                         no signing needed; run it per node)
  net-cluster reset-ble                 (bounce bluez + net-bitchat-bridge on
                                         every peer — recovery for BLE wedges
                                         like "Maximum advertisements reached";
                                         auth-gated same as update)
  net-cluster dnsmasq-switch [variant=custom|stock]
                                        (flip each gateway between the user's
                                         custom dnsmasq and the distro stock;
                                         default variant=custom; stock has a
                                         guaranteed dpkg-dist restore fallback
                                         so you can always flip back;
                                         auth-gated same as update)
  net-cluster --peers X dhcp-cycle iface=Y [count=N] [gap=SECS]
                                        (release + reacquire the DHCP lease on
                                         iface Y — drives an event window at
                                         the gateway's dnsmasq; count 1..20,
                                         gap 1..60s, settle 1..30s optional;
                                         one in-flight cycle per iface;
                                         auth-gated same as update)
  net-cluster repair action=A k=v ...   (host-maintenance REPAIR fanout:
                                         wifi_cycle/ethernet_cycle/dhcp_cycle
                                         iface=IF, conn_up/conn_down name=CONN;
                                         daemon admits loopback or a key on
                                         /etc/net-mgr/allowed_repairers, so
                                         signs by default; per-action kill
                                         switch via [repair] prohibit_<action>)

Common flags:
  --listen HOST:PORT     local seed daemon for discovery (127.0.0.1:7531)
  --peers H1,H2,...      skip discovery; "name", "host:port", or "name=host:port"
  --auth                 ssh-keygen -Y sign each connection (auth-gated writes)
  --timeout SECS         per-peer connect timeout (default 3)
  --json                 machine-readable output for snapshot/diff/observe

Exit:  0=ok · 1=divergence (diff) or per-peer failure · 2=bad args
USAGE
    exit($code // 0);
}
