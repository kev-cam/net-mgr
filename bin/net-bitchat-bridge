#!/usr/bin/perl
# net-bitchat-bridge — pipe-read a BitChat helper, post messages into a
# net-chat session via OBSERVE kind=chat_msg to localhost:7531.
#
# Architecture:
#   helper (Rust BitChat client over BLE)  --stdout JSON lines-->  this script
#                                                                       |
#                                                                       v
#                                                       NetMgr::Client::chat_post
#                                                       (loopback, no auth needed;
#                                                        `as` field stamps attribution)
#
# Each helper stdout line is one JSON event:
#   {"type":"msg","sender":"alice","body":"hello","ts":1709000000,"channel":"public"}
#   {"type":"status","raw":"<any other line from the helper, ANSI-stripped>"}
# 'msg' events become chat_post calls; 'status' lines are logged at debug.
#
# Tier-0 scope: one-way (BitChat -> net-chat) only. Tier-2 will add the
# reverse direction via a SUBSCRIBE to chat_messages.
#
# Usage:
#   net-bitchat-bridge --config /etc/net-mgr/bitchat-bridge.conf --foreground
#   net-bitchat-bridge --once     # process one line then exit (for testing)
#   net-bitchat-bridge --dry-run  # print what would be posted, don't post

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(GetOptions);
use IPC::Open3;
use IO::Select;
use Symbol qw(gensym);
use JSON::PP;
use POSIX qw(WNOHANG);
use NetMgr::Client;
use NetMgr::Config;
use NetMgr::Protocol qw(parse_line);

my %opt;
GetOptions(\%opt,
    'config=s', 'foreground', 'once', 'dry-run', 'preflight', 'help',
) or usage(2);
usage(0) if $opt{help};

# Two-stage config:
#   /etc/net-mgr/config  [bitchat_bridge]   — single source of truth for
#     the run/skip decision and the simple knobs (mode, helper_path,
#     session_name, adapter_index). Defaults from NetMgr::Config %DEFAULTS.
#   /etc/net-mgr/bitchat-bridge.conf        — optional overlay for helper
#     env vars / args; only present when the operator needs to tune.
my $main_cfg     = NetMgr::Config->load;
my $bridge_cfg   = $main_cfg->{bitchat_bridge} || {};
my $per_feat_cfg = read_per_feature_config(
    $opt{config} // '/etc/net-mgr/bitchat-bridge.conf');

my $mode    = lc($bridge_cfg->{mode} // 'on');
my $session = $per_feat_cfg->{session}{name}
           // $bridge_cfg->{session_name}
           // 'bitchat-bridge';
my $as      = $per_feat_cfg->{identity}{as}  // 'bitchat-relay';
my $listen  = $per_feat_cfg->{daemon}{listen} // '127.0.0.1:7531';

# WiFi onramp: when configured, respond to "WiFi?" (case-insensitive) on
# #mesh with a WIFI: URI DM back to the asker. This is the concrete
# credential-free onramp step from project_bitchat-bridge — any nearby
# BitChat client can request WiFi access without knowing SSID/password
# up front. Config lives in the per-feature bitchat-bridge.conf under a
# [wifi_response] section:
#
#   [wifi_response]
#   ssid     = guest-net           # required
#   auth     = WPA                 # WPA | WPA2 | WEP | nopass (default WPA)
#   password = welcome123          # required unless auth=nopass
#   hidden   = false               # optional; true for SSID-hidden networks
#   note     = "you're on VLAN 42" # optional; appended after the URI in the DM
#
# If ssid isn't set, WiFi? is ignored (no accidental broadcasts of
# credentials from a mis-configured bridge).
my $wifi_cfg = $per_feat_cfg->{wifi_response} // {};

# Helper-targeted env vars from the optional per-feature file
# (anything in [helper] starting env_ becomes $ENV{...}).
for my $k (sort keys %{ $per_feat_cfg->{helper} // {} }) {
    next unless $k =~ /^env_(.+)$/;
    $ENV{$1} = $per_feat_cfg->{helper}{$k};
}
my @helper_args = split ' ', ($per_feat_cfg->{helper}{args} // '');

# Helper path resolution. Main /etc/net-mgr/config [bitchat_bridge]
# helper_path is the SOLE source of the helper binary path. The per-feature
# file's [helper] path key is ignored on purpose: an older install may have
# it pointing at a now-stale binary, and silent overrides were exactly the
# foot-gun that wired the supervisor to the wrong helper after a default-on
# install. Per-feature file is for env/args only.
# 'auto' (default) searches PATH for bitchat-jsonl plus convention-based
# fallbacks under /home/*/src/bitchat-rust/target/release so a developer
# build wins without an absolute-path config edit.
my $helper_path = $bridge_cfg->{helper_path} // 'auto';
if (lc($helper_path) eq 'auto') {
    $helper_path = _which('bitchat-jsonl')
                // _find_in_home_clone('bitchat-rust', 'bitchat-jsonl');
}

# Preflight: gate the launch on (1) config mode, (2) BT controller, (3)
# helper findable. Returns 0 to proceed, non-zero to skip cleanly with a
# logged reason. systemd's ExecCondition treats non-zero here as "condition
# not met" — no failure, no Restart=. We also call this at main-loop
# startup as defense-in-depth for operators running by hand without
# ExecCondition.
sub preflight {
    if ($mode eq 'off') {
        warn "[bridge/preflight] skip: [bitchat_bridge] mode = off in /etc/net-mgr/config\n";
        return 1;
    }
    if (!_bt_controller_present()) {
        warn "[bridge/preflight] skip: no Bluetooth controller "
           . "(/sys/class/bluetooth is empty)\n";
        return 1;
    }
    if (!defined $helper_path || !length $helper_path || !-x $helper_path) {
        my $h = $helper_path // '(unset)';
        warn "[bridge/preflight] skip: bitchat-jsonl helper not found "
           . "('$h' is not executable). Build it from "
           . "https://github.com/joshbtn/bitchat-rust + the in-tree "
           . "src/bin/bitchat-jsonl.rs and install to /usr/local/bin, "
           . "or set [bitchat_bridge] helper_path = /full/path in "
           . "/etc/net-mgr/config.\n";
        return 1;
    }
    return 0;
}

if ($opt{preflight}) {
    exit preflight();
}
if (preflight()) {
    # belt-and-braces for older systemd / hand-runs: even with Restart=on-failure
    # systemd might wrap us, but we exit 0 to avoid being counted as a crash.
    exit 0;
}

my $backoff = 1;
while (1) {
    my $exit = eval { run_once() };
    my $err  = $@;
    if ($err) {
        warn "[bridge] $err";
    } else {
        warn "[bridge] helper exited (code=" . ($exit // '?') . ")\n";
    }
    last if $opt{once};
    # Belt-and-braces reap. run_once's blocking waitpid at line ~232 catches
    # the main helper PID, but the Rust helper's bluer runtime can hand a
    # forked-off thread (BLE central task, dbus worker) inherited pipe FDs
    # that outlive the main process — those exit right after but never get
    # reaped by us, showing up as <defunct> in ps. WNOHANG so this doesn't
    # stall between crash + backoff.
    while ((my $reaped = waitpid(-1, WNOHANG)) > 0) {
        warn "[bridge] reaped stray child pid=$reaped exit=" . ($? >> 8) . "\n";
    }
    sleep $backoff;
    $backoff = $backoff >= 30 ? 30 : $backoff * 2;
    # Successful run resets backoff (we only get here if helper actually
    # produced output for a while — a quick crash should keep backing off).
    $backoff = 1 if defined $exit && $exit == 0;
}

# ---- supervisor inner loop ----

sub run_once {
    warn "[bridge] launching helper: $helper_path @helper_args\n";
    my ($wh, $rh, $eh) = (undef, undef, gensym);
    my $pid = open3($wh, $rh, $eh, $helper_path, @helper_args);
    # Keep $wh open — it's the reverse-direction channel now. Tier-2 wires
    # net-chat's `bitchat-bridge` session to the helper's stdin JSON command
    # protocol: SUBSCRIBE to chat_messages, and each new user-typed line
    # becomes {"cmd":"send","body":"..."} on the helper's stdin, which
    # broadcasts it on BLE mesh. Buffered write so a slow helper doesn't
    # stall the supervisor.
    $wh->autoflush(1) if $wh;

    my ($cli, $sub);
    unless ($opt{'dry-run'}) {
        # $cli — write channel: chat_post inbound BLE messages.
        $cli = NetMgr::Client->new(listen => $listen, timeout => 6);
        $cli->hello(consumer => "bitchat-bridge.$$");
        # $sub — read channel: SUBSCRIBE stream. Separate client so a slow
        # chat_post never stalls the subscription (and vice versa).
        $sub = NetMgr::Client->new(listen => $listen, timeout => 6);
        $sub->hello(consumer => "bitchat-bridge.sub.$$");
        # Stream-only (not snapshot): we don't want the message backlog
        # replayed to BLE at startup, only newly-typed lines. WHERE gates
        # to just our session so we don't get every unrelated chat's
        # traffic in the loop.
        eval {
            $sub->send_line("SUBSCRIBE sub=1 mode=stream"
                          . " FROM chat_messages WHERE session = '$session'");
        };
        if ($@) {
            warn "[bridge] SUBSCRIBE send failed: $@";
        } else {
            warn "[bridge] SUBSCRIBE sent for session=$session\n";
        }
    }

    # Drain helper stdout (JSON events from BLE) AND stderr (helper diag
    # logs) AND — new for Tier-2 — the subscription stream (typed messages
    # to broadcast back onto BLE). Without concurrent draining any one of
    # them stalling would block the others (~64 KiB pipe buffer).
    my $sel = IO::Select->new($rh, $eh);
    $sel->add($sub->{sock}) if $sub && $sub->{sock};
    my %buf = ($rh => '', $eh => '');
    $buf{ $sub->{sock} } = '' if $sub && $sub->{sock};
    my $posted = 0;
    my $forwarded = 0;
    # Track EOF per fd so the helper-dies test is independent of whether
    # the subscription happens to EOF (net-mgr daemon restart, etc.) — we
    # want to keep going as long as helper stdout+stderr are live.
    my %eof;
    # Periodic peer poll: every $PEER_POLL_S seconds, ask the helper for its
    # current peer list and upsert each into bitchat_peers via loopback
    # BITCHAT_PEER_UPSERT. Feeds the net-chat GUI Members dialog when the
    # session is bitchat-bridge.
    my $PEER_POLL_S = 30;
    my $last_peer_poll = time - $PEER_POLL_S + 5;   # first poll ~5s in
    my $peer_cli;
    unless ($opt{'dry-run'}) {
        $peer_cli = NetMgr::Client->new(listen => $listen, timeout => 6);
        $peer_cli->hello(consumer => "bitchat-bridge.peers.$$");
    }

  OUTER:
    while (!($eof{$rh} && $eof{$eh})) {
        # Peer poll tick — fire only when the helper's stdin is still open
        # so we don't stall on a dead pipe during helper respawn.
        if ($wh && time - $last_peer_poll >= $PEER_POLL_S) {
            my $ok = eval { print $wh encode_json({ cmd => 'peers' }), "\n"; 1 };
            warn "[bridge] peer poll tick "
               . ($ok ? "sent" : "FAILED: $@") . "\n";
            $last_peer_poll = time;
        }
        my @ready = $sel->can_read(1) or next;
        for my $fh (@ready) {
            my $chunk;
            my $n = sysread($fh, $chunk, 4096);
            if (!defined $n || $n == 0) {
                $eof{$fh} = 1;
                $sel->remove($fh);
                next;
            }
            $buf{$fh} .= $chunk;
            while ((my $idx = index($buf{$fh}, "\n")) >= 0) {
                my $line = substr($buf{$fh}, 0, $idx, '');
                substr($buf{$fh}, 0, 1, '');
                chomp $line;
                next unless length $line;
                if ($fh == $eh) {
                    # Helper diagnostic — surface to our own stderr.
                    warn "[helper/err] $line\n";
                    next;
                }
                # Subscription stream: net-chat client posted a new message
                # to bitchat-bridge session. Forward to helper stdin so it
                # broadcasts on BLE mesh. Loop guard: skip messages our own
                # $as posted (those came FROM BLE via chat_post; forwarding
                # them back to BLE would echo).
                if ($sub && $fh == $sub->{sock}) {
                    my $c = eval { parse_line($line) };
                    if ($@ || !$c) { warn "[bridge] sub parse: $@\n" if $@; next }
                    next unless ($c->{verb} // '') eq 'ROW';
                    my $t = $c->{kv}{table} // '';
                    next unless $t eq 'chat_messages';
                    my $row_sender = $c->{kv}{sender} // '';
                    my $row_body   = $c->{kv}{body}   // '';
                    next unless length $row_body;
                    next if $row_sender eq $as;             # echo guard
                    next if $row_body =~ /^\[[^]]*\@bitchat/; # tag guard
                    # DM tag: "@HEX16: text" → route as private (Noise-
                    # encrypted) to that peer, not broadcast. The Members
                    # dialog's DM button on a bitchat_peers row posts this
                    # form via chat_post.
                    my $dm_to_peer;
                    if ($row_body =~ s/^\@([0-9a-fA-F]{16}):\s*//) {
                        $dm_to_peer = lc $1;
                    }
                    # Serialize and forward to helper. With $dm_to_peer set
                    # we include "to_peer" in the JSON so bitchat-jsonl's
                    # cmd_reader routes via send_private_message_by_hex_id
                    # instead of a broadcast.
                    my $out_body = $row_body;
                    utf8::upgrade($out_body);
                    my $cmd = encode_json({
                        cmd  => 'send',
                        body => $out_body,
                        ($dm_to_peer ? (to_peer => $dm_to_peer) : ()),
                    });
                    if ($opt{'dry-run'}) {
                        print "DRY: helper stdin << $cmd\n";
                    } else {
                        my $ok = eval { print $wh "$cmd\n"; 1 };
                        if (!$ok) {
                            warn "[bridge] stdin write failed: $@";
                        } else {
                            $forwarded++;
                        }
                    }
                    next;
                }
                # stdout path: JSON event
                my $ev = eval { decode_json($line) };
                if ($@ || ref($ev) ne 'HASH') {
                    warn "[bridge] skip non-JSON: " . substr($line, 0, 200) . "\n";
                    next;
                }
                my $type = $ev->{type} // '';
                if ($type eq 'msg') {
                    my $sender = $ev->{sender} // '?';
                    my $body   = $ev->{body}   // '';
                    my $sender_peer_id = $ev->{sender_peer_id} // '';

                    # WiFi onramp: match "WiFi?" (case-insensitive, tolerant
                    # of hyphen/space in "Wi-Fi?"). Respond with a WIFI: URI
                    # DM straight to the asker via helper stdin (bypass
                    # chat_post → SUBSCRIBE echo loop). Only when we have a
                    # 16-hex peer_id AND wifi_response.ssid is configured
                    # AND the sender isn't the bridge itself.
                    if ($body =~ /^\s*wi[- ]?fi\??\s*$/i
                        && $wifi_cfg->{ssid}
                        && $sender_peer_id =~ /^[0-9a-fA-F]{16}$/
                        && $sender ne 'System'
                        && $sender ne $as)
                    {
                        my $ssid = $wifi_cfg->{ssid};
                        my $auth = uc($wifi_cfg->{auth} // 'WPA');
                        my $pass = $wifi_cfg->{password} // '';
                        my $hidden = ($wifi_cfg->{hidden} // '') =~ /^(1|true|yes)$/i;
                        # WIFI: QR-code URI — same format iOS/Android
                        # camera and QR readers parse. Escape ";" and ","
                        # in fields per the WiFi Alliance recommendation.
                        my $esc = sub {
                            my $s = shift // ''; $s =~ s/([\\;,"'])/\\$1/g; $s
                        };
                        my $uri = 'WIFI:S:' . $esc->($ssid)
                                . ';T:' . $auth
                                . ($auth eq 'NOPASS'
                                   ? '' : ';P:' . $esc->($pass))
                                . ($hidden ? ';H:true' : '')
                                . ';;';
                        my $reply = "SSID: $ssid  (paste into WiFi QR reader "
                                  . "or use plain SSID+password)\n$uri";
                        $reply .= "\n" . $wifi_cfg->{note}
                            if $wifi_cfg->{note};
                        warn "[bridge] wifi-onramp: replying to $sender_peer_id ($sender)\n";
                        eval {
                            print $wh encode_json({
                                cmd     => 'send',
                                body    => $reply,
                                to_peer => lc $sender_peer_id,
                            }), "\n";
                        };
                        warn "[bridge] wifi-onramp write failed: $@" if $@;
                        # Also log in the net-chat session so an operator
                        # sees the reply happened (from the bridge, not
                        # the asker).
                        eval { $cli->chat_post(session => $session,
                            body => "[wifi-onramp] responded to $sender ($sender_peer_id)",
                            as   => $as) } if $cli;
                        next;
                    }

                    next unless length $body;
                    my $chan = $ev->{channel} // '';
                    # bitchat-rust system-announcement bodies embed raw Noise
                    # key bytes (client-side bug; should hex-encode). Strip
                    # bytes outside printable ASCII and BMP; squash whitespace.
                    utf8::upgrade($body);
                    $body =~ s/[^\x20-\x7e\x{00a0}-\x{ffff}]+//g;
                    $body =~ s/\s{2,}/ /g;
                    $body =~ s/^\s+|\s+$//g;
                    # Suppress "joined/left/connected/disconnected" system spam.
                    next if $sender eq 'System'
                         && $body =~ /\b(joined|left|connected|disconnected)\b/i;
                    next unless length $body;
                    my $tagged = sprintf('[%s@bitchat%s] %s',
                        $sender,
                        (length $chan && $chan ne 'mesh' ? "/$chan" : ''),
                        $body);
                    next if length($tagged) > 1024 * 1024;
                    if ($opt{'dry-run'}) {
                        print "DRY: chat_post session=$session as=$as body=$tagged\n";
                    } else {
                        eval { $cli->chat_post(session => $session, body => $tagged, as => $as) };
                        warn "[bridge] chat_post failed: $@" if $@;
                    }
                    $posted++;
                    last OUTER if $opt{once};
                } elsif ($type eq 'status') {
                    warn "[bridge] helper: " . ($ev->{raw} // '') . "\n";
                } elsif ($type eq 'cmd_reply') {
                    # cmd_reply for our {"cmd":"peers"} poll — upsert each
                    # peer into bitchat_peers via loopback. Any other
                    # cmd_reply (e.g. send ok/err) just gets logged.
                    if (($ev->{cmd} // '') eq 'peers'
                        && ref $ev->{peers} eq 'ARRAY'
                        && $peer_cli)
                    {
                        my $n_up = 0;
                        for my $p (@{ $ev->{peers} }) {
                            next unless ref $p eq 'HASH' && $p->{peer_id};
                            my $line = 'BITCHAT_PEER_UPSERT '
                                     . "peer_id=$p->{peer_id}"
                                     . (defined $p->{nickname}
                                        ? " nickname=$p->{nickname}" : '')
                                     . " is_connected="
                                     . ($p->{connected} ? 1 : 0);
                            eval { $peer_cli->send_recv($line) };
                            warn "[bridge] peer upsert failed: $@" if $@;
                            $n_up++ unless $@;
                        }
                        warn "[bridge] peer_cli upserted $n_up peer(s)\n"
                            if $n_up;
                        # Also sweep any peers now stale (not in this reply).
                        # We only mark disconnected — retention is the
                        # daemon's job via sweep_bitchat_peers.
                    } else {
                        warn "[bridge] cmd_reply ok=" . ($ev->{ok} ? 1 : 0)
                           . " path=" . ($ev->{path} // '')
                           . ($ev->{err} ? " err=$ev->{err}" : '') . "\n";
                    }
                } else {
                    warn "[bridge] unknown event type='$type'\n";
                }
            }   # close per-line while
        }       # close for my $fh
    }           # close OUTER while

    eval { $cli->bye }      if $cli;
    eval { $sub->bye }      if $sub;
    eval { $peer_cli->bye } if $peer_cli;
    eval { close $wh }      if $wh;
    waitpid($pid, 0);
    my $code = $? >> 8;
    warn "[bridge] processed $posted inbound BLE, forwarded $forwarded outbound to BLE, before helper exited\n";
    return $code;
}

# ---- config + util ----

# Per-feature config file (optional overlay — main config is authoritative).
# Returns an empty hashref when the file doesn't exist, so a default install
# without /etc/net-mgr/bitchat-bridge.conf still proceeds.
sub read_per_feature_config {
    my ($path) = @_;
    return {} unless -r $path;
    open my $fh, '<', $path or return {};
    my %cfg;
    my $section = 'default';
    while (<$fh>) {
        s/^\s+|\s+$//g;
        next if !length || /^[#;]/;
        if (/^\[(\S+)\]$/) { $section = $1; next }
        if (/^([\w-]+)\s*=\s*(.*)$/) { $cfg{$section}{$1} = $2 }
    }
    close $fh;
    return \%cfg;
}

# Tiny `which` — avoids a File::Which dependency. Returns the absolute path
# to $name in $ENV{PATH} or undef. /usr/local/bin is searched first so a
# package-installed helper wins over anything in $HOME.
sub _which {
    my ($name) = @_;
    return undef unless defined $name && length $name && $name !~ m{/};
    my @dirs = split /:/, ($ENV{PATH} // '');
    unshift @dirs, '/usr/local/bin' unless grep { $_ eq '/usr/local/bin' } @dirs;
    for my $d (@dirs) {
        my $p = "$d/$name";
        return $p if -x $p;
    }
    return undef;
}

# Convention-based fallback for helper discovery: when bitchat-jsonl was
# built from source under ~/src/<crate>/target/release on a developer
# workstation, check that path before giving up. Returns the absolute
# path to the executable, or undef. Iterates a small set of likely homes
# so the service running as root can find a dkc-built binary without an
# absolute-path config edit.
sub _find_in_home_clone {
    my ($crate, $name) = @_;
    my @homes;
    push @homes, $ENV{HOME} if $ENV{HOME};
    # When the service runs as root, $HOME is /root; the binary likely
    # sits under a developer's home. Walk /home/* shallowly to find it.
    if (opendir my $dh, '/home') {
        push @homes, map { "/home/$_" } grep { !/^\./ } readdir $dh;
        closedir $dh;
    }
    for my $h (@homes) {
        my $p = "$h/src/$crate/target/release/$name";
        return $p if -x $p;
    }
    return undef;
}

# True if at least one BLE controller is exposed by the kernel. We look at
# /sys/class/bluetooth (the canonical, no-tool, no-privilege check) rather
# than hciconfig (which may not be installed). Note this only confirms a
# kernel device exists — BlueZ may still reject operations later if rfkill
# blocks it, but those failures surface in the helper logs.
sub _bt_controller_present {
    my $dir = '/sys/class/bluetooth';
    opendir my $dh, $dir or return 0;
    my @ents = grep { /^hci\d/ } readdir $dh;
    closedir $dh;
    return scalar @ents;
}

sub usage {
    my ($rc) = @_;
    print STDERR <<'USAGE';
net-bitchat-bridge — bridge a BitChat BLE helper into a net-chat session.

  net-bitchat-bridge [--config FILE] [--foreground] [--once] [--dry-run]

Flags:
  --config FILE   path to ini-style config (default /etc/net-mgr/bitchat-bridge.conf)
  --foreground    log to stderr, don't background
  --once          read one message then exit (for smoke testing)
  --dry-run       print what would be posted, don't actually contact the daemon

Config sections (ini-style):
  [helper]
  path = /usr/local/bin/net-bitchat-helper-wrap
  args =
  env_BITCHAT_BIN = /home/dkc/src/bitchat-terminal/target/release/bitchat

  [session]
  name = bitchat-bridge

  [identity]
  as = bitchat-relay

  [daemon]
  listen = 127.0.0.1:7531
USAGE
    exit($rc // 0);
}
