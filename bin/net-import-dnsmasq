#!/usr/bin/perl
# net-import-dnsmasq â€” scan dnsmasq configs for `dhcp-range=` directives and
# import them into the net-mgr DB as kind=dhcp_range, so net-reserve knows the
# automatic DHCP pools (and leaves them uncoloured rather than treating their
# addresses as allocatable statics).
#
# Sources (combine freely):
#   net-import-dnsmasq HOST ...      scan each HOST over net-ssh (APs/gateways)
#   net-import-dnsmasq --auto        scan every AP (aps table) + gateway
#                                    (isp_links) the daemon knows about
#   net-import-dnsmasq --local       scan this host's dnsmasq config glob
#                                    ([paths] dnsmasq_conf_glob + /etc/dnsmasq.conf)
# Options:
#   --print                 print the observations instead of sending them
#   --files 'P1 P2 ...'     paths/globs to grep (override the defaults)
#   --listen HOST:PORT      manager address
#   --ssh-timeout N         per-host net-ssh timeout, seconds (default 12)
#
# Remote access uses net-ssh (alias resolution + keys); the scan is a single
# grep over the candidate config paths, bounded by --ssh-timeout so an
# unreachable host can't wedge the run.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use Sys::Hostname qw(hostname);
use NetMgr::Client;
use NetMgr::Config;
use NetMgr::Protocol qw(format_kv);

my ($listen, $print_only, $local, $auto, $files_opt, $help, $verbose, $no_prune);
my $ssh_timeout = 12;
my $ssh_cmd     = 'net-ssh';        # override with --ssh-cmd 'ssh -o BatchMode=yes'
GetOptions(
    'listen=s'      => \$listen,
    'print'         => \$print_only,
    'local'         => \$local,
    'auto'          => \$auto,
    'files=s'       => \$files_opt,
    'ssh-timeout=i' => \$ssh_timeout,
    'ssh-cmd=s'     => \$ssh_cmd,
    'verbose|v'     => \$verbose,
    'no-prune'      => \$no_prune,
    'help|h'        => \$help,
) or die "bad options\n";
usage() if $help;
my @hosts = @ARGV;

usage("nothing to scan") unless @hosts || $local || $auto;

# Candidate paths to grep on a remote device (globs expand in the remote shell).
my @REMOTE_FILES = $files_opt ? split(/\s+/, $files_opt)
    : qw(/etc/dnsmasq.conf /etc/dnsmasq.d/* /tmp/dnsmasq.conf /tmp/dnsmasq.d/*
         /jffs/etc/dnsmasq.conf);

# ---- IP helpers -----------------------------------------------------
sub ip2int {
    my @o = split /\./, ($_[0] // '');
    return undef unless @o == 4;
    my $n = 0;
    for (@o) { return undef unless /^\d+$/ && $_ <= 255; $n = ($n << 8) | $_ }
    return $n;
}
sub int2ip { my $n = $_[0]; join '.', ($n>>24)&255, ($n>>16)&255, ($n>>8)&255, $n&255 }
# Prefix length of a dotted netmask (undef if not a contiguous mask).
sub masklen {
    my $i = ip2int($_[0]);
    return undef unless defined $i;
    my $b = sprintf '%032b', $i;
    return undef if $b =~ /01/;          # non-contiguous -> not a netmask
    return ($b =~ tr/1//);
}
sub subnet_cidr_of {
    my ($ip, $len) = @_;
    $len //= 24;
    my $i = ip2int($ip);
    return undef unless defined $i;
    my $mask = $len == 0 ? 0 : (0xFFFFFFFF << (32 - $len)) & 0xFFFFFFFF;
    return int2ip($i & $mask) . "/$len";
}

# ---- parse one `dhcp-range=` value ----------------------------------
# dnsmasq syntax: dhcp-range=[tag:..,][set:..,]<start>[,<end>|,static]
#                            [,<mode>][,<netmask>][,<broadcast>][,<lease>]
# We want the first two IPv4 tokens (start,end) of a *dynamic* pool, plus the
# netmask if one is given (to derive the CIDR; default /24).
sub parse_range {
    my ($val) = @_;
    $val =~ s/\s+$//;
    my @toks = split /,/, $val;
    return () if grep { lc $_ eq 'static' } @toks;   # static-only: no pool
    my @ips = grep { /^\d{1,3}(?:\.\d{1,3}){3}$/ && defined ip2int($_) } @toks;
    return () unless @ips >= 2;                       # need start AND end
    my ($start, $end) = @ips[0, 1];
    my $len = 24;
    for my $i (2 .. $#ips) {                           # a netmask after start/end
        next unless $ips[$i] =~ /^(?:255|254|252|248|240|224|192|128)\./;
        my $m = masklen($ips[$i]);
        if (defined $m) { $len = $m; last }
    }
    my $cidr = subnet_cidr_of($start, $len) or return ();
    return { cidr => $cidr, start => $start, end => $end };
}

# Pull every dhcp-range from a config file's text, tagging each range with its
# source file + line number (surfaced by --verbose).
sub ranges_from_text {
    my ($text, $file) = @_;
    my @r;
    my $ln = 0;
    for my $line (split /\n/, $text // '') {
        $ln++;
        next unless $line =~ /^\s*dhcp-range\s*=\s*(.+?)\s*$/;
        my $p = parse_range($1) or next;
        $p->{file} = $file if defined $file;
        $p->{line} = $ln;
        push @r, $p;
    }
    return @r;
}

# Editor backups / package drafts / temp files that dnsmasq itself would not
# load. Scanning them re-imports stale or draft ranges â€” the classic "net-reserve
# shows a DHCP pool that doesn't match the live config" â€” because the scan globs
# (dnsmasq-* locally, /etc/dnsmasq.d/* remotely) otherwise match dnsmasq-foo~,
# *.new, *.bak and friends alongside the active file.
sub is_backup_file {
    my ($path) = @_;
    (my $base = $path) =~ s{.*/}{};
    return 1 if $base =~ /~\z/;                 # vi/emacs backup     foo~
    return 1 if $base =~ /\A\#.*\#\z/;          # emacs autosave      #foo#
    return 1 if $base =~ /\A\./;                # dotfile / vi swap   .foo.swp
    return 1 if $base =~ /\.(?:bak|old|orig|save|swp|swo|tmp|new
                               |dpkg-(?:old|new|dist)
                               |rpm(?:new|save|orig)
                               |ucf-(?:old|new|dist))\z/xi;
    return 0;
}

# ---- local scan -----------------------------------------------------
sub scan_local {
    my @globs;
    if ($files_opt) {
        @globs = split /\s+/, $files_opt;
    } else {
        my $cfg = eval {
            NetMgr::Config->load($ENV{NET_MGR_CONF} // '/etc/net-mgr/config') } || {};
        @globs = grep { defined && length }
                 ($cfg->{paths}{dnsmasq_conf_glob}, '/etc/dnsmasq.conf');
    }
    my @r;
    for my $g (@globs) {
        for my $f (glob $g) {
            next unless -f $f && -r $f;
            next if is_backup_file($f);              # skip *~ / *.new / *.bak ...
            open my $fh, '<', $f or next;
            local $/; my $text = <$fh>; close $fh;
            push @r, ranges_from_text($text, $f);    # per-file so source is kept
        }
    }
    return @r;
}

# ---- remote scan over net-ssh (bounded by --ssh-timeout) ------------
sub scan_remote {
    my ($host) = @_;
    # -Hn so we can drop editor backups / drafts by filename (the remote shell's
    # glob, e.g. /etc/dnsmasq.d/*, otherwise matches dnsmasq-foo~ and *.new too)
    # and report the source file:line under --verbose.
    my $cmd = "grep -HnsE '^[[:space:]]*dhcp-range=' "
            . join(' ', @REMOTE_FILES) . " 2>/dev/null";
    my @ssh = split ' ', $ssh_cmd;          # net-ssh by default; --ssh-cmd to override
    my $pid = open(my $fh, '-|', @ssh, $host, $cmd);
    unless ($pid) { warn "net-import-dnsmasq: $host: $ssh[0]: $!\n"; return () }
    my @out;
    eval {
        local $SIG{ALRM} = sub { die "timeout after ${ssh_timeout}s\n" };
        alarm $ssh_timeout;
        @out = <$fh>;
        alarm 0;
    };
    if (my $e = $@) { kill 'TERM', $pid; warn "net-import-dnsmasq: $host: $e" }
    close $fh;
    my @r;
    for my $line (@out) {
        $line =~ s/\r?\n\z//;
        my ($file, $lineno, $rest) = $line =~ /^([^:]+):(\d+):(.*)$/ or next;
        next if is_backup_file($file);              # skip *~ / *.new / *.bak ...
        next unless $rest =~ /^\s*dhcp-range\s*=\s*(.+?)\s*$/;
        my $p = parse_range($1) or next;
        $p->{file} = $file; $p->{line} = $lineno;
        push @r, $p;
    }
    return @r;
}

# ---- enumerate APs + gateways the daemon knows about ----------------
sub enumerate_auto {
    my ($cli) = @_;
    my $aps  = eval { $cli->snapshot(1, 'aps') }        || [];
    my $ifs  = eval { $cli->snapshot(2, 'interfaces') } || [];
    my $mach = eval { $cli->snapshot(3, 'machines') }   || [];
    my $isp  = eval { $cli->snapshot(4, 'isp_links') }  || [];
    my %name_of_mid = map { ($_->{id} => $_->{primary_name}) }
                      grep { defined $_->{primary_name} && length $_->{primary_name} } @$mach;
    my %mid_of_mac  = map { (lc $_->{mac} => $_->{machine_id}) }
                      grep { $_->{mac} && $_->{machine_id} } @$ifs;
    my %names;
    for my $g (@$isp) {
        my $n = $name_of_mid{ $g->{gateway_machine_id} // '' };
        $names{$n} = 1 if defined $n && length $n;
    }
    for my $ap (@$aps) {
        my $mid = $mid_of_mac{ lc($ap->{mac} // '') };
        my $n   = defined $mid ? $name_of_mid{$mid} : undef;
        $names{$n} = 1 if defined $n && length $n;
    }
    return sort keys %names;
}

# Resolve an AP/gateway name to its IP via net-lookup (the daemon's alias-aware
# resolver â€” the dnsmasq tag is the device's self-name, which plain DNS misses).
# Cached; '' when it can't be resolved (just shows the bare name then).
my %ip_cache;
sub ap_ip {
    my ($host) = @_;
    return $ip_cache{$host} if exists $ip_cache{$host};
    my $bin = (-x "$FindBin::Bin/net-lookup") ? "$FindBin::Bin/net-lookup" : 'net-lookup';
    my @ll  = defined $listen ? ('--listen', $listen) : ();
    my $ip  = '';
    if (open my $fh, '-|', $bin, '--family', 'v4', @ll, "=$host") {
        while (<$fh>) { if (/(\d+\.\d+\.\d+\.\d+)/) { $ip = $1; last } }
        close $fh;
    }
    return $ip_cache{$host} = $ip;
}

# A pool's range as bare host octets when it sits inside the CIDR's /24 (e.g.
# 90-109), since the CIDR already names the subnet. Falls back to full start-end
# if the range somehow spans the /24.
sub short_range {
    my ($cidr, $start, $end) = @_;
    my ($pfx) = $cidr =~ m{^(\d+\.\d+\.\d+)\.\d+/\d+$};
    if (defined $pfx && $start =~ /^\Q$pfx\E\.(\d+)$/) {
        my $s = $1;
        return "$s-$1" if $end =~ /^\Q$pfx\E\.(\d+)$/;
    }
    return "$start-$end";
}

# Is $ip inside $cidr? Used to attribute a shared pool to the device that
# actually lives in its subnet.
sub ip_in_subnet {
    my ($ip, $cidr) = @_;
    my ($net, $len) = $cidr =~ m{^(\d+\.\d+\.\d+\.\d+)/(\d+)$} or return 0;
    my $i = ip2int($ip)  // return 0;
    my $n = ip2int($net) // return 0;
    my $mask = $len == 0 ? 0 : (0xFFFFFFFF << (32 - $len)) & 0xFFFFFFFF;
    return ($i & $mask) == ($n & $mask) ? 1 : 0;
}

# ---- main -----------------------------------------------------------
my $need_cli = $auto || !$print_only;
my $cli;
if ($need_cli) {
    $cli = NetMgr::Client->new(listen => $listen);
    $cli->hello(source => "net-import-dnsmasq", pid => $$);
}

if ($auto) {
    my @found = enumerate_auto($cli);
    print STDERR "auto: ", scalar(@found), " AP/gateway host(s): @found\n";
    push @hosts, @found;
}
{ my %seen; @hosts = grep { !$seen{$_}++ } @hosts; }

# (source-label, range) pairs from every scanned source.
my @all;
push @all, map { ['local', $_] } scan_local() if $local;
for my $h (@hosts) {
    my @r = scan_remote($h);
    print STDERR "$h: ", scalar(@r), " dhcp-range\n";
    push @all, map { [$h, $_] } @r;
}

my ($found, $sent) = (0, 0);
my %found_by_host;                      # host -> { "cidr|start" => 1 } seen this run
my %by_range;                           # "cidr|start|end" -> [ [label,$r], ... ]
my @range_order;                        # first-seen order of unique ranges
for my $e (@all) {
    my ($label, $r) = @$e;
    # Record per host (used by the prune pass): a pool this host still serves
    # must never be pruned, even if another device reported it first.
    $found_by_host{$label}{ "$r->{cidr}|$r->{start}" } = 1;
    if ($verbose) {                     # report every source, incl. duplicates
        # Show the AP's IP next to its name (two devices reporting the same pool
        # â€” e.g. Nighthawk and NighthawkX6-2 â€” are otherwise indistinguishable),
        # and the range as bare host octets since the CIDR already gives the net.
        my $who = $label eq 'local' ? '(local)'
                : $label . (ap_ip($label) ? ' (' . ap_ip($label) . ')' : '');
        my $loc = defined $r->{file} ? "$r->{file}:" . ($r->{line} // '?') : '';
        printf STDERR "  %-34s %-26s -> %-18s %s\n",
            $who, $loc, $r->{cidr}, short_range($r->{cidr}, $r->{start}, $r->{end});
    }
    my $key = "$r->{cidr}|$r->{start}|$r->{end}";
    push @range_order, $key unless $by_range{$key};
    push @{ $by_range{$key} }, $e;
}

# One pool per unique range. When several devices report the same range,
# attribute it to the one whose own IP sits in the pool's subnet â€” the actual
# server â€” rather than whichever was scanned first. e.g. a 192.168.223.x pool
# reported by both Nighthawk (192.168.15.151) and NighthawkX6-2 (192.168.223.79)
# belongs to NighthawkX6-2.
for my $key (@range_order) {
    my @srcs = @{ $by_range{$key} };
    my ($owner) = grep {
        my ($l, $rr) = @$_;
        my $ip = $l eq 'local' ? undef : ap_ip($l);
        $ip && ip_in_subnet($ip, $rr->{cidr});
    } @srcs;
    $owner //= $srcs[0];
    my ($label, $r) = @$owner;
    $found++;
    my %kv = (kind => 'dhcp_range', subnet_cidr => $r->{cidr},
              start_ip => $r->{start}, end_ip => $r->{end},
              notes => "dnsmasq:$label");
    if ($print_only) {
        print "OBSERVE ", format_kv(%kv), "\n";
    } else {
        my $resp = $cli->observe(%kv);
        if ($resp && $resp =~ /^ERR/) {
            warn "range rejected ($label $r->{cidr} $r->{start}-$r->{end}): $resp\n";
        } else { $sent++ }
    }
}

# Reconcile: drop a server's previously-imported pools that it no longer serves
# (a removed pool, or one whose start/subnet changed â€” which otherwise upserts a
# new row and leaves the old one behind). Scoped per host and SAFE: we only prune
# a host that reported at least one pool this run (so a host that returns nothing
# â€” e.g. an unreachable AP or a transient ssh failure â€” is never touched, since
# it has no %found_by_host entry). Deleting requires auth, same as the upserts.
my $pruned = 0;
if (!$no_prune && $cli) {
    my $existing = eval { $cli->snapshot(60, 'dhcp_ranges') } || [];
    for my $row (@$existing) {
        my $notes = $row->{notes} // '';
        next unless $notes =~ /^dnsmasq:(.+)$/;
        my $owner = $1;
        next unless $found_by_host{$owner};                 # host not scanned/empty -> leave alone
        my $k = "$row->{subnet_cidr}|$row->{start_ip}";
        next if $found_by_host{$owner}{$k};                 # still served -> keep
        my %dkv = (kind => 'dhcp_range_delete',
                   subnet_cidr => $row->{subnet_cidr}, start_ip => $row->{start_ip});
        if ($print_only) {
            print "OBSERVE ", format_kv(%dkv), "\n";
            $pruned++;
        } else {
            my $resp = $cli->observe(%dkv);
            if ($resp && $resp =~ /^ERR/) {
                warn "prune rejected ($owner $row->{subnet_cidr} $row->{start_ip}): $resp\n";
            } else {
                $pruned++;
                printf STDERR "  pruned stale  %-12s %s %s-%s\n",
                    $owner, $row->{subnet_cidr}, $row->{start_ip}, ($row->{end_ip} // '?')
                    if $verbose;
            }
        }
    }
}

$cli->bye if $cli;
print STDERR "found=$found"
           . ($print_only ? " (print only)" : " imported=$sent")
           . ($no_prune ? "" : " pruned=$pruned") . "\n";

sub usage {
    my ($msg) = @_;
    print STDERR "net-import-dnsmasq: $msg\n\n" if $msg;
    print STDERR <<'USAGE';
usage:
  net-import-dnsmasq HOST ...          scan each host over net-ssh
  net-import-dnsmasq --auto            scan all known APs + gateways
  net-import-dnsmasq --local           scan this host's dnsmasq config
  options: --print  --verbose  --files 'P1 P2'  --listen H:P  --ssh-timeout N
           --ssh-cmd 'ssh -o BatchMode=yes'   (default: net-ssh)  -h/--help
  --verbose, -v   report each range's source file:line (and host, for remotes)
  --no-prune      keep a server's old pools even when it no longer serves them
                  (default: prune stale pools for every host that was scanned and
                   reported at least one pool â€” a host that reports none is never
                   touched, so a transient ssh failure can't wipe its data)
USAGE
    exit($msg ? 2 : 0);
}
