#!/usr/bin/perl
# net-discover — nmap/fping/ssh-fingerprint active-scan producer. Pushes
# observations to net-mgr; spawned by the daemon for TRIGGER discover.
#
# Usage:
#   net-discover --discover [--network CIDR]...  Full nmap sweep
#   net-discover --presence                      fping known IPs (mark dead ones GONE)
#   net-discover --fingerprint                   SSH-probe ssh-open hosts
#                                                 (DD-WRT/OpenWRT/Linux),
#                                                 cached so reruns are cheap.
#                                                 Findings printed; not pushed
#                                                 as observations (yet).
#   net-discover --print                         dump observations to stdout
#   net-discover --listen HOST:PORT              override manager
#
# With no mode flag, defaults to --discover.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);
use NetMgr::Producer::Scan;
use NetMgr::Producer::Fingerprint;
use NetMgr::Client;
use NetMgr::Protocol qw(format_kv);
use Sys::Hostname qw(hostname);

my $MY_HOST = (split /\./, hostname())[0];

my $print_only = 0;
my $listen;
my $do_discover;
my $do_presence;
my $do_fingerprint;
my @networks;
my $ports;
my $host_timeout = 20;
my $ssh_user    = 'root';
my $ssh_timeout = 3;
my $cache_path  = '/var/cache/net-mgr/fingerprints.tsv';
my $cache_ttl_days = 7;
my $force_fingerprint;

GetOptions(
    'print'          => \$print_only,
    'listen=s'       => \$listen,
    'discover'       => \$do_discover,
    'presence'       => \$do_presence,
    'fingerprint'    => \$do_fingerprint,
    'network=s@'     => \@networks,
    'ports=s'        => \$ports,
    'host-timeout=i' => \$host_timeout,
    'ssh-user=s'     => \$ssh_user,
    'ssh-timeout=i'  => \$ssh_timeout,
    'cache=s'        => \$cache_path,
    'ttl=i'          => \$cache_ttl_days,
    'force'          => \$force_fingerprint,
) or die "bad options\n";

# Default mode = discover
$do_discover = 1 unless $do_discover || $do_presence || $do_fingerprint;

my $cli;
unless ($print_only) {
    $cli = NetMgr::Client->new(listen => $listen);
    $cli->hello(source => "net-discover", pid => $$);
}

sub emit {
    my (%kv) = @_;
    # Producer::Scan uses kind_ to carry the interface kind separately
    # from the OBSERVE-dispatch kind. Promote it to iface_kind here.
    if (defined(my $ik = delete $kv{kind_})) {
        $kv{iface_kind} = $ik;
    }
    # Tag with our identity so downstream knows where the observation
    # came from (and how authoritative it is — nmap is bottom of pile).
    $kv{source} //= "$MY_HOST:nmap" if $kv{kind} eq 'host';
    %kv = map { $_ => $kv{$_} } grep { defined $kv{$_} } keys %kv;
    if ($print_only) {
        print "OBSERVE ", format_kv(%kv), "\n";
    } else {
        my $r = $cli->observe(%kv);
        warn "observe rejected: $r\n" if $r && $r =~ /^ERR/;
    }
}

if ($do_discover) {
    my @nets;
    if (@networks) {
        # Each --network CIDR; pick interface heuristically (none → blank).
        for my $cidr (@networks) {
            push @nets, { iface => 'auto', cidr => $cidr };
        }
    } else {
        @nets = NetMgr::Producer::Scan::detect_networks();
    }

    for my $net (@nets) {
        warn "discovering $net->{cidr} via $net->{iface}\n";
        my ($obs, $err) = NetMgr::Producer::Scan::discover_network(
            iface => $net->{iface},
            cidr  => $net->{cidr},
            (defined $ports ? (ports => $ports) : ()),
            host_timeout => $host_timeout,
        );
        warn "discover $net->{cidr}: $err\n" if $err;
        emit(%$_) for @$obs;
    }
}

if ($do_fingerprint) {
    # Walk the DB for IPs to probe. Skip those whose port-22 we never saw
    # open — pointless to SSH-probe — and those still fresh in the cache.
    die "--fingerprint requires --listen / daemon (no --print mode)\n"
        if $print_only;

    my $cache = NetMgr::Producer::Fingerprint::load_cache($cache_path);
    my $ttl_seconds = $cache_ttl_days * 86400;

    # Pull (mac, ip) for hosts with TCP/22 open
    my $rows = $cli->snapshot(99, 'ports', where => "port = 22 AND proto = 'tcp'");
    my %mac_seen = map { $_->{mac} => 1 } @$rows;

    my $addrs = $cli->snapshot(98, 'addresses', where => "family = 'v4'");
    my @targets;
    for my $a (@$addrs) {
        next unless $mac_seen{ $a->{mac} };
        push @targets, { ip => $a->{addr}, mac => $a->{mac} };
    }

    # Dedup by ip
    my %by_ip;
    $by_ip{ $_->{ip} } //= $_ for @targets;
    @targets = values %by_ip;

    warn scalar(@targets), " hosts have TCP/22 open\n";

    my $printed_header = 0;
    my $hits = 0; my $cached = 0;
    for my $t (sort { _ip_key($a->{ip}) cmp _ip_key($b->{ip}) } @targets) {
        my $entry = $cache->{ $t->{ip} };
        if (!$force_fingerprint
            && NetMgr::Producer::Fingerprint::is_fresh($entry, $ttl_seconds))
        {
            $cached++;
            _print_fingerprint($entry, \$printed_header, '(cached)');
            next;
        }
        my $r = NetMgr::Producer::Fingerprint::probe_host(
            ip          => $t->{ip},
            ssh_user    => $ssh_user,
            ssh_timeout => $ssh_timeout,
        );
        $r->{last_probed} = time();
        $cache->{ $t->{ip} } = $r;
        $hits++;
        _print_fingerprint($r, \$printed_header, '');
    }
    NetMgr::Producer::Fingerprint::save_cache($cache_path, $cache);
    warn "fingerprint: $hits probed, $cached cached, total ", scalar(@targets), "\n";
}

sub _ip_key {
    my $ip = shift;
    return '999.999.999.999' if $ip !~ /^\d+\.\d+\.\d+\.\d+$/;
    return sprintf "%03d.%03d.%03d.%03d", split /\./, $ip;
}

sub _print_fingerprint {
    my ($r, $hdr_ref, $tag) = @_;
    unless ($$hdr_ref) {
        printf "%-15s  %-13s  %-22s  %s\n",
            'IP', 'KIND', 'NAME / NOTES', 'BOARD/UNAME';
        printf "%-15s  %-13s  %-22s  %s\n",
            '-' x 15, '-' x 13, '-' x 22, '-' x 30;
        $$hdr_ref = 1;
    }
    my $detail = $r->{board} || $r->{uname} || $r->{notes} || '';
    my $name   = $r->{name}  || ($r->{notes} ? "($r->{notes})" : '');
    printf "%-15s  %-13s  %-22s  %s%s\n",
        $r->{ip}, $r->{kind}, $name, $detail,
        ($tag ? "  $tag" : '');
}

if ($do_presence) {
    # Snapshot known v4 addresses, fping them with RTT, push observations.
    # Alive hosts emit kind=ping (manager flips interface online=1, fires
    # interface_online on transition). A mac is declared GONE only when
    # ALL of its addresses are dead — otherwise a multi-addr host with
    # one silent IP would oscillate online/offline every cycle as the
    # alive ping and the dead-IP GONE undid each other.
    die "--presence requires --listen / daemon (no --print mode)\n" if $print_only;
    my $rows = $cli->snapshot(99, 'addresses', where => "family = 'v4'");
    my %ips;          # ip → [mac, ...]
    my %addrs_by_mac; # mac → { addr => 1 }
    for my $r (@$rows) {
        push @{ $ips{$r->{addr}} }, $r->{mac};
        $addrs_by_mac{$r->{mac}}{$r->{addr}} = 1;
    }
    my @ips = sort keys %ips;
    warn "presence-checking " . scalar(@ips) . " ips\n";
    my $res = NetMgr::Producer::Scan::fping_rtt(@ips);

    my %alive_addrs_by_mac;   # mac → { addr => 1 } observed alive this cycle
    for my $ip (sort keys %{ $res->{alive} }) {
        my $rtt = $res->{alive}{$ip};
        for my $mac (@{ $ips{$ip} }) {
            $cli->observe(kind => 'ping', mac => $mac, addr => $ip,
                          rtt_ms => $rtt);
            $alive_addrs_by_mac{$mac}{$ip} = 1;
        }
    }
    # Send GONE only for macs whose every known v4 address came back dead.
    my %dead_set = map { $_ => 1 } @{ $res->{dead} };
    for my $mac (sort keys %addrs_by_mac) {
        my @addrs = keys %{ $addrs_by_mac{$mac} };
        next unless @addrs == grep { $dead_set{$_} } @addrs;
        $cli->send_recv("GONE mac=$mac");
    }
}

$cli->bye if $cli;
