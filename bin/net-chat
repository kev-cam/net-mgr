#!/usr/bin/perl
# net-chat — talk in named chat sessions hosted by the net-mgr daemon.
#
# The daemon records every message; software identifies itself with an
# SSH key (the AUTH handshake) and humans use the web GUI. This is the
# command-line client agents use to open/join sessions, post, and watch.
#
# Usage:
#   net-chat ls [--all]                     List open chat sessions
#   net-chat open <name> [--mode M] [--topic T]
#                                           Create a session (M = open|
#                                           list|request; default open)
#   net-chat set  <name> [--mode M] [--topic T]   Edit a session (owner)
#   net-chat close <name>                   Close a session (owner)
#   net-chat join <name>                    Join (request-mode → asks)
#   net-chat leave <name>                   Drop out of the live roster
#   net-chat who  <name>                    Show the live roster
#   net-chat post <name> [text ...]         Post a message ('-'/empty =
#                                           read body from stdin)
#   net-chat read <name> [-n N] [--since D] Print recent history
#   net-chat follow <name>                  Join + stream live (Ctrl-C)
#   net-chat requests <name>                List pending join requests
#   net-chat members  <name>                List the membership list
#   net-chat approve|reject <name> <who>    Act on a join request (owner)
#   net-chat allow|deny     <name> <who>    Edit the allow-list   (owner)
#
# Connection / identity:
#   --listen HOST:PORT    Manager address (overrides --server and config).
#   --server NAME|HOST:PORT
#                         A server named in [servers] (~/.config/net-mgr/config)
#                         or a literal host[:port] — an alias for --listen. With
#                         neither flag, the configured default server is used,
#                         else loopback. The --gui shows a server menu (config
#                         servers + the daemon's known peers, shown by name with
#                         SSH known_hosts entries first) and a "set default"
#                         button that saves the active server to the config.
#   --as NAME             Display name for posts on a loopback daemon
#                         (default $NET_CHAT_AS or $USER). Ignored once
#                         AUTH'd — the server stamps the verified key.
#   --auth                Force the SSH-key handshake even on loopback.
#   --no-auth             Never AUTH (loopback-only / read-only use).
#   --key-id ID --key-file PATH   Override AUTH key (see NetMgr::Client).
#
# A non-loopback daemon is AUTH'd automatically; --key-id/--key-file
# pick the key, otherwise the NetMgr::Client defaults are used.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling pass_through);
use NetMgr::Client;
use NetMgr::Config;
use NetMgr::Protocol qw(parse_line);

# Writing to a daemon that has gone away must not kill us with SIGPIPE — the
# one-shot CLI rarely hit this, but the long-lived --gui would die (e.g. on
# Refresh) the moment the connection dropped. Treat writes to a dead socket
# as ordinary errors instead.
$SIG{PIPE} = 'IGNORE';

# --describe — for tooling that enumerates the net-* commands.
if (@ARGV && $ARGV[0] eq '--describe') {
    print "name: net-chat\n";
    print "description: talk in named chat sessions hosted by net-mgr\n";
    exit 0;
}

my $listen;
my $server;
my $as;
my $force_auth;
my $no_auth;
my $key_id;
my $key_file;
my $mode;
my $topic;
my $limit;
my $since;
my $show_all;
my $gui;
my $tty;
my $askpass;

# Termios restore callback set by cmd_tty when it enters raw mode. Lifted to
# a package var (our + top-level END) so the END block doesn't capture a
# lexical from inside cmd_tty (Perl warns "will not stay shared" otherwise).
our $TTY_TERM_RESTORER;
END { $TTY_TERM_RESTORER->() if $TTY_TERM_RESTORER }
GetOptions(
    'listen=s'   => \$listen,
    'server=s'   => \$server,
    'as=s'       => \$as,
    'auth'       => \$force_auth,
    'no-auth'    => \$no_auth,
    'key-id=s'   => \$key_id,
    'key-file=s' => \$key_file,
    'mode=s'     => \$mode,
    'topic=s'    => \$topic,
    'n=i'        => \$limit,
    'since=s'    => \$since,
    'all'        => \$show_all,
    'gui'        => \$gui,
    'tty'        => \$tty,
    'bit-chat'   => \my $bitchat_mode,
    'test'       => \my $test_mode,
    'test-interval=i' => \my $test_interval,
    'askpass'    => \$askpass,
    'version|V'  => \my $show_version,
) or die "bad options\n";

# --version / -V: print the installed build stamp and exit. The
# placeholder below (assembled at runtime so sed doesn't clobber the
# sentinel check itself) is substituted at `make install` time with
# the contents of .version — so a stale binary on gateway3 will print
# an older stamp than a freshly-installed one on bigsony.
if ($show_version) {
    my $v = '@NET_MGR_VERSION@';
    my $sentinel = '@' . 'NET_MGR_VERSION' . '@';
    $v = '(uninstalled — run make install to stamp the version)'
        if $v eq $sentinel;
    print "net-chat $v\n";
    exit 0;
}

# --bit-chat: shortcut for BitChat bridge access. Auto-selects the local
# daemon's loopback listener (that's where the bitchat-bridge session
# lives — chat_messages there aren't cluster-replicated, so it's ONLY
# reachable via loopback on a bridge site) and defaults the initial
# session to 'bitchat-bridge'. Compatible with --gui and --tty. When
# combined with --tty it drops you straight into the read-and-post loop
# on that session; --gui opens with the session pre-selected.
my $bitchat_default_session;
if ($bitchat_mode) {
    $listen                  //= '127.0.0.1:7531';
    $bitchat_default_session   = 'bitchat-bridge';
    # Loopback needs no auth server-side; belt-and-braces skip the
    # client-side auth attempt too so we don't pop the "which key" dialog.
    $no_auth                 //= 1 unless $force_auth;
}

# Persisted "Sign in always" indicator — declared here so it's visible
# in cmd_gui's anon-startup branch. Set inside the config-load block
# below when both key_file and key_id come from the USER config.
our $auto_auth_from_config = 0;

# Persisted-default fallback for the "Sign in always" choice.
#   * CLI args win.
#   * User config ~/.config/net-mgr/config [net-chat] overrides system.
#   * If BOTH key_file and key_id came from the USER config (= they
#     clicked "Sign in always" at some point), also set $force_auth so
#     cmd_gui doesn't fall into the default-anonymous branch and skip
#     using those keys entirely. Without this the GUI reads the config
#     but starts anonymous anyway, which was the "not sticky" symptom.
{
    my $cli_kf = $key_file;
    my $cli_ki = $key_id;
    # System config first (may seed defaults; usually empty).
    my $sys_path = $ENV{NET_MGR_CONF} // '/etc/net-mgr/config';
    if (defined $sys_path && -e $sys_path && -r $sys_path) {
        my $sc = eval { NetMgr::Config->load($sys_path) } || {};
        my $s = $sc->{'net-chat'} || {};
        $key_file = $s->{key_file}
            if defined $s->{key_file} && length $s->{key_file};
        $key_id   = $s->{key_id}
            if defined $s->{key_id}   && length $s->{key_id};
    }
    # User config overrides. Track whether it carried BOTH keys.
    my $user_wants_auth = 0;
    my $up = NetMgr::Config->user_path;
    if (defined $up && -e $up && -r $up) {
        my $uc = eval { NetMgr::Config->load($up) } || {};
        my $s  = $uc->{'net-chat'} || {};
        my $ukf = (defined $s->{key_file} && length $s->{key_file})
                ? $s->{key_file} : undef;
        my $uki = (defined $s->{key_id}   && length $s->{key_id})
                ? $s->{key_id}   : undef;
        $key_file = $ukf if defined $ukf;
        $key_id   = $uki if defined $uki;
        $user_wants_auth = 1 if defined $ukf && defined $uki;
    }
    # CLI wins over both.
    $key_file = $cli_kf if defined $cli_kf;
    $key_id   = $cli_ki if defined $cli_ki;
    # Persisted "Sign in always" → skip the default-anonymous branch in
    # cmd_gui so the saved keys are actually USED. We use a SEPARATE flag
    # instead of $force_auth because $force_auth is honoured even for
    # loopback connections (that's what CLI --auth means: "auth me even
    # on loopback"), and treating a persisted preference the same way
    # would break loopback: the chat-key fallthrough would require a
    # chat-authorized key, which won't exist for a local admin who's
    # just talking to their own daemon.
    $auto_auth_from_config = 1
        if $user_wants_auth && !$no_auth && !$force_auth;
}

# --askpass: invoked by ssh-keygen via SSH_ASKPASS (through the net-chat-askpass
# shim) when the user's SSH key is passphrase-protected. The prompt arrives in
# @ARGV; we pop a small Tk dialog and print the typed passphrase to stdout.
# Exits 0 on OK, 1 on cancel. Done before HELLO/connect — no daemon needed.
if ($askpass) { cmd_askpass(@ARGV); exit 0 }

my $cmd = shift @ARGV;

# Server resolution: --listen / --server pin an explicit target; bare
# invocation flows into NetMgr::Client's discover ladder ($NET_MGR_LISTEN,
# [servers] default, loopback, ~/.cache/net-mgr/last-daemon, other
# [servers] entries, LAN /24 probe). Works out of the box with no config.
if (!defined $listen && defined $server) {
    $listen = NetMgr::Config->resolve_server($server)
        or die "net-chat: unknown server '$server' (configure it in "
             . (NetMgr::Config->user_path // '~/.config/net-mgr/config')
             . " [servers])\n";
}
$as //= $ENV{NET_CHAT_AS} // $ENV{USER} // 'local';

# --test: resident tester mode. Combined with --bit-chat this is the
# gateway2/gateway3 BLE-mesh smoke tester — post a heartbeat message
# every N seconds and log every inbound line to stderr so `journalctl`
# (or a foregrounded terminal) shows the round-trip. No Tk required,
# no interactive input; just posts + prints. Runs until Ctrl-C.
if ($test_mode) {
    cmd_test($cmd // $bitchat_default_session);
    exit 0;
}

# --gui launches the Tk front-end; the leftover arg (if any) is the session
# to open initially. No subcommand is required in this mode.
if ($gui) { cmd_gui($cmd // $bitchat_default_session); exit 0; }
if ($tty) { cmd_tty($cmd // $bitchat_default_session); exit 0; }
usage() unless defined $cmd;

# ---- dispatch --------------------------------------------------------

my %DISPATCH = (
    ls       => \&cmd_ls,
    open     => \&cmd_open,
    set      => \&cmd_set,
    close    => \&cmd_close,
    join     => \&cmd_join,
    leave    => \&cmd_leave,
    who      => \&cmd_who,
    post     => \&cmd_post,
    read     => \&cmd_read,
    follow   => \&cmd_follow,
    tail     => \&cmd_follow,    # alias
    requests => \&cmd_requests,
    members  => \&cmd_members,
    delete   => \&cmd_delete,
    upload   => \&cmd_upload,
    download => \&cmd_download,
    files    => \&cmd_files,
    rm       => \&cmd_rm,
    keys     => \&cmd_keys,
    approve  => sub { cmd_member('approve', @_) },
    reject   => sub { cmd_member('reject',  @_) },
    allow    => sub { cmd_member('allow',   @_) },
    promote  => sub { cmd_member('promote', @_) },
    demote   => sub { cmd_member('demote',  @_) },
    forget   => sub { cmd_member('delete',  @_) },
    'delete-member' => sub { cmd_member('delete', @_) },
    deny     => sub { cmd_member('deny',    @_) },
    gui      => \&cmd_gui,
);

my $handler = $DISPATCH{$cmd} or usage("unknown command '$cmd'");
$handler->();
exit 0;

# ---- connection ------------------------------------------------------

sub connect_client {
    my %opt = @_;          # want_auth => bool override
    # In see-and-request mode (no-auth + as=NAME), attach the user's public key
    # to chat_join so an approval persists the key on the chat — the next
    # connect AUTHs normally (chat-key fallthrough) and auto-admits, no second
    # ask. We try .pub next to the configured/default key_file and skip
    # silently if it isn't readable (request still works, just without durable
    # key persistence).
    my $as_pubkey;
    if ($no_auth && defined $as && length $as) {
        my $kf = $key_file // NetMgr::Client::_default_key_file();
        if (defined $kf && length $kf) {
            my $pub = "$kf.pub";
            if (-r $pub) {
                if (open my $fh, '<', $pub) {
                    local $/;
                    $as_pubkey = <$fh>;
                    close $fh;
                }
            }
        }
    }
    my $cli = eval {
        my %common = (
            timeout => 10,
            as      => $as,
            (defined $as_pubkey ? (as_pubkey => $as_pubkey) : ()),
        );
        defined $listen
            ? NetMgr::Client->new(listen => $listen, %common)
            : NetMgr::Client->new(discover => 1,
                                  consumer => "net-chat.$$", %common);
    } or die "net-chat: cannot reach daemon"
           . (defined $listen ? " at $listen" : '') . ": $@";

    # Remember the address discover picked so the loopback AUTH-skip check
    # below sees the actual winner, not the initial (undef) $listen.
    $listen //= $cli->{listen};
    my ($host) = NetMgr::Client::split_hostport($listen); $host //= '';
    my $is_loopback = $host =~ /^(?:127\.\d+\.\d+\.\d+|::1|localhost)$/;

    my $do_auth = $force_auth || (!$is_loopback && !$no_auth);
    $do_auth = $opt{want_auth} if exists $opt{want_auth};
    $do_auth = 0 if $no_auth;

    if ($do_auth) {
        eval {
            $cli->auth(
                (defined $key_id   ? (key_id   => $key_id)   : ()),
                (defined $key_file ? (key_file => $key_file) : ()),
            );
        };
        die "net-chat: AUTH failed: $@" if $@;
    }
    return $cli;
}

# ---- commands --------------------------------------------------------

# Display label for a session's status. A 'closed' session is still listed and
# restartable (the messages/archive remain), so show it as "Dormant" rather than
# "closed" — the wire/DB value stays 'closed'.
sub status_label {
    my $s = shift // '?';
    return $s eq 'closed' ? 'Dormant' : $s;
}

sub cmd_ls {
    my $cli = connect_client(want_auth => 0);
    my $where = $show_all ? undef : "status = 'open'";
    my $rows = $cli->snapshot(1, 'chat_sessions', ($where ? (where => $where) : ()));
    @$rows = sort { ($b->{last_activity}//'') cmp ($a->{last_activity}//'') } @$rows;
    unless (@$rows) { print "no chat sessions\n"; return }
    printf "%-20s %-8s %-8s %-20s %s\n",
        'NAME', 'MODE', 'STATUS', 'OWNER', 'TOPIC';
    for my $s (@$rows) {
        printf "%-20s %-8s %-8s %-20s %s\n",
            $s->{name}, $s->{access_mode} // '?', status_label($s->{status}),
            trunc($s->{created_by} // '', 20), $s->{topic} // '';
    }
}

sub cmd_open {
    my $name = need_name(shift @ARGV);
    die "net-chat: --mode must be open|list|request\n"
        if defined $mode && $mode !~ /^(open|list|request)$/;
    my $cli = connect_client();
    my $r = eval { $cli->chat_open(name => $name,
        (defined $mode  ? (mode  => $mode)  : ()),
        (defined $topic ? (topic => $topic) : ())) };
    die "net-chat: $@" if $@;
    print +($r->{reopened} ? "reopened" : "opened"),
          " '$name' (mode=", $r->{mode} // $mode // 'open', ")\n";
}

sub cmd_set {
    my $name = need_name(shift @ARGV);
    die "net-chat: --mode must be open|list|request\n"
        if defined $mode && $mode !~ /^(open|list|request)$/;
    my $cli = connect_client();
    eval { $cli->chat_set(name => $name,
        (defined $mode  ? (mode  => $mode)  : ()),
        (defined $topic ? (topic => $topic) : ())) };
    die "net-chat: $@" if $@;
    print "updated '$name'\n";
}

sub cmd_close {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client();
    my $r = eval { $cli->chat_close(name => $name) };
    die "net-chat: $@" if $@;
    my $arch = (ref $r eq 'HASH') ? $r->{archive} : undef;
    if (defined $arch) {
        print "closed '$name' — messages archived to $arch\n";
        print "  resurrect with: net-chat open $name\n";
    } else {
        print "closed '$name'\n";
    }
}

sub cmd_join {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client();
    my $r = eval { $cli->chat_join(session => $name) };
    die "net-chat: $@" if $@;
    my $state = $r->{state} // 'member';
    if ($state eq 'requested') {
        print "join request sent for '$name' — waiting for an owner to approve\n";
    } else {
        print "joined '$name'\n";
    }
}

sub cmd_leave {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client(want_auth => 0);
    eval { $cli->chat_leave(session => $name) };
    die "net-chat: $@" if $@;
    print "left '$name'\n";
}

sub cmd_who {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client(want_auth => 0);
    my $rows = $cli->snapshot(1, 'chat_presence',
        where => "session = '$name'");
    my %seen;
    my @who = grep { !$seen{$_}++ } map { $_->{principal} } @$rows;
    unless (@who) { print "nobody in '$name'\n"; return }
    print "in '$name': ", join(', ', @who), "\n";
}

sub cmd_post {
    my $name = need_name(shift @ARGV);
    my $body = join ' ', @ARGV;
    if (!length $body || $body eq '-') {
        local $/; $body = <STDIN>;
        $body = '' unless defined $body;
    }
    $body =~ s/\s+\z//;
    die "net-chat: empty message\n" unless length $body;
    my $cli = connect_client();
    eval { $cli->chat_post(session => $name, body => $body, as => $as) };
    die "net-chat: $@" if $@;
}

sub cmd_read {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client(want_auth => 0);
    my $where = "session = '$name'";
    if (defined $since) {
        my $secs = parse_duration($since);
        $where .= " AND ts > ago($secs)";
    }
    my $rows = $cli->snapshot(1, 'chat_messages', where => $where);
    @$rows = sort { ($a->{id}//0) <=> ($b->{id}//0) } @$rows;
    if (defined $limit && @$rows > $limit) {
        @$rows = @$rows[ -$limit .. -1 ];
    }
    print_msg($_) for @$rows;
}

sub cmd_follow {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client();
    # Join first so we appear in the roster, then stream history+live.
    eval { $cli->chat_join(session => $name) };
    die "net-chat: $@" if $@;
    $SIG{INT} = $SIG{TERM} = sub {
        eval { $cli->chat_leave(session => $name) };
        eval { $cli->bye };
        exit 0;
    };
    $cli->send_line("SUBSCRIBE sub=1 mode=snapshot+stream FROM chat_messages"
                  . " WHERE session = '$name'");
    $| = 1;
    my $live = 0;
    while (defined(my $line = $cli->recv_line(60))) {
        my $c = parse_line($line) or next;
        if ($c->{verb} eq 'ROW' && ($c->{kv}{table} // '') eq 'chat_messages') {
            print_msg($c->{kv});
        } elsif ($c->{verb} eq 'EOS') {
            print "-- live (Ctrl-C to leave) --\n" unless $live++;
        } elsif ($c->{verb} eq 'ERR') {
            die "net-chat: $c->{msg}\n";
        }
    }
}

sub cmd_requests {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client(want_auth => 0);
    my $rows = $cli->snapshot(1, 'chat_members',
        where => "session = '$name' AND state = 'requested'");
    unless (@$rows) { print "no pending requests for '$name'\n"; return }
    print "pending requests for '$name':\n";
    for my $r (@$rows) {
        my $from = $r->{requested_from};
        printf "  %-40s%s\n", $r->{principal},
            (defined $from && length $from ? "   from $from" : '');
    }
}

# net-chat --tty [session]: dumb-terminal chat client. Plain stdin + stdout,
# no curses, no ANSI, no termios — works under script(1), on serial consoles,
# --test: resident tester. Post a heartbeat every N seconds AND print
# every inbound message on the SUBSCRIBE stream to stderr with a
# timestamp. Designed for `net-chat --test --bit-chat` on gateway2/3
# so a BLE-only smoke test can run under systemd/journal without a
# person driving a keyboard. Interval defaults to 60s; override with
# --test-interval SECS. Heartbeat body embeds hostname + ISO timestamp
# so operators grepping journals across bridges can correlate hops.
sub cmd_test {
    my ($name) = @_;
    require IO::Select;
    require Sys::Hostname;
    unless (defined $name && length $name) {
        die "net-chat --test: session required "
          . "(add --bit-chat or a session name as argv)\n";
    }
    my $interval = $test_interval && $test_interval > 0 ? $test_interval : 60;
    my $host     = Sys::Hostname::hostname();
    warn "[net-chat --test] session=$name interval=${interval}s host=$host\n";

    my $stream = connect_client(want_auth => 0);
    my $ctrl   = connect_client(want_auth => 0);
    $stream->send_line("SUBSCRIBE sub=1 mode=stream"
                     . " FROM chat_messages WHERE session = '$name'");

    my $sel = IO::Select->new($stream->{sock});
    my $last_post = 0;
    my $counter   = 0;
    while (1) {
        # Heartbeat post. Interval-timed on wall clock, so a slow SUBSCRIBE
        # doesn't drift the cadence.
        if (time() - $last_post >= $interval) {
            $counter++;
            my $iso = POSIX::strftime('%Y-%m-%dT%H:%M:%SZ', gmtime());
            my $body = "[test $host #$counter $iso] ping";
            eval { $ctrl->chat_post(
                session => $name, body => $body, as => 'bitchat-tester') };
            if ($@) {
                my $e = $@; chomp $e;
                warn "[net-chat --test] post failed: $e\n";
            } else {
                warn "[net-chat --test] posted #$counter\n";
            }
            $last_post = time();
        }

        # Wait up to 1s for an inbound row. Sub-second polling keeps
        # the heartbeat deadline responsive without a heavy loop.
        my @ready = $sel->can_read(1);
        next unless @ready;
        while (defined(my $line = $stream->recv_line(0))) {
            my $c = NetMgr::Protocol::parse_line($line) or next;
            next unless ($c->{verb} // '') eq 'ROW';
            next unless ($c->{kv}{table} // '') eq 'chat_messages';
            my $ts     = $c->{kv}{ts}     // '?';
            my $sender = $c->{kv}{sender} // '?';
            my $body   = $c->{kv}{body}   // '';
            # Truncate long bodies so a huge inbound file transfer doesn't
            # blow up the journal.
            $body = substr($body, 0, 400) . '...' if length($body) > 400;
            warn "[net-chat --test] recv $ts $sender: $body\n";
        }
    }
}

# in a container without X. IO::Select multiplexes stdin (user typing) with
# the SUBSCRIBE stream (incoming messages). Like --gui, we default to
# anonymous browse and lazily AUTH on first post / join.
sub cmd_tty {
    my ($name) = @_;
    require IO::Select;
    require POSIX;

    # Session picker (only when none passed) — mirrors --gui's
    # anonymous-browse default. Pick by number or by literal name.
    unless (defined $name && length $name) {
        my $cli = connect_client(want_auth => 0);
        my $rows = $cli->snapshot(1, 'chat_sessions',
            where => "status = 'open'") || [];
        eval { $cli->bye };
        unless (@$rows) {
            die "net-chat: no open sessions on $listen "
              . "(try 'net-chat ls --all' or 'net-chat --tty NAME')\n";
        }
        @$rows = sort { lc($a->{name}) cmp lc($b->{name}) } @$rows;
        print "Open chat sessions on $listen:\n";
        my $i = 0;
        for my $s (@$rows) {
            printf "  %2d. %-20s  %s\n", ++$i, $s->{name}, $s->{topic} // '';
        }
        local $| = 1;
        print "Pick a session (number or name, blank to quit): ";
        my $ans = <STDIN>;
        defined $ans or exit 0;
        $ans =~ s/^\s+|\s+$//g;
        exit 0 unless length $ans;
        $name = ($ans =~ /^\d+$/ && $ans >= 1 && $ans <= @$rows)
              ? $rows->[$ans - 1]{name} : $ans;
    }
    $name = need_name($name);

    # Two connections: $stream carries SUBSCRIBE (always anonymous —
    # snapshot+stream of an open session needs no auth); $ctrl is lazy and
    # AUTH-promotes on first chat_post / chat_join.
    my $stream = connect_client(want_auth => 0);
    my $ctrl;
    my $get_ctrl = sub {
        return $ctrl if $ctrl;
        $ctrl = eval { connect_client() };
        return $ctrl;
    };

    if (my $c = $get_ctrl->()) {
        my $r = eval { $c->chat_join(session => $name) };
        if ($@) {
            my $e = $@; $e =~ s/\s+\z//;
            print "-- join: $e (you can still watch) --\n";
        } elsif (($r->{state} // '') eq 'requested') {
            print "-- join request sent — waiting for an owner --\n";
        }
    }

    # === raw mode for ESC detection ===
    # We need single-byte stdin reads to catch ESC (0x1b). Save the
    # original termios so we can restore on ANY exit path — END block,
    # signal handlers, daemon hangup, die. STDIN may not be a tty (piped
    # input for testing): degrade gracefully to no-raw in that case.
    my $is_tty = -t STDIN;
    my ($orig_term, $orig_lflag, $orig_iflag);
    if ($is_tty) {
        $orig_term  = POSIX::Termios->new;
        $orig_term->getattr(fileno(STDIN));
        $orig_lflag = $orig_term->getlflag;
        $orig_iflag = $orig_term->getiflag;
        my $t = POSIX::Termios->new;
        $t->getattr(fileno(STDIN));
        $t->setlflag($orig_lflag & ~(POSIX::ICANON() | POSIX::ECHO()));
        $t->setiflag($orig_iflag & ~(POSIX::IXON()   | POSIX::ICRNL()));
        $t->setcc(POSIX::VMIN(),  1);
        $t->setcc(POSIX::VTIME(), 0);
        $t->setattr(fileno(STDIN), POSIX::TCSANOW());
    }
    # Restore termios on any exit path including unanticipated die. We use
    # a PACKAGE variable + a top-level END block (defined elsewhere) so
    # the END closure doesn't grab a `my` variable each call (Perl warns:
    # "will not stay shared"). Signal handlers below also call this
    # directly for immediate cleanup, so cursor + echo come back without
    # waiting for Perl's END phase.
    our $TTY_TERM_RESTORER;
    my $raw_restored = 0;
    my $restore_term = sub {
        return if $raw_restored;
        $raw_restored = 1;
        return unless $is_tty && $orig_term;
        $orig_term->setattr(fileno(STDIN), POSIX::TCSANOW());
    };
    $TTY_TERM_RESTORER = $restore_term;

    # === input state machine ===
    # mode='chat'  → keystrokes accumulate into $buf, Enter posts as msg
    # mode='cmd'   → keystrokes accumulate into $buf, Enter executes :cmd
    # ESC toggles. Backspace edits. Ctrl-C exits. Ctrl-D exits if buf empty.
    my $mode = 'chat';
    my $buf  = '';
    my $chat_prompt = "[$name]> ";
    my $cmd_prompt  = ':';
    my $prompt_for = sub { $mode eq 'cmd' ? $cmd_prompt : $chat_prompt };

    my $shutdown = sub {
        $restore_term->();
        eval { $ctrl->chat_leave(session => $name) } if $ctrl;
        eval { $ctrl->bye }   if $ctrl;
        eval { $stream->bye } if $stream;
        print "\n";
        exit 0;
    };
    $SIG{INT} = $SIG{TERM} = $SIG{HUP} = $shutdown;

    $stream->send_line("SUBSCRIBE sub=1 mode=snapshot+stream"
                     . " FROM chat_messages WHERE session = '$name'");

    my $sel = IO::Select->new($stream->{sock}, \*STDIN);
    $| = 1;
    my $live = 0;
    $stream->{buf} //= '';
    print $chat_prompt;

    # Reprint the current prompt + in-progress buffer after we interrupt
    # the terminal with an out-of-band line (incoming chat, command
    # output). \r moves to col 0, \e[K clears to EOL.
    my $redraw = sub {
        print "\r\e[K", $prompt_for->(), $buf;
    };
    # Emit text (with trailing newline) without disrupting the user's
    # in-progress input line. \r\e[K erases the prompt + buf, prints the
    # text, then we redraw so the cursor lands back after $buf.
    my $emit = sub {
        my ($s) = @_;
        chomp(my $clean = $s);
        print "\r\e[K", $clean, "\n";
        $redraw->();
    };

    # === ESC-mode command dispatch ===
    my $cmd_help = sub {
        $emit->(join "\n",
            "  ESC commands (press ESC to enter, ESC to cancel, Enter to run):",
            "    peers              list net-mgr cluster peers",
            "    status             daemon role / master / mesh / quorum",
            "    sessions           list chat sessions",
            "    switch <name>      switch to a different chat session",
            "    who                roster of this session",
            "    bitchat            recent bridge events",
            "    join <tier>        tier = mesh (works); neighborhood/block/city (n/i)",
            "    quit / q / exit    leave chat",
            "    help / ?           this help",
        );
    };

    my $cmd_peers = sub {
        my $c = connect_client(want_auth => 0);
        my $rows = eval {
            $c->snapshot(1, 'peers');
        } || [];
        eval { $c->bye };
        unless (@$rows) { $emit->("  (no peers known)"); return }
        my @lines = ("  peers known to daemon:");
        for my $p (sort { ($a->{name}//'') cmp ($b->{name}//'') } @$rows) {
            push @lines, sprintf("    %-18s %s:%s   %s",
                ($p->{name} // $p->{cluster_member} // '?'),
                ($p->{host} // '?'),
                ($p->{port} // '7531'),
                ($p->{last_status} // ''));
        }
        $emit->(join "\n", @lines);
    };

    my $cmd_status = sub {
        my $c = connect_client(want_auth => 0);
        my $st = eval { $c->status };
        my $err = $@;
        eval { $c->bye };
        if ($err || !$st) {
            $emit->("  status: " . ($err || 'no reply'));
            return;
        }
        my @lines = ("  daemon status:");
        for my $k (sort keys %$st) {
            push @lines, sprintf("    %-22s %s", $k, $st->{$k} // '');
        }
        $emit->(join "\n", @lines);
    };

    my $cmd_sessions = sub {
        my $c = connect_client(want_auth => 0);
        my $rows = eval { $c->snapshot(1, 'chat_sessions') } || [];
        eval { $c->bye };
        unless (@$rows) { $emit->("  (no sessions)"); return }
        my @lines = ("  chat sessions:");
        for my $s (sort { lc($a->{name}//'') cmp lc($b->{name}//'') } @$rows) {
            my $marker = (($s->{name}//'') eq $name) ? '*' : ' ';
            push @lines, sprintf("    %s %-20s %-8s %-8s %s", $marker,
                $s->{name} // '?',
                $s->{access_mode} // '?',
                $s->{status} // '?',
                $s->{topic} // '');
        }
        $emit->(join "\n", @lines);
    };

    my $cmd_switch = sub {
        my ($new) = @_;
        unless (defined $new && length $new) {
            $emit->("  usage: switch <session-name>");
            return;
        }
        $emit->("  switching to '$new' — restart will resubscribe.");
        # Tear down + relaunch ourselves with the new session arg. Cleaner
        # than rewiring SUBSCRIBE state in place.
        $restore_term->();
        eval { $ctrl->chat_leave(session => $name) } if $ctrl;
        eval { $ctrl->bye }   if $ctrl;
        eval { $stream->bye } if $stream;
        # exec is cleaner than recursing — fresh stack, fresh signals.
        exec { $^X } $^X, $0, '--tty', $new;
        exit 0;
    };

    my $cmd_who = sub {
        my $c = connect_client(want_auth => 0);
        my $rows = eval {
            $c->snapshot(1, 'chat_presence',
                where => "session = '$name'");
        } || [];
        eval { $c->bye };
        my @who = sort map { $_->{principal} } @$rows;
        $emit->("  here: " . (@who ? join(', ', @who) : '(empty)'));
    };

    my $cmd_bitchat = sub {
        my $c = connect_client(want_auth => 0);
        my $log = eval { $c->poll('netmgr-log') } // '';
        eval { $c->bye };
        my @bridge = grep { /\[(?:bridge|helper)/ } split /\n/, $log;
        @bridge = @bridge[-8..-1] if @bridge > 8;
        unless (@bridge) {
            $emit->("  (no [bridge] log lines in recent tail — bridge may be skipped)");
            return;
        }
        $emit->(join "\n", "  recent bridge events:", map { "    $_" } @bridge);
    };

    my $cmd_join = sub {
        my ($tier) = @_;
        $tier = lc($tier // '');
        if ($tier eq 'mesh' || $tier eq '') {
            $emit->("  on Mesh: subscribed to '$name' (BLE Mesh feed from the bridge).");
            return;
        }
        if ($tier =~ /^(neighborhood|block|city|building|region|province)$/) {
            $emit->("  tier '$tier' is Nostr-only in iOS BitChat — not implemented.");
            return;
        }
        $emit->("  unknown tier '$tier' — try: mesh");
    };

    my $dispatch = sub {
        my ($line) = @_;
        $line =~ s/^\s+|\s+$//g;
        return unless length $line;
        my @parts = split /\s+/, $line;
        my $verb = lc(shift @parts);
        my $arg  = "@parts";
        if    ($verb =~ /^(?:quit|q|exit)$/)  { $shutdown->() }
        elsif ($verb =~ /^(?:help|\?)$/)      { $cmd_help->() }
        elsif ($verb eq 'peers')              { $cmd_peers->() }
        elsif ($verb eq 'status')             { $cmd_status->() }
        elsif ($verb eq 'sessions')           { $cmd_sessions->() }
        elsif ($verb eq 'switch')             { $cmd_switch->(@parts) }
        elsif ($verb eq 'who')                { $cmd_who->() }
        elsif ($verb eq 'bitchat')            { $cmd_bitchat->() }
        elsif ($verb eq 'join')               { $cmd_join->(@parts) }
        else {
            $emit->("  unknown ESC command '$verb' — try 'help'");
        }
    };

    # === stream drain (server -> us) ===
    my $drain_stream = sub {
        my $sock = $stream->{sock};
        my $chunk;
        my $n = sysread($sock, $chunk, 4096);
        unless (defined $n && $n > 0) {
            $emit->("-- daemon hung up --");
            $shutdown->();
        }
        $stream->{buf} .= $chunk;
        while ($stream->{buf} =~ s/^([^\n]*)\n//) {
            my $c = parse_line($1) or next;
            if ($c->{verb} eq 'ROW'
                && ($c->{kv}{table} // '') eq 'chat_messages') {
                # print message without disrupting in-progress input.
                print "\r\e[K";
                print_msg($c->{kv});
                $redraw->();
            } elsif ($c->{verb} eq 'EOS') {
                unless ($live++) {
                    $emit->("-- live: type to send. ESC enters command mode."
                          . " Try `:help`. /quit also exits.");
                }
            } elsif ($c->{verb} eq 'ERR') {
                $emit->("-- stream error: " . ($c->{kv}{msg} // '?'));
                $shutdown->();
            }
        }
    };

    # === stdin (one byte at a time, raw mode) ===
    # ESC: chat→cmd (start fresh ':' line), cmd→chat (cancel ':' line)
    # Enter: commit the buffer per mode, then return to chat
    # Backspace/DEL: erase one char + visual erase
    # Ctrl-C: shutdown.  Ctrl-D: shutdown when buffer empty.
    # printable ASCII (0x20-0x7e): echo and append.
    # other control chars: ignore.
    my $handle_byte = sub {
        my $byte;
        my $n = sysread(STDIN, $byte, 1);
        unless (defined $n && $n > 0) { $shutdown->() }
        my $ord = ord($byte);
        if ($ord == 0x1b) {                          # ESC
            if ($mode eq 'chat') {
                $mode = 'cmd';
                $buf  = '';
                print "\r\e[K", $cmd_prompt;
            } else {
                $mode = 'chat';
                $buf  = '';
                print "\r\e[K", $chat_prompt;
            }
            return;
        }
        if ($ord == 0x0d || $ord == 0x0a) {          # Enter
            my $text = $buf; $buf = '';
            print "\r\e[K\n";
            if ($mode eq 'chat') {
                if (!length $text) { print $chat_prompt; return }
                # /-commands still work in chat mode for muscle memory.
                if ($text =~ m{^/(?:quit|exit|q)\b}i) { $shutdown->() }
                if ($text =~ m{^/help\b}i) {
                    $cmd_help->(); print $chat_prompt; return;
                }
                if ($text =~ m{^/who\b}i) {
                    $cmd_who->(); print $chat_prompt; return;
                }
                if ($text =~ m{^/}) {
                    $emit->("-- unknown slash command '$text' — /help for the list");
                    print $chat_prompt; return;
                }
                my $c = $get_ctrl->();
                unless ($c) {
                    $emit->("-- can't post: $@");
                    print $chat_prompt; return;
                }
                eval { $c->chat_post(session => $name, body => $text) };
                my $err = $@;
                if ($err) {
                    # Same join-request fallback as the GUI: server says
                    # "not a member" / "not authorized to post" → silently
                    # queue a chat_join (request) and surface "waiting for
                    # an owner" rather than the raw AUTH error. An owner
                    # on another box approves; the user's pubkey gets
                    # persisted so subsequent posts work.
                    if ($err =~ /chat_msg: not a member of|not authorized to post/i) {
                        my $jr = eval { $c->chat_join(session => $name) };
                        my $state = ($jr && ref $jr eq 'HASH') ? ($jr->{state} // '') : '';
                        if ($@) {
                            chomp(my $je = $@);
                            $emit->("-- post needs membership; join failed: $je");
                        } elsif ($state eq 'requested') {
                            my @owners = _gui_session_owners($name);
                            my $me_id = ($jr && ref $jr eq 'HASH')
                                      ? ($jr->{principal} // '') : '';
                            my $who = @owners ? join(', ', @owners) : '(unknown)';
                            $emit->("-- join request sent for '$name' "
                                  . "as '$me_id'"
                                  . " — waiting for: $who");
                        } elsif ($state eq 'member') {
                            eval { $c->chat_post(session => $name, body => $text) };
                            $emit->("-- post failed after join: $@") if $@;
                        } else {
                            chomp(my $e = $err);
                            $emit->("-- post failed: $e");
                        }
                    } else {
                        my $e = $err; $e =~ s/\s+\z//;
                        $emit->("-- post failed: $e");
                    }
                }
                print $chat_prompt;
            } else {                                  # cmd mode
                $dispatch->($text);
                $mode = 'chat';
                print $chat_prompt;
            }
            return;
        }
        if ($ord == 0x7f || $ord == 0x08) {          # Backspace / DEL
            if (length $buf) {
                chop $buf;
                print "\b \b";
            }
            return;
        }
        if ($ord == 0x03) { $shutdown->() }          # Ctrl-C
        if ($ord == 0x04) {                          # Ctrl-D
            $shutdown->() if length($buf) == 0;
            return;
        }
        if ($byte =~ /[\x20-\x7e]/) {                # printable
            $buf .= $byte;
            print $byte;
        }
        # else: ignore stray control bytes (arrow keys, etc — TODO history).
    };

    while (1) {
        my @ready = $sel->can_read or next;
        for my $fh (@ready) {
            if ($fh == $stream->{sock}) { $drain_stream->() }
            else                         { $handle_byte->() }
        }
    }
}

sub cmd_members {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client(want_auth => 0);
    my $rows = $cli->snapshot(1, 'chat_members', where => "session = '$name'");
    unless (@$rows) { print "no members for '$name'\n"; return }
    printf "%-24s %-8s %s\n", 'PRINCIPAL', 'ROLE', 'STATE';
    for my $m (sort { $a->{principal} cmp $b->{principal} } @$rows) {
        printf "%-24s %-8s %s\n",
            $m->{principal}, $m->{role} // '?', $m->{state} // '?';
    }
}

sub cmd_delete {
    my $name = need_name(shift @ARGV);
    my $force = grep { $_ eq '--force' || $_ eq '-f' } @ARGV;
    unless ($force) {
        local $| = 1;
        print STDERR "Delete chat '$name' and its ENTIRE archive "
                   . "(messages + uploaded files)? This cannot be undone. [y/N] ";
        my $ans = <STDIN>;
        unless (defined $ans && $ans =~ /^\s*y/i) { print "aborted\n"; return }
    }
    my $cli = connect_client();
    eval { $cli->chat_delete(name => $name) };
    die "net-chat: $@" if $@;
    print "deleted '$name' (archive removed)\n";
}

sub cmd_upload {
    my $session = need_name(shift @ARGV);
    my $path = shift @ARGV or die "net-chat: upload needs a file path\n";
    my $name = shift @ARGV;          # optional stored name (default: basename)
    require File::Basename;
    $name //= File::Basename::basename($path);
    open my $fh, '<', $path or die "net-chat: open $path: $!\n";
    binmode $fh;
    require MIME::Base64;
    my $cli = connect_client();
    my ($offset, $r) = (0, undef);
    while (1) {
        my $n   = read($fh, my $buf, 48 * 1024);
        $buf    = '' unless defined $n;
        my $eof = (!$n || eof($fh)) ? 1 : 0;
        $r = eval { $cli->chat_put(session => $session, file => $name,
            offset => $offset, ($eof ? (eof => 1) : ()),
            data => MIME::Base64::encode_base64($buf, '')) };
        die "net-chat: $@" if $@;
        $offset += length $buf;
        last if $eof;
    }
    close $fh;
    print "uploaded '$name' (", ($r->{size} // $offset), " bytes) to '$session'\n";
}

sub cmd_download {
    my $session = need_name(shift @ARGV);
    my $name = shift @ARGV or die "net-chat: download needs a file name\n";
    my $out  = shift @ARGV // $name;   # optional local destination
    require MIME::Base64;
    my $cli = connect_client();   # file reads are ACL-gated; auth on remote
    open my $fh, '>', $out or die "net-chat: write $out: $!\n";
    binmode $fh;
    my $offset = 0;
    while (1) {
        my $r = eval { $cli->chat_get(session => $session, file => $name,
                                      offset => $offset) };
        die "net-chat: $@" if $@;
        my $chunk = defined $r->{data} ? MIME::Base64::decode_base64($r->{data}) : '';
        print {$fh} $chunk;
        $offset += length $chunk;
        last if $r->{eof} || length($chunk) == 0;
    }
    close $fh;
    print "downloaded '$name' from '$session' -> $out ($offset bytes)\n";
}

sub cmd_files {
    my $session = need_name(shift @ARGV);
    my $cli = connect_client();   # file listing is ACL-gated; auth on remote
    my $r = eval { $cli->chat_ls(session => $session) };
    die "net-chat: $@" if $@;
    require MIME::Base64; require JSON::PP;
    my $files = $r->{files}
        ? JSON::PP->new->decode(MIME::Base64::decode_base64($r->{files})) : [];
    unless (@$files) { print "no files in '$session'\n"; return }
    printf "%-32s %10s\n", 'NAME', 'BYTES';
    printf "%-32s %10d\n", $_->{name}, $_->{size} for @$files;
}

sub cmd_rm {
    my $session = need_name(shift @ARGV);
    my $name = shift @ARGV or die "net-chat: rm needs a file name\n";
    my $cli = connect_client();
    eval { $cli->chat_rm(session => $session, file => $name) };
    die "net-chat: $@" if $@;
    print "deleted '$name' from '$session'\n";
}

# keys <chat>: list the chat's authorized SSH keys (owner only). Pre-load a key
# with `allow <chat> <key_id>`; revoke with `deny <chat> <key_id>`.
sub cmd_keys {
    my $session = need_name(shift @ARGV);
    my $cli = connect_client();             # owner-only -> wants identity
    my $r = eval { $cli->chat_keys(session => $session) };
    die "net-chat: $@" if $@;
    require MIME::Base64; require JSON::PP;
    my $keys = $r->{keys}
        ? JSON::PP->new->decode(MIME::Base64::decode_base64($r->{keys})) : [];
    unless (@$keys) { print "no authorized keys for '$session'\n"; return }
    printf "%-18s %-9s %s\n", 'LABEL', 'TYPE', 'KEY_ID';
    for my $k (@$keys) {
        printf "%-18s %-9s %s\n",
            ($k->{label} // ''), ($k->{key_type} // ''), $k->{key_id};
    }
}

sub cmd_member {
    my ($op) = @_;
    my $name      = need_name(shift @ARGV);
    my $principal = shift @ARGV
        or die "net-chat: $op needs a principal\n";
    my $cli = connect_client();
    eval { $cli->chat_member($op, session => $name, principal => $principal) };
    die "net-chat: $@" if $@;
    print "$op: $principal on '$name'\n";
}

# True if SSH has a known_hosts entry for any of the given host tokens. Uses
# `ssh-keygen -F`, which matches hashed (HashKnownHosts) entries too — plain
# parsing can't read those back, and hashing is the default on many systems.
# Memoized per token; tolerant of a missing ssh-keygen (then nothing floats).
{
    my %memo;
    my $have_keygen;
    sub _ssh_knows {
        unless (defined $have_keygen) {
            $have_keygen = 0;
            for my $d (split /:/, ($ENV{PATH} // '')) {
                -x "$d/ssh-keygen" and $have_keygen = 1, last;
            }
        }
        return 0 unless $have_keygen;
        for my $t (@_) {
            next unless defined $t && length $t;
            $memo{lc $t} //= do {
                my $pid = open(my $kh, '-|');
                my $hit = 0;
                if (defined $pid && !$pid) {          # child
                    open STDERR, '>', '/dev/null';
                    exec('ssh-keygen', '-F', $t);
                    exit 127;
                } elsif ($pid) {                      # parent: drain + reap
                    local $/; my $out = <$kh>; close $kh;   # close sets $?
                    $hit = ($? == 0 && defined $out && $out =~ /\S/) ? 1 : 0;
                }
                $hit;
            };
            return 1 if $memo{lc $t};
        }
        return 0;
    }
}

# Map IP address -> machine primary_name via the daemon's
# addresses -> interfaces -> machines tables (net-lookup's reverse path), so
# the server picker can show names instead of bare peer IPs.
sub _daemon_ip_names {
    my ($cli) = @_;
    my %ip2name;
    my $machines = eval { $cli->snapshot(11, 'machines') }   || [];
    my $ifaces   = eval { $cli->snapshot(12, 'interfaces') } || [];
    my $addrs    = eval { $cli->snapshot(13, 'addresses') }  || [];
    my %name_of_mid = map { ($_->{id} => $_->{primary_name}) }
                      grep { $_->{primary_name} } @$machines;
    my %mid_of_mac;
    for my $i (@$ifaces) {
        $mid_of_mac{lc $i->{mac}} = $i->{machine_id}
            if $i->{mac} && $i->{machine_id};
    }
    for my $a (@$addrs) {
        next unless defined $a->{addr} && defined $a->{mac};
        my $mid = $mid_of_mac{lc $a->{mac}} or next;
        my $nm  = $name_of_mid{$mid} or next;
        $ip2name{$a->{addr}} //= $nm;
    }
    return %ip2name;
}

# ---- GUI (Perl/Tk) ---------------------------------------------------
# net-chat --gui [session]: a desktop chat window — pick a session (or
# "+ new chat" to create one), watch it live, type to post, send a file
# with the up-arrow button, and right-click an "uploaded …" line to Save
# As or Delete it. Owners also get approve/reject pop-ups for join requests. Bar widgets
# use ASCII (the default UI font lacks many glyphs; the message pane is
# Courier and renders Unicode fine).
# The "terminal" button launches your terminal emulator on a tmux session bound
# to the current chat; its input is the keyboard plus any chat message starting
# "@<local user>" (injected via tmux send-keys). See _ssh_knows/$term_feed.
# Multi-line messages fold to their first line (a " [+]"
# marker; left-click to open, right-click to close) and older/seeded lines
# start folded; the search box reveals and highlights matches across the whole
# loaded log; each sender gets a light background tint. Uses two connections:
# one read via Tk fileevent for
# subscriptions, one for blocking control ops (snapshot/post/join/member).
sub cmd_gui {
    my ($session) = @_;
    $session //= shift @ARGV;
    # Fall back to the last-open session from the per-user config when the
    # user didn't pass a session name. Same two-path merge the auth defaults
    # use — user config overwrites system, then we keep the CLI (or the
    # $session arg passed in from a switch-server re-exec) on top.
    unless (defined $session && length $session) {
        for my $path ($ENV{NET_MGR_CONF} // '/etc/net-mgr/config',
                      NetMgr::Config->user_path)
        {
            next unless defined $path && -e $path && -r $path;
            my $ucfg = eval { NetMgr::Config->load($path) } || {};
            my $ls = $ucfg->{'net-chat'}{last_session};
            $session = $ls if defined $ls && length $ls;
        }
    }
    # Dumb-terminal fallback: when there's no DISPLAY and stdin/stdout are
    # both ttys, drop through to cmd_tty so `net-chat --gui` Just Works
    # over ssh, serial consoles, or in a container without X. Same idea
    # for the case where Perl/Tk isn't installed at all.
    my $no_display = !defined $ENV{DISPLAY} || $ENV{DISPLAY} eq '';
    if ($no_display && -t STDIN && -t STDOUT) {
        warn "net-chat: no DISPLAY — falling back to --tty mode\n";
        return cmd_tty($session);
    }
    unless (eval { require Tk; 1 }) {
        my $err = $@ || 'Tk load failed';
        chomp $err;
        if (-t STDIN && -t STDOUT) {
            warn "net-chat: Perl/Tk not available ($err) — falling back to --tty mode\n";
            return cmd_tty($session);
        }
        die "net-chat: Perl/Tk not installed and no tty for --tty fallback: $err\n";
    }
    _gui_set_askpass_env();   # let ssh-keygen pop a Tk passphrase prompt

    # Build MainWindow FIRST so a connect/auth failure can pop a dialog instead
    # of dying. Without this, an AUTH failure (no key, key not in remote's
    # allowed_signers, etc.) crashed the whole GUI.
    my $mw = Tk::MainWindow->new;
    $mw->title('net-chat');
    $mw->geometry('660x480');

    # Default the GUI to ANONYMOUS browse mode for remote daemons. Open
    # sessions allow anonymous SUBSCRIBE/snapshot, and that covers reading
    # + picking a session, which is what users open the GUI for first.
    # Auth gets attempted only when the user explicitly tries to post or
    # do an owner-only op. Skipping auth on startup avoids both the
    # ssh-askpass popup AND the auth-failure dialog for the common case
    # of "I just want to look at this open session". Loopback connections
    # are still auth-exempt server-side, so this also covers --listen
    # 127.0.0.1:7531 without any change. --auth (force_auth) still wins.
    # Persisted "Sign in always" (from ~/.config/net-mgr/config's
    # [net-chat] block) skips the anon-startup branch so the saved key
    # actually gets used — but WITHOUT setting $force_auth, so a loopback
    # daemon still enjoys server-side auth exemption instead of getting
    # rejected by the chat-key fallthrough for lacking a chat-authorized
    # key.
    my $anon_at_startup = 0;
    if (!$force_auth && !$no_auth && !$auto_auth_from_config) {
        $no_auth = 1;
        $anon_at_startup = 1;
    }
    my ($stream, $ctrl) = _gui_connect_with_dialog($mw);
    return unless $stream && $ctrl;   # user cancelled — MainWindow destroyed

    # Forward-declare so the anonymous popup's callback (which fires later
    # via Tk::after) can close over the lexical. The actual `sub { ... }`
    # assignment happens further down once $statusvar exists; by the time
    # the after() callback fires, the main-loop has run cmd_gui through
    # to MainLoop and the assignment has landed.
    my $set_status;

    # Forward-declared for the server-picker Optionmenu -command below (defined
    # further up in the layout code). The actual sub is filled in near the end
    # of cmd_gui, after every closure it needs ($refresh, $stream_reader, etc.)
    # has been assigned. Doing an in-place switch (rather than exec'ing net-chat
    # into itself with a new --listen) keeps the window position, session menu
    # scroll, message-log widget, and Tk::Balloon state intact.
    my $switch_server;
    # The Tk fileevent handler that drains the SUBSCRIBE stream socket. Lifted
    # out of its original inline `$mw->fileevent(..., sub { ... })` so the
    # in-place server-switch can cancel it on the old socket and re-bind the
    # SAME closure on the new one. The closure captures $stream by lexical
    # reference — reassigning $stream on switch is enough for the reader to
    # see the new object without redefinition.
    my $stream_reader;

    # Non-blocking notice: tell the user they're anonymous so they aren't
    # surprised when posts get refused. Replaces the old info messageBox
    # — that one couldn't offer to sign in. This dialog has the same SSH
    # key picker as the auth-failure dialog so the user can upgrade right
    # here without restarting net-chat. Non-modal: -transient but not
    # -grab, so the GUI underneath stays usable.
    if ($anon_at_startup && $no_auth) {
        $mw->after(200, sub {
            require Tk::BrowseEntry;
            require Tk::Balloon;
            my $dlg = $mw->Toplevel(-title => 'net-chat: anonymous browse');
            $dlg->transient($mw);
            $dlg->Label(-text =>
                "Browsing $listen as anonymous (no AUTH key sent).\n\n"
              . "You can read open sessions. Posting requires a key in the "
              . "daemon's allowed_chat — sign in below or stay anonymous.",
                -justify => 'left', -wraplength => 480)
                ->pack(-fill => 'x', -padx => 12, -pady => [10, 6]);

            my @keys = _discover_ssh_keys();
            my %v = (
                key_file => ($key_file // NetMgr::Client::_default_key_file()
                                       // ($keys[0] // '')),
                key_id   => ($key_id   // NetMgr::Client::_default_key_id() // ''),
            );
            if (!defined $key_id && @keys && $v{key_file} eq $keys[0]) {
                my $c = _ssh_key_comment($keys[0]);
                $v{key_id} = $c if defined $c && length $c;
            }

            my $kf_frame = $dlg->Frame->pack(-fill => 'x', -padx => 12, -pady => 2);
            $kf_frame->Label(-text => 'SSH key file:', -width => 12, -anchor => 'w')
                     ->pack(-side => 'left');
            my $kf_combo = $kf_frame->BrowseEntry(-variable => \$v{key_file},
                -width => 36, -listwidth => 60,
                -browsecmd => sub {
                    my $c = _ssh_key_comment($v{key_file});
                    $v{key_id} = $c if defined $c && length $c;
                });
            $kf_combo->insert('end', $_) for @keys;
            $kf_combo->pack(-side => 'left', -fill => 'x', -expand => 1);
            $kf_frame->Button(-text => 'Browse…', -command => sub {
                my $f = $dlg->getOpenFile(-title => 'Select SSH private key',
                                          -initialdir => "$ENV{HOME}/.ssh");
                if (defined $f && length $f) {
                    $v{key_file} = $f;
                    my $c = _ssh_key_comment($f);
                    $v{key_id} = $c if defined $c && length $c;
                }
            })->pack(-side => 'left', -padx => [4, 0]);

            my $kid_frame = $dlg->Frame->pack(-fill => 'x', -padx => 12, -pady => 2);
            $kid_frame->Label(-text => 'Key ID:', -width => 12, -anchor => 'w')
                      ->pack(-side => 'left');
            $kid_frame->Entry(-textvariable => \$v{key_id}, -width => 36)
                      ->pack(-side => 'left', -fill => 'x', -expand => 1);

            # Try to AUTH-promote the existing $ctrl connection with the
            # chosen creds. Stream stays anonymous (read-only subscriptions
            # don't need auth). On failure, restore anonymous mode and tell
            # the user — better UX than a hard error popup.
            my $signin = sub {
                my ($persist) = @_;
                # Persist to ~/.config/net-mgr/config first when "Always" is
                # picked so a sign-in failure mid-process doesn't lose the
                # operator's intent (next launch retries with the same key).
                if ($persist) {
                    eval {
                        NetMgr::Config->save_user_value('net-chat',
                            'key_file', $v{key_file}) if length $v{key_file};
                        NetMgr::Config->save_user_value('net-chat',
                            'key_id',   $v{key_id})   if length $v{key_id};
                    };
                }
                $key_file   = $v{key_file};
                $key_id     = $v{key_id};
                $no_auth    = 0;
                $force_auth = 1;
                # Rebuild only $ctrl — that's the post/join connection.
                eval { $ctrl->bye } if $ctrl;
                my $new_ctrl = eval { connect_client() };
                if ($@ || !$new_ctrl) {
                    my $e = $@ || 'no connection'; chomp $e;
                    $set_status->("sign-in failed: $e (still anonymous)");
                    $no_auth    = 1;
                    $force_auth = 0;
                    # Reopen an anonymous $ctrl so post-tries still work.
                    $ctrl = eval { connect_client(want_auth => 0) };
                } else {
                    $ctrl = $new_ctrl;
                    $set_status->("signed in as "
                                . ($v{key_id} // '(unset)')
                                . ($persist ? ' (saved to config)'
                                            : ' (this session only)'));
                }
                $dlg->destroy;
            };

            my $btns = $dlg->Frame->pack(-fill => 'x', -padx => 12, -pady => 10);
            my $stay_btn = $btns->Button(-text => 'Stay anonymous',
                -command => sub { $dlg->destroy });
            $stay_btn->pack(-side => 'right', -padx => 2);
            my $once_btn = $btns->Button(-text => 'Sign in (this session)',
                -command => sub { $signin->(0) });
            $once_btn->pack(-side => 'left', -padx => 2);
            my $always_btn = $btns->Button(-text => 'Sign in always',
                -command => sub { $signin->(1) });
            $always_btn->pack(-side => 'left', -padx => 2);

            my $bln = $dlg->Balloon(-state => 'balloon', -initwait => 600);
            $bln->attach($kf_combo,
                -msg => "Pick a private key from ~/.ssh/. The matching .pub "
                      . "file's comment auto-fills Key ID.");
            $bln->attach($once_btn,
                -msg => "Apply these creds to this net-chat process only. "
                      . "Next launch goes back to anonymous unless you "
                      . "pass --auth.");
            $bln->attach($always_btn,
                -msg => "Apply these creds AND save them to "
                      . "~/.config/net-mgr/config [net-chat] so future "
                      . "launches default to them.");
            $bln->attach($stay_btn,
                -msg => "Browse anonymously. Posts will trigger the "
                      . "join-request flow (server queues the request "
                      . "for an owner to approve).");
        });
    }

    # Recompute auth state AFTER the dialog — the user may have flipped to
    # --no-auth, picked a different key file, etc.
    my ($host) = NetMgr::Client::split_hostport($listen); $host //= '';
    my $is_loopback = $host =~ /^(?:127\.\d+\.\d+\.\d+|::1|localhost)$/;
    my $authed = $force_auth || (!$is_loopback && !$no_auth);
    $authed = 0 if $no_auth;
    # Our chat identity, for filtering request pop-ups to sessions we own.
    my $me = $authed ? ($key_id // NetMgr::Client::_default_key_id()) : $as;

    # Shared named fonts so A+/A- scale the WHOLE UI (buttons, labels, dropdown,
    # entry) not just the message pane. optionAdd (high priority) makes every
    # widget created below inherit 'ncui'; the pane uses the monospace 'ncmono'.
    my $fontsize = 10;
    $mw->fontCreate('ncui',   -size => $fontsize);
    $mw->fontCreate('ncmono', -family => 'Courier', -size => $fontsize);
    # Bold mono, a couple of points up — for the upload-arrow button so the
    # glyph reads as a chunky icon rather than a thin stroke.
    $mw->fontCreate('ncmonob', -family => 'Courier', -size => $fontsize + 2,
                    -weight => 'bold');
    $mw->optionAdd('*font' => 'ncui', 81);

    my %created_by;          # session -> created_by (for request ownership)
    my %status;              # session -> 'open'|'closed' (closed = restartable)
    my $cur;                 # session currently followed
    my %seen_req;            # "$session/$principal" -> 1 (dedupe pop-ups)
    my $statusvar = 'connecting...';

    # -- top: server + session picker + refresh --------------------------
    my $top = $mw->Frame->pack(-fill => 'x', -padx => 4, -pady => 3);

    # Server picker. Options are the configured [servers] PLUS the peers the
    # current daemon knows about (its `peers` table — net-mgr instances
    # discovered on the LAN), so you can hop to any of them without editing
    # config. Switching rebuilds both sockets, the fileevent, and identity
    # (loopback vs remote auth differ), so we just re-exec with the new
    # --listen: clean and state-free. "set default" persists the active server
    # to the per-user config. See ~/.config/net-mgr/config [servers].
    my ($srvmap) = NetMgr::Config->servers;
    my %addr2name = reverse %$srvmap;              # host:port -> config name
    my $host_of = sub { (NetMgr::Client::split_hostport($_[0]))[0] // $_[0] };

    # Candidate servers: configured [servers], the active one, then the peers
    # the daemon knows about. Each is (addr, optional config name).
    my @raw = ( (map { [ $srvmap->{$_}, $_ ] } sort keys %$srvmap),
                [ $listen, undef ] );
    {
        my $peers = eval { $ctrl->snapshot(6, 'peers') } || [];
        push @raw, [ $_->{host} . ':' . ($_->{port} // 7531), undef ]
            for grep { defined $_->{host} && length $_->{host} } @$peers;
    }
    # Resolve bare-IP hosts to machine names (only worth the table snapshots if
    # some host is actually an IP); float known_hosts entries to the top.
    my $need_names = grep { local $_ = $host_of->($_->[0]);
                            /^\d+\.\d+\.\d+\.\d+$/ || /:/ } @raw;
    my %ip2name = $need_names ? _daemon_ip_names($ctrl) : ();

    # Pre-seed a "-self-" entry pinned to the local daemon's loopback. Doing
    # it before the discovery loop below means //= there won't clobber the
    # label — any hostname that also happens to resolve to 127.0.0.1 will
    # still get its normal entry keyed by its LAN address, so bigsony and
    # -self- coexist. Loopback is where the bitchat-bridge session lives,
    # and it's also the escape hatch when a remote you're on goes down.
    my %cand = ( '127.0.0.1:7531' => { name => '-self-', kh => 1 } );
    for my $r (@raw) {
        my ($addr, $cfgname) = @$r;
        next unless defined $addr && length $addr;
        my $host = $host_of->($addr);
        my $name = $cfgname // $ip2name{$host} // $host;
        # familiar = the host, the resolved name, or the config name is in
        # the user's SSH known_hosts.
        my $kh   = _ssh_knows($host, $name, ($cfgname // ())) ? 1 : 0;
        $cand{$addr} //= { name => $name, kh => $kh };   # first (config) wins
    }
    # Amalgamate by short name: 3 addresses that all resolve to "nas3"
    # collapse to ONE dropdown entry labelled "nas3". Pick a canonical
    # address per name preferring, in order:
    #   1. the currently-active $listen (so "nas3" in the picker still
    #      maps to whichever nas3 address you happen to be on)
    #   2. a known_hosts entry (proves you've reached it before)
    #   3. the first alphabetical address (deterministic tiebreak)
    # The un-chosen addresses vanish from the picker — pass --listen
    # <addr> on the CLI if you need a specific physical interface.
    my %by_name;
    push @{ $by_name{ $cand{$_}{name} } }, $_ for keys %cand;
    my %label2addr;
    for my $name (sort keys %by_name) {
        my @addrs = @{ $by_name{$name} };
        my $chosen;
        ($chosen) = grep { $_ eq $listen } @addrs;
        ($chosen) = grep { $cand{$_}{kh} } sort @addrs   unless defined $chosen;
        $chosen //= (sort @addrs)[0];
        $label2addr{$name}      = $chosen;
        $cand{$chosen}{label}   = $name;
        $cand{$chosen}{addrs}   = [ sort @addrs ];   # for tooltip
    }
    # known_hosts first, then by name (case-insensitive). "-self-" pinned to
    # the very top: it's the escape hatch and the local-daemon-only sessions
    # (bitchat-bridge etc) don't show up anywhere else in the picker.
    my @opts = sort {
        $cand{$label2addr{$b}}{kh} <=> $cand{$label2addr{$a}}{kh}
            || lc($a) cmp lc($b)
    } keys %label2addr;
    @opts = ('-self-', grep { $_ ne '-self-' } @opts);

    # $srvvar drives the picker's -variable AND is updated by $switch_server
    # when a switch reverts to the old server (so the visible label matches
    # reality). Declared outside the `if` so switch_server (further down) can
    # see it even when the picker itself isn't shown.
    my $srvvar = $cand{$listen}{label} // $listen;
    if (@opts > 1) {
        $top->Label(-text => 'server:')->pack(-side => 'left');
        my $srv_om = $top->Optionmenu(-variable => \$srvvar, -options => \@opts,
            -command => sub {
                my $addr = $label2addr{$srvvar} // $srvvar;
                return if $addr eq $listen;
                # $switch_server is a forward-declared lexical filled in near
                # the end of cmd_gui (after $refresh, $follow, $stream_reader
                # exist). Guard against a picker fire during early layout: if
                # it isn't set yet, fall back to the old exec path so the user
                # still lands on the picked server, just via a fresh process.
                if ($switch_server) {
                    $switch_server->($addr);
                    return;
                }
                eval { $ctrl->chat_leave(session => $cur) } if defined $cur;
                eval { $ctrl->bye }; eval { $stream->bye };
                my @argv = ('--gui', '--listen', $addr);
                push @argv, '--auth'                  if $force_auth;
                push @argv, '--no-auth'               if $no_auth;
                push @argv, '--key-id',   $key_id     if defined $key_id;
                push @argv, '--key-file', $key_file   if defined $key_file;
                push @argv, '--as',       $as         if defined $as;
                push @argv, $cur                      if defined $cur;
                exec $^X, $0, @argv;
            });
        $srv_om->pack(-side => 'left');
        # Tooltip lists the collapsed addresses so the operator can see
        # what "nas3" actually maps to under the hood — plus the active
        # one. Cheap to lazy-load Tk::Balloon if it hasn't already been
        # loaded for the send/upload buttons further down.
        require Tk::Balloon;
        my $bln = $mw->Balloon(-state => 'balloon', -initwait => 500);
        my $tip = "Chosen for each name — addresses collapse to one entry.\n\n";
        for my $lbl (@opts) {
            my $addr = $label2addr{$lbl};
            my $addrs = $cand{$addr}{addrs} || [$addr];
            my $star  = ($addr eq $listen) ? ' *' : '';
            $tip .= sprintf "  %s%s\n", $lbl, $star;
            for my $a (@$addrs) {
                my $mark = ($a eq $addr) ? '→' : ' ';
                $tip .= sprintf "      %s %s\n", $mark, $a;
            }
        }
        $tip .= "\n* = active   → = chosen for that name";
        $bln->attach($srv_om, -msg => $tip);
        # Persist the active server as the user-config default (a config name
        # when the address has one, else the literal address).
        $top->Button(-text => 'set default', -command => sub {
            my $sel = $addr2name{$listen} // $listen;
            my $ok  = eval { NetMgr::Config->save_default($sel); 1 };
            $statusvar = $ok ? "default server = $sel (saved to config)"
                             : "set default failed: $@";
        })->pack(-side => 'left');
    }

    my $NEWCHAT = '+ new chat';   # sentinel entry in the chat picker
    my $new_chat;                 # assigned below (it uses $refresh/$follow)
    $top->Label(-text => 'chat:')->pack(-side => 'left');
    my $sessvar = $session // 'select';      # placeholder until a chat is picked
    my $om = $top->Optionmenu(-variable => \$sessvar,
                              -options => ['select', $NEWCHAT])
                 ->pack(-side => 'left');

    # BitChat scope selector: only meaningful when the current session is
    # the bitchat-bridge (which is scoped at the BLE mesh layer). Options
    # mirror mainline permissionlesstech/bitchat's ChannelID / GeohashChannelLevel
    # enums: mesh (BLE broadcast, the default) + geohash-precision channels
    # from finest (building=8 chars) to coarsest (region=2). For the geohash-
    # scoped ones we also need a geohash string — a small Entry to its right
    # feeds that. Value is persisted per-user in [net-chat] bitchat_scope /
    # bitchat_geohash so the selection survives across GUI restarts.
    my @BITCHAT_SCOPES = ('#mesh', '#building', '#block', '#neighborhood',
                          '#city', '#province', '#region');
    my $bitchat_lbl    = $top->Label(-text => 'scope:');
    my $bitchat_scope  = do {
        my $s = eval { NetMgr::Config->user_value('net-chat', 'bitchat_scope') };
        (defined $s && grep { $_ eq $s } @BITCHAT_SCOPES) ? $s : '#mesh';
    };
    my $bitchat_geo    = eval { NetMgr::Config->user_value('net-chat', 'bitchat_geohash') } // '';
    my $bitchat_om     = $top->Optionmenu(
        -variable => \$bitchat_scope,
        -options  => \@BITCHAT_SCOPES,
        -command  => sub {
            eval { NetMgr::Config->save_user_value('net-chat',
                       'bitchat_scope', $bitchat_scope) };
            $set_status->("scope: $bitchat_scope"
                . ($bitchat_scope ne '#mesh' && !length($bitchat_geo)
                   ? " (needs a geohash — type one to the right)" : ''))
                if $set_status;
        },
    );
    my $bitchat_geo_entry = $top->Entry(-textvariable => \$bitchat_geo, -width => 10);
    # Save the geohash on FocusOut so we don't hammer the config on every keystroke.
    $bitchat_geo_entry->bind('<FocusOut>' => sub {
        my $v = $bitchat_geo // '';
        $v =~ s/^\s+|\s+$//g;
        eval { NetMgr::Config->save_user_value('net-chat', 'bitchat_geohash', $v) };
    });

    # Show/hide the scope widgets depending on whether the current chat is
    # the bitchat bridge. Called from $follow (session-change) below.
    my $update_bitchat_ui = sub {
        my ($sess) = @_;
        my $is_bridge = defined $sess
                     && ($sess eq 'bitchat-bridge' || $sess =~ /^bitchat[-\/]/);
        if ($is_bridge) {
            $bitchat_lbl->pack(-side => 'left', -padx => [8, 0])
                unless $bitchat_lbl->ismapped;
            $bitchat_om->pack(-side => 'left')
                unless $bitchat_om->ismapped;
            $bitchat_geo_entry->pack(-side => 'left', -padx => [2, 0])
                unless $bitchat_geo_entry->ismapped;
        } else {
            $_->packForget for grep { $_->ismapped }
                ($bitchat_lbl, $bitchat_om, $bitchat_geo_entry);
        }
    };

    # Topic label shows "owner: <created_by>" when a session is selected.
    # The string can be long (multi-owner sessions, fully-qualified key
    # ids), and the label is squeezed between the dropdowns and the
    # action buttons, so clip is easy. Give it -wraplength + -justify
    # to wrap inside its allotted space; the reflow handler below sets
    # wraplength to the actual widget width on every <Configure>.
    my $topiclbl = $top->Label(-text => '', -anchor => 'w',
        -justify => 'left', -wraplength => 200)
                       ->pack(-side => 'left', -fill => 'x', -expand => 1);

    # -- middle: message log (read-only).  CREATED here, PACKED below
    # after the bottom widgets — see the geometry block at the end of
    # this section for why ordering matters.
    my $txt = $mw->Scrolled('Text', -scrollbars => 'oe', -wrap => 'word',
                            -state => 'disabled', -height => 22,
                            -font => 'ncmono');

    # -- bottom: input + send. Created (no pack) before $txt's pack.
    my $bot = $mw->Frame;
    my $entry = $bot->Entry->pack(-side => 'left', -fill => 'x', -expand => 1);
    # Status bar wraps to the window width so long messages (join-request
    # waiting-for, owner lists, error chains) don't get clipped on narrow
    # windows. -wraplength is in pixels; we update it on resize so the
    # bar grows with the toplevel.
    my $status_lbl = $mw->Label(-textvariable => \$statusvar, -anchor => 'w',
        -justify => 'left', -relief => 'sunken', -wraplength => 600);

    # Pack geometry: reserve the bottom-most strips FIRST (status, then
    # input), then let the message log expand into whatever's left. If
    # the user shrinks the window vertically, only the message log
    # collapses — the entry and status stay full-height.
    #   Order matters with -side=>bottom: status packs first, so it
    #   claims the very bottom row; the entry frame packs next, claiming
    #   the row above status. $txt then -expand=>1 fills the middle.
    # Without this ordering the text widget's natural -height=>22 wins
    # the cavity allocation and the entry box gets clipped first.
    $status_lbl->pack(-fill => 'x', -side => 'bottom');
    $bot->pack(-fill => 'x', -side => 'bottom', -padx => 4, -pady => 3);
    $txt->pack(-fill => 'both', -expand => 1, -padx => 4);

    $set_status = sub { $statusvar = $_[0] };
    my $set_font = sub {
        $mw->fontConfigure('ncui',    -size => $fontsize);
        $mw->fontConfigure('ncmono',  -size => $fontsize);
        $mw->fontConfigure('ncmonob', -size => $fontsize + 2);
    };
    my $min_shown;     # smallest message id on screen — the History cursor
    my %shown;         # ids already displayed — dedup live/seed/history overlap
    my $fmt = sub {
        my ($kv) = @_;
        my $ts = $kv->{ts} // ''; $ts =~ s/\.\d+$//; $ts =~ s/^\d{4}-//;
        my $who  = $kv->{sender} // '?';
        my $body = $kv->{body} // '';
        utf8::decode($who); utf8::decode($body);   # UTF-8 wire bytes -> chars
        return sprintf("%s  %s: %s\n", $ts, $who, $body);
    };
    my $note_id = sub {
        my ($id) = @_;
        $min_shown = $id if defined $id
                         && (!defined $min_shown || $id < $min_shown);
    };

    # Folding + search bookkeeping. Each message gets a unique ordinal $ord and a
    # clickable tag "i$ord"; a multi-line message also gets a body tag "b$ord"
    # (everything past the first line) and a marker tag "k$ord" (the " [+]" shown
    # only while folded). Folding just toggles -elide on those two tags. @order
    # keeps the on-screen ordinals top->bottom and %otext their text, so Search
    # can scan the full (even folded) content without the widget's own search.
    my $mseq = 0;
    my @order;         # message ordinals, top -> bottom
    my %otext;         # ord -> decoded full text (for Search)
    my %folded;        # ord -> bool
    my %file_of_ord;   # ord -> uploaded filename (for the right-click Save As)
    my $last_hit;      # ord the last Search hit landed in
    my $last_q = '';   # query that produced $last_hit

    # Light per-sender row tint: each new sender claims the next palette colour
    # (cycling), kept stable across session switches so a person reads the same.
    my @PALETTE = ('#fde7e9', '#e7f3fe', '#e9f9ec', '#fff6df', '#f1eafc',
                   '#e4f7f7', '#fbe6f2', '#eef2e0', '#f6e8df', '#e9ecf8');
    my %ucolor;        # sender -> tag name ("u<n>")
    my $unext = 0;
    my $user_tag = sub {
        my ($who) = @_;
        return $ucolor{$who} if exists $ucolor{$who};
        my $tag = 'u' . $unext;
        $txt->tagConfigure($tag, -background => $PALETTE[$unext % @PALETTE]);
        $unext++;
        return $ucolor{$who} = $tag;
    };

    my $set_fold = sub {
        my ($ord, $f) = @_;
        return unless defined $ord && $txt->tagRanges("b$ord");   # foldable only
        $folded{$ord} = $f ? 1 : 0;
        $txt->tagConfigure("b$ord", -elide => $f ? 1 : 0);
        $txt->tagConfigure("k$ord", -elide => $f ? 0 : 1);
    };

    my $insert_msg = sub {
        my ($where, $kv, $fold) = @_;        # $where = 'end' or '1.0'
        return if defined $kv->{id} && $shown{$kv->{id}}++;
        my $ord = $mseq++;
        my $t = $fmt->($kv);
        chomp $t;
        # Fold boundary: the first newline or column 100, whichever comes first.
        # A folded message shows head + " [+]"; expanding reveals head + rest
        # contiguously (no inserted newline) so a long line wraps as written.
        my $cut = length $t;
        my $nl  = index($t, "\n");
        $cut = $nl if $nl >= 0 && $nl < $cut;
        $cut = 100 if 100 < $cut;
        my $head = substr($t, 0, $cut);
        my $rest = substr($t, $cut);
        my $who  = $kv->{sender} // '?'; utf8::decode($who);
        my $ut   = $user_tag->($who);        # per-sender background tint
        # A completed upload is a system message "<who> uploaded <file> (size)";
        # tag it 'file' and remember the name so right-click can offer Save As.
        my @base = ('msg', $ut, "i$ord");
        if (($kv->{sender_kind} // '') eq 'system'
            && ($kv->{body} // '') =~ /\buploaded\s+(\S+)\s+\(/) {
            $file_of_ord{$ord} = $1;
            push @base, 'file';
        }
        $txt->configure(-state => 'normal');
        if (length $rest) {                  # long / multi-line -> foldable
            $txt->insert($where,
                $head,  [@base],
                ' [+]', [@base, "k$ord"],
                $rest,  [@base, "b$ord"],
                "\n",   [@base]);
            $txt->tagConfigure("b$ord", -elide => $fold ? 1 : 0);
            $txt->tagConfigure("k$ord", -elide => $fold ? 0 : 1);
            $folded{$ord} = $fold ? 1 : 0;
        } else {                             # single line -> nothing to fold
            $txt->insert($where, $head."\n", [@base]);
        }
        $txt->configure(-state => 'disabled');
        if ($where eq '1.0') { unshift @order, $ord } else { push @order, $ord }
        $otext{$ord} = $t;
        $txt->see('end') if $where eq 'end';
        $note_id->($kv->{id});
    };
    my $append  = sub { $insert_msg->('end', $_[0], $_[1]) };  # live  (unfolded)
    my $prepend = sub { $insert_msg->('1.0', $_[0], 1) };      # older (folded)

    my $clear = sub {
        $txt->configure(-state => 'normal');
        $txt->delete('1.0', 'end');
        $txt->configure(-state => 'disabled');
        $min_shown = undef;
        %shown = (); @order = (); %otext = (); %folded = (); %file_of_ord = ();
        $last_hit = undef; $last_q = '';
    };

    # Click handling: left-click opens a folded message, right-click folds it.
    # The ordinal is read back from the "i<n>" tag under the pointer.
    $txt->tagConfigure('hit', -background => '#ffd54a', -foreground => 'black');
    my $ord_at = sub {
        my ($idx) = @_;
        for my $tag ($txt->tagNames($idx)) { return $1 if $tag =~ /^i(\d+)$/ }
        return undef;
    };
    $txt->tagBind('msg', '<Button-1>',
        sub { $set_fold->($ord_at->($txt->index('current')), 0) });
    $txt->tagBind('msg', '<Button-3>',
        sub { $set_fold->($ord_at->($txt->index('current')), 1) });
    $txt->tagBind('msg', '<Enter>', sub { $txt->configure(-cursor => 'hand2') });
    $txt->tagBind('msg', '<Leave>', sub { $txt->configure(-cursor => 'xterm') });

    # Uploaded files (system "… uploaded <file> …" lines) are tagged 'file' and
    # underlined; right-click one for a Save As menu that downloads it (chunked
    # CHAT_GET, like `net-chat download`).
    $txt->tagConfigure('file', -underline => 1);
    my $download_file = sub {
        my ($name) = @_;
        return unless defined $name && length $name && defined $cur;
        my $dest = $mw->getSaveFile(-title => "Save '$name' as",
                                    -initialfile => $name);
        return unless defined $dest && length $dest;
        open my $fh, '>', $dest or return $set_status->("write $dest: $!");
        binmode $fh;
        require MIME::Base64;
        $set_status->("downloading $name ..."); $mw->update;
        my $offset = 0;
        while (1) {
            my $gr = eval { $ctrl->chat_get(session => $cur, file => $name,
                                            offset => $offset) };
            if ($@) { close $fh; return $set_status->("download failed: $@") }
            my $chunk = defined $gr->{data}
                ? MIME::Base64::decode_base64($gr->{data}) : '';
            print {$fh} $chunk;
            $offset += length $chunk;
            last if $gr->{eof} || length($chunk) == 0;
        }
        close $fh;
        $set_status->("saved $name -> $dest ($offset bytes)");
    };
    # Delete an uploaded file from the chat (confirm first — it's irreversible).
    my $delete_file = sub {
        my ($name) = @_;
        return unless defined $name && length $name && defined $cur;
        my $ans = $mw->messageBox(
            -type => 'yesno', -icon => 'warning', -default => 'no',
            -title => 'Delete file',
            -message => "Delete '$name' from '$cur'?\nThis cannot be undone.");
        return unless lc($ans) eq 'yes';
        my $ok = eval { $ctrl->chat_rm(session => $cur, file => $name); 1 };
        $set_status->($ok ? "deleted $name" : "delete failed: $@");
    };
    my $rc_file;
    my $filemenu = $mw->Menu(-tearoff => 0);
    $filemenu->add('command', -label => 'Save As...',
                   -command => sub { $download_file->($rc_file) });
    $filemenu->add('separator');
    $filemenu->add('command', -label => 'Delete...',
                   -command => sub { $delete_file->($rc_file) });
    $txt->tagBind('file', '<Button-3>', sub {
        my $ord = $ord_at->($txt->index('current'));
        return unless defined $ord && defined $file_of_ord{$ord};
        $rc_file = $file_of_ord{$ord};
        $filemenu->entryconfigure(0, -label => "Save '$rc_file' As...");
        $filemenu->entryconfigure(2, -label => "Delete '$rc_file'...");
        $filemenu->post($txt->pointerxy);
    });

    # -- search row: scan all loaded messages, reveal + highlight the match ----
    my $srch = $mw->Frame;
    $srch->pack(-before => $txt, -fill => 'x', -padx => 4, -pady => 2);
    $srch->Label(-text => 'search:')->pack(-side => 'left');
    my $searchvar = '';
    my $se = $srch->Entry(-textvariable => \$searchvar)
                  ->pack(-side => 'left', -fill => 'x', -expand => 1);
    my $find = sub {
        my ($dir) = @_;                      # +1 next match, -1 previous
        my $q = $searchvar;
        $txt->tagRemove('hit', '1.0', 'end');
        return unless length $q;
        if ($q ne $last_q) { $last_hit = undef; $last_q = $q }
        my $n = @order or return $set_status->('no messages');
        my $lc = lc $q;
        my $from = $dir > 0 ? -1 : 0;        # first search starts at the top
        if (defined $last_hit) {
            for my $j (0 .. $n-1) { $from = $j, last if $order[$j] == $last_hit }
        }
        for my $step (1 .. $n) {
            my $j = ($from + $dir*$step) % $n; $j += $n if $j < 0;
            my $ord = $order[$j];
            next unless index(lc($otext{$ord}), $lc) >= 0;
            $last_hit = $ord;
            $set_fold->($ord, 0);            # reveal the matching message
            my @r = $txt->tagRanges("i$ord") or last;
            my $hit = $txt->search('-nocase', '--', $q, $r[0], $r[1]);
            if ($hit) {
                $txt->tagAdd('hit', $hit, "$hit + ".length($q)." chars");
                $txt->tagRaise('hit');       # stay above per-user tint
                $txt->see($hit);
            } else { $txt->see($r[0]) }
            return $set_status->("match ".($j+1)."/$n for '$q'"
                               . " - Enter=next, Shift-Enter=prev");
        }
        $set_status->("no match for '$q'");
    };
    $se->bind('<Return>',       sub { $find->( 1) });
    $se->bind('<Shift-Return>', sub { $find->(-1) });
    $srch->Button(-text => '>', -width => 2, -command => sub { $find->( 1) })
         ->pack(-side => 'right');
    $srch->Button(-text => '<', -width => 2, -command => sub { $find->(-1) })
         ->pack(-side => 'right');

    # Friendly display for a requester: an SSH key fingerprint becomes the
    # owning machine name (host_keys + machines) when known, else a shortened
    # fingerprint. Loopback 'as' names pass through unchanged.
    my $who_label = sub {
        my ($p) = @_;
        return $p unless defined $p && $p =~ /^SHA256:[\w+\/=]+$/;
        my $short = substr($p, 0, 18) . '...';
        my $hk = eval { $ctrl->snapshot(7, 'host_keys', where => "key_id = '$p'") } || [];
        if (@$hk && defined $hk->[0]{machine_id}) {
            my $mr = eval { $ctrl->snapshot(7, 'machines',
                                            where => "id = $hk->[0]{machine_id}") } || [];
            return "$mr->[0]{primary_name} ($short)"
                if @$mr && length($mr->[0]{primary_name} // '');
        }
        return $short;
    };
    my $req_popup = sub {
        my ($kv) = @_;
        my $sess = $kv->{session}   // return;
        my $who  = $kv->{principal} // return;
        return if $who eq $me;                       # not our own request
        return if $seen_req{"$sess/$who"}++;         # once per request
        # Pop for owners (always) and also when this user is ACTIVE IN the
        # session (currently viewing it == joined). The daemon (since the
        # see-and-request change) lets active members approve, not just
        # owners, so a member viewing the chat can let an unverified user in.
        return unless $is_loopback
                   || (($created_by{$sess} // '') eq $me)
                   || (defined $cur && $cur eq $sess);
        # Make the unverified prefix visible so the approver knows what they're
        # admitting — bake the explicit warning into the popup body.
        my $is_unverified = ($who =~ /^unverified:/);
        my $from = $kv->{requested_from};
        my $body = "'" . $who_label->($who) . "' requests to join '$sess'"
                 . (defined $from && length $from
                    ? "\nfrom $from" : '')
                 . ($is_unverified
                    ? "\n\nWARNING: This name is NOT cryptographically verified.\n"
                      . "Anyone calling themselves this from the network can join\n"
                      . "with the same name once you approve."
                    : "");
        my $pop = $mw->Toplevel; $pop->title('join request');
        $pop->Label(-text => $body, -padx => 14, -pady => 12,
                    -justify => 'left')->pack;
        my $act = sub {
            my ($op) = @_;
            eval { $ctrl->chat_member($op, session => $sess, principal => $who) };
            $set_status->($@ ? "$op failed: $@" : "$op $who -> $sess");
            $pop->destroy;
        };
        my $bf = $pop->Frame->pack(-pady => 8);
        my $approve_btn = $bf->Button(-text => 'Approve',
                                      -command => sub { $act->('approve') });
        $approve_btn->pack(-side => 'left', -padx => 6);
        my $reject_btn  = $bf->Button(-text => 'Reject',
                                      -command => sub { $act->('reject') });
        $reject_btn->pack(-side => 'left', -padx => 6);
        # Ignore is process-scoped: dedup'd by %seen_req which is reset every
        # time the GUI starts. The chat_members row stays at 'requested', so
        # the next net-chat process's SUBSCRIBE snapshot re-delivers it and
        # the popup re-appears. Surface that to the user in the status bar
        # so they aren't worried about "did I just lose this request".
        my $ignore_btn = $bf->Button(-text => 'Ignore', -command => sub {
            $set_status->("ignored '" . $who_label->($who)
                        . "' for '$sess' — will reappear next net-chat launch");
            $pop->destroy;
        });
        $ignore_btn->pack(-side => 'left', -padx => 6);
        require Tk::Balloon;
        my $bln = $pop->Balloon(-state => 'balloon', -initwait => 600);
        $bln->attach($approve_btn,
            -msg => "Admit '$who' to '$sess'. The server records the principal "
                  . "(and stashes the SSH pubkey if one was sent) so future "
                  . "AUTH from the same key auto-admits.");
        $bln->attach($reject_btn,
            -msg => "Mark '$who' as denied for '$sess'. Future join requests "
                  . "from this principal won't show a popup until you "
                  . "explicitly re-allow.");
        $bln->attach($ignore_btn,
            -msg => "Dismiss this popup for now. The request stays pending "
                  . "on the server and reappears the next time you launch "
                  . "net-chat. Useful for 'I'll decide later'.");
    };

    # Show the last N messages of the current session (one snapshot), oldest
    # first, so joining a chat isn't a blank window. History extends further
    # back from there; dedup keeps these from doubling with the live stream.
    my $seed_recent = sub {
        my $n = shift // 10;
        my $rows = eval { $ctrl->snapshot(8, 'chat_messages',
                                          where => "session = '$cur'") } || [];
        my @s = sort { ($a->{id} // 0) <=> ($b->{id} // 0) } @$rows;
        @s = @s[-$n .. -1] if @s > $n;
        $append->($_, 1) for @s;            # seeded context starts folded
    };

    my $follow = sub {
        my ($name) = @_;
        return unless defined $name && length $name;
        return if $name eq 'select' || $name eq '(no open chats)'
               || $name eq $NEWCHAT;
        return if defined $cur && $cur eq $name;
        # A closed session is still listed (it can be restarted): reopen it
        # before joining, so picking it from the list just works.
        if (($status{$name} // 'open') eq 'closed') {
            my $ok = eval { $ctrl->chat_open(name => $name); 1 };
            unless ($ok) { my $e = $@; chomp $e;
                           $set_status->("couldn't restart $name: $e"); return }
            $status{$name} = 'open';
        }
        $stream->send_line('UNSUB sub=1') if defined $cur;
        $clear->();
        $cur = $name;
        $mw->title("net-chat - $name");
        $topiclbl->configure(-text => ($created_by{$name} ? "owner: $created_by{$name}" : ''));
        # Remember this session as the "last open" for next launch. Silent
        # save failure (config unwritable, etc) — the picker still works.
        eval { NetMgr::Config->save_user_value('net-chat', 'last_session', $name) };
        eval { $ctrl->chat_join(session => $name) };   # roster + post rights
        # Stream new messages only; past messages are pulled in on demand with
        # the History button (one older line per click), so joining a busy chat
        # doesn't dump the whole backlog.
        $stream->send_line("SUBSCRIBE sub=1 mode=stream"
                         . " FROM chat_messages WHERE session = '$name'");
        $seed_recent->(10);                 # last 10 lines for context
        $set_status->("following $name - History for older messages");
        $update_bitchat_ui->($name);
        $entry->focus;
    };

    my $refresh = sub {
        # List ALL sessions, not just open ones — a closed session is still
        # joinable (it gets restarted when you pick it), so it should stay in
        # the list rather than vanishing.
        my $rows = eval { $ctrl->snapshot(9, 'chat_sessions') };
        if ($@) { $set_status->("refresh failed: $@"); return }
        $rows ||= [];
        %created_by = map { ($_->{name} => ($_->{created_by} // '')) } @$rows;
        %status     = map { ($_->{name} => ($_->{status}     // 'open')) } @$rows;
        # open first, then closed (restartable); alphabetical within each.
        my @names = sort {
            (($status{$a} // '') eq 'closed') <=> (($status{$b} // '') eq 'closed')
                || $a cmp $b
        } map { $_->{name} } @$rows;
        # Repopulate the menu WITHOUT firing -command (which would re-follow /
        # switch sessions mid-refresh), and keep the current selection if it
        # still exists.
        my $keep = $sessvar;
        $om->configure(-command => undef);
        # Rebuild the menu via the core runtime methods, NOT configure(-options=>...):
        # some Tk::Optionmenu versions only honor -options at creation, so a
        # post-creation configure(-options) silently no-ops — the picker never
        # repopulates and Refresh looks dead. menu->delete + addOptions works
        # across versions. (-command is nulled above so addOptions' auto-select
        # of the first entry can't fire a follow mid-rebuild.)
        $om->menu->delete(0, 'end');
        # Dormant (closed-but-restartable) sessions show a "(dormant)" label but
        # keep their bare name as the value, so $follow (which restarts them)
        # still gets the real session name.
        $om->addOptions('select',
            (map { ($status{$_} // 'open') eq 'closed' ? [ "$_  (dormant)" => $_ ] : $_ }
                 @names),
            $NEWCHAT);
        $sessvar = (defined $keep && grep { $_ eq $keep } @names) ? $keep : 'select';
        $om->configure(-command => sub {
            $sessvar eq $NEWCHAT ? $new_chat->() : $follow->($sessvar) });
        # Reload the open conversation too: re-arm the live stream (in case it
        # dropped) and re-seed recent lines. Without this Refresh only touched
        # the session menu, so sitting in a chat it looked like it did nothing.
        if (defined $cur) {
            $stream->send_line('UNSUB sub=1');
            $clear->();
            $stream->send_line("SUBSCRIBE sub=1 mode=stream"
                             . " FROM chat_messages WHERE session = '$cur'");
            $seed_recent->(10);
            $set_status->("refreshed $cur - " . scalar(@names) . ' chat(s)');
        } else {
            $set_status->(scalar(@names) . ' chat(s)');
        }
    };
    # History: each click pulls in the single next-older message (the newest one
    # below what's already shown) and prepends it at the top.
    my $load_history = sub {
        unless (defined $cur) { $set_status->('pick a chat first'); return }
        my $where = "session = '$cur'";
        $where .= " AND id < $min_shown" if defined $min_shown;
        my $rows = eval { $ctrl->snapshot(8, 'chat_messages', where => $where) };
        if ($@) { $set_status->("history failed: $@"); return }
        my ($msg) = sort { ($b->{id} // 0) <=> ($a->{id} // 0) } @{ $rows || [] };
        unless ($msg) { $set_status->('no older history'); return }
        $prepend->($msg);
        $set_status->("history: + 1 older line (id $msg->{id})");
    };

    # New-chat dialog: prompt for name/topic/mode, create it via the control
    # connection, then refresh the picker and follow the new chat.
    $new_chat = sub {
        my $pop = $mw->Toplevel; $pop->title('new chat');
        my $row = sub {
            my ($label) = @_;
            my $f = $pop->Frame->pack(-fill => 'x', -padx => 8, -pady => 3);
            $f->Label(-text => $label, -width => 6, -anchor => 'e')
              ->pack(-side => 'left');
            return $f;
        };
        my $namevar  = '';
        my $ne = $row->('name:')->Entry(-textvariable => \$namevar, -width => 26)
                     ->pack(-side => 'left', -fill => 'x', -expand => 1);
        my $topicvar = '';
        $row->('topic:')->Entry(-textvariable => \$topicvar, -width => 26)
            ->pack(-side => 'left', -fill => 'x', -expand => 1);
        my $modevar  = 'open';
        $row->('mode:')->Optionmenu(-variable => \$modevar,
                                    -options => ['open', 'list', 'request'])
            ->pack(-side => 'left');
        my $create = sub {
            (my $name = $namevar) =~ s/^\s+|\s+$//g;
            unless ($name =~ /\A[A-Za-z0-9][A-Za-z0-9._-]{0,63}\z/) {
                $set_status->("bad chat name (use A-Z a-z 0-9 . _ -)"); return;
            }
            my $ok = eval { $ctrl->chat_open(name => $name, mode => $modevar,
                (length $topicvar ? (topic => $topicvar) : ())); 1 };
            unless ($ok) { $set_status->("create '$name' failed: $@"); return }
            $pop->destroy;
            $refresh->();
            $sessvar = $name;
            $follow->($name);
        };
        my $bf = $pop->Frame->pack(-pady => 8);
        $bf->Button(-text => 'Create', -command => $create)
           ->pack(-side => 'left', -padx => 6);
        $bf->Button(-text => 'Cancel',
            -command => sub { $pop->destroy; $sessvar = $cur // 'select' })
           ->pack(-side => 'left', -padx => 6);
        $ne->bind('<Return>', $create);
        $ne->focus;
    };

    # -- chat-driven terminal --------------------------------------------
    # "terminal" launches your terminal emulator running a tmux session bound to
    # the current chat. Its input is then BOTH the keyboard (native, in the
    # terminal) AND any chat message that starts with "@<local user>": the
    # prefix is stripped and the rest is injected with `tmux send-keys`. Only
    # live messages from others in this chat are fed; output is not echoed back.
    my $localuser = $ENV{USER} // (getpwuid($<))[0] // 'user';
    my $term_cfg;                       # optional [chat] terminal override
    for my $p ($ENV{NET_MGR_CONF} // '/etc/net-mgr/config', NetMgr::Config->user_path) {
        next unless defined $p && -r $p;
        my $c = eval { NetMgr::Config->load($p) } or next;
        $term_cfg = $c->{chat}{terminal} if $c->{chat} && defined $c->{chat}{terminal};
    }
    my $term_prog = $term_cfg || $ENV{TERMINAL};
    unless ($term_prog) {
        CAND: for my $c (qw(x-terminal-emulator xterm gnome-terminal konsole
                            alacritty foot kitty)) {
            for my $d (split /:/, ($ENV{PATH} // '')) {
                -x "$d/$c" and $term_prog = $c, last CAND;
            }
        }
    }
    my ($term_session, $term_chat);
    my $tmux_send = sub {               # one literal line + Enter (no shell)
        my ($text) = @_;
        return unless defined $term_session;
        system('tmux', 'send-keys', '-t', $term_session, '-l', '--', $text);
        system('tmux', 'send-keys', '-t', $term_session, 'Enter');
    };
    my $term_feed = sub {               # inject a live chat message if it's for us
        my ($kv) = @_;
        return unless defined $term_session && defined $term_chat;
        return unless ($kv->{session} // '') eq $term_chat;
        return if ($kv->{sender} // '') eq $me;          # skip our own posts
        my $body = $kv->{body};
        return unless defined $body
                   && $body =~ s/^\s*\@\Q$localuser\E\b[\s:,]*//i && length $body;
        $tmux_send->($body);
        $set_status->("terminal <= \@$localuser: $body");
    };
    my $launch_term = sub {
        return $set_status->('terminal: no terminal emulator found '
                           . '(set [chat] terminal or $TERMINAL)') unless $term_prog;
        return $set_status->('terminal: pick a chat first') unless defined $cur;
        (my $name = "nc-$cur") =~ s/[^A-Za-z0-9_-]/_/g;   # tmux-safe session name
        # Pre-create the session so injection works the instant it's bound.
        system("tmux has-session -t $name 2>/dev/null") == 0
            or system('tmux', 'new-session', '-d', '-s', $name);
        my @cmd  = ('tmux', 'new-session', '-A', '-s', $name);
        my @argv = ($term_prog =~ /(?:gnome-terminal|konsole)$/)
                 ? ($term_prog, '--', @cmd) : ($term_prog, '-e', @cmd);
        my $pid = fork();
        return $set_status->("terminal: fork failed: $!") unless defined $pid;
        if ($pid == 0) {                              # detach via double-fork
            my $p2 = fork();
            CORE::exit(0) if $p2;
            { exec { $argv[0] } @argv }
            CORE::exit(127);
        }
        waitpid($pid, 0);
        ($term_session, $term_chat) = ($name, $cur);
        $set_status->("terminal '$name' up - '\@$localuser ...' in '$cur' runs in it");
    };

    $om->configure(-command => sub {
        $sessvar eq $NEWCHAT ? $new_chat->() : $follow->($sessvar) });
    # Action buttons. Pack on the right of $top when the window is wide
    # enough; on a narrow window, fold into a second row below $top.
    # Buttons are children of $mw so we can re-pack them with -in => $top
    # (wide) or -in => $top2 (narrow) without re-parenting.
    my $top2 = $mw->Frame;   # not packed yet
    # Members management dialog — opens a non-modal Toplevel listing the
    # current session's chat_members rows with per-row actions
    # (approve/reject for requested, remove for member, re-allow for
    # denied), plus an "Add by Key ID" entry at the bottom. Refresh on
    # each action so the list stays current without manual reopen.
    my $members_popup = sub {
        unless (defined $cur && length $cur) {
            $set_status->('pick a chat first to manage members');
            return;
        }
        my $dlg = $mw->Toplevel(-title => "Members of $cur");
        $dlg->transient($mw);
        $dlg->Label(-text => "Session: $cur",
                    -font => 'sans-serif 11 bold', -anchor => 'w')
            ->pack(-fill => 'x', -padx => 10, -pady => [10, 2]);
        my $info = $created_by{$cur} ? "owner: $created_by{$cur}" : '';
        $dlg->Label(-text => $info, -anchor => 'w', -foreground => '#666')
            ->pack(-fill => 'x', -padx => 10, -pady => [0, 6]) if length $info;

        my $list_frame = $dlg->Frame(-relief => 'sunken', -borderwidth => 1);
        $list_frame->pack(-fill => 'both', -expand => 1, -padx => 10, -pady => 4);

        my $populate;
        $populate = sub {
            # Tear down + rebuild — simpler than per-row diffing for a
            # member count that's never going to be large.
            $_->destroy for $list_frame->children;
            my $c = connect_client(want_auth => 0);
            my $rows = eval {
                $c->snapshot(1, 'chat_members', where => "session = '$cur'");
            } || [];
            eval { $c->bye };

            my $hdr = $list_frame->Frame->pack(-fill => 'x', -padx => 4, -pady => 2);
            $hdr->Label(-text => 'principal', -width => 26,
                        -font => 'sans-serif 9 bold', -anchor => 'w')
                ->pack(-side => 'left');
            $hdr->Label(-text => 'role', -width => 8,
                        -font => 'sans-serif 9 bold', -anchor => 'w')
                ->pack(-side => 'left');
            $hdr->Label(-text => 'state', -width => 10,
                        -font => 'sans-serif 9 bold', -anchor => 'w')
                ->pack(-side => 'left');
            $hdr->Label(-text => 'from', -width => 20,
                        -font => 'sans-serif 9 bold', -anchor => 'w')
                ->pack(-side => 'left');

            # IP → hostname resolver with a per-populate cache. The
            # requested_from column carries whatever peer address the
            # daemon captured when the CHAT_JOIN arrived — usually the
            # remote IPv4 (or v6). Show the friendly name where DNS/
            # /etc/hosts has one; strip the port for cleaner display.
            # Sync gethostbyaddr with a 1s alarm guards against a slow
            # resolver blocking the whole GUI thread.
            my %hostcache;
            my $host_for = sub {
                my ($from) = @_;
                return '' unless defined $from && length $from;
                my $host_port = $from;
                (my $host = $host_port) =~ s/:\d+$//;
                return $hostcache{$host} if exists $hostcache{$host};
                # Already a name (contains letters)? just return.
                if ($host =~ /[A-Za-z]/) { return $hostcache{$host} = $host }
                my $name;
                eval {
                    require Socket;
                    local $SIG{ALRM} = sub { die "timeout\n" };
                    alarm 1;
                    my $packed = Socket::inet_aton($host);
                    if ($packed) {
                        $name = gethostbyaddr($packed, Socket::AF_INET());
                    }
                    alarm 0;
                };
                alarm 0;
                # Drop the trailing .grfx.com / .local / whatever so it fits
                # in the 20-char column — the shortname is what the user
                # recognises anyway ("gateway2" not "gateway2.grfx.com").
                if (defined $name && length $name) {
                    $name =~ s/\..*$//;
                    return $hostcache{$host} = $name;
                }
                return $hostcache{$host} = $host;
            };
            $hdr->Label(-text => 'actions',
                        -font => 'sans-serif 9 bold', -anchor => 'w')
                ->pack(-side => 'left');

            unless (@$rows) {
                $list_frame->Label(-text => '(no members yet)',
                                   -foreground => '#888')
                    ->pack(-padx => 10, -pady => 8);
                return;
            }

            # Sort: requested first (action-needed), then members, then
            # invited / denied. Within each group: alphabetical principal.
            my %prio = (requested => 0, invited => 1, member => 2, denied => 3);
            for my $m (sort {
                ($prio{$a->{state} // ''} // 9) <=>
                ($prio{$b->{state} // ''} // 9)
                || ($a->{principal} // '') cmp ($b->{principal} // '')
            } @$rows) {
                my $rf = $list_frame->Frame->pack(-fill => 'x',
                                                  -padx => 4, -pady => 1);
                $rf->Label(-text => $m->{principal}    // '?',
                           -width => 26, -anchor => 'w')->pack(-side => 'left');
                $rf->Label(-text => $m->{role}         // '?',
                           -width => 8,  -anchor => 'w')->pack(-side => 'left');
                $rf->Label(-text => $m->{state}        // '?',
                           -width => 10, -anchor => 'w')->pack(-side => 'left');
                $rf->Label(-text => $host_for->($m->{requested_from}),
                           -width => 20, -anchor => 'w')->pack(-side => 'left');
                # State-specific actions. All four ops go through the
                # same $ctrl, which may need to be AUTH'd — server-side
                # only owners + members-of-the-session can run these.
                my $state = $m->{state} // '';
                my $princ = $m->{principal};
                my $act = sub {
                    my ($op) = @_;
                    eval { $ctrl->chat_member($op, session => $cur,
                                              principal => $princ) };
                    if ($@) {
                        my $e = $@; chomp $e;
                        # Errors from destructive ops (delete/promote/deny)
                        # commonly come back as "not authorized" or
                        # "refuse to delete the last owner" — both are
                        # ONLY visible in the tiny status bar today. Pop
                        # a modal so the operator actually sees why the
                        # row didn't disappear.
                        $set_status->("$op $princ failed: $e");
                        $dlg->messageBox(
                            -type    => 'ok',
                            -icon    => 'warning',
                            -title   => "$op failed",
                            -message => "$op '$princ' -> '$cur' failed:\n\n$e");
                    } else {
                        $set_status->("$op $princ → $cur");
                    }
                    $populate->();
                };
                if ($state eq 'requested') {
                    $rf->Button(-text => 'Approve',
                                -command => sub { $act->('approve') })
                        ->pack(-side => 'left', -padx => 2);
                    $rf->Button(-text => 'Reject',
                                -command => sub { $act->('reject') })
                        ->pack(-side => 'left', -padx => 2);
                } elsif ($state eq 'member') {
                    # Promote a plain member to owner. Owners get no
                    # promote button (nothing above owner); demote could
                    # be added here later if the ask surfaces.
                    if (($m->{role} // '') eq 'member') {
                        $rf->Button(-text => 'Promote',
                                    -command => sub { $act->('promote') })
                            ->pack(-side => 'left', -padx => 2);
                    }
                    # Disable = set state='denied' (reversible via
                    # Re-allow). Replaces the old "Remove" label — the row
                    # persists so history stays clear about who was here.
                    $rf->Button(-text => 'Disable',
                                -command => sub { $act->('deny') })
                        ->pack(-side => 'left', -padx => 2);
                } elsif ($state eq 'denied') {
                    $rf->Button(-text => 'Re-allow',
                                -command => sub { $act->('allow') })
                        ->pack(-side => 'left', -padx => 2);
                } elsif ($state eq 'invited') {
                    $rf->Button(-text => 'Cancel',
                                -command => sub { $act->('deny') })
                        ->pack(-side => 'left', -padx => 2);
                }
                # DM — open a private two-party session between me and
                # this principal. Session names must match
                # [A-Za-z0-9][A-Za-z0-9._-]{0,63} (see need_name +
                # server-side validator), so principals like "dkc@bigsony"
                # need sanitizing: '@' and any other non-allowed char → '_'.
                # Both endpoints compute the same canonical name because
                # sanitize+sort are deterministic. Use request-mode so
                # the DM roster is locked to the two named parties. Human-
                # readable topic keeps the ORIGINAL principals visible.
                my $dm_target = $princ;
                if (defined $dm_target && length $dm_target && $dm_target !~ /^unverified:/) {
                    $rf->Button(-text => 'DM', -command => sub {
                        my $me   = $as // $key_id // 'anon';
                        my @who  = sort ($me, $dm_target);
                        my $sanitize = sub {
                            (my $s = shift) =~ s/[^A-Za-z0-9._-]/_/g; $s
                        };
                        # `dm-<a>__<b>` — 'dm-' prefix + __ separator both
                        # allowed; keeps the two sanitized principals visible
                        # in the dropdown label. Cap at 63 chars total after
                        # the leading 'dm-' (server allows up to 64).
                        my $dm_name = 'dm-' . join('__',
                            $sanitize->($who[0]), $sanitize->($who[1]));
                        $dm_name = substr($dm_name, 0, 64);
                        eval { $ctrl->chat_open(name => $dm_name,
                                                mode => 'request',
                                                topic => "DM: $who[0] & $who[1]") };
                        # Server returns "CHAT_OPEN: session 'X' exists" for
                        # already-open sessions — that's the happy path here,
                        # we just want the session to EXIST. Report other
                        # errors (e.g. bad mode, name too long) so a
                        # dead-in-the-water DM click isn't silent.
                        if ($@ && $@ !~ /\bexists\b/i) {
                            my $e = $@; chomp $e;
                            $set_status->("DM: $e");
                            return;
                        }
                        eval { $ctrl->chat_member('allow', session => $dm_name,
                                                  principal => $dm_target) };
                        # (allow-failed is non-fatal — target may already be
                        # a member; the follow below is what actually matters)
                        $refresh->();
                        $follow->($dm_name);
                        $set_status->("DM $dm_name — " . scalar(@who) . " parties");
                        $dlg->destroy;
                    })->pack(-side => 'left', -padx => 2);
                }
                # Delete (destructive) — available on every state. Removes
                # the chat_members row entirely; the principal can rejoin
                # via a fresh CHAT_JOIN. Server refuses to delete the
                # last owner. No confirmation prompt: the wastebasket
                # icon is unambiguous, and the previous yesno messageBox
                # was silently swallowing clicks on some Tk builds
                # because the return value wasn't literally 'yes'. If
                # you want the ROW-preserving version, use Disable.
                $rf->Button(-text => "\x{1f5d1}",   # 🗑 wastebasket
                            -font => 'ncui',
                            -command => sub { $act->('delete') })
                    ->pack(-side => 'left', -padx => 2);
            }

            # BitChat peer section — shown only when the current session
            # IS the bitchat-bridge (or a bitchat/geohash subsession). Rows
            # come from the bitchat_peers table, populated by the local
            # net-bitchat-bridge supervisor's periodic {"cmd":"peers"} poll.
            # These aren't chat_members — they're distinct BLE peers with
            # no chat_authorized_keys or role — so they get a separator +
            # a "BitChat #mesh" label and no per-row action buttons (for
            # now). Future: promote a BitChat peer to chat_member with
            # one click, once SSH-Ed25519 identity binding lands on both
            # sides.
            if (defined $cur && ($cur eq 'bitchat-bridge'
                              || $cur =~ /^bitchat[-\/]/))
            {
                my $peers = eval {
                    my $c2 = connect_client(want_auth => 0);
                    my $r  = $c2->snapshot(4, 'bitchat_peers');
                    eval { $c2->bye };
                    $r;
                } || [];
                if (@$peers) {
                    # Section header — a thin separator + label.
                    $list_frame->Frame(-height => 1, -background => '#888')
                        ->pack(-fill => 'x', -padx => 4, -pady => [10, 2]);
                    $list_frame->Label(
                        -text   => 'BitChat #mesh — BLE peers in range',
                        -font   => 'sans-serif 9 bold',
                        -anchor => 'w',
                        -foreground => '#555',
                    )->pack(-fill => 'x', -padx => 4);
                    # Sort connected first, then last_seen desc, then nick.
                    for my $p (sort {
                        (($b->{is_connected} // 0) <=> ($a->{is_connected} // 0))
                        || (($b->{last_seen} // '') cmp ($a->{last_seen} // ''))
                        || (($a->{nickname} // '') cmp ($b->{nickname} // ''))
                    } @$peers) {
                        my $rf = $list_frame->Frame->pack(-fill => 'x',
                                                          -padx => 4, -pady => 1);
                        $rf->Label(-text => $p->{nickname} // '(anon)',
                                   -width => 26, -anchor => 'w')
                            ->pack(-side => 'left');
                        $rf->Label(-text => $p->{peer_id} // '?',
                                   -width => 18, -anchor => 'w',
                                   -foreground => '#888',
                                   -font => 'ncmono 9')
                            ->pack(-side => 'left');
                        $rf->Label(
                            -text  => ($p->{is_connected} ? 'connected' : 'seen'),
                            -width => 10, -anchor => 'w',
                            -foreground => ($p->{is_connected} ? '#080' : '#888'),
                        )->pack(-side => 'left');
                        my $seen = $p->{last_seen} // '';
                        # DB gives "YYYY-MM-DD HH:MM:SS" — show the time only
                        # if today, else the whole thing.
                        $seen =~ s/^\d{4}-\d\d-\d\d //
                            if $seen =~ /^\Q@{[substr($seen,0,10)]}\E/;
                        $rf->Label(-text => $seen, -anchor => 'w',
                                   -foreground => '#888')
                            ->pack(-side => 'left');
                        # DM button — pops a small text dialog that posts a
                        # message tagged with "@<peer_id>:" prefix. The
                        # net-bitchat-bridge supervisor recognises that
                        # prefix and, instead of a broadcast, writes a
                        # {"cmd":"send","to_peer":"HEX16","body":"..."} to
                        # the helper's stdin — Noise-encrypted private
                        # message straight to that BitChat peer.
                        my $peer_id = $p->{peer_id};
                        my $peer_nick = $p->{nickname} // '(anon)';
                        if (defined $peer_id && length $peer_id) {
                            $rf->Button(-text => 'DM', -command => sub {
                                my $dm = $mw->Toplevel(
                                    -title => "DM BitChat: $peer_nick");
                                $dm->transient($dlg);
                                $dm->Label(
                                    -text => "Private message to $peer_nick ($peer_id)",
                                    -anchor => 'w')
                                    ->pack(-fill => 'x', -padx => 10, -pady => [10,4]);
                                my $txt = $dm->Text(-height => 5, -width => 50,
                                                    -wrap => 'word', -font => 'ncui');
                                $txt->pack(-fill => 'both', -expand => 1,
                                           -padx => 10, -pady => 4);
                                $txt->focus;
                                my $btns = $dm->Frame->pack(-fill => 'x',
                                                            -padx => 10, -pady => 8);
                                $btns->Button(-text => 'Cancel',
                                    -command => sub { $dm->destroy })
                                    ->pack(-side => 'right', -padx => 2);
                                $btns->Button(-text => 'Send',
                                    -command => sub {
                                        my $body = $txt->get('1.0', 'end');
                                        $body =~ s/\s+$//;
                                        return unless length $body;
                                        my $tagged = "\@$peer_id: $body";
                                        eval { $ctrl->chat_post(
                                            session => 'bitchat-bridge',
                                            body    => $tagged, as => $as) };
                                        if ($@) {
                                            my $e = $@; chomp $e;
                                            $set_status->("DM to $peer_nick failed: $e");
                                        } else {
                                            $set_status->("DM sent to $peer_nick");
                                        }
                                        $dm->destroy;
                                    })->pack(-side => 'right', -padx => 2);
                            })->pack(-side => 'left', -padx => 4);
                        }
                    }
                } else {
                    $list_frame->Frame(-height => 1, -background => '#888')
                        ->pack(-fill => 'x', -padx => 4, -pady => [10, 2]);
                    $list_frame->Label(
                        -text => 'BitChat #mesh — no BLE peers seen yet',
                        -foreground => '#888',
                    )->pack(-padx => 4, -pady => 2);
                }
            }
        };
        $populate->();

        # Pin a min-size after the first populate so a Delete doesn't snap the
        # dialog to a smaller natural size on the first row removal. Tk's
        # default geometry manager auto-fits the Toplevel to the current
        # requested size of its packed contents, and the FIRST time we destroy
        # + rebuild $list_frame with fewer rows the outer window shrinks;
        # subsequent deletes look stable only because the dialog is already at
        # natural size. Deferring via `after idle` runs this AFTER the window
        # is actually realized on screen — width()/height() before then can
        # return 1 (unmapped default) and pin a useless minsize=1x1. Reqwidth
        # /reqheight are the widget's computed natural size, safe regardless
        # of mapping state.
        $dlg->after(0, sub {
            my ($w, $h) = ($dlg->reqwidth, $dlg->reqheight);
            $dlg->minsize($w, $h) if $w > 20 && $h > 20;
        });

        # Add a new member by Key ID (= principal in remote allowed_signers).
        # Uses CHAT_ALLOW which puts them straight on the allow-list as a
        # member without requiring a join request.
        my $add_frame = $dlg->Frame->pack(-fill => 'x', -padx => 10, -pady => 4);
        $add_frame->Label(-text => 'Add by Key ID:', -anchor => 'w')
                  ->pack(-side => 'left');
        my $new_p = '';
        $add_frame->Entry(-textvariable => \$new_p, -width => 30)
                  ->pack(-side => 'left', -padx => 4, -fill => 'x',
                         -expand => 1);
        $add_frame->Button(-text => 'Add', -command => sub {
            my $p = $new_p; $p =~ s/^\s+|\s+$//g;
            return unless length $p;
            eval { $ctrl->chat_member('allow', session => $cur,
                                      principal => $p) };
            if ($@) {
                my $e = $@; chomp $e;
                $set_status->("add $p failed: $e");
            } else {
                $set_status->("added $p to $cur");
                $new_p = '';
                $populate->();
            }
        })->pack(-side => 'left', -padx => 2);

        my $btns = $dlg->Frame->pack(-fill => 'x', -padx => 10, -pady => 8);
        $btns->Button(-text => 'Refresh', -command => $populate)
             ->pack(-side => 'left', -padx => 2);
        $btns->Button(-text => 'Close', -command => sub { $dlg->destroy })
             ->pack(-side => 'right', -padx => 2);
    };

    my $refresh_btn = $mw->Button(-text => 'Refresh', -command => $refresh);
    my $history_btn = $mw->Button(-text => 'History', -command => $load_history);
    my $term_btn    = $mw->Button(-text => 'terminal', -command => $launch_term);
    my $members_btn = $mw->Button(-text => 'Members',  -command => $members_popup);
    my $aplus_btn   = $mw->Button(-text => 'A+', -width => 2,
        -command => sub { $fontsize++ if $fontsize < 32; $set_font->() });
    my $aminus_btn  = $mw->Button(-text => 'A-', -width => 2,
        -command => sub { $fontsize-- if $fontsize > 6; $set_font->() });
    my @action_btns = ($refresh_btn, $history_btn, $term_btn, $members_btn,
                       $aplus_btn, $aminus_btn);
    # Initial pack: side-by-side in $top (wide). Reflow on <Configure>.
    $_->pack(-in => $top, -side => 'right') for @action_btns;

    # Width threshold at which the action buttons fold to row 2. Picked by
    # measuring the bare-minimum layout (server picker + chat picker + a
    # few topic chars) so the fold kicks in only when truly cramped. Both
    # the topbar fold AND the status label wraplength rebind to current
    # window width so they grow with the toplevel.
    my $folded = 0;
    my $reflow_topbar = sub {
        my $w = $mw->width;
        return unless defined $w && $w > 1;   # initial firing has bogus width
        $status_lbl->configure(-wraplength => $w - 20) if $status_lbl;
        # Topic label wraps within whatever horizontal space it actually
        # got after the dropdowns/buttons claim theirs. Read the widget's
        # rendered width directly so we wrap to the SPACE IT HAS, not the
        # whole window. Guard against the feedback loop (configure ->
        # repaint -> Configure event -> configure) by only changing when
        # the delta is meaningful.
        if ($topiclbl) {
            my $lw = $topiclbl->width;
            if ($lw > 30) {
                my $cur = $topiclbl->cget(-wraplength);
                my $new = $lw - 8;
                $topiclbl->configure(-wraplength => $new)
                    if abs(($cur // 0) - $new) > 4;
            }
        }
        my $thresh = 720;
        if ($w < $thresh && !$folded) {
            $_->packForget for @action_btns;
            $top2->pack(-fill => 'x', -padx => 4, -pady => [0, 3], -after => $top);
            for my $b (@action_btns) {
                $b->pack(-in => $top2, -side => 'right', -padx => 2);
            }
            $folded = 1;
        } elsif ($w >= $thresh && $folded) {
            $_->packForget for @action_btns;
            $top2->packForget;
            $_->pack(-in => $top, -side => 'right') for @action_btns;
            $folded = 0;
        }
    };
    $mw->bind('<Configure>', $reflow_topbar);

    my $send = sub {
        my $body = $entry->get;
        return unless length $body;
        unless (defined $cur) { $set_status->('pick a chat first'); return }
        eval { $ctrl->chat_post(session => $cur, body => $body,
                                ($is_loopback ? (as => $as) : ())) };
        my $err = $@;
        if (!$err) {
            $entry->delete(0, 'end');
            return;
        }
        # Membership gating: unauth user posting to a non-loopback session
        # gets "not a member of '<X>'" or "not authorized to post". Don't
        # surface that as a raw error or pop a local AUTH dialog — the
        # right flow is to QUEUE a join request (server-side already
        # supports it; see chat_join's see-and-request mode). The user
        # then sees "waiting" while an owner on ANOTHER machine sees the
        # request and approves; the user's pubkey gets persisted into the
        # chat's allow-list so subsequent posts work without re-asking.
        if ($err =~ /chat_msg: not a member of|not authorized to post/i) {
            my $jr = eval { $ctrl->chat_join(session => $cur) };
            my $jerr = $@;
            my $state = ($jr && ref $jr eq 'HASH') ? ($jr->{state} // '') : '';
            if ($jerr) {
                # join itself failed (e.g. session in list-only mode and we
                # have no key to attach) — fall back to the raw error so
                # the user knows it's not a transient hiccup.
                chomp $jerr;
                $set_status->("post needs membership; join failed: $jerr");
            } elsif ($state eq 'requested') {
                # Name the actual owners + the principal we were
                # identified as, so the user knows WHO has to approve
                # and WHAT they'll see. Owners come from chat_members
                # (role='owner', state='member'); fall back to the
                # session's created_by row if no chat_members owners
                # exist (single-creator session). Identity comes from
                # the chat_join reply ($jr->{principal}) so the user
                # sees the exact name the owner will see.
                my @owners = _gui_session_owners($cur);
                my $me_id  = ($jr && ref $jr eq 'HASH')
                           ? ($jr->{principal} // '') : '';
                $me_id ||= ($as // '');
                my $owner_str = @owners ? join(', ', @owners) : '(unknown)';
                $set_status->("join request sent for '$cur' "
                            . "as '$me_id'; waiting for: $owner_str. "
                            . "Text stays in the box.");
                # Keep the entry text so the user can retry once admitted
                # — no $entry->delete here.
                return;
            } elsif ($state eq 'member') {
                # Already a member somehow (race? loopback elevation?).
                # Retry the post once.
                eval { $ctrl->chat_post(session => $cur, body => $body,
                                        ($is_loopback ? (as => $as) : ())) };
                if ($@) {
                    chomp(my $e2 = $@);
                    $set_status->("post failed after join: $e2");
                } else {
                    $entry->delete(0, 'end');
                }
                return;
            } else {
                chomp(my $e = $err);
                $set_status->("post failed: $e (join state='$state')");
            }
            return;
        }
        chomp $err;
        $set_status->("post failed: $err");
        $entry->delete(0, 'end');
    };

    # Upload: pick a file and stream it to the current chat in 48 KB chunks
    # (the same CHAT_PUT loop as `net-chat upload`); the daemon posts a system
    # message on completion, which arrives live in the pane.
    my $upload = sub {
        unless (defined $cur) { $set_status->('pick a chat first'); return }
        my $path = $mw->getOpenFile(-title => "Upload to $cur");
        return unless defined $path && length $path;   # cancelled
        open my $fh, '<', $path or return $set_status->("open $path: $!");
        binmode $fh;
        require File::Basename; require MIME::Base64;
        my $name = File::Basename::basename($path);
        $set_status->("uploading $name ..."); $mw->update;
        my ($offset, $r) = (0, undef);
        while (1) {
            my $n   = read($fh, my $buf, 48 * 1024);
            $buf    = '' unless defined $n;
            my $eof = (!$n || eof($fh)) ? 1 : 0;
            $r = eval { $ctrl->chat_put(session => $cur, file => $name,
                offset => $offset, ($eof ? (eof => 1) : ()),
                data => MIME::Base64::encode_base64($buf, '')) };
            if ($@) { close $fh; return $set_status->("upload failed: $@") }
            $offset += length $buf;
            last if $eof;
        }
        close $fh;
        $set_status->("uploaded $name (" . ($r->{size} // $offset) . " bytes)");
    };

    $entry->bind('<Return>', $send);
    # Lazy-load Tk::Balloon (Tk's auto-loader warns otherwise — same idiom
    # find-xpra uses). Shared single Balloon attached to multiple buttons.
    require Tk::Balloon;
    my $balloon = $mw->Balloon(-state => 'balloon', -initwait => 600);
    my $send_btn   = $bot->Button(-text => 'Send', -command => $send)
                         ->pack(-side => 'right');
    # Upload glyph (an up-arrow). Rendered in the Courier 'ncmono' font, which
    # has Unicode coverage on this system — the default bar font does not.
    # Downloads are reached by right-clicking the upload message in the pane.
    my $upload_btn = $bot->Button(-text => "\x{2191}", -font => 'ncmonob',
                                  -command => $upload)
                         ->pack(-side => 'right');
    $balloon->attach($send_btn,
        -msg => "Send the message (Enter also sends).\n"
              . "Posting requires AUTH on closed/list-mode sessions.");
    $balloon->attach($upload_btn,
        -msg => "Upload a file to this chat.\n"
              . "Picks via a file dialog; posts a system message "
              . "with a link. Right-click an upload line in the "
              . "pane to download.");
    # Top-bar action tooltips — same shared Balloon.
    $balloon->attach($members_btn,
        -msg => "Open the members dialog for this chat. Shows everyone "
              . "in the roster (members, pending requests, denied) with "
              . "approve / reject / remove / re-allow buttons. Also lets "
              . "you add by Key ID. Server-side member ops require AUTH; "
              . "anonymous browse can view but not change.");
    $balloon->attach($refresh_btn,
        -msg => "Reload chat / session list from the daemon.");
    $balloon->attach($history_btn,
        -msg => "Load one older message into the pane (per click).");

    # live reader: drain all complete lines without blocking the event loop.
    # Assigned to the forward-declared $stream_reader so the server-switch
    # path can cancel this handler on the outgoing socket and re-bind the
    # same closure on the new one. The body reads through the $stream
    # lexical, so a reassignment of $stream (inside $switch_server below) is
    # picked up automatically — no need to redefine the reader.
    $stream_reader = sub {
        my $got = 0;
        while (defined(my $line = $stream->recv_line(0))) {
            $got++;
            my $c = parse_line($line) or next;
            if ($c->{verb} eq 'ROW') {
                my $t = $c->{kv}{table} // '';
                if    ($t eq 'chat_messages') { $append->($c->{kv});
                                                $term_feed->($c->{kv}) }
                elsif ($t eq 'chat_members'
                    && (($c->{kv}{state} // '') eq 'requested')) {
                    $req_popup->($c->{kv});
                }
            } elsif ($c->{verb} eq 'ERR') {
                $set_status->('err: ' . ($c->{msg} // ''));
            }
        }
        # Readable but no complete line drained: distinguish EOF (daemon gone)
        # from a partial line, so a closed socket doesn't busy-loop the GUI.
        if (!$got) {
            my $n = sysread($stream->{sock}, my $b, 4096);
            if (defined $n && $n == 0) {
                $mw->fileevent($stream->{sock}, 'readable', '');
                $set_status->('disconnected (daemon gone) -- pick a server to reconnect');
                $cur = undef;
                $sessvar = 'select';
                $om->menu->delete(0, 'end');
                $om->addOptions('select');
            } elsif (defined $n) {
                $stream->{buf} .= $b;
            }
        }
    };
    $mw->fileevent($stream->{sock}, 'readable', $stream_reader);
    # watch join requests across all sessions (filtered to ours in the popup)
    $stream->send_line('SUBSCRIBE sub=2 mode=snapshot+stream'
                     . " FROM chat_members WHERE state = 'requested'");

    # In-place server switch (used by the top-bar server picker). Tears the
    # current $stream + $ctrl down cleanly, updates $listen, reconnects
    # against the new address (with the same auth-failure fallback machinery
    # the initial connect uses), re-binds the SAME stream reader on the new
    # socket, then re-populates the session menu. Preserves the MainWindow,
    # font size, message log widget, and Tk::Balloon state — no exec, no
    # visible flash.
    #
    # If the reconnect fails or the user cancels the auth-failure dialog,
    # we STAY on the current server (revert $listen, keep the existing
    # $stream/$ctrl) — the alternative (destroy $mw) would be the same as
    # a hard exit, which is worse than "the switch didn't take".
    $switch_server = sub {
        my ($addr) = @_;
        return if $addr eq $listen;
        my $old_listen  = $listen;
        my $wanted      = $cur;   # try to re-follow this session on new server

        # Announce departure to the old daemon and stop the reader firing
        # against a socket that's about to be closed.
        eval { $ctrl->chat_leave(session => $cur) } if defined $cur;
        eval { $stream->send_line('UNSUB sub=1') };
        eval { $stream->send_line('UNSUB sub=2') };
        eval { $mw->fileevent($stream->{sock}, 'readable', '') };
        my $old_stream = $stream;
        my $old_ctrl   = $ctrl;

        # Try new. _gui_connect_with_dialog handles the auth-failure retry
        # loop; on_cancel here is a NO-OP so a cancelled dialog just leaves
        # us on the old server instead of exiting the GUI.
        $listen = $addr;
        my $cancelled = 0;
        my ($new_stream, $new_ctrl) = _gui_connect_with_dialog(
            $mw, on_cancel => sub { $cancelled = 1 });

        if (!$new_stream || !$new_ctrl) {
            # Revert. The old sockets are still alive (we sent UNSUB but
            # didn't close them), so rebind the reader against $old_stream
            # and carry on.
            $listen = $old_listen;
            $stream = $old_stream;
            $ctrl   = $old_ctrl;
            eval { $mw->fileevent($stream->{sock}, 'readable', $stream_reader) };
            # Re-arm the watcher subscription that we UNSUB'd above so join
            # requests keep landing in the popup.
            eval {
                $stream->send_line('SUBSCRIBE sub=2 mode=snapshot+stream'
                                 . " FROM chat_members WHERE state = 'requested'");
                if (defined $cur) {
                    $stream->send_line("SUBSCRIBE sub=1 mode=stream"
                                     . " FROM chat_messages WHERE session = '$cur'");
                }
            };
            # Restore the picker label so it reflects the still-live server.
            $srvvar = $cand{$listen}{label} // $listen;
            $set_status->($cancelled
                          ? "stayed on $old_listen (switch cancelled)"
                          : "switch to $addr failed - stayed on $old_listen");
            return;
        }

        # Success — retire the old sockets and swap.
        eval { $old_ctrl->bye };
        eval { $old_stream->bye };
        $stream = $new_stream;
        $ctrl   = $new_ctrl;
        $mw->fileevent($stream->{sock}, 'readable', $stream_reader);
        $stream->send_line('SUBSCRIBE sub=2 mode=snapshot+stream'
                         . " FROM chat_members WHERE state = 'requested'");

        # Reset the current-session state; $refresh + optional $follow
        # below will re-establish it against the new server.
        $cur     = undef;
        $sessvar = 'select';
        $clear->();
        $refresh->();

        # Re-follow the same session on the new server if it exists there
        # too — otherwise leave the user on the session picker. $refresh
        # populated %status; a session that survived the switch shows up
        # as an entry in the Optionmenu.
        if (defined $wanted && exists $status{$wanted}) {
            $sessvar = $wanted;
            $follow->($wanted);
        } else {
            $set_status->("connected to $addr - pick a session"
                          . (defined $wanted ? " ('$wanted' isn't on $addr)" : ""));
        }
    };

    $mw->protocol('WM_DELETE_WINDOW', sub {
        eval { $ctrl->chat_leave(session => $cur) } if defined $cur;
        eval { $ctrl->bye }; eval { $stream->bye };
        $mw->destroy;
    });

    $refresh->();
    $follow->($session) if defined $session && length $session;
    $entry->focus;
    Tk::MainLoop();
}

# ---- helpers ---------------------------------------------------------

# Wire SSH_ASKPASS to net-chat-askpass so ssh-keygen pops a Tk passphrase
# prompt for an encrypted SSH key instead of blocking on /dev/tty. Found via
# the same dir as the running net-chat (FindBin), so installs to non-default
# prefixes still work. SSH_ASKPASS_REQUIRE=force (OpenSSH >= 8.4) makes
# ssh-keygen use the askpass even with a controlling tty; on older OpenSSH the
# setsid wrapper in NetMgr::Client::auth is the fallback. Doesn't OVERRIDE a
# user-set SSH_ASKPASS (their custom helper wins).
sub _gui_set_askpass_env {
    require FindBin;
    my $shim = "$FindBin::Bin/net-chat-askpass";
    return unless -x $shim;
    $ENV{SSH_ASKPASS}         //= $shim;
    $ENV{SSH_ASKPASS_REQUIRE} //= 'force';
    # DISPLAY must be set for Tk to find the X server. Inherit if present;
    # otherwise the askpass child can't open a window and ssh-keygen falls back
    # to the (setsid'd) tty path. We don't try to invent one.
}

# net-chat --askpass MODE: stand-alone Tk passphrase prompt, invoked by
# ssh-keygen via the SSH_ASKPASS shim. The single argv is the prompt text
# ssh-keygen wants displayed (e.g. "Enter passphrase for key '/home/.../id_rsa':").
# Prints the typed passphrase to stdout on OK; exits 1 on cancel.
sub cmd_askpass {
    my @prompt_words = @_;
    my $prompt = join(' ', @prompt_words);
    $prompt = 'Enter passphrase:' unless length $prompt;
    require Tk;
    my $mw = Tk::MainWindow->new;
    $mw->withdraw;          # don't show the root MainWindow
    my $dlg = $mw->Toplevel(-title => 'SSH passphrase');
    $dlg->Label(-text => $prompt, -wraplength => 380,
                -justify => 'left', -anchor => 'w')
        ->pack(-fill => 'x', -padx => 12, -pady => [10, 6]);
    my $val = '';
    my $entry = $dlg->Entry(-textvariable => \$val, -show => '*', -width => 40)
                    ->pack(-fill => 'x', -padx => 12, -pady => [0, 8]);
    $entry->focus;
    my $result;     # 'ok' | 'cancel'
    my $btns = $dlg->Frame->pack(-fill => 'x', -padx => 12, -pady => [0, 10]);
    $btns->Button(-text => 'Cancel',
                  -command => sub { $result = 'cancel'; $dlg->destroy })
         ->pack(-side => 'right', -padx => 2);
    $btns->Button(-text => 'OK',
                  -command => sub { $result = 'ok'; $dlg->destroy })
         ->pack(-side => 'right', -padx => 2);
    $dlg->bind('<Return>' => sub { $result = 'ok';     $dlg->destroy });
    $dlg->bind('<Escape>' => sub { $result = 'cancel'; $dlg->destroy });
    $dlg->protocol('WM_DELETE_WINDOW',
                   sub { $result = 'cancel'; $dlg->destroy });
    $dlg->grab;
    $mw->waitWindow($dlg);
    if (defined $result && $result eq 'ok') {
        # Newline is required — ssh-keygen reads one line.
        print "$val\n";
        exit 0;
    }
    exit 1;
}

# Try to connect; if AUTH fails, pop a Tk dialog and let the user pick a
# different key, continue read-only, or cancel. Returns (stream, ctrl) on
# success or () if the user cancelled (MainWindow destroyed). Loops until one
# of those terminal outcomes — connect+auth retries with whatever the user just
# changed ($key_file/$key_id/$no_auth/$force_auth).
# Approvers for a chat session: every chat_members principal with
# role='owner' and state='member', plus the session's created_by as a
# fallback when no chat_members owner row exists. Returns a sorted
# unique list of principal strings (typically "user@host" key-ids).
# Called from $send's join-request path so the UI can surface WHO can
# approve, not just "an owner".
sub _gui_session_owners {
    my ($name) = @_;
    return () unless defined $name && length $name;
    my $c = eval { connect_client(want_auth => 0) } or return ();
    my $mrows = eval {
        $c->snapshot(1, 'chat_members',
            where => "session = '$name' AND role = 'owner' AND state = 'member'");
    } || [];
    my %seen;
    my @out;
    for my $r (@$mrows) {
        my $p = $r->{principal};
        next unless defined $p && length $p;
        next if $seen{$p}++;
        push @out, $p;
    }
    unless (@out) {
        my $srows = eval {
            $c->snapshot(2, 'chat_sessions', where => "name = '$name'");
        } || [];
        if (@$srows) {
            my $cb = $srows->[0]{created_by};
            push @out, $cb if defined $cb && length $cb;
        }
    }
    eval { $c->bye };
    return sort @out;
}

sub _gui_connect_with_dialog {
    my ($mw, %opts) = @_;
    # on_cancel lets a mid-session caller (the server-switch path) treat a
    # dialog cancel as "stay on the old server" instead of exiting the GUI —
    # startup callers keep the default (destroy $mw, exit).
    my $on_cancel = $opts{on_cancel} // sub { $mw->destroy };
    while (1) {
        my ($stream, $ctrl);
        my $err = '';
        eval {
            $stream = connect_client();
            $ctrl   = connect_client();
        };
        $err = $@ if $@;
        return ($stream, $ctrl) unless $err;

        # Transparent anonymous fallback: AUTH failed (key not in remote's
        # allowed_chat, etc.) but the daemon's open-mode sessions allow
        # anonymous BROWSE — only writes get gated. Try once with want_auth=>0
        # before bothering the user with the dialog. If anon also fails (e.g.
        # network unreachable), fall through to the dialog as before.
        if (!$no_auth && $err =~ /AUTH failed/i) {
            my ($s2, $c2);
            eval {
                $s2 = connect_client(want_auth => 0);
                $c2 = connect_client(want_auth => 0);
            };
            if (!$@ && $s2 && $c2) {
                $no_auth = 1;          # remember for downstream connect_client calls
                $force_auth = 0;
                return ($s2, $c2);
            }
        }

        chomp $err;
        my $choice = _auth_failure_dialog($mw, $listen, $err);
        if ($choice eq 'cancel') {
            $on_cancel->();
            return ();
        }
        elsif (ref $choice eq 'HASH' && $choice->{no_auth}) {
            # "Browse + request access" path.
            $no_auth = 1; $force_auth = 0;
            $as = $choice->{as} if defined $choice->{as} && length $choice->{as};
        }
        elsif (ref $choice eq 'HASH') {
            $key_file   = $choice->{key_file} if defined $choice->{key_file}
                                              && length $choice->{key_file};
            $key_id     = $choice->{key_id}   if defined $choice->{key_id}
                                              && length $choice->{key_id};
            $no_auth    = 0;          # we're retrying WITH auth
            $force_auth = 1;          # ...even if listen looks loopback-ish
        }
        else {
            # unknown — bail rather than spin
            $on_cancel->(); return ();
        }
    }
}

# A blocking Tk dialog explaining the auth failure and offering the user three
# choices: retry with a different SSH key / key_id; continue read-only (no
# auth); or cancel (close the GUI). Returns:
#   'cancel'                    — user closed/canceled
#   'no_auth'                   — read-only
#   { key_file=>..., key_id=>...} — retry with these
# The current key_file/key_id are pre-filled. The text shows the daemon's exact
# error so the user can tell "key not registered there" from "wrong key file".
# Enumerate the user's likely SSH private keys for the auth dialog dropdown.
# A "key" is a regular file under ~/.ssh/ that has a matching .pub sibling,
# excluding obviously-not-key files (known_hosts/authorized_keys/config/etc).
# Returns absolute paths in deterministic order (id_ed25519 first if present,
# then id_rsa / id_ecdsa, then others sorted by name).
sub _discover_ssh_keys {
    my $dir = "$ENV{HOME}/.ssh";
    return () unless -d $dir;
    opendir(my $dh, $dir) or return ();
    my @entries = readdir $dh;
    closedir $dh;
    my %pub = map { $_ => 1 } grep { /\.pub\z/ } @entries;
    my @keys;
    for my $f (@entries) {
        next if $f =~ /\A\./;
        next if $f =~ /\.pub\z/;
        next if $f =~ /\A(known_hosts|authorized_keys|config|environment|ssh-)/;
        next unless exists $pub{"$f.pub"};
        my $p = "$dir/$f";
        next unless -f $p && -r $p;
        push @keys, $p;
    }
    # Prefer the conventional names first; everything else alphabetical.
    my @preferred = qw(id_ed25519 id_rsa id_ecdsa id_dsa);
    my %rank;
    @rank{@preferred} = (0..$#preferred);
    return sort {
        ($rank{(_basename($a))} // 99) <=> ($rank{(_basename($b))} // 99)
        || lc(_basename($a)) cmp lc(_basename($b))
    } @keys;
}

sub _basename { my $p = shift; $p =~ s{.*/}{}; $p }

# Read the comment field (the key_id principal) from a .pub file. The format
# is `type b64data comment`, where comment is everything after the second
# space and typically a "user@host" string the keygen tool stamped. Returns
# undef when the .pub is missing or unparseable.
sub _ssh_key_comment {
    my ($priv) = @_;
    return undef unless defined $priv && length $priv;
    my $pub = "$priv.pub";
    return undef unless -r $pub;
    open my $fh, '<', $pub or return undef;
    my $line = <$fh>;
    close $fh;
    return undef unless defined $line;
    chomp $line;
    my @parts = split /\s+/, $line, 3;
    return undef unless @parts >= 3;
    my $c = $parts[2];
    $c =~ s/^\s+|\s+$//g;
    return length $c ? $c : undef;
}

sub _auth_failure_dialog {
    my ($mw, $target, $err) = @_;
    require Tk;
    require Tk::BrowseEntry;
    my $dlg = $mw->Toplevel(-title => 'authentication required');
    $dlg->transient($mw);

    $dlg->Label(-text => "Could not connect to $target.",
                -justify => 'left', -anchor => 'w')
        ->pack(-fill => 'x', -padx => 12, -pady => [8, 2]);
    $dlg->Label(-text => "Reason: $err",
                -justify => 'left', -anchor => 'w', -wraplength => 480)
        ->pack(-fill => 'x', -padx => 12, -pady => [0, 8]);

    my @keys = _discover_ssh_keys();
    my %vals = (
        key_file => ($key_file // NetMgr::Client::_default_key_file()
                               // ($keys[0] // '')),
        key_id   => ($key_id   // NetMgr::Client::_default_key_id()   // ''),
        # For the "browse + request access" path: a self-asserted name.
        # Owners see it prefixed with "unverified:" so it's blatantly not
        # cryptographic.
        as       => ($as       // (getpwuid($<))[0] // 'guest'),
    );
    # If the user hasn't overridden the key_id and we just defaulted the
    # key_file from discovery, prefer the discovered key's pubkey comment
    # over the synthetic user@host fallback — it's the actual principal.
    if (!defined $key_id && @keys && $vals{key_file} eq $keys[0]) {
        my $c = _ssh_key_comment($keys[0]);
        $vals{key_id} = $c if defined $c && length $c;
    }

    # SSH key file — dropdown of discovered keys + Browse for the unusual
    # case (key outside ~/.ssh, freshly generated and not yet listed, ...).
    my $kf_frame = $dlg->Frame->pack(-fill => 'x', -padx => 12, -pady => 2);
    $kf_frame->Label(-text => 'SSH key file:', -width => 12, -anchor => 'w')
             ->pack(-side => 'left');
    my $kf_combo;
    $kf_combo = $kf_frame->BrowseEntry(-variable => \$vals{key_file},
                                       -width    => 40,
                                       -listwidth=> 60,
                                       -browsecmd => sub {
        # When a dropdown choice is selected, auto-populate key_id from
        # the .pub comment so the user doesn't have to copy/paste.
        my $c = _ssh_key_comment($vals{key_file});
        $vals{key_id} = $c if defined $c && length $c;
    });
    $kf_combo->insert('end', $_) for @keys;
    $kf_combo->pack(-side => 'left', -fill => 'x', -expand => 1);
    $kf_frame->Button(-text => 'Browse…', -command => sub {
        my $f = $dlg->getOpenFile(-title => 'Select SSH private key',
                                  -initialdir => "$ENV{HOME}/.ssh");
        if (defined $f && length $f) {
            $vals{key_file} = $f;
            my $c = _ssh_key_comment($f);
            $vals{key_id} = $c if defined $c && length $c;
        }
    })->pack(-side => 'left', -padx => [4, 0]);

    my $kid_frame = $dlg->Frame->pack(-fill => 'x', -padx => 12, -pady => 2);
    $kid_frame->Label(-text => 'Key ID:', -width => 12, -anchor => 'w')
              ->pack(-side => 'left');
    $kid_frame->Entry(-textvariable => \$vals{key_id}, -width => 40)
              ->pack(-side => 'left', -fill => 'x', -expand => 1);

    $dlg->Label(-text => "(Key ID is the principal name in the remote's allowed_signers — "
                       . "usually user\@host of the key's comment. Auto-filled "
                       . "from the .pub when you pick a key from the dropdown.)",
                -justify => 'left', -wraplength => 480, -anchor => 'w')
        ->pack(-fill => 'x', -padx => 12, -pady => [4, 8]);

    # "Browse + request access" path: pick a display name; the remote sees it as
    # "unverified:NAME" and present members can admit you.
    my $as_frame = $dlg->Frame->pack(-fill => 'x', -padx => 12, -pady => 2);
    $as_frame->Label(-text => 'Your name:', -width => 12, -anchor => 'w')
             ->pack(-side => 'left');
    $as_frame->Entry(-textvariable => \$vals{as}, -width => 40)
             ->pack(-side => 'left', -fill => 'x', -expand => 1);
    $dlg->Label(-text => "(Used for \"Browse + request access\" — chat owners "
                       . "will see this as \"unverified:<name>\" and must admit you.)",
                -justify => 'left', -wraplength => 480, -anchor => 'w')
        ->pack(-fill => 'x', -padx => 12, -pady => [2, 0]);

    my $result;
    my $btns = $dlg->Frame->pack(-fill => 'x', -padx => 12, -pady => 10);
    # Two retry buttons: "Use this session" applies the chosen creds to the
    # current process only (matches the old "Retry with these" behavior);
    # "Always" additionally persists key_file + key_id to ~/.config/net-mgr/
    # config [net-chat] so future net-chat runs pick them up by default.
    # Both return the same result hash to the caller — the persistence is
    # a side effect.
    $btns->Button(-text => 'Use this session', -command => sub {
        $result = { key_file => $vals{key_file}, key_id => $vals{key_id} };
        $dlg->destroy;
    })->pack(-side => 'left', -padx => 2);
    $btns->Button(-text => 'Always', -command => sub {
        eval {
            NetMgr::Config->save_user_value('net-chat', 'key_file', $vals{key_file})
                if length $vals{key_file};
            NetMgr::Config->save_user_value('net-chat', 'key_id', $vals{key_id})
                if length $vals{key_id};
        };
        # Silently ignore save errors — they shouldn't block the retry.
        $result = { key_file => $vals{key_file}, key_id => $vals{key_id} };
        $dlg->destroy;
    })->pack(-side => 'left', -padx => 2);
    $btns->Button(-text => 'Browse + request access (no auth)', -command => sub {
        $result = { no_auth => 1, as => $vals{as} };
        $dlg->destroy;
    })->pack(-side => 'left', -padx => 2);
    $btns->Button(-text => 'Cancel', -command => sub {
        $result = 'cancel';
        $dlg->destroy;
    })->pack(-side => 'right', -padx => 2);
    # ESC / window-close = cancel.
    $dlg->protocol('WM_DELETE_WINDOW', sub { $result = 'cancel'; $dlg->destroy });
    $dlg->bind('<Escape>' => sub { $result = 'cancel'; $dlg->destroy });

    require Tk::Balloon;
    my $bln = $dlg->Balloon(-state => 'balloon', -initwait => 600);
    $bln->attach($kf_combo,
        -msg => "Pick a private key from ~/.ssh/. The matching .pub file's "
              . "comment is auto-filled into Key ID below.");

    $dlg->grab;
    $mw->waitWindow($dlg);
    return $result // 'cancel';
}

sub need_name {
    my ($n) = @_;
    die "net-chat: missing session name\n" unless defined $n && length $n;
    die "net-chat: bad session name '$n' (use A-Z a-z 0-9 . _ -)\n"
        unless $n =~ /\A[A-Za-z0-9][A-Za-z0-9._-]{0,63}\z/;
    return $n;
}

sub print_msg {
    my ($kv) = @_;
    my $ts = $kv->{ts} // '';
    $ts =~ s/\.\d+$//;             # drop microseconds
    $ts =~ s/^\d{4}-//;           # drop year for compactness
    my $who = $kv->{sender} // '?';
    my $body = $kv->{body} // '';
    printf "%s  %s: %s\n", $ts, $who, $body;
}

sub parse_duration {
    my ($s) = @_;
    return $1            if $s =~ /^(\d+)$/;
    return $1            if $s =~ /^(\d+)s$/;
    return $1 * 60       if $s =~ /^(\d+)m$/;
    return $1 * 3600     if $s =~ /^(\d+)h$/;
    return $1 * 86400    if $s =~ /^(\d+)d$/;
    die "net-chat: bad --since '$s' (use Ns/Nm/Nh/Nd or seconds)\n";
}

sub trunc {
    my ($s, $w) = @_;
    return $s if length($s) <= $w;
    return substr($s, 0, $w - 1) . '…';
}

sub usage {
    my ($msg) = @_;
    print STDERR "net-chat: $msg\n\n" if $msg;
    print STDERR <<'USAGE';
usage: net-chat <command> [args]

  ls [--all]                       list chat sessions
  open  <name> [--mode M] [--topic T]   create, or resurrect an archived chat
  set   <name> [--mode M] [--topic T]   edit (owner)
  close <name>                     close (owner): archive messages to disk
  join  <name>                     join a session
  leave <name>                     drop out of the roster
  who   <name>                     show who's in a session
  post  <name> [text ...]          post a message ('-' = stdin)
  read  <name> [-n N] [--since D]  show recent history
  follow <name>                    join + stream live (Ctrl-C)
  requests <name>                  list pending join requests
  members  <name>                  list the membership list
  delete   <name> [--force]        owner: delete chat + archive (destructive)
  upload   <name> <file> [as]      upload a file (posts a system message)
  download <name> <file> [to]      download a file
  files    <name>                  list uploaded files
  rm       <name> <file>           delete an uploaded file
  keys     <name>                  list the chat's authorized SSH keys (owner)
  approve|reject <name> <who>      act on a join request (owner)
  allow|deny     <name> <who>      edit the allow-list / keys (owner)

  --gui [name]                     Tk window: pick/watch a chat, type to
                                   post, approve/reject join requests via
                                   pop-ups (Perl/Tk required). The "terminal"
                                   button opens a tmux terminal fed by the
                                   keyboard + chat msgs starting "@<user>".

  --listen HOST:PORT   daemon address (overrides --server and config)
  --server NAME|HOST:PORT
                       a server from [servers] (~/.config/net-mgr/config) or a
                       literal host[:port] — an alias for --listen
  --as NAME            display name on a loopback daemon
  --auth / --no-auth   force / suppress the SSH-key handshake

  Address precedence: --listen, then --server, then $NET_MGR_LISTEN, then
  the configured default server, then 127.0.0.1:7531.
  --gui server menu: configured [servers] + the daemon's known peers (shown by
  name, known_hosts entries first), with a "set default" button that saves the
  active server to the user config.
USAGE
    exit($msg ? 2 : 0);
}
