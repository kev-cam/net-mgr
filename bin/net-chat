#!/usr/bin/perl
# net-chat — talk in named chat sessions hosted by the net-mgr daemon.
#
# The daemon records every message; software identifies itself with an
# SSH key (the AUTH handshake) and humans use the web GUI. This is the
# command-line client agents use to open/join sessions, post, and watch.
#
# Usage:
#   net-chat ls [--all]                     List open chat sessions
#   net-chat open <name> [--mode M] [--topic T]
#                                           Create a session (M = open|
#                                           list|request; default open)
#   net-chat set  <name> [--mode M] [--topic T]   Edit a session (owner)
#   net-chat close <name>                   Close a session (owner)
#   net-chat join <name>                    Join (request-mode → asks)
#   net-chat leave <name>                   Drop out of the live roster
#   net-chat who  <name>                    Show the live roster
#   net-chat post <name> [text ...]         Post a message ('-'/empty =
#                                           read body from stdin)
#   net-chat read <name> [-n N] [--since D] Print recent history
#   net-chat follow <name>                  Join + stream live (Ctrl-C)
#   net-chat requests <name>                List pending join requests
#   net-chat members  <name>                List the membership list
#   net-chat approve|reject <name> <who>    Act on a join request (owner)
#   net-chat allow|deny     <name> <who>    Edit the allow-list   (owner)
#
# Connection / identity:
#   --listen HOST:PORT    Manager address (overrides --server and config).
#   --server NAME         A server named in [servers] in the config file
#                         (~/.config/net-mgr/config). With neither flag, the
#                         configured default server is used, else loopback.
#                         The --gui shows a server menu to switch between them.
#   --as NAME             Display name for posts on a loopback daemon
#                         (default $NET_CHAT_AS or $USER). Ignored once
#                         AUTH'd — the server stamps the verified key.
#   --auth                Force the SSH-key handshake even on loopback.
#   --no-auth             Never AUTH (loopback-only / read-only use).
#   --key-id ID --key-file PATH   Override AUTH key (see NetMgr::Client).
#
# A non-loopback daemon is AUTH'd automatically; --key-id/--key-file
# pick the key, otherwise the NetMgr::Client defaults are used.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling pass_through);
use NetMgr::Client;
use NetMgr::Config;
use NetMgr::Protocol qw(parse_line);

# Writing to a daemon that has gone away must not kill us with SIGPIPE — the
# one-shot CLI rarely hit this, but the long-lived --gui would die (e.g. on
# Refresh) the moment the connection dropped. Treat writes to a dead socket
# as ordinary errors instead.
$SIG{PIPE} = 'IGNORE';

# --describe — for tooling that enumerates the net-* commands.
if (@ARGV && $ARGV[0] eq '--describe') {
    print "name: net-chat\n";
    print "description: talk in named chat sessions hosted by net-mgr\n";
    exit 0;
}

my $listen;
my $server;
my $as;
my $force_auth;
my $no_auth;
my $key_id;
my $key_file;
my $mode;
my $topic;
my $limit;
my $since;
my $show_all;
my $gui;
GetOptions(
    'listen=s'   => \$listen,
    'server=s'   => \$server,
    'as=s'       => \$as,
    'auth'       => \$force_auth,
    'no-auth'    => \$no_auth,
    'key-id=s'   => \$key_id,
    'key-file=s' => \$key_file,
    'mode=s'     => \$mode,
    'topic=s'    => \$topic,
    'n=i'        => \$limit,
    'since=s'    => \$since,
    'all'        => \$show_all,
    'gui'        => \$gui,
) or die "bad options\n";

my $cmd = shift @ARGV;

# Server resolution: an explicit --listen address wins; otherwise --server
# names an entry in the [servers] config (see NetMgr::Config), then
# $NET_MGR_LISTEN, then the configured default server, then loopback.
if (!defined $listen) {
    if (defined $server) {
        $listen = NetMgr::Config->resolve_server($server)
            or die "net-chat: unknown server '$server' (configure it in "
                 . (NetMgr::Config->user_path // '~/.config/net-mgr/config')
                 . " [servers])\n";
    } else {
        $listen = $ENV{NET_MGR_LISTEN}
               // NetMgr::Config->resolve_server(undef)
               // '127.0.0.1:7531';
    }
}
$as //= $ENV{NET_CHAT_AS} // $ENV{USER} // 'local';

# --gui launches the Tk front-end; the leftover arg (if any) is the session
# to open initially. No subcommand is required in this mode.
if ($gui) { cmd_gui($cmd); exit 0; }
usage() unless defined $cmd;

# ---- dispatch --------------------------------------------------------

my %DISPATCH = (
    ls       => \&cmd_ls,
    open     => \&cmd_open,
    set      => \&cmd_set,
    close    => \&cmd_close,
    join     => \&cmd_join,
    leave    => \&cmd_leave,
    who      => \&cmd_who,
    post     => \&cmd_post,
    read     => \&cmd_read,
    follow   => \&cmd_follow,
    tail     => \&cmd_follow,    # alias
    requests => \&cmd_requests,
    members  => \&cmd_members,
    delete   => \&cmd_delete,
    upload   => \&cmd_upload,
    download => \&cmd_download,
    files    => \&cmd_files,
    approve  => sub { cmd_member('approve', @_) },
    reject   => sub { cmd_member('reject',  @_) },
    allow    => sub { cmd_member('allow',   @_) },
    deny     => sub { cmd_member('deny',    @_) },
    gui      => \&cmd_gui,
);

my $handler = $DISPATCH{$cmd} or usage("unknown command '$cmd'");
$handler->();
exit 0;

# ---- connection ------------------------------------------------------

sub connect_client {
    my %opt = @_;          # want_auth => bool override
    my $cli = eval { NetMgr::Client->new(listen => $listen, timeout => 10,
                                         as => $as) }
        or die "net-chat: cannot reach daemon at $listen: $@";

    my ($host) = NetMgr::Client::split_hostport($listen); $host //= '';
    my $is_loopback = $host =~ /^(?:127\.\d+\.\d+\.\d+|::1|localhost)$/;

    my $do_auth = $force_auth || (!$is_loopback && !$no_auth);
    $do_auth = $opt{want_auth} if exists $opt{want_auth};
    $do_auth = 0 if $no_auth;

    if ($do_auth) {
        eval {
            $cli->auth(
                (defined $key_id   ? (key_id   => $key_id)   : ()),
                (defined $key_file ? (key_file => $key_file) : ()),
            );
        };
        die "net-chat: AUTH failed: $@" if $@;
    }
    return $cli;
}

# ---- commands --------------------------------------------------------

sub cmd_ls {
    my $cli = connect_client(want_auth => 0);
    my $where = $show_all ? undef : "status = 'open'";
    my $rows = $cli->snapshot(1, 'chat_sessions', ($where ? (where => $where) : ()));
    @$rows = sort { ($b->{last_activity}//'') cmp ($a->{last_activity}//'') } @$rows;
    unless (@$rows) { print "no chat sessions\n"; return }
    printf "%-20s %-8s %-7s %-20s %s\n",
        'NAME', 'MODE', 'STATUS', 'OWNER', 'TOPIC';
    for my $s (@$rows) {
        printf "%-20s %-8s %-7s %-20s %s\n",
            $s->{name}, $s->{access_mode} // '?', $s->{status} // '?',
            trunc($s->{created_by} // '', 20), $s->{topic} // '';
    }
}

sub cmd_open {
    my $name = need_name(shift @ARGV);
    die "net-chat: --mode must be open|list|request\n"
        if defined $mode && $mode !~ /^(open|list|request)$/;
    my $cli = connect_client();
    my $r = eval { $cli->chat_open(name => $name,
        (defined $mode  ? (mode  => $mode)  : ()),
        (defined $topic ? (topic => $topic) : ())) };
    die "net-chat: $@" if $@;
    print +($r->{reopened} ? "reopened" : "opened"),
          " '$name' (mode=", $r->{mode} // $mode // 'open', ")\n";
}

sub cmd_set {
    my $name = need_name(shift @ARGV);
    die "net-chat: --mode must be open|list|request\n"
        if defined $mode && $mode !~ /^(open|list|request)$/;
    my $cli = connect_client();
    eval { $cli->chat_set(name => $name,
        (defined $mode  ? (mode  => $mode)  : ()),
        (defined $topic ? (topic => $topic) : ())) };
    die "net-chat: $@" if $@;
    print "updated '$name'\n";
}

sub cmd_close {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client();
    my $r = eval { $cli->chat_close(name => $name) };
    die "net-chat: $@" if $@;
    my $arch = (ref $r eq 'HASH') ? $r->{archive} : undef;
    if (defined $arch) {
        print "closed '$name' — messages archived to $arch\n";
        print "  resurrect with: net-chat open $name\n";
    } else {
        print "closed '$name'\n";
    }
}

sub cmd_join {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client();
    my $r = eval { $cli->chat_join(session => $name) };
    die "net-chat: $@" if $@;
    my $state = $r->{state} // 'member';
    if ($state eq 'requested') {
        print "join request sent for '$name' — waiting for an owner to approve\n";
    } else {
        print "joined '$name'\n";
    }
}

sub cmd_leave {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client(want_auth => 0);
    eval { $cli->chat_leave(session => $name) };
    die "net-chat: $@" if $@;
    print "left '$name'\n";
}

sub cmd_who {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client(want_auth => 0);
    my $rows = $cli->snapshot(1, 'chat_presence',
        where => "session = '$name'");
    my %seen;
    my @who = grep { !$seen{$_}++ } map { $_->{principal} } @$rows;
    unless (@who) { print "nobody in '$name'\n"; return }
    print "in '$name': ", join(', ', @who), "\n";
}

sub cmd_post {
    my $name = need_name(shift @ARGV);
    my $body = join ' ', @ARGV;
    if (!length $body || $body eq '-') {
        local $/; $body = <STDIN>;
        $body = '' unless defined $body;
    }
    $body =~ s/\s+\z//;
    die "net-chat: empty message\n" unless length $body;
    my $cli = connect_client();
    eval { $cli->chat_post(session => $name, body => $body, as => $as) };
    die "net-chat: $@" if $@;
}

sub cmd_read {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client(want_auth => 0);
    my $where = "session = '$name'";
    if (defined $since) {
        my $secs = parse_duration($since);
        $where .= " AND ts > ago($secs)";
    }
    my $rows = $cli->snapshot(1, 'chat_messages', where => $where);
    @$rows = sort { ($a->{id}//0) <=> ($b->{id}//0) } @$rows;
    if (defined $limit && @$rows > $limit) {
        @$rows = @$rows[ -$limit .. -1 ];
    }
    print_msg($_) for @$rows;
}

sub cmd_follow {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client();
    # Join first so we appear in the roster, then stream history+live.
    eval { $cli->chat_join(session => $name) };
    die "net-chat: $@" if $@;
    $SIG{INT} = $SIG{TERM} = sub {
        eval { $cli->chat_leave(session => $name) };
        eval { $cli->bye };
        exit 0;
    };
    $cli->send_line("SUBSCRIBE sub=1 mode=snapshot+stream FROM chat_messages"
                  . " WHERE session = '$name'");
    $| = 1;
    my $live = 0;
    while (defined(my $line = $cli->recv_line(60))) {
        my $c = parse_line($line) or next;
        if ($c->{verb} eq 'ROW' && ($c->{kv}{table} // '') eq 'chat_messages') {
            print_msg($c->{kv});
        } elsif ($c->{verb} eq 'EOS') {
            print "-- live (Ctrl-C to leave) --\n" unless $live++;
        } elsif ($c->{verb} eq 'ERR') {
            die "net-chat: $c->{msg}\n";
        }
    }
}

sub cmd_requests {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client(want_auth => 0);
    my $rows = $cli->snapshot(1, 'chat_members',
        where => "session = '$name' AND state = 'requested'");
    unless (@$rows) { print "no pending requests for '$name'\n"; return }
    print "pending requests for '$name':\n";
    print "  $_->{principal}\n" for @$rows;
}

sub cmd_members {
    my $name = need_name(shift @ARGV);
    my $cli = connect_client(want_auth => 0);
    my $rows = $cli->snapshot(1, 'chat_members', where => "session = '$name'");
    unless (@$rows) { print "no members for '$name'\n"; return }
    printf "%-24s %-8s %s\n", 'PRINCIPAL', 'ROLE', 'STATE';
    for my $m (sort { $a->{principal} cmp $b->{principal} } @$rows) {
        printf "%-24s %-8s %s\n",
            $m->{principal}, $m->{role} // '?', $m->{state} // '?';
    }
}

sub cmd_delete {
    my $name = need_name(shift @ARGV);
    my $force = grep { $_ eq '--force' || $_ eq '-f' } @ARGV;
    unless ($force) {
        local $| = 1;
        print STDERR "Delete chat '$name' and its ENTIRE archive "
                   . "(messages + uploaded files)? This cannot be undone. [y/N] ";
        my $ans = <STDIN>;
        unless (defined $ans && $ans =~ /^\s*y/i) { print "aborted\n"; return }
    }
    my $cli = connect_client();
    eval { $cli->chat_delete(name => $name) };
    die "net-chat: $@" if $@;
    print "deleted '$name' (archive removed)\n";
}

sub cmd_upload {
    my $session = need_name(shift @ARGV);
    my $path = shift @ARGV or die "net-chat: upload needs a file path\n";
    my $name = shift @ARGV;          # optional stored name (default: basename)
    require File::Basename;
    $name //= File::Basename::basename($path);
    open my $fh, '<', $path or die "net-chat: open $path: $!\n";
    binmode $fh;
    require MIME::Base64;
    my $cli = connect_client();
    my ($offset, $r) = (0, undef);
    while (1) {
        my $n   = read($fh, my $buf, 48 * 1024);
        $buf    = '' unless defined $n;
        my $eof = (!$n || eof($fh)) ? 1 : 0;
        $r = eval { $cli->chat_put(session => $session, file => $name,
            offset => $offset, ($eof ? (eof => 1) : ()),
            data => MIME::Base64::encode_base64($buf, '')) };
        die "net-chat: $@" if $@;
        $offset += length $buf;
        last if $eof;
    }
    close $fh;
    print "uploaded '$name' (", ($r->{size} // $offset), " bytes) to '$session'\n";
}

sub cmd_download {
    my $session = need_name(shift @ARGV);
    my $name = shift @ARGV or die "net-chat: download needs a file name\n";
    my $out  = shift @ARGV // $name;   # optional local destination
    require MIME::Base64;
    my $cli = connect_client(want_auth => 0);
    open my $fh, '>', $out or die "net-chat: write $out: $!\n";
    binmode $fh;
    my $offset = 0;
    while (1) {
        my $r = eval { $cli->chat_get(session => $session, file => $name,
                                      offset => $offset) };
        die "net-chat: $@" if $@;
        my $chunk = defined $r->{data} ? MIME::Base64::decode_base64($r->{data}) : '';
        print {$fh} $chunk;
        $offset += length $chunk;
        last if $r->{eof} || length($chunk) == 0;
    }
    close $fh;
    print "downloaded '$name' from '$session' -> $out ($offset bytes)\n";
}

sub cmd_files {
    my $session = need_name(shift @ARGV);
    my $cli = connect_client(want_auth => 0);
    my $r = eval { $cli->chat_ls(session => $session) };
    die "net-chat: $@" if $@;
    require MIME::Base64; require JSON::PP;
    my $files = $r->{files}
        ? JSON::PP->new->decode(MIME::Base64::decode_base64($r->{files})) : [];
    unless (@$files) { print "no files in '$session'\n"; return }
    printf "%-32s %10s\n", 'NAME', 'BYTES';
    printf "%-32s %10d\n", $_->{name}, $_->{size} for @$files;
}

sub cmd_member {
    my ($op) = @_;
    my $name      = need_name(shift @ARGV);
    my $principal = shift @ARGV
        or die "net-chat: $op needs a principal\n";
    my $cli = connect_client();
    eval { $cli->chat_member($op, session => $name, principal => $principal) };
    die "net-chat: $@" if $@;
    print "$op: $principal on '$name'\n";
}

# ---- GUI (Perl/Tk) ---------------------------------------------------
# net-chat --gui [session]: a desktop chat window — pick a session (or
# "+ new chat" to create one), watch it live, type to post, send a file
# with the up-arrow button, and right-click an "uploaded …" line to Save
# As. Owners also get approve/reject pop-ups for join requests. Bar widgets
# use ASCII (the default UI font lacks many glyphs; the message pane is
# Courier and renders Unicode fine).
# Multi-line messages fold to their first line (a " [+]"
# marker; left-click to open, right-click to close) and older/seeded lines
# start folded; the search box reveals and highlights matches across the whole
# loaded log; each sender gets a light background tint. Uses two connections:
# one read via Tk fileevent for
# subscriptions, one for blocking control ops (snapshot/post/join/member).
sub cmd_gui {
    my ($session) = @_;
    $session //= shift @ARGV;
    require Tk;   # loaded on demand; fully-qualified below so non-gui use
                  # of net-chat never needs Perl/Tk installed.

    my ($host) = NetMgr::Client::split_hostport($listen); $host //= '';
    my $is_loopback = $host =~ /^(?:127\.\d+\.\d+\.\d+|::1|localhost)$/;
    my $authed = $force_auth || (!$is_loopback && !$no_auth);
    $authed = 0 if $no_auth;
    # Our chat identity, for filtering request pop-ups to sessions we own.
    my $me = $authed ? ($key_id // NetMgr::Client::_default_key_id()) : $as;

    my $stream = connect_client();   # subscriptions; drained via fileevent
    my $ctrl   = connect_client();   # blocking request/reply ops

    my $mw = Tk::MainWindow->new;
    $mw->title('net-chat');
    $mw->geometry('660x480');

    # Shared named fonts so A+/A- scale the WHOLE UI (buttons, labels, dropdown,
    # entry) not just the message pane. optionAdd (high priority) makes every
    # widget created below inherit 'ncui'; the pane uses the monospace 'ncmono'.
    my $fontsize = 10;
    $mw->fontCreate('ncui',   -size => $fontsize);
    $mw->fontCreate('ncmono', -family => 'Courier', -size => $fontsize);
    $mw->optionAdd('*font' => 'ncui', 81);

    my %created_by;          # session -> created_by (for request ownership)
    my $cur;                 # session currently followed
    my %seen_req;            # "$session/$principal" -> 1 (dedupe pop-ups)
    my $statusvar = 'connecting...';

    # -- top: server + session picker + refresh --------------------------
    my $top = $mw->Frame->pack(-fill => 'x', -padx => 4, -pady => 3);

    # Server picker — shown only when the config lists servers. Switching
    # rebuilds both sockets, the fileevent, and identity (loopback vs remote
    # auth differ), so we just re-exec with the new --listen: clean and
    # state-free. See ~/.config/net-mgr/config [servers].
    my ($srvmap) = NetMgr::Config->servers;
    if (%$srvmap) {
        my $cursrv = $listen;          # reverse-map the active addr to a name
        for (keys %$srvmap) { $cursrv = $_, last if ($srvmap->{$_}//'') eq $listen }
        my @opts = sort keys %$srvmap;
        push @opts, $cursrv unless grep { $_ eq $cursrv } @opts;   # unnamed addr
        my $srvvar = $cursrv;
        $top->Label(-text => 'server:')->pack(-side => 'left');
        $top->Optionmenu(-variable => \$srvvar, -options => \@opts,
            -command => sub {
                my $addr = $srvmap->{$srvvar} // $srvvar;
                return if $addr eq $listen;
                eval { $ctrl->chat_leave(session => $cur) } if defined $cur;
                eval { $ctrl->bye }; eval { $stream->bye };
                my @argv = ('--gui', '--listen', $addr);
                push @argv, '--auth'                  if $force_auth;
                push @argv, '--no-auth'               if $no_auth;
                push @argv, '--key-id',   $key_id     if defined $key_id;
                push @argv, '--key-file', $key_file   if defined $key_file;
                push @argv, '--as',       $as         if defined $as;
                push @argv, $cur                      if defined $cur;
                exec $^X, $0, @argv;
            })->pack(-side => 'left');
    }

    my $NEWCHAT = '+ new chat';   # sentinel entry in the chat picker
    my $new_chat;                 # assigned below (it uses $refresh/$follow)
    $top->Label(-text => 'chat:')->pack(-side => 'left');
    my $sessvar = $session // 'select';      # placeholder until a chat is picked
    my $om = $top->Optionmenu(-variable => \$sessvar,
                              -options => ['select', $NEWCHAT])
                 ->pack(-side => 'left');
    my $topiclbl = $top->Label(-text => '', -anchor => 'w')
                       ->pack(-side => 'left', -fill => 'x', -expand => 1);

    # -- middle: message log (read-only) ---------------------------------
    my $txt = $mw->Scrolled('Text', -scrollbars => 'oe', -wrap => 'word',
                            -state => 'disabled', -height => 22,
                            -font => 'ncmono')
                 ->pack(-fill => 'both', -expand => 1, -padx => 4);

    # -- bottom: input + send --------------------------------------------
    my $bot = $mw->Frame->pack(-fill => 'x', -padx => 4, -pady => 3);
    my $entry = $bot->Entry->pack(-side => 'left', -fill => 'x', -expand => 1);
    $mw->Label(-textvariable => \$statusvar, -anchor => 'w', -relief => 'sunken')
       ->pack(-fill => 'x', -side => 'bottom');

    my $set_status = sub { $statusvar = $_[0] };
    my $set_font = sub {
        $mw->fontConfigure('ncui',   -size => $fontsize);
        $mw->fontConfigure('ncmono', -size => $fontsize);
    };
    my $min_shown;     # smallest message id on screen — the History cursor
    my %shown;         # ids already displayed — dedup live/seed/history overlap
    my $fmt = sub {
        my ($kv) = @_;
        my $ts = $kv->{ts} // ''; $ts =~ s/\.\d+$//; $ts =~ s/^\d{4}-//;
        my $who  = $kv->{sender} // '?';
        my $body = $kv->{body} // '';
        utf8::decode($who); utf8::decode($body);   # UTF-8 wire bytes -> chars
        return sprintf("%s  %s: %s\n", $ts, $who, $body);
    };
    my $note_id = sub {
        my ($id) = @_;
        $min_shown = $id if defined $id
                         && (!defined $min_shown || $id < $min_shown);
    };

    # Folding + search bookkeeping. Each message gets a unique ordinal $ord and a
    # clickable tag "i$ord"; a multi-line message also gets a body tag "b$ord"
    # (everything past the first line) and a marker tag "k$ord" (the " [+]" shown
    # only while folded). Folding just toggles -elide on those two tags. @order
    # keeps the on-screen ordinals top->bottom and %otext their text, so Search
    # can scan the full (even folded) content without the widget's own search.
    my $mseq = 0;
    my @order;         # message ordinals, top -> bottom
    my %otext;         # ord -> decoded full text (for Search)
    my %folded;        # ord -> bool
    my %file_of_ord;   # ord -> uploaded filename (for the right-click Save As)
    my $last_hit;      # ord the last Search hit landed in
    my $last_q = '';   # query that produced $last_hit

    # Light per-sender row tint: each new sender claims the next palette colour
    # (cycling), kept stable across session switches so a person reads the same.
    my @PALETTE = ('#fde7e9', '#e7f3fe', '#e9f9ec', '#fff6df', '#f1eafc',
                   '#e4f7f7', '#fbe6f2', '#eef2e0', '#f6e8df', '#e9ecf8');
    my %ucolor;        # sender -> tag name ("u<n>")
    my $unext = 0;
    my $user_tag = sub {
        my ($who) = @_;
        return $ucolor{$who} if exists $ucolor{$who};
        my $tag = 'u' . $unext;
        $txt->tagConfigure($tag, -background => $PALETTE[$unext % @PALETTE]);
        $unext++;
        return $ucolor{$who} = $tag;
    };

    my $set_fold = sub {
        my ($ord, $f) = @_;
        return unless defined $ord && $txt->tagRanges("b$ord");   # foldable only
        $folded{$ord} = $f ? 1 : 0;
        $txt->tagConfigure("b$ord", -elide => $f ? 1 : 0);
        $txt->tagConfigure("k$ord", -elide => $f ? 0 : 1);
    };

    my $insert_msg = sub {
        my ($where, $kv, $fold) = @_;        # $where = 'end' or '1.0'
        return if defined $kv->{id} && $shown{$kv->{id}}++;
        my $ord = $mseq++;
        my $t = $fmt->($kv);
        chomp $t;
        # Fold boundary: the first newline or column 100, whichever comes first.
        # A folded message shows head + " [+]"; expanding reveals head + rest
        # contiguously (no inserted newline) so a long line wraps as written.
        my $cut = length $t;
        my $nl  = index($t, "\n");
        $cut = $nl if $nl >= 0 && $nl < $cut;
        $cut = 100 if 100 < $cut;
        my $head = substr($t, 0, $cut);
        my $rest = substr($t, $cut);
        my $who  = $kv->{sender} // '?'; utf8::decode($who);
        my $ut   = $user_tag->($who);        # per-sender background tint
        # A completed upload is a system message "<who> uploaded <file> (size)";
        # tag it 'file' and remember the name so right-click can offer Save As.
        my @base = ('msg', $ut, "i$ord");
        if (($kv->{sender_kind} // '') eq 'system'
            && ($kv->{body} // '') =~ /\buploaded\s+(\S+)\s+\(/) {
            $file_of_ord{$ord} = $1;
            push @base, 'file';
        }
        $txt->configure(-state => 'normal');
        if (length $rest) {                  # long / multi-line -> foldable
            $txt->insert($where,
                $head,  [@base],
                ' [+]', [@base, "k$ord"],
                $rest,  [@base, "b$ord"],
                "\n",   [@base]);
            $txt->tagConfigure("b$ord", -elide => $fold ? 1 : 0);
            $txt->tagConfigure("k$ord", -elide => $fold ? 0 : 1);
            $folded{$ord} = $fold ? 1 : 0;
        } else {                             # single line -> nothing to fold
            $txt->insert($where, $head."\n", [@base]);
        }
        $txt->configure(-state => 'disabled');
        if ($where eq '1.0') { unshift @order, $ord } else { push @order, $ord }
        $otext{$ord} = $t;
        $txt->see('end') if $where eq 'end';
        $note_id->($kv->{id});
    };
    my $append  = sub { $insert_msg->('end', $_[0], $_[1]) };  # live  (unfolded)
    my $prepend = sub { $insert_msg->('1.0', $_[0], 1) };      # older (folded)

    my $clear = sub {
        $txt->configure(-state => 'normal');
        $txt->delete('1.0', 'end');
        $txt->configure(-state => 'disabled');
        $min_shown = undef;
        %shown = (); @order = (); %otext = (); %folded = (); %file_of_ord = ();
        $last_hit = undef; $last_q = '';
    };

    # Click handling: left-click opens a folded message, right-click folds it.
    # The ordinal is read back from the "i<n>" tag under the pointer.
    $txt->tagConfigure('hit', -background => '#ffd54a', -foreground => 'black');
    my $ord_at = sub {
        my ($idx) = @_;
        for my $tag ($txt->tagNames($idx)) { return $1 if $tag =~ /^i(\d+)$/ }
        return undef;
    };
    $txt->tagBind('msg', '<Button-1>',
        sub { $set_fold->($ord_at->($txt->index('current')), 0) });
    $txt->tagBind('msg', '<Button-3>',
        sub { $set_fold->($ord_at->($txt->index('current')), 1) });
    $txt->tagBind('msg', '<Enter>', sub { $txt->configure(-cursor => 'hand2') });
    $txt->tagBind('msg', '<Leave>', sub { $txt->configure(-cursor => 'xterm') });

    # Uploaded files (system "… uploaded <file> …" lines) are tagged 'file' and
    # underlined; right-click one for a Save As menu that downloads it (chunked
    # CHAT_GET, like `net-chat download`).
    $txt->tagConfigure('file', -underline => 1);
    my $download_file = sub {
        my ($name) = @_;
        return unless defined $name && length $name && defined $cur;
        my $dest = $mw->getSaveFile(-title => "Save '$name' as",
                                    -initialfile => $name);
        return unless defined $dest && length $dest;
        open my $fh, '>', $dest or return $set_status->("write $dest: $!");
        binmode $fh;
        require MIME::Base64;
        $set_status->("downloading $name ..."); $mw->update;
        my $offset = 0;
        while (1) {
            my $gr = eval { $ctrl->chat_get(session => $cur, file => $name,
                                            offset => $offset) };
            if ($@) { close $fh; return $set_status->("download failed: $@") }
            my $chunk = defined $gr->{data}
                ? MIME::Base64::decode_base64($gr->{data}) : '';
            print {$fh} $chunk;
            $offset += length $chunk;
            last if $gr->{eof} || length($chunk) == 0;
        }
        close $fh;
        $set_status->("saved $name -> $dest ($offset bytes)");
    };
    my $rc_file;
    my $filemenu = $mw->Menu(-tearoff => 0);
    $filemenu->add('command', -label => 'Save As...',
                   -command => sub { $download_file->($rc_file) });
    $txt->tagBind('file', '<Button-3>', sub {
        my $ord = $ord_at->($txt->index('current'));
        return unless defined $ord && defined $file_of_ord{$ord};
        $rc_file = $file_of_ord{$ord};
        $filemenu->entryconfigure(0, -label => "Save '$rc_file' As...");
        $filemenu->post($txt->pointerxy);
    });

    # -- search row: scan all loaded messages, reveal + highlight the match ----
    my $srch = $mw->Frame;
    $srch->pack(-before => $txt, -fill => 'x', -padx => 4, -pady => 2);
    $srch->Label(-text => 'search:')->pack(-side => 'left');
    my $searchvar = '';
    my $se = $srch->Entry(-textvariable => \$searchvar)
                  ->pack(-side => 'left', -fill => 'x', -expand => 1);
    my $find = sub {
        my ($dir) = @_;                      # +1 next match, -1 previous
        my $q = $searchvar;
        $txt->tagRemove('hit', '1.0', 'end');
        return unless length $q;
        if ($q ne $last_q) { $last_hit = undef; $last_q = $q }
        my $n = @order or return $set_status->('no messages');
        my $lc = lc $q;
        my $from = $dir > 0 ? -1 : 0;        # first search starts at the top
        if (defined $last_hit) {
            for my $j (0 .. $n-1) { $from = $j, last if $order[$j] == $last_hit }
        }
        for my $step (1 .. $n) {
            my $j = ($from + $dir*$step) % $n; $j += $n if $j < 0;
            my $ord = $order[$j];
            next unless index(lc($otext{$ord}), $lc) >= 0;
            $last_hit = $ord;
            $set_fold->($ord, 0);            # reveal the matching message
            my @r = $txt->tagRanges("i$ord") or last;
            my $hit = $txt->search('-nocase', '--', $q, $r[0], $r[1]);
            if ($hit) {
                $txt->tagAdd('hit', $hit, "$hit + ".length($q)." chars");
                $txt->tagRaise('hit');       # stay above per-user tint
                $txt->see($hit);
            } else { $txt->see($r[0]) }
            return $set_status->("match ".($j+1)."/$n for '$q'"
                               . " - Enter=next, Shift-Enter=prev");
        }
        $set_status->("no match for '$q'");
    };
    $se->bind('<Return>',       sub { $find->( 1) });
    $se->bind('<Shift-Return>', sub { $find->(-1) });
    $srch->Button(-text => '>', -width => 2, -command => sub { $find->( 1) })
         ->pack(-side => 'right');
    $srch->Button(-text => '<', -width => 2, -command => sub { $find->(-1) })
         ->pack(-side => 'right');

    my $req_popup = sub {
        my ($kv) = @_;
        my $sess = $kv->{session}   // return;
        my $who  = $kv->{principal} // return;
        return if $who eq $me;                       # not our own request
        return if $seen_req{"$sess/$who"}++;         # once per request
        return unless $is_loopback || (($created_by{$sess} // '') eq $me);
        my $pop = $mw->Toplevel; $pop->title('join request');
        $pop->Label(-text => "'$who' requests to join '$sess'",
                    -padx => 14, -pady => 12)->pack;
        my $act = sub {
            my ($op) = @_;
            eval { $ctrl->chat_member($op, session => $sess, principal => $who) };
            $set_status->($@ ? "$op failed: $@" : "$op $who -> $sess");
            $pop->destroy;
        };
        my $bf = $pop->Frame->pack(-pady => 8);
        $bf->Button(-text => 'Approve', -command => sub { $act->('approve') })
           ->pack(-side => 'left', -padx => 6);
        $bf->Button(-text => 'Reject',  -command => sub { $act->('reject') })
           ->pack(-side => 'left', -padx => 6);
        $bf->Button(-text => 'Ignore',  -command => sub { $pop->destroy })
           ->pack(-side => 'left', -padx => 6);
    };

    # Show the last N messages of the current session (one snapshot), oldest
    # first, so joining a chat isn't a blank window. History extends further
    # back from there; dedup keeps these from doubling with the live stream.
    my $seed_recent = sub {
        my $n = shift // 10;
        my $rows = eval { $ctrl->snapshot(8, 'chat_messages',
                                          where => "session = '$cur'") } || [];
        my @s = sort { ($a->{id} // 0) <=> ($b->{id} // 0) } @$rows;
        @s = @s[-$n .. -1] if @s > $n;
        $append->($_, 1) for @s;            # seeded context starts folded
    };

    my $follow = sub {
        my ($name) = @_;
        return unless defined $name && length $name;
        return if $name eq 'select' || $name eq '(no open chats)'
               || $name eq $NEWCHAT;
        return if defined $cur && $cur eq $name;
        $stream->send_line('UNSUB sub=1') if defined $cur;
        $clear->();
        $cur = $name;
        $mw->title("net-chat - $name");
        $topiclbl->configure(-text => ($created_by{$name} ? "owner: $created_by{$name}" : ''));
        eval { $ctrl->chat_join(session => $name) };   # roster + post rights
        # Stream new messages only; past messages are pulled in on demand with
        # the History button (one older line per click), so joining a busy chat
        # doesn't dump the whole backlog.
        $stream->send_line("SUBSCRIBE sub=1 mode=stream"
                         . " FROM chat_messages WHERE session = '$name'");
        $seed_recent->(10);                 # last 10 lines for context
        $set_status->("following $name - History for older messages");
        $entry->focus;
    };

    my $refresh = sub {
        my $rows = eval { $ctrl->snapshot(9, 'chat_sessions',
                                          where => "status = 'open'") };
        if ($@) { $set_status->("refresh failed: $@"); return }
        $rows ||= [];
        %created_by = map { ($_->{name} => ($_->{created_by} // '')) } @$rows;
        my @names = sort map { $_->{name} } @$rows;
        # Repopulate the menu WITHOUT firing -command (which would re-follow /
        # switch sessions mid-refresh), and keep the current selection if it
        # still exists.
        my $keep = $sessvar;
        $om->configure(-command => undef);
        $om->configure(-options => [ 'select', @names, $NEWCHAT ]);
        $sessvar = (defined $keep && grep { $_ eq $keep } @names) ? $keep : 'select';
        $om->configure(-command => sub {
            $sessvar eq $NEWCHAT ? $new_chat->() : $follow->($sessvar) });
        $set_status->(scalar(@names) . ' open chat(s)');
    };
    # History: each click pulls in the single next-older message (the newest one
    # below what's already shown) and prepends it at the top.
    my $load_history = sub {
        unless (defined $cur) { $set_status->('pick a chat first'); return }
        my $where = "session = '$cur'";
        $where .= " AND id < $min_shown" if defined $min_shown;
        my $rows = eval { $ctrl->snapshot(8, 'chat_messages', where => $where) };
        if ($@) { $set_status->("history failed: $@"); return }
        my ($msg) = sort { ($b->{id} // 0) <=> ($a->{id} // 0) } @{ $rows || [] };
        unless ($msg) { $set_status->('no older history'); return }
        $prepend->($msg);
        $set_status->("history: + 1 older line (id $msg->{id})");
    };

    # New-chat dialog: prompt for name/topic/mode, create it via the control
    # connection, then refresh the picker and follow the new chat.
    $new_chat = sub {
        my $pop = $mw->Toplevel; $pop->title('new chat');
        my $row = sub {
            my ($label) = @_;
            my $f = $pop->Frame->pack(-fill => 'x', -padx => 8, -pady => 3);
            $f->Label(-text => $label, -width => 6, -anchor => 'e')
              ->pack(-side => 'left');
            return $f;
        };
        my $namevar  = '';
        my $ne = $row->('name:')->Entry(-textvariable => \$namevar, -width => 26)
                     ->pack(-side => 'left', -fill => 'x', -expand => 1);
        my $topicvar = '';
        $row->('topic:')->Entry(-textvariable => \$topicvar, -width => 26)
            ->pack(-side => 'left', -fill => 'x', -expand => 1);
        my $modevar  = 'open';
        $row->('mode:')->Optionmenu(-variable => \$modevar,
                                    -options => ['open', 'list', 'request'])
            ->pack(-side => 'left');
        my $create = sub {
            (my $name = $namevar) =~ s/^\s+|\s+$//g;
            unless ($name =~ /\A[A-Za-z0-9][A-Za-z0-9._-]{0,63}\z/) {
                $set_status->("bad chat name (use A-Z a-z 0-9 . _ -)"); return;
            }
            my $ok = eval { $ctrl->chat_open(name => $name, mode => $modevar,
                (length $topicvar ? (topic => $topicvar) : ())); 1 };
            unless ($ok) { $set_status->("create '$name' failed: $@"); return }
            $pop->destroy;
            $refresh->();
            $sessvar = $name;
            $follow->($name);
        };
        my $bf = $pop->Frame->pack(-pady => 8);
        $bf->Button(-text => 'Create', -command => $create)
           ->pack(-side => 'left', -padx => 6);
        $bf->Button(-text => 'Cancel',
            -command => sub { $pop->destroy; $sessvar = $cur // 'select' })
           ->pack(-side => 'left', -padx => 6);
        $ne->bind('<Return>', $create);
        $ne->focus;
    };

    $om->configure(-command => sub {
        $sessvar eq $NEWCHAT ? $new_chat->() : $follow->($sessvar) });
    $top->Button(-text => 'Refresh', -command => $refresh)->pack(-side => 'right');
    $top->Button(-text => 'History', -command => $load_history)->pack(-side => 'right');
    # font size controls
    $top->Button(-text => 'A+', -width => 2,
                 -command => sub { $fontsize++ if $fontsize < 32; $set_font->() })
        ->pack(-side => 'right');
    $top->Button(-text => 'A-', -width => 2,
                 -command => sub { $fontsize-- if $fontsize > 6; $set_font->() })
        ->pack(-side => 'right');

    my $send = sub {
        my $body = $entry->get;
        return unless length $body;
        unless (defined $cur) { $set_status->('pick a chat first'); return }
        eval { $ctrl->chat_post(session => $cur, body => $body,
                                ($is_loopback ? (as => $as) : ())) };
        $set_status->("post failed: $@") if $@;
        $entry->delete(0, 'end');
    };

    # Upload: pick a file and stream it to the current chat in 48 KB chunks
    # (the same CHAT_PUT loop as `net-chat upload`); the daemon posts a system
    # message on completion, which arrives live in the pane.
    my $upload = sub {
        unless (defined $cur) { $set_status->('pick a chat first'); return }
        my $path = $mw->getOpenFile(-title => "Upload to $cur");
        return unless defined $path && length $path;   # cancelled
        open my $fh, '<', $path or return $set_status->("open $path: $!");
        binmode $fh;
        require File::Basename; require MIME::Base64;
        my $name = File::Basename::basename($path);
        $set_status->("uploading $name ..."); $mw->update;
        my ($offset, $r) = (0, undef);
        while (1) {
            my $n   = read($fh, my $buf, 48 * 1024);
            $buf    = '' unless defined $n;
            my $eof = (!$n || eof($fh)) ? 1 : 0;
            $r = eval { $ctrl->chat_put(session => $cur, file => $name,
                offset => $offset, ($eof ? (eof => 1) : ()),
                data => MIME::Base64::encode_base64($buf, '')) };
            if ($@) { close $fh; return $set_status->("upload failed: $@") }
            $offset += length $buf;
            last if $eof;
        }
        close $fh;
        $set_status->("uploaded $name (" . ($r->{size} // $offset) . " bytes)");
    };

    $entry->bind('<Return>', $send);
    $bot->Button(-text => 'Send', -command => $send)->pack(-side => 'right');
    # Upload glyph (an up-arrow). Rendered in the Courier 'ncmono' font, which
    # has Unicode coverage on this system — the default bar font does not.
    # Downloads are reached by right-clicking the upload message in the pane.
    $bot->Button(-text => "\x{2191}", -font => 'ncmono', -command => $upload)
        ->pack(-side => 'right');

    # live reader: drain all complete lines without blocking the event loop
    $mw->fileevent($stream->{sock}, 'readable', sub {
        my $got = 0;
        while (defined(my $line = $stream->recv_line(0))) {
            $got++;
            my $c = parse_line($line) or next;
            if ($c->{verb} eq 'ROW') {
                my $t = $c->{kv}{table} // '';
                if    ($t eq 'chat_messages') { $append->($c->{kv}) }
                elsif ($t eq 'chat_members'
                    && (($c->{kv}{state} // '') eq 'requested')) {
                    $req_popup->($c->{kv});
                }
            } elsif ($c->{verb} eq 'ERR') {
                $set_status->('err: ' . ($c->{msg} // ''));
            }
        }
        # Readable but no complete line drained: distinguish EOF (daemon gone)
        # from a partial line, so a closed socket doesn't busy-loop the GUI.
        if (!$got) {
            my $n = sysread($stream->{sock}, my $b, 4096);
            if (defined $n && $n == 0) {
                $mw->fileevent($stream->{sock}, 'readable', '');
                $set_status->('disconnected (daemon gone) -- restart to reconnect');
                $cur = undef;
                $sessvar = 'select';
                $om->configure(-options => ['select']);
            } elsif (defined $n) {
                $stream->{buf} .= $b;
            }
        }
    });
    # watch join requests across all sessions (filtered to ours in the popup)
    $stream->send_line('SUBSCRIBE sub=2 mode=snapshot+stream'
                     . " FROM chat_members WHERE state = 'requested'");

    $mw->protocol('WM_DELETE_WINDOW', sub {
        eval { $ctrl->chat_leave(session => $cur) } if defined $cur;
        eval { $ctrl->bye }; eval { $stream->bye };
        $mw->destroy;
    });

    $refresh->();
    $follow->($session) if defined $session && length $session;
    $entry->focus;
    Tk::MainLoop();
}

# ---- helpers ---------------------------------------------------------

sub need_name {
    my ($n) = @_;
    die "net-chat: missing session name\n" unless defined $n && length $n;
    die "net-chat: bad session name '$n' (use A-Z a-z 0-9 . _ -)\n"
        unless $n =~ /\A[A-Za-z0-9][A-Za-z0-9._-]{0,63}\z/;
    return $n;
}

sub print_msg {
    my ($kv) = @_;
    my $ts = $kv->{ts} // '';
    $ts =~ s/\.\d+$//;             # drop microseconds
    $ts =~ s/^\d{4}-//;           # drop year for compactness
    my $who = $kv->{sender} // '?';
    my $body = $kv->{body} // '';
    printf "%s  %s: %s\n", $ts, $who, $body;
}

sub parse_duration {
    my ($s) = @_;
    return $1            if $s =~ /^(\d+)$/;
    return $1            if $s =~ /^(\d+)s$/;
    return $1 * 60       if $s =~ /^(\d+)m$/;
    return $1 * 3600     if $s =~ /^(\d+)h$/;
    return $1 * 86400    if $s =~ /^(\d+)d$/;
    die "net-chat: bad --since '$s' (use Ns/Nm/Nh/Nd or seconds)\n";
}

sub trunc {
    my ($s, $w) = @_;
    return $s if length($s) <= $w;
    return substr($s, 0, $w - 1) . '…';
}

sub usage {
    my ($msg) = @_;
    print STDERR "net-chat: $msg\n\n" if $msg;
    print STDERR <<'USAGE';
usage: net-chat <command> [args]

  ls [--all]                       list chat sessions
  open  <name> [--mode M] [--topic T]   create, or resurrect an archived chat
  set   <name> [--mode M] [--topic T]   edit (owner)
  close <name>                     close (owner): archive messages to disk
  join  <name>                     join a session
  leave <name>                     drop out of the roster
  who   <name>                     show who's in a session
  post  <name> [text ...]          post a message ('-' = stdin)
  read  <name> [-n N] [--since D]  show recent history
  follow <name>                    join + stream live (Ctrl-C)
  requests <name>                  list pending join requests
  members  <name>                  list the membership list
  delete   <name> [--force]        owner: delete chat + archive (destructive)
  upload   <name> <file> [as]      upload a file (posts a system message)
  download <name> <file> [to]      download a file
  files    <name>                  list uploaded files
  approve|reject <name> <who>      act on a join request (owner)
  allow|deny     <name> <who>      edit the allow-list (owner)

  --gui [name]                     Tk window: pick/watch a chat, type to
                                   post, approve/reject join requests via
                                   pop-ups (Perl/Tk required)

  --listen HOST:PORT   daemon address (overrides --server and config)
  --server NAME        a server from [servers] in the config file
                       (~/.config/net-mgr/config); default = its 'default'
  --as NAME            display name on a loopback daemon
  --auth / --no-auth   force / suppress the SSH-key handshake

  Address precedence: --listen, then --server, then $NET_MGR_LISTEN, then
  the configured default server, then 127.0.0.1:7531.
USAGE
    exit($msg ? 2 : 0);
}
