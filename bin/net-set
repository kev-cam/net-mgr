#!/usr/bin/perl
# net-set — push routing decisions to network hosts. The mechanism
# depends on what the target is, classified by querying the local
# net-mgr daemon's aps/interfaces/addresses snapshots:
#
#   - DD-WRT AP (target's MAC is in `aps`)
#       ssh in. `ip route replace default via $IP dev br0` for the
#       AP's own egress. Then nvram set lan_gateway/wan_gateway,
#       nvram commit, restart dnsmasq — so the option=3 advertised
#       to DHCP clients changes too. Clients pick it up at lease
#       renewal.
#
#   - net-mgr peer (target reachable on TCP/7531)
#       SET_GATEWAY action=set via=$IP. Daemon installs a metric=1
#       default route that beats DHCP's. Clean revert via --clear.
#
#   - Plain Linux without net-mgr
#       ssh in. `ip route replace default via $IP metric 1`. Same
#       semantics as the daemon path. No persistence — reverts on
#       next dhclient renew or reboot.
#
# Usage:
#   net-set --gateway HOST  TARGET [TARGET ...]
#   net-set --clear         TARGET [TARGET ...]
#   net-set --status        TARGET [TARGET ...]
#
# HOST    = gateway to install. Resolved via net-lookup if not an IP.
# TARGET  = name or IP of the host whose gateway to switch.
#
# --metric N         route metric for our entry (default 1)
# --dev IFACE        pin egress interface (Linux paths only)
# --listen H[:P]     where to query the local daemon for classification
#                    (default 127.0.0.1:7531)
# --ssh-user USER    ssh user for AP/Linux fallback (default root)
# --dry-run / -n     show what would happen, do nothing
# --quiet   / -q     only print changes
#
# Exit: 0 ok · non-0 if any target failed.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);

use NetMgr::Client;

my ($gateway, $via_isp, $clear, $status, $metric, $dev,
    $listen, $ssh_user, $dry, $quiet, $help, $all, $kind_filter);
GetOptions(
    'gateway=s'  => \$gateway,
    'via-isp=s'  => \$via_isp,
    'clear'      => \$clear,
    'status'     => \$status,
    'metric=i'   => \$metric,
    'dev=s'      => \$dev,
    'listen=s'   => \$listen,
    'ssh-user=s' => \$ssh_user,
    'all'        => \$all,
    'kind=s'     => \$kind_filter,
    'dry-run|n'  => \$dry,
    'quiet|q'    => \$quiet,
    'help|h'     => \$help,
) or usage(2);
usage(0) if $help;
usage(2) unless $gateway || $via_isp || $clear || $status;
usage(2) if $clear && ($gateway || $via_isp);
usage(2) if $gateway && $via_isp;
usage(2) if $kind_filter && $kind_filter !~ /^(ap|netmgr)$/;
usage(2) unless @ARGV || $all;

$listen   //= '127.0.0.1:7531';
$ssh_user //= 'root';

# Pull classification info from the local daemon up-front. If it
# isn't reachable we can still operate, just without the AP/MAC
# correlation — every target falls back to net-mgr-or-ssh detection.
my $cls = load_classifier($listen);

# Resolve --via-isp NAME → a gateway name. Picks the first
# isp_links row with isp_name=NAME and status='active', then maps
# its gateway_machine_id back to a primary_name. From there the
# rest of the pipeline treats it the same as --gateway NAME.
if (defined $via_isp) {
    my $name = resolve_via_isp($listen, $via_isp);
    die "net-set: no active gateway found for ISP '$via_isp'\n"
        unless defined $name;
    $gateway = $name;
    print STDERR "net-set: --via-isp $via_isp → --gateway $gateway\n"
        unless $quiet;
}

my $rc = 0;
my @targets = @ARGV;
if ($all) {
    push @targets, expand_all($cls, $kind_filter);

    # Don't tell the destination gateway to use itself. Match by mac
    # so we skip every IP belonging to the same machine — e.g. if
    # gateway2-down resolves to .15.251 we'll also skip the .15.175
    # wifi address belonging to gateway2.
    if ($gateway && (my $gw_ip = resolve_gw($gateway))) {
        my $gw_mac = $cls->{ip_to_mac}{$gw_ip};
        @targets = grep {
            my $ip  = is_ipv4($_) ? $_ : net_lookup($_);
            my $mac = defined $ip ? $cls->{ip_to_mac}{$ip} : undef;
            !($ip && $ip eq $gw_ip)
              && !($mac && $gw_mac && $mac eq $gw_mac);
        } @targets;
    }

    unless (@targets) {
        die "net-set: --all matched nothing (local daemon down? "
          . "no aps + no peers known?)\n";
    }
    print STDERR "net-set --all: " . scalar(@targets) . " target(s): "
               . join(', ', @targets) . "\n" unless $quiet;
}

for my $t (@targets) {
    my ($ok, $msg) = handle_target($t, {
        action  => $clear ? 'clear' : ($status ? 'status' : 'set'),
        gateway => $gateway,
        metric  => $metric,
        dev     => $dev,
    });
    $rc = 1 unless $ok;
    print "$msg\n" if $msg && (!$quiet || !$ok);
}
exit $rc;

# =====================================================================
# Per-target dispatcher
# =====================================================================

sub handle_target {
    my ($t, $args) = @_;
    my ($host, $port) = split /:/, $t, 2;
    $port //= 7531;

    # Resolve the target host to an IP for classification + ssh.
    my $ip = is_ipv4($host) ? $host : net_lookup($host);
    return (0, "$t: cannot resolve '$host'") unless defined $ip;

    my $kind = classify_target($cls, $ip, $host);
    # status doesn't change anything; report classification + routes.
    if ($args->{action} eq 'status') {
        return status_target($t, $host, $port, $ip, $kind);
    }

    if ($kind eq 'ap') {
        return ($args->{action} eq 'set'
                ? ap_set($t, $ip, resolve_gw($args->{gateway}))
                : ap_clear($t, $ip));
    }

    # Try net-mgr first (unless we already know it's not an option).
    if ($kind ne 'plain') {
        my ($ok, $msg) = try_netmgr($t, $host, $port, $args);
        return ($ok, $msg) if $ok || $msg !~ /connect|connection refused|no route/i;
    }

    # ssh fallback (plain Linux semantics)
    return ($args->{action} eq 'set'
            ? linux_set($t, $ip, resolve_gw($args->{gateway}), $args->{metric}, $args->{dev})
            : linux_clear($t, $ip, $args->{metric}));
}

# =====================================================================
# net-mgr peer path
# =====================================================================

sub try_netmgr {
    my ($t, $host, $port, $args) = @_;
    my $cli = eval { NetMgr::Client->new(listen => "$host:$port", timeout => 4) };
    if ($@ || !$cli) {
        my $m = $@ // 'connect failed';
        $m =~ s/\s+at\s+\S+\s+line\s+\d+\.?$//;
        return (0, "$t: net-mgr unreachable ($m)");
    }
    eval { $cli->hello(consumer => "net-set.$$") };
    return (0, "$t: hello failed ($@)") if $@;

    # Best-effort SSH-key auth. Fall back silently to the legacy
    # IP-based gate (loopback / [forward] allow_peers) if the local
    # SSH key isn't trusted by the remote daemon — the verb itself
    # will then fail with a clearer "peer not permitted" message.
    eval { $cli->auth };
    if ($@ && $@ !~ /AUTH failed/) {
        # Anything other than a clean AUTH-rejection is worth showing
        # (missing ssh-keygen, missing key file, etc.).
        my $m = $@; chomp $m;
        warn "$t: auth: $m\n";
    }

    my $rc = 0; my $msg;
    if ($args->{action} eq 'clear') {
        my %k; $k{metric} = $args->{metric} if defined $args->{metric};
        if ($dry) {
            $msg = "$t [netmgr]: would SET_GATEWAY action=clear"
                 . (defined $args->{metric} ? " metric=$args->{metric}" : '');
            $rc = 1;
        } else {
            my $r = eval { $cli->set_gateway(action => 'clear', %k) };
            if ($@) { $msg = "$t [netmgr]: $@"; chomp $msg }
            else {
                $msg = "$t [netmgr]: cleared (metric=$r->{metric}, removed=$r->{removed})";
                $rc = 1;
            }
        }
    } else {
        my $via = resolve_gw($args->{gateway})
            or return (0, "$t: cannot resolve gateway '$args->{gateway}'");
        my %k = (action => 'set', via => $via);
        $k{dev}    = $args->{dev}    if defined $args->{dev};
        $k{metric} = $args->{metric} if defined $args->{metric};
        if ($dry) {
            $msg = "$t [netmgr]: would SET_GATEWAY via=$via"
                 . (defined $args->{dev} ? " dev=$args->{dev}" : '')
                 . (defined $args->{metric} ? " metric=$args->{metric}" : '');
            $rc = 1;
        } else {
            my $r = eval { $cli->set_gateway(%k) };
            if ($@) { $msg = "$t [netmgr]: $@"; chomp $msg }
            else {
                $msg = sprintf "%s [netmgr]: gateway → %s (dev=%s metric=%s)",
                    $t, $r->{via}, ($r->{dev} // '?'), ($r->{metric} // '?');
                $rc = 1;
            }
        }
    }
    eval { $cli->bye };
    return ($rc, $msg);
}

# =====================================================================
# DD-WRT AP path (ssh)
# =====================================================================

sub ap_set {
    my ($t, $ip, $via) = @_;
    return (0, "$t: cannot resolve gateway") unless defined $via;
    # Two effects:
    #   1. ip route replace default via $via dev br0   — AP's own egress
    #   2. nvram lan_gateway / wan_gateway + dnsmasq restart
    #      so option=3 advertised to DHCP clients also flips.
    # br0 is the canonical bridge name on every DD-WRT AP — eth +
    # vlan + radios are all enslaved to it.
    my $script = <<"SH";
set -e
ip route replace default via $via dev br0
nvram set lan_gateway=$via
nvram set wan_gateway=$via
nvram commit
# restart dnsmasq so the new option=3 reaches clients on renewal
stopservice dnsmasq 2>/dev/null
startservice dnsmasq 2>/dev/null
echo OK iface=br0 via=$via
SH
    if ($dry) {
        return (1, "$t [ap]: would ssh $ssh_user\@$ip + ip route replace default via $via dev br0; nvram + dnsmasq restart");
    }
    my ($ok, $out) = ssh_run($ip, $script);
    return $ok
        ? (1, "$t [ap]: gateway → $via (br0 + nvram + dnsmasq)")
        : (0, "$t [ap]: ssh failed: $out");
}

sub ap_clear {
    my ($t, $ip) = @_;
    # AP --clear is intentionally not supported: we don't track a
    # 'previous' nvram value and runtime metric=1 doesn't help on
    # DD-WRT (default route is at metric=0). User should switch
    # explicitly with --gateway gateway3 instead.
    return (0, "$t [ap]: --clear not supported for APs; use "
              . "--gateway gateway3 (or whichever) to switch back");
}

# =====================================================================
# Plain Linux path (ssh fallback when net-mgr is missing)
# =====================================================================

sub linux_set {
    my ($t, $ip, $via, $metric, $dev) = @_;
    return (0, "$t: cannot resolve gateway") unless defined $via;
    $metric //= 1;
    my $devarg = defined $dev ? "dev $dev " : '';
    my $script = "ip route replace default via $via ${devarg}metric $metric && echo OK";
    if ($dry) {
        return (1, "$t [linux]: would ssh $ssh_user\@$ip + $script");
    }
    my ($ok, $out) = ssh_run($ip, $script);
    return $ok
        ? (1, "$t [linux]: gateway → $via (metric=$metric, runtime only)")
        : (0, "$t [linux]: ssh failed: $out");
}

sub linux_clear {
    my ($t, $ip, $metric) = @_;
    $metric //= 1;
    my $script = "ip route del default metric $metric 2>/dev/null; echo OK";
    if ($dry) {
        return (1, "$t [linux]: would ssh $ssh_user\@$ip + $script");
    }
    my ($ok, $out) = ssh_run($ip, $script);
    return $ok
        ? (1, "$t [linux]: cleared metric=$metric override")
        : (0, "$t [linux]: ssh failed: $out");
}

# =====================================================================
# Status (read-only)
# =====================================================================

sub status_target {
    my ($t, $host, $port, $ip, $kind) = @_;
    # Try net-mgr's host-debug first (unless it's an AP — APs don't
    # run net-mgr). Fall back to a tiny ssh probe.
    if ($kind ne 'ap') {
        my $cli = eval { NetMgr::Client->new(listen => "$host:$port", timeout => 4) };
        if ($cli) {
            $cli->hello(consumer => "net-set.$$");
            my $out = eval { $cli->poll('host-debug') };
            if (!$@ && defined $out) {
                my ($section) = $out =~ /(==\[ ROUTER \]==.*?)(?:\n==\[|\z)/s;
                eval { $cli->bye };
                return (1, "=== $t [$kind] ===\n" . ($section // '(no ROUTER section)'));
            }
            eval { $cli->bye };
        }
    }
    # ssh probe for AP / no-net-mgr
    my ($ok, $out) = ssh_run($ip, 'ip route show default 2>/dev/null || route -n 2>/dev/null | grep ^0');
    return $ok
        ? (1, "=== $t [$kind] ===\n  default routes:\n    "
              . join("\n    ", split /\n/, $out))
        : (0, "$t: cannot probe ($out)");
}

# =====================================================================
# Classification — query local daemon for aps/interfaces/addresses
# =====================================================================

# Returns a list of target IPs covering the LAN: every AP from the
# `aps` table, plus every reachable net-mgr peer from `peers`. With
# $kind, restrict to one kind.
sub expand_all {
    my ($cls, $kind) = @_;
    my @out;
    my %seen;
    if (!$kind || $kind eq 'ap') {
        # APs — pick the first IP we know for each AP MAC.
        for my $mac (sort keys %{ $cls->{ap_mac} }) {
            my $ip = _ip_for_mac($cls, $mac);
            next unless defined $ip && !$seen{$ip}++;
            push @out, $ip;
        }
    }
    if (!$kind || $kind eq 'netmgr') {
        # net-mgr peers.
        my $peers = $cls->{peers} || [];
        for my $p (@$peers) {
            my $h = $p->{host} or next;
            next if $seen{$h}++;
            push @out, $h;
        }
    }
    return @out;
}

sub _ip_for_mac {
    my ($cls, $mac) = @_;
    # Reverse the ip_to_mac map to find the first IP for $mac.
    while (my ($ip, $m) = each %{ $cls->{ip_to_mac} }) {
        return $ip if $m eq $mac;
    }
    return undef;
}

# Snapshot isp_links from the local daemon, find an active row for
# $isp, return the matching machine's primary_name. Returns undef
# if nothing matches. We re-snapshot machines specifically because
# the global $cls was built before this function was called and the
# caller wants a name back (so the existing --gateway logic can pick
# up from there).
sub resolve_via_isp {
    my ($listen, $isp) = @_;
    my %args; $args{listen} = $listen if defined $listen;
    my $c = NetMgr::Client->new(%args, timeout => 5) or return undef;
    $c->hello(consumer => "net-set-via-isp.$$");
    my $links = eval { $c->snapshot(1, 'isp_links',
                                     where => "isp_name = '$isp'") } || [];
    my $machs = eval { $c->snapshot(2, 'machines') } || [];
    eval { $c->bye };
    my %name = map { $_->{id} => $_->{primary_name} }
               grep { defined $_->{primary_name} } @$machs;
    # Prefer status=active; fall back to first match if nothing's
    # explicitly active (operator may have left status blank).
    my @active = grep { ($_->{status} // '') eq 'active' } @$links;
    my $row = $active[0] // $links->[0];
    return undef unless $row && $name{ $row->{gateway_machine_id} };
    return $name{ $row->{gateway_machine_id} };
}

sub load_classifier {
    my ($listen) = @_;
    my %c = (ip_to_mac => {}, ap_mac => {}, kind_by_mac => {},
             name_to_ips => {}, peers => [], available => 0);
    my $cli = eval { NetMgr::Client->new(listen => $listen, timeout => 5) };
    return \%c unless $cli;
    eval {
        $cli->hello(consumer => "net-set-cls.$$");
        my $aps   = $cli->snapshot(1, 'aps');
        my $ifs   = $cli->snapshot(2, 'interfaces');
        my $addrs = $cli->snapshot(3, 'addresses',
                                    where => "family = 'v4'");
        my $machs = $cli->snapshot(4, 'machines');
        my $peers = eval { $cli->snapshot(5, 'peers') } || [];
        $cli->bye;
        $c{peers} = [ grep { $_->{host} } @$peers ];

        $c{ap_mac}{ lc $_->{mac} } = 1 for grep { $_->{mac} } @$aps;
        my %name_by_mid = map { $_->{id} => $_->{primary_name} }
                          grep { defined $_->{primary_name} } @$machs;
        my %mid_by_mac;
        for my $i (@$ifs) {
            next unless $i->{mac};
            $c{kind_by_mac}{ lc $i->{mac} } = $i->{kind} // 'unknown';
            $mid_by_mac{ lc $i->{mac} } = $i->{machine_id}
                if defined $i->{machine_id};
        }
        for my $a (@$addrs) {
            next unless $a->{mac} && $a->{addr};
            $c{ip_to_mac}{ $a->{addr} } = lc $a->{mac};
            my $name = $name_by_mid{ $mid_by_mac{ lc $a->{mac} } // 0 };
            push @{ $c{name_to_ips}{$name} }, $a->{addr} if $name;
        }
        $c{available} = 1;
    };
    return \%c;
}

sub classify_target {
    my ($cls, $ip, $name) = @_;
    return 'unknown' unless $cls->{available};
    my $mac = $cls->{ip_to_mac}{$ip};
    return 'ap' if defined $mac && $cls->{ap_mac}{$mac};
    return 'unknown';   # could be netmgr or plain — caller probes
}

# =====================================================================
# Helpers
# =====================================================================

sub net_lookup {
    my ($name) = @_;
    chomp(my $ip = `net-lookup --include-stale @{[ shell_quote($name) ]} 2>/dev/null`);
    return $ip if is_ipv4($ip);
    # net-lookup matches against the daemon's known names. FQDNs that
    # include dots usually aren't in primary_name as-is, so fall back
    # to system DNS.
    if ($name =~ /\./) {
        require Socket;
        my @r = gethostbyname($name);
        if (@r >= 5 && defined $r[4]) {
            my $packed = $r[4];
            return Socket::inet_ntoa($packed) if length($packed) == 4;
        }
    }
    return undef;
}

sub resolve_gw {
    my ($name) = @_;
    return undef unless defined $name;
    return $name if is_ipv4($name);

    # If the local classifier has multiple IPs for this name, prefer
    # an ethernet-kind interface — wifi gateways are nearly always
    # the wrong thing for routing (they may not be wired into the
    # LAN backbone, may rate-limit, etc.). Fall through to net-lookup
    # if the classifier doesn't know.
    if (my $ips = $cls->{name_to_ips}{$name}) {
        my @eth = grep {
            my $mac = $cls->{ip_to_mac}{$_};
            $mac && ($cls->{kind_by_mac}{$mac} // '') eq 'ethernet';
        } @$ips;
        return $eth[0] if @eth;
        return $ips->[0] if @$ips;
    }
    return net_lookup($name);
}

sub is_ipv4 { defined $_[0] && $_[0] =~ /^(\d+)\.(\d+)\.(\d+)\.(\d+)$/ }

sub shell_quote {
    my ($s) = @_;
    return "''" unless defined $s && length $s;
    return $s   if $s =~ /^[A-Za-z0-9_.\/=:,@-]+$/;
    (my $q = $s) =~ s/'/'\\''/g;
    return "'$q'";
}

# Run a shell snippet on a remote host. Returns (rc-bool, captured-output).
sub ssh_run {
    my ($host, $script) = @_;
    my @cmd = ('ssh', '-o', 'BatchMode=yes',
                       '-o', 'ConnectTimeout=5',
                       '-o', 'StrictHostKeyChecking=accept-new',
                       '-T', '-q', "$ssh_user\@$host", 'sh');
    my $pid = open my $fh, '|-';
    return (0, "fork: $!") unless defined $pid;
    if ($pid == 0) {
        # child writes to ssh's stdin
        exec { $cmd[0] } @cmd;
        die "exec: $!";
    }
    print $fh $script;
    close $fh;
    my $rc = $?;
    return ($rc == 0, $rc ? "ssh rc=" . ($rc >> 8) : 'ok');
}

sub usage {
    my ($rc) = @_;
    print STDERR <<"EOF";
net-set — point a host's DEFAULT ROUTE at a chosen gateway (egress control).
It changes ONLY which gateway each TARGET uses to reach the Internet; it does
not touch DHCP ranges, reservations, DNS, or any other host setting. For
DD-WRT APs it also flips the advertised default-gateway (DHCP option 3) so
clients follow at lease renewal.

Usage:
  net-set --gateway HOST   TARGET [TARGET ...] | --all
  net-set --via-isp NAME   TARGET [TARGET ...] | --all
  net-set --clear          TARGET [TARGET ...] | --all
  net-set --status         TARGET [TARGET ...] | --all

  HOST    = gateway to install (resolved via net-lookup if not an IP)
  NAME    = ISP name in isp_links table (e.g. 'comcast', 'tmobile').
            Resolved to a gateway by picking a row with status=active.
  TARGET  = host whose gateway to switch (name or IP)
  --all   = enumerate from the local daemon's snapshots: every AP in
            'aps' (DD-WRT path) plus every reachable peer in 'peers'
            (net-mgr path). The destination gateway and any other
            interface on the same machine are auto-skipped.

Per target, net-set picks the right mechanism by querying the local
net-mgr's classification:
  - DD-WRT AP   → ssh + ip route replace + nvram lan_gateway +
                  dnsmasq reload (also flips advertised option=3)
  - net-mgr     → SET_GATEWAY verb (metric-1 override; --clear reverts)
  - plain Linux → ssh + ip route replace default ... metric 1

Options:
  --metric N         route metric (Linux paths; default 1)
  --dev IFACE        pin egress interface
  --kind ap|netmgr   restrict --all to one kind
  --listen H[:P]     local daemon for classification (default 127.0.0.1:7531)
  --ssh-user USER    ssh user for AP/Linux paths (default root)
  --dry-run / -n     don't apply
  --quiet   / -q     only print changes
  --help    / -h
EOF
    exit($rc // 0);
}
