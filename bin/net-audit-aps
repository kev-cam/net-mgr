#!/usr/bin/perl
# net-audit-aps — check that every AP's DHCP server is advertising
# the right default-gateway, and fix the drifted ones with --fix.
#
# Two passes:
#
# 1. Default-gateway check.  DD-WRT APs run their own dnsmasq for the
#    clients on their L2 segment. The advertised default-gateway
#    (DHCP option 3) comes from nvram lan_gateway. If it drifts
#    (operator changes via net-set, AP firmware reset, rogue manual
#    config) the clients on that AP route through the wrong place
#    until their lease renews and they pick up the right option=3.
#
# 2. Per-MAC static-lease check.  DD-WRT also keeps a
#    nvram static_leases list mapping MAC → IP for DHCP reservations
#    (Services > DHCP > Static Leases in the web UI). When an
#    operator edits one on the AP without updating
#    /etc/net-mgr/dhcp.master (the source of truth) the AP and
#    dhcp.master disagree about which IP that device should get.
#    For any MAC present in both, the IPs are compared; mismatch
#    is flagged as DRIFT. Missing-on-AP / extra-on-AP are not
#    flagged (not every AP serves every host's segment).
#
# Usage:
#   net-audit-aps                          read-only audit (exit 1 if drift)
#   net-audit-aps --gateway gateway3-down  compare against a specific gateway
#   net-audit-aps --via-isp comcast        compare against the ISP-serving gw
#   net-audit-aps --fix                    interactive: per drift, choose
#                                          [a]p / [m]aster / [s]kip
#   net-audit-aps --auto                   non-interactive: master wins for all
#
# Other options:
#   --listen H[:P]    daemon for snapshot reads (default 127.0.0.1:7531)
#   --ssh-user USER   ssh user for AP probes (default root)
#   --quiet / -q      only print drift
#   --help / -h
#
# Exits 0 if every AP is correct (or --fix succeeded for all);
# 1 if at least one AP is drifted (without --fix) or fix failed;
# 2 on bad args / can't determine expected gateway.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);

use NetMgr::Client;
use NetMgr::Producer::DhcpMaster;

my ($gateway, $via_isp, $fix, $auto, $listen, $ssh_user, $quiet, $help);
GetOptions(
    'gateway=s'  => \$gateway,
    'via-isp=s'  => \$via_isp,
    'fix'        => \$fix,
    'auto'       => \$auto,
    'listen=s'   => \$listen,
    'ssh-user=s' => \$ssh_user,
    'quiet|q'    => \$quiet,
    'help|h'     => \$help,
) or usage(2);
usage(0) if $help;
usage(2) if $gateway && $via_isp;
$fix = 1 if $auto;     # --auto implies --fix (just without the prompts)
$ssh_user //= 'root';
$listen   //= '127.0.0.1:7531';

# ---- snapshot the daemon's view -------------------------------------

my $cli = NetMgr::Client->new(listen => $listen, timeout => 5);
$cli->hello(consumer => "net-audit-aps.$$");
my $aps   = $cli->snapshot(1, 'aps');
my $ifs   = $cli->snapshot(2, 'interfaces');
my $addrs = $cli->snapshot(3, 'addresses', where => "family = 'v4'");
my $machs = $cli->snapshot(4, 'machines');
my $links = eval { $cli->snapshot(5, 'isp_links') } || [];
$cli->bye;

my %name_by_mid = map { $_->{id} => $_->{primary_name} }
                  grep { defined $_->{primary_name} } @$machs;
my %mid_by_mac;
for my $i (@$ifs) {
    next unless $i->{mac} && defined $i->{machine_id};
    $mid_by_mac{ lc $i->{mac} } = $i->{machine_id};
}
my %ip_by_mac;
for my $a (@$addrs) {
    next unless $a->{mac} && $a->{addr};
    push @{ $ip_by_mac{ lc $a->{mac} } }, $a->{addr};
}

# ---- resolve the expected gateway IP --------------------------------

my $expected_name = $gateway;
if ($via_isp && !$expected_name) {
    my @act = grep { ($_->{status}//'') eq 'active'
                  && ($_->{isp_name}//'') eq $via_isp } @$links;
    @act = grep { ($_->{isp_name}//'') eq $via_isp } @$links unless @act;
    if (@act) {
        $expected_name = $name_by_mid{ $act[0]{gateway_machine_id} };
    }
    die "net-audit-aps: no isp_links row for ISP '$via_isp'\n"
        unless $expected_name;
}
if (!$expected_name) {
    # Default: pick whichever isp_links row is currently active. If
    # multiple, prefer one whose name contains 'down' (LAN-side).
    my @act = grep { ($_->{status}//'') eq 'active' } @$links;
    die "net-audit-aps: no active isp_links rows; pass --gateway HOST\n"
        unless @act;
    my @names = map  { $name_by_mid{ $_->{gateway_machine_id} } } @act;
    @names = grep { defined } @names;
    @names = sort { ($b =~ /-down$/) <=> ($a =~ /-down$/) || $a cmp $b } @names;
    $expected_name = $names[0];
    die "net-audit-aps: couldn't pick a default gateway from isp_links\n"
        unless $expected_name;
}
# Resolve name → IP, preferring ethernet
my $expected_ip = resolve_gw($expected_name);
die "net-audit-aps: can't resolve '$expected_name' to an IP\n"
    unless $expected_ip;

print "expected gateway: $expected_name = $expected_ip\n" unless $quiet;

# ---- iterate APs ----------------------------------------------------

my @ap_list;
for my $a (@$aps) {
    my $mac = lc $a->{mac};
    my $mid = $mid_by_mac{$mac};
    my $name = defined $mid ? $name_by_mid{$mid} : undef;
    my $ips = $ip_by_mac{$mac} || [];
    my ($ip) = grep { defined } @$ips;
    push @ap_list, { mac => $mac, name => $name // '(unknown)',
                     ip  => $ip // '?' };
}

my @drifted;
my @failed;
my @ok;

printf "%-22s %-15s  %-15s  %s\n",
    "AP", "IP", "lan_gateway", "status" unless $quiet;
for my $a (sort { $a->{name} cmp $b->{name} } @ap_list) {
    next unless $a->{ip} ne '?';
    my $cur = probe_ap_gateway($a->{ip});
    if (!defined $cur) {
        push @failed, $a;
        next if $quiet;
        printf "%-22s %-15s  %-15s  %s\n",
            $a->{name}, $a->{ip}, '?', 'probe FAILED';
        next;
    }
    if ($cur eq $expected_ip) {
        push @ok, $a;
        next if $quiet;
        printf "%-22s %-15s  %-15s  OK\n", $a->{name}, $a->{ip}, $cur;
    } else {
        push @drifted, { %$a, cur => $cur };
        printf "%-22s %-15s  %-15s  DRIFT (should be $expected_ip)\n",
            $a->{name}, $a->{ip}, $cur;
    }
}

unless ($quiet) {
    printf "\n%d ok / %d drift / %d unreachable (of %d)\n",
        scalar(@ok), scalar(@drifted), scalar(@failed), scalar(@ap_list);
}

if ($fix && @drifted) {
    print "\n--- fixing gateway drift ---\n";
    for my $a (@drifted) {
        # The gateway audit has only one "right answer" (the expected
        # gateway), so there's no AP-vs-master choice — just confirm
        # the push. Y/N pattern reused via ask_a_m's [M] default
        # (master-wins = "push the expected value").
        my $do_push;
        if ($auto) {
            $do_push = 1;
        } else {
            my $prompt = sprintf "  %-22s %-15s  set lan_gateway → %s ?",
                $a->{name}, $a->{ip}, $expected_ip;
            my $c = ask_a_m($prompt);   # 'm' default → push
            $do_push = ($c eq 'm');
            # 'a' (take AP) for gateway doesn't make sense — there's
            # no master-file equivalent. Treat as skip with a note.
            if ($c eq 'a') {
                print "    (AP gateway is operator-controlled; "
                    . "use 'm' to push or 's' to skip)\n";
                next;
            }
        }
        next unless $do_push;
        my @cmd = ('net-set', '--gateway', $expected_name, $a->{ip});
        my $rc = system(@cmd);
        print($rc == 0 ? "    OK\n" : "    FAILED (rc=" . ($rc>>8) . ")\n");
    }
}

# ---- static-lease audit --------------------------------------------
#
# DD-WRT stores per-MAC DHCP reservations in nvram static_leases as
#   mac=name=ip=lease_minutes  (space-separated entries).
#
# Tablets and phones roam: the SAME MAC may legitimately have
# different IPs on different /24 subnets (a per-subnet reservation
# for whichever AP it's currently associated to). dhcp.master often
# only has one entry per MAC (whichever subnet was first set up).
# So the audit is subnet-scoped:
#
#   - Index dhcp.master by (mac, /24-of-fixed-address).
#   - For each AP's lease, compute the /24 of the leased IP and
#     compare only against dhcp.master's entry for that (mac,/24)
#     pair. No entry in master for that subnet = not master's
#     opinion, skip (just check propagation).
#   - Cross-AP within the same /24 must agree: if two APs serving
#     192.168.15.0/24 disagree on a MAC's IP, that's a real bug
#     (clients get different IPs depending on which AP they DHCP
#     from) and is flagged independently.
my $master = '/etc/net-mgr/dhcp.master';
my @lease_drift;          # AP disagrees with master, same subnet
my @intra_subnet_drift;   # APs disagree with each other in same /24
my @lease_fix_fail;
if (-r $master) {
    my @records = NetMgr::Producer::DhcpMaster::parse_file($master);
    my @hosts   = NetMgr::Producer::DhcpMaster::hosts_only(@records);
    # %master_ip{ mac }{ subnet/24 } = { ip, name }
    my %master_ip;
    for my $h (grep { $_->{mac} && $_->{ip} } @hosts) {
        my $sn = _subnet_of($h->{ip}) or next;
        $master_ip{ lc $h->{mac} }{$sn} = { ip => $h->{ip}, name => $h->{name} };
    }

    print "\n--- static-lease audit (vs $master) ---\n" unless $quiet;
    my %seen_propagation;     # mac:ip → 1, dedupe across APs
    my @new_macs;             # entries to propagate
    # ip_by_mac_sn{mac}{subnet} = { ap_name => ip } for intra-subnet check.
    my %ip_by_mac_sn;
    for my $a (sort { $a->{name} cmp $b->{name} } @ap_list) {
        next unless $a->{ip} ne '?';
        my $leases = probe_ap_leases($a->{ip});
        if (!defined $leases) {
            next if $quiet;
            printf "  %-22s %-15s  (leases probe failed)\n", $a->{name}, $a->{ip};
            next;
        }
        for my $mac (sort keys %$leases) {
            my $ap_ip   = $leases->{$mac}{ip};
            my $ap_name = $leases->{$mac}{name};
            my $sn      = _subnet_of($ap_ip);
            $ip_by_mac_sn{$mac}{$sn}{ $a->{name} } = $ap_ip if $sn;

            if (my $m = $sn ? $master_ip{$mac}{$sn} : undef) {
                next if $m->{ip} eq $ap_ip;        # agree → OK
                push @lease_drift, {
                    ap_name   => $a->{name},
                    ap_ip     => $a->{ip},
                    mac       => $mac,
                    ap_lease  => $ap_ip,
                    master_ip => $m->{ip},
                    name      => $m->{name},
                };
            } else {
                # No master entry for this (mac, subnet) pair. Either:
                # a) MAC unknown to master entirely → propagate as new
                # b) MAC known to master in a DIFFERENT subnet → this is
                #    a roaming-device per-subnet assignment; treat as
                #    propagation if not in DB yet.
                my $key = "$mac:$ap_ip";
                next if $seen_propagation{$key}++;
                my @known = @{ $ip_by_mac{$mac} || [] };
                next if grep { $_ eq $ap_ip } @known;
                push @new_macs, {
                    ap_name => $a->{name},
                    mac     => $mac,
                    ip      => $ap_ip,
                    name    => $ap_name,
                };
            }
        }
    }

    # Intra-subnet consistency: any (mac, subnet) where two APs
    # disagree on the IP is logged independently of the master.
    for my $mac (sort keys %ip_by_mac_sn) {
        for my $sn (sort keys %{ $ip_by_mac_sn{$mac} }) {
            my %ips;
            push @{ $ips{ $ip_by_mac_sn{$mac}{$sn}{$_} } }, $_
                for sort keys %{ $ip_by_mac_sn{$mac}{$sn} };
            next if keys(%ips) == 1;     # all APs in this /24 agree
            for my $ip (sort keys %ips) {
                push @intra_subnet_drift, {
                    mac    => $mac,
                    subnet => $sn,
                    ip     => $ip,
                    aps    => $ips{$ip},
                };
            }
        }
    }

    if (@lease_drift) {
        printf "\n%-22s %-17s  %-12s  %-15s  %-15s\n",
            "AP", "MAC", "HOST", "AP says", "master says"
            unless $quiet;
        for my $d (@lease_drift) {
            printf "%-22s %-17s  %-12s  %-15s  %-15s  DRIFT\n",
                $d->{ap_name}, $d->{mac}, $d->{name},
                $d->{ap_lease}, $d->{master_ip};
        }
    } elsif (!$quiet) {
        print "  all per-MAC reservations agree with $master\n";
    }

    if (@intra_subnet_drift) {
        # Group by (mac, subnet) for a more readable display.
        my %by_key;
        for my $i (@intra_subnet_drift) {
            push @{ $by_key{"$i->{mac}|$i->{subnet}"} }, $i;
        }
        print "\n--- intra-subnet disagreement (APs in same /24 differ) ---\n";
        for my $k (sort keys %by_key) {
            my @rows = @{ $by_key{$k} };
            my ($mac, $sn) = split /\|/, $k;
            print "  $mac in $sn:\n";
            for my $r (@rows) {
                printf "    %-15s  via %s\n", $r->{ip}, join(',', @{ $r->{aps} });
            }
        }
    }

    if ($fix && @lease_drift) {
        print "\n--- resolving static-lease drift ---\n";
        # Per-item user choice — but the actual nvram push is batched
        # per-AP because each push is a single nvram set + commit +
        # dnsmasq HUP. Accumulate per-AP fix lists keyed by the
        # operator's choice.
        my %ap_fix_master_wins;    # ap_ip → arrayref of drift entries
        my %ap_name_for;
        for my $d (sort {
                $a->{ap_name} cmp $b->{ap_name} || $a->{mac} cmp $b->{mac}
            } @lease_drift) {
            my $choice;
            if ($auto) {
                $choice = 'm';
            } else {
                my $prompt = sprintf "  %-22s %-17s  %-12s  AP=%s  master=%s ?",
                    $d->{ap_name}, $d->{mac}, $d->{name},
                    $d->{ap_lease}, $d->{master_ip};
                $choice = ask_a_m($prompt);
            }
            if ($choice eq 'm') {
                push @{ $ap_fix_master_wins{ $d->{ap_ip} } }, $d;
                $ap_name_for{ $d->{ap_ip} } //= $d->{ap_name};
            } elsif ($choice eq 'a') {
                # Take AP value: update dhcp.master + propagate to DB.
                my $n = update_master_ip($master, $d->{mac}, $d->{ap_lease});
                if ($n > 0) {
                    print "    dhcp.master: $d->{name} ($d->{mac}) "
                        . "→ $d->{ap_lease}\n";
                    push @new_macs, {
                        ap_name => $d->{ap_name},
                        mac     => $d->{mac},
                        ip      => $d->{ap_lease},
                        name    => $d->{name},
                    };
                } else {
                    warn "    dhcp.master: couldn't find $d->{mac} to update\n";
                    push @lease_fix_fail, $d->{ap_ip};
                }
            }
            # 's' / skip → no-op
        }

        # Now push master-wins corrections, one batch per AP.
        for my $ap_ip (sort keys %ap_fix_master_wins) {
            my $items = $ap_fix_master_wins{$ap_ip};
            print "  $ap_name_for{$ap_ip} ($ap_ip): pushing "
                . scalar(@$items) . " correction(s) to AP\n";
            my $ok = push_lease_fix($ap_ip, $items);
            printf "    %s\n", $ok ? "OK" : "FAILED";
            push @lease_fix_fail, $ap_ip unless $ok;
        }
    }

    # Propagate AP-only MACs (not in dhcp.master, not in DB at that
    # IP) so net-mgr picks them up. OBSERVE kind=host is idempotent,
    # so repeated runs cost nothing. Tagged source so it's clear
    # where the entry came from when looking at the addresses table.
    if (@new_macs) {
        print "\n--- new MACs propagated to net-mgr ---\n" unless $quiet;
        my $cli2 = NetMgr::Client->new(listen => $listen, timeout => 5);
        $cli2->hello(consumer => "net-audit-aps.propagate.$$");
        for my $n (@new_macs) {
            my $reply = $cli2->observe(
                kind        => 'host',
                mac         => $n->{mac},
                ip          => $n->{ip},
                family      => 'v4',
                name        => $n->{name} // '',
                name_source => 'ap-static-leases',
                source      => "audit:ap-static-leases:$n->{ap_name}",
            );
            if ($reply && $reply =~ /^ERR/) {
                warn "  $n->{mac} -> $n->{ip} ($n->{name}): $reply\n";
            } elsif (!$quiet) {
                printf "  %-17s  %-15s  %-12s  from $n->{ap_name}\n",
                    $n->{mac}, $n->{ip}, $n->{name} // '';
            }
        }
        $cli2->bye;
    }
}

# Exit code semantics:
#   any drift (gateway or lease) → 1 unless --fix
#   --fix but any push failed     → 1
#   probe failures (no audit run) → 1
#   else                          → 0
my $drift_left = @drifted || @lease_drift || @intra_subnet_drift;
my $fix_bad    = @lease_fix_fail;
# Intra-subnet drift isn't auto-fixable (which AP is right?), so it
# always demands operator attention — non-zero even under --fix.
if ($drift_left && !$fix)  { exit 1 }
if ($fix && $fix_bad)      { exit 1 }
if ($fix && @intra_subnet_drift) { exit 1 }
exit($failed[0] ? 1 : 0);

# =====================================================================
# Helpers
# =====================================================================

# Pull the lan_gateway value from an AP's nvram via ssh. Returns the
# IP string or undef on any probe failure. DD-WRT keeps both
# lan_gateway and wan_gateway nvram values; lan_gateway is what
# dnsmasq's option=3 uses on a bridge-mode AP. We read both for
# diagnostic completeness but only return lan_gateway for the audit.
sub probe_ap_gateway {
    my ($ip) = @_;
    my @cmd = ('ssh', '-o', 'BatchMode=yes',
                       '-o', 'ConnectTimeout=5',
                       '-o', 'StrictHostKeyChecking=accept-new',
                       '-T', '-q', "$ssh_user\@$ip",
                       'nvram get lan_gateway');
    my $pid = open my $fh, '-|';
    return undef unless defined $pid;
    if ($pid == 0) {
        open STDIN, '<', '/dev/null';
        exec @cmd; exit 127;
    }
    chomp(my $val = <$fh> // '');
    close $fh;
    return undef if $? != 0;
    return undef unless $val =~ /^\d+\.\d+\.\d+\.\d+$/;
    return $val;
}

# Pull `nvram get static_leases` from an AP and parse into
# { mac (lc) => { ip => ..., name => ... } }. DD-WRT's format is
# space-separated entries, each "mac=name=ip=lease_minutes".
# Returns undef on probe failure, empty hashref if the AP has no
# static leases configured.
sub probe_ap_leases {
    my ($ip) = @_;
    my @cmd = ('ssh', '-o', 'BatchMode=yes',
                       '-o', 'ConnectTimeout=5',
                       '-o', 'StrictHostKeyChecking=accept-new',
                       '-T', '-q', "$ssh_user\@$ip",
                       'nvram get static_leases');
    my $pid = open my $fh, '-|';
    return undef unless defined $pid;
    if ($pid == 0) {
        open STDIN, '<', '/dev/null';
        exec @cmd; exit 127;
    }
    chomp(my $val = <$fh> // '');
    close $fh;
    return undef if $? != 0;
    my %out;
    for my $entry (split /\s+/, $val) {
        my @f = split /=/, $entry;
        next unless @f >= 3;
        my ($mac, $name, $lease_ip) = ($f[0], $f[1], $f[2]);
        next unless $mac =~ /^[0-9a-fA-F:]{17}$/
                 && $lease_ip =~ /^\d+\.\d+\.\d+\.\d+$/;
        $out{ lc $mac } = { ip => $lease_ip, name => $name };
    }
    return \%out;
}

# Push corrected static_leases back to an AP. $fixes is an arrayref
# of {mac, master_ip, ...}. Reads current nvram static_leases,
# replaces the IP field on matching MAC entries (leaves non-drifted
# entries untouched), pushes back, commits, and HUPs dnsmasq so the
# change takes effect immediately. Returns 1 on success, 0 on any
# step failing.
sub push_lease_fix {
    my ($ap_ip, $fixes) = @_;
    my $raw = _ssh_capture($ap_ip, 'nvram get static_leases');
    return 0 unless defined $raw;
    my %wanted = map { lc($_->{mac}) => $_->{master_ip} } @$fixes;
    my @new;
    for my $entry (split /\s+/, $raw) {
        my @f = split /=/, $entry;
        if (@f >= 3 && exists $wanted{ lc $f[0] }) {
            $f[2] = $wanted{ lc $f[0] };
        }
        push @new, join('=', @f);
    }
    my $new_val = join(' ', @new);
    # Single-quote the value because it contains spaces; the value
    # itself never contains single quotes (MAC=NAME=IP=NUM tokens).
    my $cmd = "nvram set static_leases='$new_val' && nvram commit "
            . "&& killall -HUP dnsmasq";
    return _ssh_run($ap_ip, $cmd);
}

# Per-drift choice: which side wins?
#   a = take AP value      (update dhcp.master + propagate to DB)
#   m = take master value  (push master to AP, current --fix path)
#   s = skip               (leave drift in place)
# Default is master-wins, matching the historical --fix behaviour.
# EOF returns default so a piped run doesn't accidentally edit
# dhcp.master.
sub ask_a_m {
    my ($prompt) = @_;
    print "$prompt [A]P / [M]aster / [S]kip [M] ";
    my $line = <STDIN>;
    return 'm' unless defined $line;
    $line =~ s/^\s+|\s+$//g;
    return 'm' if $line eq '' || $line =~ /^m/i;
    return 'a' if $line =~ /^a/i;
    return 's' if $line =~ /^s/i;
    return 'm';   # unrecognised → safe default
}

# In-place update of dhcp.master: find the host{} block containing
# the given MAC and rewrite its fixed-address to $new_ip. Backup
# copy goes to "$path.bak" before write. Returns the number of
# host blocks matched (0 = not found, 1 = normal, >1 = duplicate
# MAC entries which we'd all rewrite — flag suggests dhcp.master
# itself needs cleanup).
sub update_master_ip {
    my ($path, $mac, $new_ip) = @_;
    open my $rfh, '<', $path or return 0;
    local $/;
    my $content = <$rfh>;
    close $rfh;
    my $mac_re = quotemeta $mac;
    my $count = ($content =~ s{
        ( host \s+ \S+ \s* \{ [^{}]*
          hardware \s+ ethernet \s+ $mac_re [^{}]*
          fixed-address \s+ )
        \d+\.\d+\.\d+\.\d+
        ( [^{}]* \} )
    }{$1$new_ip$2}gxsi);
    return 0 if $count == 0;
    # Backup, then atomic-ish write.
    rename $path, "$path.bak" or warn "  backup: $!\n";
    open my $wfh, '>', $path or do {
        rename "$path.bak", $path;
        die "write $path: $!\n";
    };
    print $wfh $content;
    close $wfh;
    return $count;
}

# /24-classful subnet string for an IPv4 address. NULL on bad input.
sub _subnet_of {
    my ($ip) = @_;
    return undef unless defined $ip && $ip =~ /^(\d+\.\d+\.\d+)\.\d+$/;
    return "$1.0/24";
}

sub _ssh_capture {
    my ($ip, $cmd) = @_;
    my @c = ('ssh', '-o', 'BatchMode=yes', '-o', 'ConnectTimeout=5',
             '-T', '-q', "$ssh_user\@$ip", $cmd);
    my $pid = open my $fh, '-|';
    return undef unless defined $pid;
    if ($pid == 0) { open STDIN, '<', '/dev/null'; exec @c; exit 127 }
    chomp(my $val = <$fh> // '');
    close $fh;
    return $? == 0 ? $val : undef;
}

sub _ssh_run {
    my ($ip, $cmd) = @_;
    my @c = ('ssh', '-o', 'BatchMode=yes', '-o', 'ConnectTimeout=5',
             '-T', '-q', "$ssh_user\@$ip", $cmd);
    return system(@c) == 0;
}

# Resolve a machine name to an IP, preferring ethernet over wifi
# (matching net-set's resolve_gw behaviour).
sub resolve_gw {
    my ($name) = @_;
    return $name if $name =~ /^(\d+)\.(\d+)\.(\d+)\.(\d+)$/;
    # Same per-name lookup logic as net-set: pick ethernet first.
    my %kind_by_mac;
    for my $i (@$ifs) {
        next unless $i->{mac};
        $kind_by_mac{ lc $i->{mac} } = lc($i->{kind} // 'unknown');
    }
    my %ip_to_mac;
    for my $a (@$addrs) {
        next unless $a->{mac} && $a->{addr};
        $ip_to_mac{ $a->{addr} } = lc $a->{mac};
    }
    my @ips_for;
    for my $a (@$addrs) {
        next unless $a->{mac} && $a->{addr};
        my $mac = lc $a->{mac};
        my $mid = $mid_by_mac{$mac};
        next unless defined $mid;
        push @ips_for, $a->{addr} if ($name_by_mid{$mid}//'') eq $name;
    }
    return undef unless @ips_for;
    my @eth = grep { ($kind_by_mac{ $ip_to_mac{$_} // '' } // '')
                     eq 'ethernet' } @ips_for;
    return $eth[0] || $ips_for[0];
}

sub usage {
    my ($rc) = @_;
    print STDERR <<"EOF";
Usage:
  net-audit-aps                              audit against active isp_links
  net-audit-aps --gateway gateway3-down      audit against specific gateway
  net-audit-aps --via-isp comcast            audit against ISP-resolved gateway
  net-audit-aps --fix                        per drift: [A]P / [M]aster / [S]kip
  net-audit-aps --auto                       master wins everywhere, no prompts

For each AP in the `aps` table, ssh in and read nvram lan_gateway
and nvram static_leases. Compare against the expected gateway IP
and /etc/net-mgr/dhcp.master per (mac, /24). Per-MAC drift inside
a single /24 is reported; cross-subnet roaming reservations
(same MAC, different IP on different /24) are intentionally NOT
flagged. New MACs on an AP that aren't yet in net-mgr's DB get
propagated automatically via OBSERVE kind=host.

With --fix, each drift is presented with a per-item choice:
  A — take the AP's value (rewrite dhcp.master + propagate to DB)
  M — take master's value (push to the AP, default)
  S — skip (leave drift in place)
With --auto, every drift is resolved master-wins without prompting.
dhcp.master gets a .bak copy on the first write.
EOF
    exit($rc // 0);
}
