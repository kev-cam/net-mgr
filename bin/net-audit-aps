#!/usr/bin/perl
# net-audit-aps — check that every AP's DHCP server is advertising
# the right default-gateway, and fix the drifted ones with --fix.
#
# Two passes:
#
# 1. Default-gateway check.  DD-WRT APs run their own dnsmasq for the
#    clients on their L2 segment. The advertised default-gateway
#    (DHCP option 3) comes from nvram lan_gateway. If it drifts
#    (operator changes via net-set, AP firmware reset, rogue manual
#    config) the clients on that AP route through the wrong place
#    until their lease renews and they pick up the right option=3.
#
# 2. Per-MAC static-lease check.  DD-WRT also keeps a
#    nvram static_leases list mapping MAC → IP for DHCP reservations
#    (Services > DHCP > Static Leases in the web UI). When an
#    operator edits one on the AP without updating
#    /etc/net-mgr/dhcp.master (the source of truth) the AP and
#    dhcp.master disagree about which IP that device should get.
#    For any MAC present in both, the IPs are compared; mismatch
#    is flagged as DRIFT. Missing-on-AP / extra-on-AP are not
#    flagged (not every AP serves every host's segment).
#
# Usage:
#   net-audit-aps                          compare against the active gateway
#                                          per isp_links (status='active')
#   net-audit-aps --gateway gateway3-down  compare against a specific gateway
#   net-audit-aps --via-isp comcast        compare against the gateway serving
#                                          the named ISP
#   net-audit-aps --fix                    push the corrected lan_gateway to
#                                          drifted APs (via net-set)
#
# Other options:
#   --listen H[:P]    daemon for snapshot reads (default 127.0.0.1:7531)
#   --ssh-user USER   ssh user for AP probes (default root)
#   --quiet / -q      only print drift
#   --help / -h
#
# Exits 0 if every AP is correct (or --fix succeeded for all);
# 1 if at least one AP is drifted (without --fix) or fix failed;
# 2 on bad args / can't determine expected gateway.

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Getopt::Long qw(:config no_ignore_case bundling);

use NetMgr::Client;
use NetMgr::Producer::DhcpMaster;

my ($gateway, $via_isp, $fix, $listen, $ssh_user, $quiet, $help);
GetOptions(
    'gateway=s'  => \$gateway,
    'via-isp=s'  => \$via_isp,
    'fix'        => \$fix,
    'listen=s'   => \$listen,
    'ssh-user=s' => \$ssh_user,
    'quiet|q'    => \$quiet,
    'help|h'     => \$help,
) or usage(2);
usage(0) if $help;
usage(2) if $gateway && $via_isp;
$ssh_user //= 'root';
$listen   //= '127.0.0.1:7531';

# ---- snapshot the daemon's view -------------------------------------

my $cli = NetMgr::Client->new(listen => $listen, timeout => 5);
$cli->hello(consumer => "net-audit-aps.$$");
my $aps   = $cli->snapshot(1, 'aps');
my $ifs   = $cli->snapshot(2, 'interfaces');
my $addrs = $cli->snapshot(3, 'addresses', where => "family = 'v4'");
my $machs = $cli->snapshot(4, 'machines');
my $links = eval { $cli->snapshot(5, 'isp_links') } || [];
$cli->bye;

my %name_by_mid = map { $_->{id} => $_->{primary_name} }
                  grep { defined $_->{primary_name} } @$machs;
my %mid_by_mac;
for my $i (@$ifs) {
    next unless $i->{mac} && defined $i->{machine_id};
    $mid_by_mac{ lc $i->{mac} } = $i->{machine_id};
}
my %ip_by_mac;
for my $a (@$addrs) {
    next unless $a->{mac} && $a->{addr};
    push @{ $ip_by_mac{ lc $a->{mac} } }, $a->{addr};
}

# ---- resolve the expected gateway IP --------------------------------

my $expected_name = $gateway;
if ($via_isp && !$expected_name) {
    my @act = grep { ($_->{status}//'') eq 'active'
                  && ($_->{isp_name}//'') eq $via_isp } @$links;
    @act = grep { ($_->{isp_name}//'') eq $via_isp } @$links unless @act;
    if (@act) {
        $expected_name = $name_by_mid{ $act[0]{gateway_machine_id} };
    }
    die "net-audit-aps: no isp_links row for ISP '$via_isp'\n"
        unless $expected_name;
}
if (!$expected_name) {
    # Default: pick whichever isp_links row is currently active. If
    # multiple, prefer one whose name contains 'down' (LAN-side).
    my @act = grep { ($_->{status}//'') eq 'active' } @$links;
    die "net-audit-aps: no active isp_links rows; pass --gateway HOST\n"
        unless @act;
    my @names = map  { $name_by_mid{ $_->{gateway_machine_id} } } @act;
    @names = grep { defined } @names;
    @names = sort { ($b =~ /-down$/) <=> ($a =~ /-down$/) || $a cmp $b } @names;
    $expected_name = $names[0];
    die "net-audit-aps: couldn't pick a default gateway from isp_links\n"
        unless $expected_name;
}
# Resolve name → IP, preferring ethernet
my $expected_ip = resolve_gw($expected_name);
die "net-audit-aps: can't resolve '$expected_name' to an IP\n"
    unless $expected_ip;

print "expected gateway: $expected_name = $expected_ip\n" unless $quiet;

# ---- iterate APs ----------------------------------------------------

my @ap_list;
for my $a (@$aps) {
    my $mac = lc $a->{mac};
    my $mid = $mid_by_mac{$mac};
    my $name = defined $mid ? $name_by_mid{$mid} : undef;
    my $ips = $ip_by_mac{$mac} || [];
    my ($ip) = grep { defined } @$ips;
    push @ap_list, { mac => $mac, name => $name // '(unknown)',
                     ip  => $ip // '?' };
}

my @drifted;
my @failed;
my @ok;

printf "%-22s %-15s  %-15s  %s\n",
    "AP", "IP", "lan_gateway", "status" unless $quiet;
for my $a (sort { $a->{name} cmp $b->{name} } @ap_list) {
    next unless $a->{ip} ne '?';
    my $cur = probe_ap_gateway($a->{ip});
    if (!defined $cur) {
        push @failed, $a;
        next if $quiet;
        printf "%-22s %-15s  %-15s  %s\n",
            $a->{name}, $a->{ip}, '?', 'probe FAILED';
        next;
    }
    if ($cur eq $expected_ip) {
        push @ok, $a;
        next if $quiet;
        printf "%-22s %-15s  %-15s  OK\n", $a->{name}, $a->{ip}, $cur;
    } else {
        push @drifted, { %$a, cur => $cur };
        printf "%-22s %-15s  %-15s  DRIFT (should be $expected_ip)\n",
            $a->{name}, $a->{ip}, $cur;
    }
}

unless ($quiet) {
    printf "\n%d ok / %d drift / %d unreachable (of %d)\n",
        scalar(@ok), scalar(@drifted), scalar(@failed), scalar(@ap_list);
}

if ($fix && @drifted) {
    print "\n--- fixing drifted APs ---\n";
    for my $a (@drifted) {
        printf "%-22s %s ", $a->{name}, $a->{ip};
        my @cmd = ('net-set', '--gateway', $expected_name, $a->{ip});
        my $rc = system(@cmd);
        print($rc == 0 ? "OK\n" : "FAILED (rc=" . ($rc>>8) . ")\n");
    }
}

# ---- static-lease audit --------------------------------------------
#
# DD-WRT stores per-MAC DHCP reservations in nvram static_leases as
#   mac=name=ip=lease_minutes  (space-separated entries).
# Compare each AP's reservations against /etc/net-mgr/dhcp.master:
# for any MAC present in both, the IP must match. Missing-on-AP /
# extra-on-AP are common (each AP serves a different segment) and
# would be noise, so we don't flag those by default.
my $master = '/etc/net-mgr/dhcp.master';
my @lease_drift;
my @lease_fix_fail;
if (-r $master) {
    my @records = NetMgr::Producer::DhcpMaster::parse_file($master);
    my @hosts   = NetMgr::Producer::DhcpMaster::hosts_only(@records);
    my %master_ip = map { lc($_->{mac}) => { ip => $_->{ip}, name => $_->{name} } }
                    grep { $_->{mac} && $_->{ip} } @hosts;

    print "\n--- static-lease audit (vs $master) ---\n" unless $quiet;
    my %seen_propagation;     # mac:ip → 1, dedupe across APs
    my @new_macs;             # entries to propagate
    my %ap_leases_by_mac;     # mac → AP-side name (for propagation)
    for my $a (sort { $a->{name} cmp $b->{name} } @ap_list) {
        next unless $a->{ip} ne '?';
        my $leases = probe_ap_leases($a->{ip});
        if (!defined $leases) {
            next if $quiet;
            printf "  %-22s %-15s  (leases probe failed)\n", $a->{name}, $a->{ip};
            next;
        }
        for my $mac (sort keys %$leases) {
            my $ap_ip   = $leases->{$mac}{ip};
            my $ap_name = $leases->{$mac}{name};
            if (my $m = $master_ip{$mac}) {
                next if $m->{ip} eq $ap_ip;        # agree → OK
                push @lease_drift, {
                    ap_name   => $a->{name},
                    ap_ip     => $a->{ip},
                    mac       => $mac,
                    ap_lease  => $ap_ip,
                    master_ip => $m->{ip},
                    name      => $m->{name},
                };
            } else {
                # MAC not in dhcp.master. Maybe already in the DB
                # (addresses) at this IP — if so it's noise, skip.
                # Otherwise propagate.
                my $key = "$mac:$ap_ip";
                next if $seen_propagation{$key}++;
                my @known = @{ $ip_by_mac{$mac} || [] };
                next if grep { $_ eq $ap_ip } @known;
                push @new_macs, {
                    ap_name => $a->{name},
                    mac     => $mac,
                    ip      => $ap_ip,
                    name    => $ap_name,
                };
            }
        }
    }
    if (@lease_drift) {
        printf "\n%-22s %-17s  %-12s  %-15s  %-15s\n",
            "AP", "MAC", "HOST", "AP says", "master says"
            unless $quiet;
        for my $d (@lease_drift) {
            printf "%-22s %-17s  %-12s  %-15s  %-15s  DRIFT\n",
                $d->{ap_name}, $d->{mac}, $d->{name},
                $d->{ap_lease}, $d->{master_ip};
        }
    } elsif (!$quiet) {
        print "  all per-MAC reservations agree with $master\n";
    }

    if ($fix && @lease_drift) {
        print "\n--- fixing static-lease drift (pushing dhcp.master to APs) ---\n";
        my %by_ap;
        push @{ $by_ap{ $_->{ap_ip} } }, $_ for @lease_drift;
        my %name_for;
        $name_for{ $_->{ap_ip} } //= $_->{ap_name} for @lease_drift;
        for my $ap_ip (sort keys %by_ap) {
            my $ok = push_lease_fix($ap_ip, $by_ap{$ap_ip});
            printf "  %-22s %-15s  %s\n",
                $name_for{$ap_ip}, $ap_ip, $ok ? "OK" : "FAILED";
            push @lease_fix_fail, $ap_ip unless $ok;
        }
    }

    # Propagate AP-only MACs (not in dhcp.master, not in DB at that
    # IP) so net-mgr picks them up. OBSERVE kind=host is idempotent,
    # so repeated runs cost nothing. Tagged source so it's clear
    # where the entry came from when looking at the addresses table.
    if (@new_macs) {
        print "\n--- new MACs propagated to net-mgr ---\n" unless $quiet;
        my $cli2 = NetMgr::Client->new(listen => $listen, timeout => 5);
        $cli2->hello(consumer => "net-audit-aps.propagate.$$");
        for my $n (@new_macs) {
            my $reply = $cli2->observe(
                kind        => 'host',
                mac         => $n->{mac},
                ip          => $n->{ip},
                family      => 'v4',
                name        => $n->{name} // '',
                name_source => 'ap-static-leases',
                source      => "audit:ap-static-leases:$n->{ap_name}",
            );
            if ($reply && $reply =~ /^ERR/) {
                warn "  $n->{mac} -> $n->{ip} ($n->{name}): $reply\n";
            } elsif (!$quiet) {
                printf "  %-17s  %-15s  %-12s  from $n->{ap_name}\n",
                    $n->{mac}, $n->{ip}, $n->{name} // '';
            }
        }
        $cli2->bye;
    }
}

# Exit code semantics:
#   any drift (gateway or lease) → 1 unless --fix
#   --fix but any push failed     → 1
#   probe failures (no audit run) → 1
#   else                          → 0
my $drift_left = @drifted || @lease_drift;
my $fix_bad    = @lease_fix_fail;
if ($drift_left && !$fix)  { exit 1 }
if ($fix && $fix_bad)      { exit 1 }
exit($failed[0] ? 1 : 0);

# =====================================================================
# Helpers
# =====================================================================

# Pull the lan_gateway value from an AP's nvram via ssh. Returns the
# IP string or undef on any probe failure. DD-WRT keeps both
# lan_gateway and wan_gateway nvram values; lan_gateway is what
# dnsmasq's option=3 uses on a bridge-mode AP. We read both for
# diagnostic completeness but only return lan_gateway for the audit.
sub probe_ap_gateway {
    my ($ip) = @_;
    my @cmd = ('ssh', '-o', 'BatchMode=yes',
                       '-o', 'ConnectTimeout=5',
                       '-o', 'StrictHostKeyChecking=accept-new',
                       '-T', '-q', "$ssh_user\@$ip",
                       'nvram get lan_gateway');
    my $pid = open my $fh, '-|';
    return undef unless defined $pid;
    if ($pid == 0) {
        open STDIN, '<', '/dev/null';
        exec @cmd; exit 127;
    }
    chomp(my $val = <$fh> // '');
    close $fh;
    return undef if $? != 0;
    return undef unless $val =~ /^\d+\.\d+\.\d+\.\d+$/;
    return $val;
}

# Pull `nvram get static_leases` from an AP and parse into
# { mac (lc) => { ip => ..., name => ... } }. DD-WRT's format is
# space-separated entries, each "mac=name=ip=lease_minutes".
# Returns undef on probe failure, empty hashref if the AP has no
# static leases configured.
sub probe_ap_leases {
    my ($ip) = @_;
    my @cmd = ('ssh', '-o', 'BatchMode=yes',
                       '-o', 'ConnectTimeout=5',
                       '-o', 'StrictHostKeyChecking=accept-new',
                       '-T', '-q', "$ssh_user\@$ip",
                       'nvram get static_leases');
    my $pid = open my $fh, '-|';
    return undef unless defined $pid;
    if ($pid == 0) {
        open STDIN, '<', '/dev/null';
        exec @cmd; exit 127;
    }
    chomp(my $val = <$fh> // '');
    close $fh;
    return undef if $? != 0;
    my %out;
    for my $entry (split /\s+/, $val) {
        my @f = split /=/, $entry;
        next unless @f >= 3;
        my ($mac, $name, $lease_ip) = ($f[0], $f[1], $f[2]);
        next unless $mac =~ /^[0-9a-fA-F:]{17}$/
                 && $lease_ip =~ /^\d+\.\d+\.\d+\.\d+$/;
        $out{ lc $mac } = { ip => $lease_ip, name => $name };
    }
    return \%out;
}

# Push corrected static_leases back to an AP. $fixes is an arrayref
# of {mac, master_ip, ...}. Reads current nvram static_leases,
# replaces the IP field on matching MAC entries (leaves non-drifted
# entries untouched), pushes back, commits, and HUPs dnsmasq so the
# change takes effect immediately. Returns 1 on success, 0 on any
# step failing.
sub push_lease_fix {
    my ($ap_ip, $fixes) = @_;
    my $raw = _ssh_capture($ap_ip, 'nvram get static_leases');
    return 0 unless defined $raw;
    my %wanted = map { lc($_->{mac}) => $_->{master_ip} } @$fixes;
    my @new;
    for my $entry (split /\s+/, $raw) {
        my @f = split /=/, $entry;
        if (@f >= 3 && exists $wanted{ lc $f[0] }) {
            $f[2] = $wanted{ lc $f[0] };
        }
        push @new, join('=', @f);
    }
    my $new_val = join(' ', @new);
    # Single-quote the value because it contains spaces; the value
    # itself never contains single quotes (MAC=NAME=IP=NUM tokens).
    my $cmd = "nvram set static_leases='$new_val' && nvram commit "
            . "&& killall -HUP dnsmasq";
    return _ssh_run($ap_ip, $cmd);
}

sub _ssh_capture {
    my ($ip, $cmd) = @_;
    my @c = ('ssh', '-o', 'BatchMode=yes', '-o', 'ConnectTimeout=5',
             '-T', '-q', "$ssh_user\@$ip", $cmd);
    my $pid = open my $fh, '-|';
    return undef unless defined $pid;
    if ($pid == 0) { open STDIN, '<', '/dev/null'; exec @c; exit 127 }
    chomp(my $val = <$fh> // '');
    close $fh;
    return $? == 0 ? $val : undef;
}

sub _ssh_run {
    my ($ip, $cmd) = @_;
    my @c = ('ssh', '-o', 'BatchMode=yes', '-o', 'ConnectTimeout=5',
             '-T', '-q', "$ssh_user\@$ip", $cmd);
    return system(@c) == 0;
}

# Resolve a machine name to an IP, preferring ethernet over wifi
# (matching net-set's resolve_gw behaviour).
sub resolve_gw {
    my ($name) = @_;
    return $name if $name =~ /^(\d+)\.(\d+)\.(\d+)\.(\d+)$/;
    # Same per-name lookup logic as net-set: pick ethernet first.
    my %kind_by_mac;
    for my $i (@$ifs) {
        next unless $i->{mac};
        $kind_by_mac{ lc $i->{mac} } = lc($i->{kind} // 'unknown');
    }
    my %ip_to_mac;
    for my $a (@$addrs) {
        next unless $a->{mac} && $a->{addr};
        $ip_to_mac{ $a->{addr} } = lc $a->{mac};
    }
    my @ips_for;
    for my $a (@$addrs) {
        next unless $a->{mac} && $a->{addr};
        my $mac = lc $a->{mac};
        my $mid = $mid_by_mac{$mac};
        next unless defined $mid;
        push @ips_for, $a->{addr} if ($name_by_mid{$mid}//'') eq $name;
    }
    return undef unless @ips_for;
    my @eth = grep { ($kind_by_mac{ $ip_to_mac{$_} // '' } // '')
                     eq 'ethernet' } @ips_for;
    return $eth[0] || $ips_for[0];
}

sub usage {
    my ($rc) = @_;
    print STDERR <<"EOF";
Usage:
  net-audit-aps                              audit against active isp_links
  net-audit-aps --gateway gateway3-down      audit against specific gateway
  net-audit-aps --via-isp comcast            audit against ISP-resolved gateway
  net-audit-aps --fix                        also push fix to drifted APs

For each AP in the `aps` table, ssh in and read nvram lan_gateway.
Compare against the expected gateway IP; print OK / DRIFT / unreachable.
With --fix, call 'net-set --gateway HOST IP' for each drifted AP.
EOF
    exit($rc // 0);
}
